---
// ============================================================
//  /account (MARVEXA) — authenticated customer dashboard (profile +
//  orders). Redirects to login when there is no valid session.
// ============================================================
import Layout from '~/layouts/Layout.astro';
import {
  createCustomerClient,
  CUSTOMER_OVERVIEW_QUERY,
  getPublicOrigin,
  NotAuthenticatedError,
} from '~/lib/shopify/customer';
import type { CustomerOverview } from '~/lib/shopify/customer';

export const prerender = false;

const client = createCustomerClient(Astro.cookies, getPublicOrigin(Astro.request, Astro.url));

if (!client.isLoggedIn()) {
  return Astro.redirect('/account/login?return_to=/account');
}

let customer: CustomerOverview['customer'] = null;
let error: string | null = null;

try {
  const data = await client.query<CustomerOverview>(CUSTOMER_OVERVIEW_QUERY, { first: 10 });
  customer = data.customer;
} catch (err) {
  if (err instanceof NotAuthenticatedError) {
    return Astro.redirect('/account/login?return_to=/account');
  }
  console.error('[account] load failed:', (err as Error).message);
  error = (err as Error).message;
}

const fullName = [customer?.firstName, customer?.lastName].filter(Boolean).join(' ');
const greeting = fullName || customer?.emailAddress?.emailAddress || 'there';
const orders = customer?.orders?.nodes ?? [];

const fmtMoney = (m: { amount: string; currencyCode: string } | null) =>
  m
    ? new Intl.NumberFormat('en-US', { style: 'currency', currency: m.currencyCode }).format(
        Number(m.amount),
      )
    : '—';

const fmtDate = (iso: string) =>
  new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(
    new Date(iso),
  );
---

<Layout title="Account" description="Manage your account, orders, and details." noindex>
  <section class="sec">
    <div class="container">
      <header class="acc-head">
        <div>
          <div class="acc-eyebrow">My account</div>
          <h1 class="h1">Hi, {greeting}</h1>
        </div>
        <a href="/account/logout" class="btn btn-ghost">Sign out</a>
      </header>

      {
        error && (
          <p class="acc-alert">Couldn't load your account: {error}</p>
        )
      }

      <section class="acc-section">
        <h2 class="acc-label">Profile</h2>
        <dl class="acc-cards">
          <div class="acc-card">
            <dt>Name</dt>
            <dd>{fullName || '—'}</dd>
          </div>
          <div class="acc-card">
            <dt>Email</dt>
            <dd>{customer?.emailAddress?.emailAddress || '—'}</dd>
          </div>
        </dl>
      </section>

      <section class="acc-section">
        <h2 class="acc-label">Recent orders</h2>
        {
          orders.length === 0 ? (
            <p class="acc-muted">You haven't placed any orders yet.</p>
          ) : (
            <ul class="acc-orders">
              {orders.map((order) => (
                <li>
                  <div>
                    <p class="acc-order-name">{order.name}</p>
                    <p class="acc-order-date">{fmtDate(order.processedAt)}</p>
                  </div>
                  <p class="acc-order-total">{fmtMoney(order.totalPrice)}</p>
                </li>
              ))}
            </ul>
          )
        }
      </section>
    </div>
  </section>
</Layout>

<style>
  .sec { padding-top: 150px; }

  .acc-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 36px;
  }
  .acc-eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .acc-head .h1 {
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 0;
  }

  .acc-alert {
    margin-bottom: 28px;
    padding: 12px 16px;
    border: 1px solid #fca5a5;
    background: #fef2f2;
    color: #b91c1c;
    border-radius: 12px;
  }

  .acc-section { margin-bottom: 44px; }
  .acc-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 16px;
  }
  .acc-muted { color: var(--muted); margin: 0; }

  .acc-cards {
    display: grid;
    gap: 14px;
    grid-template-columns: 1fr;
    margin: 0;
  }
  @media (min-width: 640px) { .acc-cards { grid-template-columns: 1fr 1fr; } }
  .acc-card {
    border: 1px solid var(--border);
    background: var(--white);
    border-radius: 14px;
    padding: 16px 18px;
  }
  .acc-card dt {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .acc-card dd { margin: 6px 0 0; color: var(--text); font-weight: 500; }

  .acc-orders {
    list-style: none;
    margin: 0;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    background: var(--white);
  }
  .acc-orders li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 18px;
  }
  .acc-orders li + li { border-top: 1px solid var(--border); }
  .acc-order-name { margin: 0; font-weight: 600; color: var(--text); }
  .acc-order-date { margin: 3px 0 0; font-size: 0.82rem; color: var(--muted); }
  .acc-order-total { margin: 0; font-weight: 600; color: var(--text); font-variant-numeric: tabular-nums; }

  .btn-ghost {
    border: 1px solid var(--border);
    background: var(--white);
    color: var(--text);
    padding: 11px 20px;
  }
  .btn-ghost:hover { border-color: var(--accent); color: var(--accent); }
</style>
