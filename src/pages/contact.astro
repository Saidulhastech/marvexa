---
// ============================================================
//  Contact (MAISON) — fashion reskin. Static page: hero header,
//  split contact form + info sidebar, store locations, FAQ.
//  Demo contact form (client-only validation + success view).
// ============================================================
import Layout from '~/layouts/Layout.astro';
import '~/styles/contact.css';
---

<Layout
  title="Contact — Maison"
  description="Get in touch with Maison. Reach our team about orders, returns, sizing, wholesale or press — real people, replies within 24 hours, and three flagship stores worldwide."
>
  <main id="contactModern" class="contact-pg">

    <!-- ── Hero header ── -->
    <div class="cart-hd-block">
      <div class="cart-hd-inner">
        <div class="cart-hd-toprow">
          <nav class="cart-bc" aria-label="breadcrumb">
            <a href="/">Home</a>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6" /></svg>
            <span class="cart-bc-cur">Contact</span>
          </nav>
          <div class="cart-hd-perks">
            <span class="cart-hd-perk"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg> hello@maison.com</span>
            <span class="cart-hd-perk-div"></span>
            <span class="cart-hd-perk"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.54 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l.81-.81a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" /></svg> +1 (212) 555-0140</span>
            <span class="cart-hd-perk-div"></span>
            <span class="cart-hd-perk cart-hd-perk--secure"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg> Mon&ndash;Fri, 9am&ndash;6pm EST</span>
          </div>
        </div>
        <div class="cart-hd-hero">
          <div class="cart-hd-hero-left">
            <div class="cart-hd-eyebrow">Get in Touch</div>
            <h1 class="cart-hd-title">Contact Us</h1>
            <p class="cart-hd-sub">We're here to help. Reach out and we'll get back to you within 24 hours.</p>
          </div>
          <div class="cart-hd-stats">
            <div class="cart-hd-stat">
              <div class="cart-hd-stat-num">&lt;24h</div>
              <div class="cart-hd-stat-lbl">Response</div>
            </div>
            <div class="cart-hd-stat-div"></div>
            <div class="cart-hd-stat">
              <div class="cart-hd-stat-num">3</div>
              <div class="cart-hd-stat-lbl">Locations</div>
            </div>
            <div class="cart-hd-stat-div"></div>
            <div class="cart-hd-stat">
              <div class="cart-hd-stat-num">4.9</div>
              <div class="cart-hd-stat-lbl">Rating</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Split layout: form + info sidebar ── -->
    <div class="contact-layout">
      <div class="contact-form-col">

        <!-- CONTACT FORM -->
        <div class="contact-section">
          <div class="contact-section-hd">
            <div class="contact-section-icon"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13" /><polygon points="22 2 15 22 11 13 2 9 22 2" /></svg></div>
            <h2 class="contact-section-title">Send a Message</h2>
            <span class="contact-section-tag">24h reply</span>
          </div>
          <div class="contact-section-body">
            <form id="cfForm" novalidate>
              <div class="cf-row">
                <div class="cf-field"><label for="cfFirst">First Name</label><input type="text" class="cf-input" placeholder="Jane" id="cfFirst" autocomplete="given-name" required data-label="first name" /><span class="cf-err">Required.</span></div>
                <div class="cf-field"><label for="cfLast">Last Name</label><input type="text" class="cf-input" placeholder="Doe" id="cfLast" autocomplete="family-name" required data-label="last name" /><span class="cf-err">Required.</span></div>
              </div>
              <div class="cf-row">
                <div class="cf-field"><label for="cfEmail">Email Address</label><input type="email" class="cf-input" placeholder="jane@example.com" id="cfEmail" autocomplete="email" required data-label="email" /><span class="cf-err">Enter a valid email.</span></div>
                <div class="cf-field"><label for="cfPhone">Phone (optional)</label><input type="tel" class="cf-input" placeholder="+1 (212) 555-0000" id="cfPhone" autocomplete="tel" /></div>
              </div>
              <div class="cf-field">
                <label for="cfSubject">Subject</label>
                <select class="cf-select" id="cfSubject" required>
                  <option value="">Select a topic...</option>
                  <option>Orders &amp; shipping</option>
                  <option>Returns &amp; exchanges</option>
                  <option>Product / sizing question</option>
                  <option>Styling advice</option>
                  <option>Wholesale</option>
                  <option>Press</option>
                  <option>Something else</option>
                </select>
                <span class="cf-err">Please choose a topic.</span>
              </div>
              <div class="cf-field"><label for="cfOrder">Order Number (optional)</label><input type="text" class="cf-input" placeholder="#MAISON-00000" id="cfOrder" /></div>
              <div class="cf-field">
                <label for="cfMsg">Your Message</label>
                <textarea class="cf-textarea" placeholder="How can we help you today?" id="cfMsg" maxlength="500" required data-label="message"></textarea>
                <div class="cf-char-count" id="cfChars">0/500</div>
                <span class="cf-err">Please write your message.</span>
              </div>
              <button type="submit" class="cf-submit" id="cfSubmit"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13" /><polygon points="22 2 15 22 11 13 2 9 22 2" /></svg> <span class="cf-submit-txt">Send Message</span></button>
            </form>

            <!-- Success state -->
            <div class="cf-success" id="cfSuccess">
              <div class="cf-success-ico"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5" /></svg></div>
              <h3>Message sent</h3>
              <p>Thanks for reaching out, <span id="cfSuccessName">there</span>. Our team will get back to you within 24 hours.</p>
              <button type="button" class="cf-success-btn" id="cfSendAnother"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" /><path d="M3 3v5h5" /></svg> Send another message</button>
            </div>
          </div>
        </div>

        <!-- SUPPORT PROMISE -->
        <div class="contact-section">
          <div class="contact-section-hd">
            <div class="contact-section-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg></div>
            <h2 class="contact-section-title">Our Support Promise</h2>
            <span class="contact-section-tag">Always Here</span>
          </div>
          <div class="support-promise-grid">
            <div class="support-promise-item">
              <div class="support-promise-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg></div>
              <div class="support-promise-num">&lt;24h</div>
              <div class="support-promise-title">Response Time</div>
              <div class="support-promise-sub">Weekdays within 2 hours</div>
            </div>
            <div class="support-promise-item">
              <div class="support-promise-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10" /><path d="M3.51 15a9 9 0 1 0 .49-3.99" /></svg></div>
              <div class="support-promise-num">30</div>
              <div class="support-promise-title">Day Free Returns</div>
              <div class="support-promise-sub">No questions asked</div>
            </div>
            <div class="support-promise-item">
              <div class="support-promise-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" /></svg></div>
              <div class="support-promise-num">4.9</div>
              <div class="support-promise-title">Customer Rating</div>
              <div class="support-promise-sub">Rated by 3,200+ customers</div>
            </div>
            <div class="support-promise-item">
              <div class="support-promise-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" /></svg></div>
              <div class="support-promise-num">5K+</div>
              <div class="support-promise-title">Happy Customers</div>
              <div class="support-promise-sub">3 flagship stores worldwide</div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── RIGHT info sidebar ── -->
      <div class="contact-info-col">
        <div class="contact-info-card">
          <div class="contact-info-hd">
            <div class="contact-info-hd-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg></div>
            <div class="contact-info-hd-title" style="flex:1">Our Details</div>
          </div>
          <div class="contact-store">
            <div class="contact-store-item">
              <div class="contact-store-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg></div>
              <div>
                <div class="contact-store-lbl">Email</div>
                <div class="contact-store-val">hello@maison.com<br /><span style="color:var(--muted);font-size:11px">Replies within 24 hours</span></div>
              </div>
            </div>
            <div class="contact-store-divider"></div>
            <div class="contact-store-item">
              <div class="contact-store-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.54 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l.81-.81a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" /></svg></div>
              <div>
                <div class="contact-store-lbl">Phone</div>
                <div class="contact-store-val">+1 (212) 555-0140<br /><span style="color:var(--muted);font-size:11px">Mon&ndash;Fri, 9am&ndash;6pm EST</span></div>
              </div>
            </div>
            <div class="contact-store-divider"></div>
            <div class="contact-store-item">
              <div class="contact-store-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg></div>
              <div>
                <div class="contact-store-lbl">Flagship Store</div>
                <div class="contact-store-val">142 Spring Street, SoHo<br />New York, NY 10012</div>
              </div>
            </div>
          </div>
        </div>

        <div class="contact-info-card">
          <div class="contact-info-hd">
            <div class="contact-info-hd-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg></div>
            <div class="contact-info-hd-title" style="flex:1">Store Hours</div>
            <span class="contact-open-badge"><span class="contact-open-dot"></span> Open Now</span>
          </div>
          <div class="contact-hours">
            <div class="contact-hour-row"><span class="contact-hour-day">Monday</span><span class="contact-hour-time">10:00 &ndash; 20:00</span></div>
            <div class="contact-hour-row"><span class="contact-hour-day">Tuesday</span><span class="contact-hour-time">10:00 &ndash; 20:00</span></div>
            <div class="contact-hour-row"><span class="contact-hour-day">Wednesday</span><span class="contact-hour-time">10:00 &ndash; 20:00</span></div>
            <div class="contact-hour-row"><span class="contact-hour-day">Thursday</span><span class="contact-hour-time">10:00 &ndash; 20:00</span></div>
            <div class="contact-hour-row"><span class="contact-hour-day">Friday</span><span class="contact-hour-time">10:00 &ndash; 20:00</span></div>
            <div class="contact-hour-row"><span class="contact-hour-day">Saturday</span><span class="contact-hour-time">11:00 &ndash; 18:00</span></div>
            <div class="contact-hour-row"><span class="contact-hour-day">Sunday</span><span class="contact-hour-time contact-hour-closed">Closed</span></div>
          </div>
        </div>

        <div class="contact-info-card">
          <div class="contact-info-hd">
            <div class="contact-info-hd-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5" /><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" /><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" /></svg></div>
            <div class="contact-info-hd-title">Follow &amp; Connect</div>
          </div>
          <div class="contact-socials">
            <a class="contact-soc-btn" href="https://instagram.com" target="_blank" rel="noopener">
              <div class="contact-soc-icon ig"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5" /><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" /><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" /></svg></div>
              <div>
                <div class="contact-soc-name">Instagram</div>
                <div class="contact-soc-handle">@maison</div>
              </div>
            </a>
            <a class="contact-soc-btn" href="#" rel="noopener">
              <div class="contact-soc-icon tw"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z" /></svg></div>
              <div>
                <div class="contact-soc-name">Twitter/X</div>
                <div class="contact-soc-handle">@maison</div>
              </div>
            </a>
            <a class="contact-soc-btn" href="#" data-toast="WhatsApp opening...">
              <div class="contact-soc-icon wa"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" /></svg></div>
              <div>
                <div class="contact-soc-name">WhatsApp</div>
                <div class="contact-soc-handle">Chat with us</div>
              </div>
            </a>
            <a class="contact-soc-btn" href="mailto:hello@maison.com">
              <div class="contact-soc-icon em"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg></div>
              <div>
                <div class="contact-soc-name">Email</div>
                <div class="contact-soc-handle">Direct mail</div>
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- ── STORE LOCATIONS ── -->
    <div class="contact-stores-section">
      <div class="contact-stores-inner">
        <div class="contact-stores-top">
          <div>
            <div class="contact-stores-eyebrow">Retail Presence</div>
            <h2 class="contact-stores-title">Our Locations</h2>
          </div>
          <a href="https://www.google.com/maps?q=142+Spring+Street+SoHo+New+York" target="_blank" rel="noopener" class="contact-map-btn"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11" /></svg> View on Map</a>
        </div>
        <div class="contact-stores-grid">
          <div class="store-card">
            <div class="store-card-map">
              <iframe src="https://www.google.com/maps?q=142+Spring+Street+SoHo+New+York&output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Maison New York flagship store location"></iframe>
              <div class="store-card-map-pin">
                <div class="store-pin-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg></div>
                <span class="store-pin-label">SoHo, New York</span>
              </div>
            </div>
            <div class="store-card-body">
              <h3 class="store-card-city">New York</h3>
              <p class="store-card-addr">142 Spring Street, SoHo<br />New York, NY 10012, USA</p>
              <div class="store-card-meta"><span class="store-chip open-chip"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg> Open Now</span><span class="store-chip"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg> 10am &ndash; 8pm</span><span class="store-chip">Flagship</span></div>
              <div class="store-card-dir">
                <a class="store-dir-btn" href="https://www.google.com/maps?q=142+Spring+Street+SoHo+New+York" target="_blank" rel="noopener"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11" /></svg> Get Directions</a>
                <span class="store-phone">+1 (212) 555-0140</span>
              </div>
            </div>
          </div>
          <div class="store-card">
            <div class="store-card-map">
              <iframe src="https://www.google.com/maps?q=8405+Melrose+Avenue+West+Hollywood&output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Maison Los Angeles store location"></iframe>
              <div class="store-card-map-pin">
                <div class="store-pin-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg></div>
                <span class="store-pin-label">Melrose, Los Angeles</span>
              </div>
            </div>
            <div class="store-card-body">
              <h3 class="store-card-city">Los Angeles</h3>
              <p class="store-card-addr">8405 Melrose Avenue<br />West Hollywood, CA 90069, USA</p>
              <div class="store-card-meta"><span class="store-chip open-chip"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg> Open Now</span><span class="store-chip"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg> 11am &ndash; 7pm</span></div>
              <div class="store-card-dir">
                <a class="store-dir-btn" href="https://www.google.com/maps?q=8405+Melrose+Avenue+West+Hollywood" target="_blank" rel="noopener"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11" /></svg> Get Directions</a>
                <span class="store-phone">+1 (323) 555-0188</span>
              </div>
            </div>
          </div>
          <div class="store-card">
            <div class="store-card-map">
              <iframe src="https://www.google.com/maps?q=24+Ledbury+Road+Notting+Hill+London&output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Maison London store location"></iframe>
              <div class="store-card-map-pin">
