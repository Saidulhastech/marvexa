<script is:inline>
  (function () {
    var root = document.getElementById('contactModern');
    if (!root) return;
    var $ = function (s) { return root.querySelector(s); };
    var $$ = function (s) { return Array.prototype.slice.call(root.querySelectorAll(s)); };

    /* ── Toast ── */
    var toastEl = $('#cfToast');
    var toastTimer = null;
    function toast(msg) {
      if (!toastEl) return;
      toastEl.textContent = msg;
      toastEl.classList.add('show');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(function () { toastEl.classList.remove('show'); }, 3000);
    }
    $$('[data-toast]').forEach(function (el) {
      el.addEventListener('click', function (e) { e.preventDefault(); toast(el.getAttribute('data-toast')); });
    });
    var liveChat = $('#liveChatBtn');
    if (liveChat) liveChat.addEventListener('click', function () { toast('Live chat coming soon!'); });

    /* ── Char counter ── */
    var msgEl = $('#cfMsg');
    var charsEl = $('#cfChars');
    if (msgEl && charsEl) {
      msgEl.addEventListener('input', function () { charsEl.textContent = msgEl.value.length + '/500'; });
    }

    /* ── Form validation + submit ── */
    function validate() {
      var ok = true;
      [
        { sel: '#cfFirst', email: false },
        { sel: '#cfLast', email: false },
        { sel: '#cfEmail', email: true },
        { sel: '#cfSubject', email: false },
        { sel: '#cfMsg', email: false }
      ].forEach(function (f) {
        var el = $(f.sel);
        var field = el.closest('.cf-field');
        var val = el.value.trim();
        var bad = !val;
        if (f.email && val) bad = !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(val);
        if (field) field.classList.toggle('err', bad);
        if (bad) ok = false;
      });
      return ok;
    }

    $$('.cf-input, .cf-select, .cf-textarea').forEach(function (el) {
      var clear = function () { var f = el.closest('.cf-field'); if (f) f.classList.remove('err'); };
      el.addEventListener('input', clear);
      el.addEventListener('change', clear);
    });

    var form = $('#cfForm');
    var submitBtn = $('#cfSubmit');
    if (form) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        if (!validate()) {
          var firstErr = root.querySelector('.cf-field.err');
          if (firstErr) firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
          toast('Please fill in all required fields.');
          return;
        }
        if (submitBtn) { submitBtn.classList.add('loading'); submitBtn.disabled = true; }
        setTimeout(function () {
          if (submitBtn) { submitBtn.classList.remove('loading'); submitBtn.disabled = false; }
          $('#cfSuccessName').textContent = $('#cfFirst').value.trim() || 'there';
          form.style.display = 'none';
          $('#cfSuccess').classList.add('show');
          $('#cfSuccess').scrollIntoView({ behavior: 'smooth', block: 'center' });
        }, 1300);
      });
    }

    var sendAnother = $('#cfSendAnother');
    if (sendAnother) {
      sendAnother.addEventListener('click', function () {
        form.reset();
        if (charsEl) charsEl.textContent = '0/500';
        $$('.cf-field.err').forEach(function (f) { f.classList.remove('err'); });
        $('#cfSuccess').classList.remove('show');
        form.style.display = '';
        form.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }

    /* ── "Send a Message" jump from FAQ ── */
    var jump = $('#faqJumpForm');
    if (jump) jump.addEventListener('click', function () {
      var t = root.querySelector('.contact-layout');
      if (t) t.scrollIntoView({ behavior: 'smooth' });
    });

    /* ── FAQ accordion ── */
    var faqList = $('#faqList');
    if (faqList) {
      faqList.addEventListener('click', function (e) {
        var trig = e.target.closest('.faq-q');
        if (!trig) return;
        var item = trig.closest('.faq-item');
        var wasOpen = item.classList.contains('open');
        $$('.faq-item').forEach(function (it) { it.classList.remove('open'); });
        if (!wasOpen) item.classList.add('open');
      });
    }

    /* ── Highlight current day in store hours ── */
    var days = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
    var today = days[new Date().getDay()];
    $$('.contact-hour-row').forEach(function (row) {
      var day = row.querySelector('.contact-hour-day');
      if (day && day.textContent.trim() === today) row.classList.add('today');
    });
  })();
</script>
