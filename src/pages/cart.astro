---
// ============================================================
//  Cart (Marvexa) — full cart page reskinned to maison-modern-html
//  Cart.html (.cart-pg: header block + split items/summary layout +
//  "You may also like"). The Shopify data layer is untouched: the
//  vanilla <script> binds this static markup to the shared nanostore
//  (stores/cart.ts) for line items, qty, remove, promo (real
//  cartDiscountCodesUpdate), checkout, free-ship meter and totals.
//  Order notes / gift message sync to the real cart (note + attribute);
//  paid gift wrap adds a real line when a variant is configured
//  (CART_EXTRAS in src/config/marvexa.ts), else it's hidden.
// ============================================================
import Layout from '~/layouts/Layout.astro';
import { getProducts } from '~/lib/shopify';
import { BRAND, DELIVERY_ESTIMATE_DAYS, RETURNS_WINDOW_DAYS } from '~/config/marvexa';
import { resolveCartExtras } from '~/lib/cart-extras';
import { formatMoney } from '~/lib/money';
import type { ProductCard as TProductCard } from '~/lib/shopify/types';
import ProductCard from '~/components/product/marvexa/ProductCard.astro';
import Newsletter from '~/components/home/marvexa/Newsletter.astro';
import '~/styles/cart.css';

export const prerender = false;

const market = Astro.locals.market;
let reco: TProductCard[] = [];
try {
  const page = await getProducts({ pageSize: 4, sortKey: 'BEST_SELLING' }, market);
  reco = page.items;
} catch (err) {
  console.error('[cart] reco load failed:', (err as Error).message);
}

// Free-shipping meter is OFF when the threshold is null/0.
const FREE_SHIP = Number(BRAND.freeShippingThreshold) || 0;
const FREE_SHIP_ON = FREE_SHIP > 0;

// Resolve real extras. Gift message is attribute-only (always available).
const EXTRAS = await resolveCartExtras(market);

// Paid gift wrap — real Shopify product/variant resolved by handle. Shows only
// when buyable. Reuses the existing resolver.
const giftWrap = EXTRAS.giftWrap;
const GIFTWRAP_ON = giftWrap.show && !!giftWrap.variantId;
const giftWrapPriceLabel = giftWrap.price ? formatMoney(giftWrap.price) : '';

const extrasConfig = {
  giftMessage: { maxLength: EXTRAS.giftWrap.messageMaxLength ?? 200 },
  giftWrap: GIFTWRAP_ON ? { variantId: giftWrap.variantId, label: giftWrap.label } : null,
};
---

<Layout title="Cart" description="Review your selection and check out securely." noindex>
  <main
    class="cart-pg"
    id="cartModern"
    data-free-ship={BRAND.freeShippingThreshold}
    data-delivery-days={DELIVERY_ESTIMATE_DAYS}
    data-extras={JSON.stringify(extrasConfig)}
  >

    {/* ══ HEADER BLOCK ══ */}
    <div class="cart-hd-block">
      <div class="cart-hd-inner">

        {/* Top row: breadcrumb + perks */}
        <div class="cart-hd-toprow">
          <nav class="cart-bc" aria-label="breadcrumb">
            <a href="/">Home</a>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
            <a href="/products">Shop</a>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
            <span class="cart-bc-cur">Your Bag</span>
          </nav>
          <div class="cart-hd-perks">
            {FREE_SHIP_ON && (
              <>
                <span class="cart-hd-perk">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 8h14M5 8a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-6a2 2 0 0 0-2-2M5 8V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v2"/></svg>
                  <span id="freeShipPerk">Free Shipping</span>
                </span>
                <span class="cart-hd-perk-div"></span>
              </>
            )}
            <span class="cart-hd-perk" title={`Free returns within ${RETURNS_WINDOW_DAYS} days`}>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 14 4 9l5-5"/><path d="M4 9h10.5a5.5 5.5 0 0 1 0 11H11"/></svg>
              Free Returns
            </span>
            <span class="cart-hd-perk-div"></span>
            <span class="cart-hd-perk cart-hd-perk--secure">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              Secure Checkout
            </span>
          </div>
        </div>

        {/* Hero row: heading + stats */}
        <div class="cart-hd-hero">
          <div class="cart-hd-hero-left">
            <div class="cart-hd-eyebrow">SS26 Collection</div>
            <h1 class="cart-hd-title">Your Bag</h1>
            <p class="cart-hd-sub">Review your items and complete your order.</p>
          </div>
          <div class="cart-hd-stats">
            <div class="cart-hd-stat">
              <div class="cart-hd-stat-num" id="cartItemCount">0</div>
              <div class="cart-hd-stat-lbl">Items</div>
            </div>
            {/* Saved-for-later count — shown only when something is saved. */}
            <div class="cart-hd-stat-div" id="cartSavedDiv" style="display:none;"></div>
            <div class="cart-hd-stat" id="cartSavedStat" style="display:none;">
              <div class="cart-hd-stat-num" id="cartSavedCount">0</div>
              <div class="cart-hd-stat-lbl">Saved</div>
            </div>
            <div class="cart-hd-stat-div"></div>
            <div class="cart-hd-stat">
              <div class="cart-hd-stat-num" id="cartHdSubtotal">—</div>
              <div class="cart-hd-stat-lbl">Subtotal</div>
            </div>
          </div>
        </div>

        {/* Free shipping bar */}
        {FREE_SHIP_ON && (
          <div class="cart-ship-bar" id="cartShipBar">
            <div class="cart-ship-inner">
              <div class="cart-ship-msg">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h5a1 1 0 0 1 1 1v7a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                <span id="shipMsgText"></span>
              </div>
              <div class="cart-ship-track">
                <div class="cart-ship-fill" id="shipFill" style="width:0%"></div>
              </div>
            </div>
          </div>
        )}

      </div>
    </div>

    {/* ══ LOADING SKELETON — visible by default, hidden by the first render()
         call once the real cart resolves. Mirrors the real grid's column
         widths so nothing jumps when it swaps in. Fixes the blank flash on
         first paint (cmEmpty/cmGrid are both display:none until JS runs). ══ */}
    <div class="cart-layout cart-skeleton" id="cmSkeleton">
      <div>
        <div class="cart-items-hd">
          <span>Product</span>
          <span>Details</span>
          <span>Total</span>
        </div>
        <div class="cart-items">
          {[0, 1].map(() => (
            <div class="cart-item cart-item--skeleton">
              <div class="cart-item__img sk-block"></div>
              <div class="cart-item__body">
                <div class="sk-line" style="width:40%;"></div>
                <div class="sk-line" style="width:75%;height:14px;"></div>
                <div class="sk-line" style="width:55%;"></div>
              </div>
              <div class="cart-item__side">
                <div class="sk-line" style="width:60px;margin-left:auto;"></div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="cart-summary">
        <div class="cart-summary-hd"><div class="sk-line" style="width:50%;height:16px;"></div></div>
        <div class="cart-summary-body">
          <div class="sk-block" style="height:200px;border-radius:10px;"></div>
        </div>
      </div>
    </div>

    {/* ══ EMPTY STATE ══ */}
    <div class="cart-empty" id="cmEmpty">
      <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
      <h3>Your bag is empty</h3>
      <p>Looks like you haven't added anything yet. Explore the collection and find something you'll love.</p>
      <a href="/products">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        Start shopping
      </a>
    </div>

    {/* ══ MAIN LAYOUT ══ */}
    <div class="cart-layout" id="cmGrid" style="display:none;">

      {/* LEFT: items */}
      <div>
        <div class="cart-items-hd">
          <span>Product</span>
          <span>Details</span>
          <span>Total</span>
        </div>

        <div class="cart-items" id="cartItemsList"></div>

        {/* Saved for Later — local (localStorage); shown only when non-empty */}
        <div class="cart-saved-hd" id="savedHd" style="display:none;">
          Saved for Later <span id="savedCt">0</span>
        </div>
        <div class="cart-items" id="savedList"></div>

        <a href="/products" class="cart-continue">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Continue Shopping
        </a>
      </div>

      {/* RIGHT: order summary */}
      <div class="cart-summary">
        <div class="cart-summary-hd">
          <h3>Order Summary</h3>
        </div>
        <div class="cart-summary-body">

          <div class="cart-sum-thumbs" id="sumThumbs"></div>

          <div class="cart-sum-row">
            <span>Subtotal (<span id="sumItemCt">0 items</span>)</span>
            <span id="sumSubtotal">—</span>
          </div>
          <div class="cart-sum-row discount" id="discountRow" style="display:none;">
            <span id="discountLabel">Promo discount</span>
            <span id="discountAmt"></span>
          </div>
          <div class="cart-sum-row savings" id="savingsRow" style="display:none;">
            <span>You save</span>
            <span id="sumSavings"></span>
          </div>
          <div class="cart-sum-row">
            <span>Shipping</span>
            <span id="sumShipping">Calculated at checkout</span>
          </div>
          <div class="cart-sum-row">
            <span>Estimated tax</span>
            <span id="sumTax">Calculated at checkout</span>
          </div>
          <div class="cart-sum-row total">
            <span>Total</span>
            <span id="sumTotal">—</span>
          </div>

          <div class="cart-sum-delivery">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h5a1 1 0 0 1 1 1v7a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span>Est. delivery by <strong id="cartDelivery">—</strong></span>
          </div>

          {/* Promo — real Shopify discount codes */}
          <div class="cart-promo">
            <input class="cart-promo-input" type="text" id="promoInput" placeholder="Gift or promo code" autocomplete="off">
            <button class="cart-promo-btn" id="promoApply" type="button">Apply</button>
          </div>
          <div class="cart-promo-applied" id="promoMsg" style="display:none;"></div>
          <div class="cart-promo-tags" id="promoTags"></div>

          {/* Checkout */}
          <button class="cart-checkout-btn" id="cmCheckout" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Proceed to Checkout
          </button>

          {/* Gift box — ONE collapsible box. When a paid gift-wrap product is
              buyable it's the wrap (with price); opening adds the real wrap line.
              Otherwise it's the free gift-message attribute. Either way the body
              holds the personal-message textarea. */}
          <div class="cart-gift">
            <div class="cart-gift-hd" id="giftHd">
              <div class="cart-gift-hd-left">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                {GIFTWRAP_ON ? giftWrap.label : 'Add Gift Message'}
              </div>
              <div class="cart-gift-hd-right">
                {GIFTWRAP_ON && giftWrapPriceLabel && <span class="cart-gift-price">{giftWrapPriceLabel}</span>}
                <button class="cart-gift-switch" id="giftToggleBtn" type="button" role="switch" aria-checked="false" aria-label="Toggle gift">
                  <span class="cart-gift-switch-knob"></span>
                </button>
              </div>
            </div>
            <div class="cart-gift-body" id="giftBody">
              {GIFTWRAP_ON && <p class="cart-gift-desc">{giftWrap.desc}</p>}
              <textarea class="cart-gift-textarea" id="giftMsg" placeholder="Write your personal message here…" maxlength={extrasConfig.giftMessage.maxLength}></textarea>
            </div>
          </div>

          {/* Trust */}
          <div class="cart-trust-row">
            <div class="cart-trust-line">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              Secure checkout — SSL encrypted
            </div>
            <div class="cart-trust-line">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.95"/></svg>
              Free returns within {RETURNS_WINDOW_DAYS} days
            </div>
            <div class="cart-trust-line">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Authenticity guaranteed
            </div>
          </div>

        </div>
      </div>

    </div>

    {/* ══ YOU MAY ALSO LIKE ══ */}
    {reco.length > 0 && (
      <section class="cart-related" id="cmReco">
        <div class="cart-related-hd">
          <h2>You May Also Like</h2>
          <a href="/products" class="cart-view-all-btn">Shop All <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        </div>
        <div class="cart-related-grid" id="cartRelatedGrid">
          {reco.map((p) => <ProductCard product={p} />)}
        </div>
      </section>
    )}

    {/* Toast */}
    <div class="toast" id="cartToast"></div>
  </main>

  {/* Newsletter CTA (overlaps the footer) — bg synced to the .cart-related section above */}
  <Newsletter surface="var(--bg2)" />
</Layout>

<script>
  // ============================================================
  //  Cart page controller — binds the marvexa markup above to the
  //  framework-agnostic nanostore (stores/cart.ts). Line items are
  //  rendered into #cartItemsList; totals/free-ship/promo/checkout
  //  mirror the cart drawer. Gift message → cart attribute; gift wrap
  //  toggle → real paid line when a variant is configured.
  // ============================================================
  import {
    $cart,
    $cartBusy,
    $cartError,
    $busyLines,
    initCart,
    addItem,
    updateItem,
    removeItem,
    applyDiscount,
    setAttributes,
    checkout,
  } from '../stores/cart';
  import { formatMoney } from '../lib/money';
  import type { Cart } from '../lib/shopify/types';

  const root = document.getElementById('cartModern');
  const FREE_SHIP = Number(root?.dataset.freeShip ?? 0);
  const DELIVERY_DAYS = Number(root?.dataset.deliveryDays ?? 5);

  // Real date, computed fresh client-side on every visit (not a fake countdown).
  const deliveryEl = document.getElementById('cartDelivery');
  if (deliveryEl) {
    const d = new Date(Date.now() + DELIVERY_DAYS * 86400000);
    deliveryEl.textContent = d.toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' });
  }

  type Extras = {
    giftMessage: { maxLength: number };
    giftWrap: { variantId: string; label: string } | null;
  };
  const EXTRAS: Extras = (() => {
    try { return JSON.parse(root?.dataset.extras || '{}'); } catch { return { giftMessage: { maxLength: 200 }, giftWrap: null }; }
  })();
  const GIFTWRAP_VID = EXTRAS.giftWrap?.variantId || '';
  const GIFTWRAP_LABEL = EXTRAS.giftWrap?.label || '';

  const $ = (id: string) => document.getElementById(id);
  const setText = (id: string, v: string) => { const el = $(id); if (el) el.textContent = v; };

  let currency = 'USD';
  const m = (n: number) => formatMoney({ amount: String(n), currencyCode: currency });

  function esc(s: string) {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  // Toast
  let toastTimer: ReturnType<typeof setTimeout> | undefined;
  function showToast(msg: string) {
    const t = $('cartToast');
    if (!t) return;
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => t.classList.remove('show'), 2600);
  }

  const trashSvg =
    '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>';

  // Variant gids that are "extras" (gift wrap) — hidden from the visible item list.
  const isExtraLine = (vid: string) => !!GIFTWRAP_VID && vid === GIFTWRAP_VID;

  function visibleLines(cart: Cart | null) {
    return (cart?.lines ?? []).filter((l) => !isExtraLine(l.merchandise.id));
  }

  function renderItems(cart: Cart | null) {
    const wrap = $('cartItemsList');
    if (!wrap) return;
    wrap.innerHTML = visibleLines(cart)
      .map((line) => {
        const md = line.merchandise;
        const image = md.image ?? md.product?.featuredImage ?? null;
        const lineTotal = Number(line.cost?.totalAmount?.amount ?? 0);
        const unitPrice = Number(md.price?.amount ?? 0);
        const opts = md.selectedOptions.filter((o) => o.value !== 'Default Title');
        const tags = opts
          .map((o) => `<span class="cart-item__meta-tag">${esc(o.name)}: ${esc(o.value)}</span>`)
          .join('');
        // Compare-at ("was") price — render Sale badge + strikethrough only
        // when the merchant actually set a higher compare-at on the variant.
        const compareUnit = Number(md.compareAtPrice?.amount ?? 0);
        const onSale = compareUnit > unitPrice;
        const badge = onSale ? '<span class="cart-item__badge">Sale</span>' : '';
        const orig = onSale
          ? `<span class="cart-item__price-orig">${m(compareUnit * line.quantity)}</span>`
          : (line.quantity > 1 ? `<span class="cart-item__price-orig">${m(unitPrice)} each</span>` : '');
        return `
        <div class="cart-item" data-id="${esc(line.id)}">
          <div class="cart-item__img">
            ${badge}
            ${image ? `<img src="${esc(image.url)}" alt="${esc(image.altText ?? md.product.title)}" loading="lazy">` : ''}
          </div>
          <div class="cart-item__body">
            <div class="cart-item__cat">${esc(md.product.title !== md.title ? md.title : 'Marvexa')}</div>
            <a href="/products/${esc(md.product.handle)}" class="cart-item__name">${esc(md.product.title)}</a>
            <div class="cart-item__meta">${tags}</div>
            <div class="cart-item__actions">
              <button class="cart-item__action-btn" type="button" data-act="save"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg> Save</button>
              <button class="cart-item__action-btn remove" type="button" data-act="remove">${trashSvg} Remove</button>
            </div>
          </div>
          <div class="cart-item__side">
            <div class="cart-item__price-block">
              <span class="cart-item__price">${m(lineTotal)}</span>
              ${orig}
            </div>
            <div class="cart-qty">
              <button class="cart-qty-btn" type="button" data-act="dec" aria-label="Decrease"${line.quantity <= 1 ? ' disabled' : ''}>−</button>
              <div class="cart-qty-val">${line.quantity}</div>
              <button class="cart-qty-btn" type="button" data-act="inc" aria-label="Increase">+</button>
            </div>
            <div class="cart-item__subtotal">Subtotal: ${m(lineTotal)}</div>
          </div>
        </div>`;
      })
      .join('');
    applyLineBusy($busyLines.get());
  }

  function renderThumbs(cart: Cart | null) {
    const el = $('sumThumbs');
    if (!el) return;
    el.innerHTML = visibleLines(cart)
      .map((line) => {
        const img = line.merchandise.image ?? line.merchandise.product?.featuredImage ?? null;
        return img ? `<img class="cart-sum-thumb" src="${esc(img.url)}" alt="" loading="lazy">` : '';
      })
      .join('');
  }

  function renderSummary(cart: Cart | null) {
    const lines = visibleLines(cart);
    currency = cart?.cost?.subtotalAmount?.currencyCode ?? 'USD';
    const subtotal = Number(cart?.cost?.subtotalAmount?.amount ?? 0);
    const total = Number(cart?.cost?.totalAmount?.amount ?? subtotal);
    const tax = cart?.cost?.totalTaxAmount ? Number(cart.cost.totalTaxAmount.amount) : null;
    const discountTotal = (cart?.discountAllocations ?? []).reduce(
      (s, d) => s + Number(d.discountedAmount?.amount ?? 0), 0,
    );
    const appliedCodes = (cart?.discountCodes ?? []).filter((c) => c.applicable).map((c) => c.code);
    const count = lines.reduce((s, l) => s + l.quantity, 0);
    const itemWord = count === 1 ? 'item' : 'items';

    // Header stats
    setText('cartItemCount', String(count));
    setText('cartHdSubtotal', m(subtotal));
    setText('cartHdTotal', m(total));

    // Summary rows
    setText('sumItemCt', `${count} ${itemWord}`);
    setText('sumSubtotal', m(subtotal));
    setText('sumTotal', m(total));

    const discRow = $('discountRow');
    if (discRow) {
      discRow.style.display = discountTotal > 0 ? '' : 'none';
      setText('discountLabel', appliedCodes.length ? `Promo (${appliedCodes.join(', ')})` : 'Promo discount');
      setText('discountAmt', `−${m(discountTotal)}`);
    }

    // Compare-at savings — sum (was − now) × qty across lines; shown only when > 0.
    const savings = lines.reduce((s, l) => {
      const u = Number(l.merchandise.price?.amount ?? 0);
      const c = Number(l.merchandise.compareAtPrice?.amount ?? 0);
      return s + (c > u ? (c - u) * l.quantity : 0);
    }, 0);
    const savRow = $('savingsRow');
    if (savRow) savRow.style.display = savings > 0 ? '' : 'none';
    if (savings > 0) setText('sumSavings', `−${m(savings)}`);

    // Shipping (free once the threshold is unlocked)
    const unlocked = FREE_SHIP > 0 && subtotal >= FREE_SHIP;
    setText('sumShipping', unlocked ? 'Free' : 'Calculated at checkout');

    // Tax
    setText('sumTax', tax != null ? m(tax) : 'Calculated at checkout');

    // Free-ship meter
    if (FREE_SHIP > 0) {
      const remaining = Math.max(0, FREE_SHIP - subtotal);
      const progress = Math.min(100, Math.round((subtotal / FREE_SHIP) * 100));
      const txt = $('shipMsgText');
      if (txt) {
        txt.innerHTML = unlocked
          ? "<strong>Free shipping unlocked!</strong> Your order ships free."
          : `You're <strong>${m(remaining)}</strong> away from free shipping!`;
      }
      const fill = $('shipFill');
      if (fill) fill.style.width = `${progress}%`;
      setText('freeShipPerk', `Free Shipping over ${m(FREE_SHIP)}`);
    }

    // Applied promo tags
    const tags = $('promoTags');
    if (tags) {
      tags.innerHTML = appliedCodes
        .map((c) => `<button class="cart-promo-tag is-active" type="button" data-code="${esc(c)}" title="Remove code">${esc(c)} ✕</button>`)
        .join('');
    }
  }

  function render(cart: Cart | null) {
    // First real render — swap the loading skeleton out for good.
    const sk = $('cmSkeleton');
    if (sk) sk.style.display = 'none';
    const hasItems = visibleLines(cart).length > 0;
    // Keep the layout (and saved list) visible when only saved items remain.
    const empty = !hasItems && getSaved().length === 0;
    $('cmEmpty')?.classList.toggle('show', empty);
    const grid = $('cmGrid');
    if (grid) grid.style.display = empty ? 'none' : '';
    const reco = $('cmReco');
    if (reco) reco.style.display = empty ? 'none' : '';
    renderItems(cart);
    renderThumbs(cart);
    renderSummary(cart);
    renderSaved();
    // Checkout needs at least one cart line (saved-only carts can't check out).
    ($('cmCheckout') as HTMLButtonElement | null)?.toggleAttribute('disabled', !hasItems);
  }

  // ---- Busy states ----
  function applyBusy(busy: boolean) {
    for (const id of ['promoInput', 'promoApply', 'cmCheckout']) {
      const el = $(id) as HTMLButtonElement | HTMLInputElement | null;
      if (el) el.toggleAttribute('disabled', busy);
    }
  }
  function applyLineBusy(map: Record<string, boolean>) {
    document.querySelectorAll<HTMLElement>('.cart-item[data-id]').forEach((row) => {
      const id = row.dataset.id!;
      const busy = !!map[id];
      row.classList.toggle('removing', busy);
      row.querySelectorAll('button[data-act]').forEach((b) => (b as HTMLButtonElement).toggleAttribute('disabled', busy));
    });
  }

  // ---- Subscriptions ----
  $cart.subscribe(render);
  $cartBusy.subscribe(applyBusy);
  $busyLines.subscribe(applyLineBusy);
  $cartError.subscribe((err) => { if (err) showToast(err); });

  // ---- Line item controls (delegation) ----
  $('cartItemsList')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button[data-act]');
    if (!btn) return;
    const row = btn.closest<HTMLElement>('.cart-item[data-id]');
    const id = row?.dataset.id;
    if (!id) return;
    const line = $cart.get()?.lines.find((l) => l.id === id);
    const qty = line?.quantity ?? 1;
    const act = (btn as HTMLElement).dataset.act;
    if (act === 'inc') updateItem(id, qty + 1);
    else if (act === 'dec') { if (qty > 1) updateItem(id, qty - 1); }
    else if (act === 'remove') removeItem(id);
    else if (act === 'save') { if (line) { saveLine(line); removeItem(id); } }
  });

  // ---- Promo ----
  function setPromoMsg(kind: 'ok' | 'err' | null, text = '') {
    const el = $('promoMsg');
    if (!el) return;
    el.style.display = kind ? 'block' : 'none';
    el.style.color = kind === 'err' ? 'var(--rust)' : 'var(--accent)';
    el.textContent = text;
  }
  async function submitPromo() {
    const input = $('promoInput') as HTMLInputElement | null;
    const code = (input?.value || '').trim();
    if (!code) { setPromoMsg('err', 'Enter a code first.'); return; }
    setPromoMsg(null);
    const applied = ($cart.get()?.discountCodes ?? []).filter((c) => c.applicable).map((c) => c.code);
    const res = await applyDiscount([...applied, code]);
    const ok = res.cart?.discountCodes?.some((c) => c.applicable && c.code.toUpperCase() === code.toUpperCase());
    if (ok) {
      if (input) input.value = '';
      setPromoMsg('ok', `Applied: ${code.toUpperCase()} ✓`);
    } else {
      setPromoMsg('err', 'Invalid or expired code.');
    }
  }
  $('promoApply')?.addEventListener('click', submitPromo);
  $('promoInput')?.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter') { e.preventDefault(); submitPromo(); }
  });
  $('promoTags')?.addEventListener('click', (e) => {
    const tag = (e.target as HTMLElement).closest<HTMLElement>('[data-code]');
    if (!tag) return;
    setPromoMsg(null);
    const applied = ($cart.get()?.discountCodes ?? []).filter((c) => c.applicable).map((c) => c.code);
    applyDiscount(applied.filter((c) => c !== tag.dataset.code));
  });

  // ---- Checkout (goes to Shopify checkout, which offers wallet pay) ----
  $('cmCheckout')?.addEventListener('click', () => checkout());

  // ---- Cart attribute helper (wholesale merge) ----
  async function syncAttrs(updates: Record<string, string | null>) {
    const kept = ($cart.get()?.attributes ?? []).filter((a) => !(a.key in updates));
    const next = [...kept];
    for (const [key, value] of Object.entries(updates)) if (value) next.push({ key, value });
    await setAttributes(next);
  }

  // ---- Gift box: collapsible message + (when buyable) paid wrap line ----
  const giftHd = $('giftHd');
  const giftBody = $('giftBody');
  const giftToggleBtn = $('giftToggleBtn');
  const giftMsg = $('giftMsg') as HTMLTextAreaElement | null;
  // Add/remove the paid wrap line, coalescing clicks during the in-flight
  // mutation. No-op when no wrap product.
  let gwBusy = false;
  let gwPending: boolean | null = null;
  async function applyGiftWrap(on: boolean) {
    const line = lineByVariant(GIFTWRAP_VID);
    if (on && !line) await addItem(GIFTWRAP_VID, 1, { open: false });
    else if (!on && line) await removeItem(line.id);
    await syncAttrs({ gift_wrap: on ? GIFTWRAP_LABEL : null });
  }
  function setGiftWrap(on: boolean) {
    if (!GIFTWRAP_VID) return;
    gwPending = on;
    if (gwBusy) return;
    gwBusy = true;
    (async () => {
      try {
        while (gwPending !== null) {
          const w = gwPending;
          gwPending = null;
          await applyGiftWrap(w);
        }
      } finally {
        gwBusy = false;
      }
    })();
  }
  function setGiftSwitch(on: boolean) {
    if (!giftToggleBtn) return;
    giftToggleBtn.classList.toggle('on', on);
    giftToggleBtn.setAttribute('aria-checked', String(on));
  }
  giftHd?.addEventListener('click', () => {
    const open = giftBody?.classList.toggle('open') ?? false;
    setGiftSwitch(open);
    // When a paid wrap is configured, opening the box adds the wrap line; closing removes it.
    setGiftWrap(open);
  });
  let giftTimer: ReturnType<typeof setTimeout> | undefined;
  giftMsg?.addEventListener('input', () => {
    clearTimeout(giftTimer);
    giftTimer = setTimeout(() => syncAttrs({ gift_message: giftMsg.value.trim() || null }), 600);
  });

  const lineByVariant = (vid: string) => $cart.get()?.lines.find((l) => l.merchandise.id === vid) ?? null;

  // ---- Hydrate extras from the server cart (once) ----
  let hydrated = false;
  function hydrate(cart: Cart | null) {
    if (hydrated || !cart) return;
    hydrated = true;
    const attrs = Object.fromEntries((cart.attributes ?? []).map((a) => [a.key, a.value]));
    if (giftMsg && attrs.gift_message) giftMsg.value = attrs.gift_message;
    // Open the box if a wrap line is already in the cart, or a message was saved.
    const hasWrap = !!GIFTWRAP_VID && cart.lines.some((l) => l.merchandise.id === GIFTWRAP_VID);
    if (hasWrap || (giftMsg && attrs.gift_message)) {
      giftBody?.classList.add('open');
      setGiftSwitch(true);
    }
  }
  $cart.subscribe(hydrate);

  // ============================================================
  //  Save for Later — local (localStorage). Shopify has no native
  //  "saved" cart, so headless storefronts persist this client-side.
  //  Each saved entry keeps enough to re-add the exact variant.
  // ============================================================
  type SavedItem = {
    variantId: string;
    handle: string;
    title: string;
    variantTitle: string;
    image: string;
    imageAlt: string;
    price: { amount: string; currencyCode: string };
    options: { name: string; value: string }[];
  };
  const SAVED_KEY = 'marvexa_saved_v1';

  function getSaved(): SavedItem[] {
    try { return JSON.parse(localStorage.getItem(SAVED_KEY) || '[]'); } catch { return []; }
  }
  function writeSaved(arr: SavedItem[]) {
    localStorage.setItem(SAVED_KEY, JSON.stringify(arr));
    renderSaved();
  }
  function saveLine(line: Cart['lines'][number]) {
    const md = line.merchandise;
    const saved = getSaved();
    if (saved.some((s) => s.variantId === md.id)) return;
    const img = md.image ?? md.product?.featuredImage ?? null;
    saved.push({
      variantId: md.id,
      handle: md.product.handle,
      title: md.product.title,
      variantTitle: md.title && md.title !== md.product.title ? md.title : '',
      image: img?.url ?? '',
      imageAlt: img?.altText ?? md.product.title,
      price: { amount: String(md.price?.amount ?? 0), currencyCode: md.price?.currencyCode ?? currency },
      options: md.selectedOptions.filter((o) => o.value !== 'Default Title'),
    });
    writeSaved(saved);
  }

  function renderSaved() {
    const saved = getSaved();
    const show = saved.length > 0;
    const hd = $('savedHd');
    if (hd) hd.style.display = show ? '' : 'none';
    $('cartSavedStat')!.style.display = show ? '' : 'none';
    $('cartSavedDiv')!.style.display = show ? '' : 'none';
    setText('savedCt', String(saved.length));
    setText('cartSavedCount', String(saved.length));

    const list = $('savedList');
    if (!list) return;
    list.innerHTML = saved
      .map((s) => {
        const tags = s.options
          .map((o) => `<span class="cart-item__meta-tag">${esc(o.name)}: ${esc(o.value)}</span>`)
          .join('');
        return `
        <div class="cart-item" data-saved="${esc(s.variantId)}">
          <div class="cart-item__img">${s.image ? `<img src="${esc(s.image)}" alt="${esc(s.imageAlt)}" loading="lazy">` : ''}</div>
          <div class="cart-item__body">
            ${s.variantTitle ? `<div class="cart-item__cat">${esc(s.variantTitle)}</div>` : ''}
            <a href="/products/${esc(s.handle)}" class="cart-item__name">${esc(s.title)}</a>
            <div class="cart-item__meta">${tags}</div>
            <div class="cart-item__actions">
              <button class="cart-item__action-btn" type="button" data-act="move"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg> Move to Cart</button>
              <button class="cart-item__action-btn remove" type="button" data-act="unsave">${trashSvg} Remove</button>
            </div>
          </div>
          <div class="cart-item__side">
            <div class="cart-item__price-block"><span class="cart-item__price">${formatMoney(s.price)}</span></div>
          </div>
        </div>`;
      })
      .join('');
  }

  $('savedList')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button[data-act]');
    if (!btn) return;
    const row = btn.closest<HTMLElement>('.cart-item[data-saved]');
    const vid = row?.dataset.saved;
    if (!vid) return;
    const act = (btn as HTMLElement).dataset.act;
    if (act === 'move') {
      addItem(vid, 1, { open: false });
      writeSaved(getSaved().filter((s) => s.variantId !== vid));
    } else if (act === 'unsave') {
      writeSaved(getSaved().filter((s) => s.variantId !== vid));
    }
  });

  renderSaved();

  initCart();
</script>
