---
// ============================================================
//  Blog detail (MARVEXA "Modern") — a single journal article in the
//  `.bd-pg` editorial layout: meta bar, title, hero, article body +
//  sticky TOC sidebar, tags, author card, and related posts. Driven
//  by the `blog` content collection; SSR looks the post up by slug
//  and 404s if missing. Site chrome + newsletter come from Layout.
// ============================================================
import Layout from '~/layouts/Layout.astro';
import '~/styles/blog-detail.css';
import Newsletter from '~/components/home/marvexa/Newsletter.astro';
import { getArticleByHandle, getBlogArticles } from '~/lib/shopify';
import { BRAND } from '~/config/marvexa';

const { slug } = Astro.params;
const post = slug ? await getArticleByHandle(slug) : null;

if (!post) {
  Astro.response.status = 404;
}

const fmt = (d: string) =>
  new Date(d).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
const fmtShort = (d: string) =>
  new Date(d).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
const initials = (name: string) =>
  name.split(' ').map((w) => w[0]).slice(0, 2).join('').toUpperCase();

const headings = post?.headings ?? [];
const related = post
  ? (await getBlogArticles()).filter((p) => p.handle !== post.handle).slice(0, 3)
  : [];
const author = post?.author;

const authorName = author?.name ?? 'MARVEXA';
const authorRole = author?.role ?? '';
const authorBio = author?.bio ?? '';
const authorAvatar = author?.avatar;

const canonical = post ? new URL(Astro.url.pathname, Astro.url.origin).href : undefined;
const ogImage = post?.image
  ? new URL(post.image.url, Astro.site ?? Astro.url.origin).href
  : undefined;
const articleJsonLd = post
  ? {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: post.title,
      description: post.excerpt,
      ...(ogImage ? { image: [ogImage] } : {}),
      datePublished: post.publishedAt,
      ...(author ? { author: { '@type': 'Person', name: author.name } } : {}),
      publisher: { '@type': 'Organization', name: BRAND.legalName },
      mainEntityOfPage: canonical,
    }
  : undefined;
---

{
  post ? (
    <Layout
      title={`${post.title} — MARVEXA Journal`}
      description={post.excerpt}
      type="article"
      image={ogImage}
      jsonLd={articleJsonLd}
    >
      <main id="mainContent" class="bd-pg">

        {/* META BAR ───────────────────────── */}
        <div class="bd-meta-bar">
          <div class="bd-meta-left">
            <nav style="font-family:var(--fb);font-size:12px;color:var(--muted);display:flex;align-items:center;gap:6px;">
              <a href="/" style="color:var(--muted);text-decoration:none;transition:color .18s;"
                onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--muted)'">Home</a>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6" />
              </svg>
              <a href="/blog" style="color:var(--muted);text-decoration:none;transition:color .18s;"
                onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--muted)'">Journal</a>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6" />
              </svg>
              <span style="color:var(--text);font-weight:600;">{post.category}</span>
            </nav>
            <span class="bd-cat">{post.category}</span>
            <div class="bd-meta-items">
              {post.readingTime && (
                <span class="bd-meta-item"><svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                  </svg> {post.readingTime}</span>
              )}
              <span class="bd-meta-sep"></span>
              <span class="bd-meta-item"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                  <line x1="16" y1="2" x2="16" y2="6" />
                  <line x1="8" y1="2" x2="8" y2="6" />
                  <line x1="3" y1="10" x2="21" y2="10" />
                </svg> {fmt(post.publishedAt)}</span>
            </div>
          </div>
        </div>

        {/* TITLE ──────────────────────────── */}
        <div class="bd-title-wrap">
          <h1 class="bd-title">{post.title}</h1>
          <p class="bd-intro">{post.excerpt}</p>
        </div>

        {/* HERO IMAGE ─────────────────────── */}
        {post.image && (
          <div class="bd-wrap">
            <div class="bd-hero-img">
              <img src={post.image.url} alt={post.image.altText || post.title} loading="eager" />
            </div>
          </div>
        )}

        {/* ARTICLE LAYOUT ─────────────────── */}
        <div class="bd-layout">

          {/* BODY */}
          <article class="bd-body">
            <Fragment set:html={post.contentHtml} />

            {post.tags.length > 0 && (
              <div class="bd-tags">
                {post.tags.map((t) => <a href="/blog" class="bd-tag">{t}</a>)}
              </div>
            )}

            {author && (
              <div class="bd-author-card">
                <div class="bd-author-card-av">{authorAvatar ? <img src={authorAvatar} alt={authorName} /> : initials(authorName)}</div>
                <div>
                  <div class="bd-author-card-lbl">Written by</div>
                  <div class="bd-author-card-name">
                    {author.handle ? <a href={`/blog/author/${author.handle}`}>{authorName}</a> : authorName}
                  </div>
                  {authorRole && <div class="bd-author-card-role">{authorRole}, MARVEXA</div>}
                  {authorBio && <p class="bd-author-card-bio">{authorBio}</p>}
                </div>
              </div>
            )}
          </article>

          {/* SIDEBAR */}
          <aside class="bd-sidebar">
            {headings.length > 0 && (
              <div class="bd-toc-card">
                <div class="bd-toc-title">In this article</div>
                <div class="bd-toc-list">
                  {headings.map((h, i) => (
                    <a href={`#${h.slug}`} class="bd-toc-item">
                      <span class="bd-toc-n">{String(i + 1).padStart(2, '0')}</span>
                      <span class="bd-toc-t">{h.text}</span>
                    </a>
                  ))}
                </div>
              </div>
            )}
            <div class="bd-sidebar-share">
              <div class="bd-sidebar-share-title">Share this article</div>
              <div class="bd-sidebar-btns">
                <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(canonical ?? '')}&text=${encodeURIComponent(post.title)}`}
                  target="_blank" rel="noopener" class="bd-sb-btn"><svg width="14" height="14" viewBox="0 0 24 24"
                    fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path
                      d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z" />
                  </svg> Twitter</a>
                <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(canonical ?? '')}`}
                  target="_blank" rel="noopener" class="bd-sb-btn"><svg width="14" height="14" viewBox="0 0 24 24"
                    fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
                  </svg> Facebook</a>
                <button type="button" id="bdCopyLink" class="bd-sb-btn"><svg width="14" height="14" viewBox="0 0 24 24"
                    fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
                  </svg> Copy</button>
              </div>
            </div>
          </aside>
        </div>

        {/* RELATED POSTS ───────────────────── */}
        {related.length > 0 && (
          <section class="bd-related">
            <div class="bd-related-inner">
              <div class="bd-related-head">
                <h2 class="bd-related-title">Continue Reading</h2>
                <a href="/blog"
                  style="display:inline-flex;align-items:center;gap:7px;font-family:var(--fb);font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:#fff;text-decoration:none;background:var(--text);border:1.5px solid var(--text);border-radius:4px;padding:11px 20px;white-space:nowrap;transition:background .2s,border-color .2s;"
                  onmouseover="this.style.background='var(--accent)';this.style.borderColor='var(--accent)'"
                  onmouseout="this.style.background='var(--text)';this.style.borderColor='var(--text)'">View all <svg
                    width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="13 6 19 12 13 18" />
                  </svg></a>
              </div>
              <div class="bd-related-grid">
                {
                  related.map((p) => (
                    <a href={`/blog/${p.handle}`} class="bd-rel-card">
                      <div class="bd-rel-img">{p.image && <img src={p.image.url} alt={p.image.altText || p.title} loading="lazy" />}</div>
                      <div class="bd-rel-body">
                        <span class="bd-rel-cat">{p.category}</span>
                        <div class="bd-rel-title">{p.title}</div>
                        <div class="bd-rel-meta">
                          {p.readingTime && (
                            <span class="bd-rel-meta-item"><svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10" />
                                <polyline points="12 6 12 12 16 14" />
                              </svg> {p.readingTime}</span>
                          )}
                          <span class="bd-meta-sep" style="width:3px;height:3px;border-radius:50%;background:var(--border);"></span>
                          <span class="bd-rel-meta-item">{fmtShort(p.publishedAt)}</span>
                        </div>
                      </div>
                    </a>
                  ))
                }
              </div>
            </div>
          </section>
        )}

      </main>

      {/* ── Newsletter CTA (last — overlaps the footer) ── */}
      <Newsletter surface="var(--bg)" padTop="0" />

      <script>
        // TOC smooth-scroll (offset for the fixed header) + scroll-spy, plus copy-link.
        const main = document.getElementById('mainContent');
        if (main) {
          const tocItems = Array.from(main.querySelectorAll<HTMLAnchorElement>('.bd-toc-item'));
          const headings = tocItems
            .map((a) => {
              const id = (a.getAttribute('href') || '').slice(1);
              return id ? document.getElementById(id) : null;
            })
            .filter((el): el is HTMLElement => !!el);

          const HEADER_OFFSET = 120;

          tocItems.forEach((a) => {
            a.addEventListener('click', (e) => {
              const id = (a.getAttribute('href') || '').slice(1);
              const target = id ? document.getElementById(id) : null;
              if (!target) return;
              e.preventDefault();
              const top = target.getBoundingClientRect().top + window.scrollY - HEADER_OFFSET;
              window.scrollTo({ top, behavior: 'smooth' });
              history.replaceState(null, '', '#' + id);
            });
          });

          const setActive = () => {
            const pos = window.scrollY + HEADER_OFFSET + 8;
            let current = headings[0]?.id;
            for (const h of headings) {
              if (h.offsetTop <= pos) current = h.id;
            }
            tocItems.forEach((a) => {
              a.classList.toggle('active', a.getAttribute('href') === '#' + current);
            });
          };

          if (headings.length) {
            setActive();
            window.addEventListener('scroll', setActive, { passive: true });
          }

          const copyBtn = document.getElementById('bdCopyLink');
          copyBtn?.addEventListener('click', async () => {
            try {
              await navigator.clipboard.writeText(window.location.href);
              const original = copyBtn.innerHTML;
              copyBtn.textContent = 'Copied!';
              setTimeout(() => { copyBtn.innerHTML = original; }, 1500);
            } catch {}
          });
        }
      </script>
    </Layout>
  ) : (
    <Layout title="Post not found" description="We couldn’t find that journal entry." noindex>
      <section class="sec">
        <div class="container nf2">
          <p class="nf2-eyebrow">Error 404</p>
          <h1 class="h1">Post not found</h1>
          <p>We couldn't find that journal entry.</p>
          <a class="btn btn-primary" href="/blog">All articles</a>
        </div>
      </section>
    </Layout>
  )
}
