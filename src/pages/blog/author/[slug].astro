---
// ============================================================
//  Author page (MARVEXA "Modern") — author header + bio + every post
//  they've written, styled to match the Journal index / detail pages
//  (`.cart-hd-*` header + `.bl-*` card grid). SSR: looks the author
//  up by slug, 404 if missing. Site chrome + newsletter from Layout.
// ============================================================
import Layout from '~/layouts/Layout.astro';
import '~/styles/blog.css';
import Newsletter from '~/components/home/marvexa/Newsletter.astro';
import { getEntry, getCollection } from 'astro:content';
import { resolveImage } from '~/lib/asset';

const { slug } = Astro.params;
const author = slug ? await getEntry('authors', slug) : undefined;

if (!author) {
  Astro.response.status = 404;
}

// Coloured category pill — shared with the Journal index.
const CAT_STYLE: Record<string, string> = {
  'Style Guide': 'background:rgba(122,143,58,.12);color:var(--accent);',
  'Wardrobe Tips': 'background:rgba(100,130,180,.12);color:#5A7AB4;',
  'Craft & Care': 'background:rgba(160,100,60,.12);color:#A0643C;',
  'Behind MARVEXA': 'background:rgba(80,80,80,.1);color:var(--muted);',
};
const catStyle = (c?: string) => (c && CAT_STYLE[c]) || CAT_STYLE['Behind MARVEXA'];
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const initials = (name: string) =>
  name.split(' ').map((w) => w[0]).slice(0, 2).join('').toUpperCase();

let posts: Awaited<ReturnType<typeof getCollection<'blog'>>> = [];
if (author) {
  posts = (await getCollection('blog'))
    .filter((p) => p.data.author === slug)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
}

// Distinct topics across this author's posts → "writes about" chips.
const topics = [...new Set(posts.flatMap((p) => p.data.tags))].slice(0, 6);
---

{
  author ? (
    <Layout title={`${author.data.name} — MARVEXA Journal`} description={author.data.bio}>
      <main id="mainContent" class="blog-pg">

        {/* ── HEADER ── */}
        <div class="cart-hd-block">
          <div class="cart-hd-inner">
            <div class="cart-hd-toprow">
              <nav class="cart-bc"><a href="/">Home</a><svg width="12" height="12" viewBox="0 0 24 24"
                  fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="9 18 15 12 9 6" />
                </svg><a href="/blog">Journal</a><svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="9 18 15 12 9 6" />
                </svg><span class="cart-bc-cur">{author.data.name}</span></nav>
              <div class="cart-hd-perks">
                {author.data.twitter && (
                  <a class="cart-hd-perk" href={`https://twitter.com/${author.data.twitter.replace('@', '')}`}
                    target="_blank" rel="noopener" style="text-decoration:none;">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                      stroke-linecap="round" stroke-linejoin="round">
                      <path
                        d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z" />
                    </svg> {author.data.twitter}</a>
                )}
              </div>
            </div>
            <div class="cart-hd-hero">
              <div class="cart-hd-hero-left">
                <div class="au-id-row">
                  {author.data.avatar ? (
                    <img class="au-avatar" src={author.data.avatar} alt={author.data.name} />
                  ) : (
                    <div class="au-avatar au-avatar--fallback">{initials(author.data.name)}</div>
                  )}
                  <div>
                    <div class="cart-hd-eyebrow">Author</div>
                    <h1 class="cart-hd-title">{author.data.name}</h1>
                    {author.data.role && <p class="cart-hd-sub">{author.data.role}</p>}
                  </div>
                </div>
                {author.data.bio && <p class="au-bio">{author.data.bio}</p>}
                {topics.length > 0 && (
                  <div class="au-topics">
                    {topics.map((t) => <span class="bl-cat" style="background:var(--bg2);color:var(--muted);">{t}</span>)}
                  </div>
                )}
              </div>
              <div class="cart-hd-stats">
                <div class="cart-hd-stat">
                  <div class="cart-hd-stat-num">{posts.length}</div>
                  <div class="cart-hd-stat-lbl">Article{posts.length === 1 ? '' : 's'}</div>
                </div>
                <div class="cart-hd-stat-div"></div>
                <div class="cart-hd-stat">
                  <div class="cart-hd-stat-num">{topics.length}</div>
                  <div class="cart-hd-stat-lbl">Topic{topics.length === 1 ? '' : 's'}</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* ── POSTS GRID ── */}
        <section class="bl-grid-section">
          <div class="bl-grid-inner">
            <div class="bl-grid-header">
              <h2 class="bl-grid-title">Latest stories</h2>
              <span class="bl-grid-count">{posts.length} article{posts.length === 1 ? '' : 's'}</span>
            </div>
            {
              posts.length > 0 ? (
                <div class="bl-grid">
                  {
                    posts.map((p) => (
                      <article class="bl-card">
                        <a href={`/blog/${p.id}`} class="bl-card-img-wrap">
                          <img src={resolveImage(p.data.image).src} alt={p.data.title} loading="lazy" class="bl-card-img" />
                          <div class="bl-card-img-overlay"></div>
                        </a>
                        <div class="bl-card-body">
                          <div class="bl-card-meta-top"><span class="bl-cat" style={catStyle(p.data.category)}>{p.data.category}</span></div>
                          <h3 class="bl-card-title"><a href={`/blog/${p.id}`}>{p.data.title}</a></h3>
                          <p class="bl-card-excerpt">{p.data.excerpt}</p>
                          <div class="bl-card-meta-bot">
                            {p.data.readingTime && (
                              <span class="bl-meta-item"><svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                                  stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                  <circle cx="12" cy="12" r="10" />
                                  <polyline points="12 6 12 12 16 14" />
                                </svg> {p.data.readingTime}</span>
                            )}
                            <span class="bl-meta-sep"></span>
                            <span class="bl-meta-item"><svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                                <line x1="16" y1="2" x2="16" y2="6" />
                                <line x1="8" y1="2" x2="8" y2="6" />
                                <line x1="3" y1="10" x2="21" y2="10" />
                              </svg> {fmt(p.data.date)}</span>
                          </div>
                        </div>
                      </article>
                    ))
                  }
                </div>
              ) : (
                <p class="au-empty">No articles from this author yet.</p>
              )
            }
          </div>
        </section>

      </main>

      {/* ── Newsletter CTA (last — overlaps the footer) ── */}
      <Newsletter surface="var(--bg)" padTop="0" />
    </Layout>
  ) : (
    <Layout title="Author not found" description="We couldn’t find that author." noindex>
      <main id="mainContent" class="blog-pg">
        <div class="cart-hd-block">
          <div class="cart-hd-inner">
            <div class="cart-hd-hero">
              <div class="cart-hd-hero-left">
                <div class="cart-hd-eyebrow">Error 404</div>
                <h1 class="cart-hd-title">Author not found</h1>
                <p class="cart-hd-sub">We couldn't find that author. <a href="/blog" style="color:var(--accent);text-decoration:underline;">Back to the Journal</a></p>
              </div>
            </div>
          </div>
        </div>
      </main>
    </Layout>
  )
}

<style>
  /* Author identity — avatar + name row inside the shared header. */
  .au-id-row { display: flex; align-items: center; gap: 18px; }
  .au-avatar {
    width: 72px; height: 72px; border-radius: 50%; object-fit: cover;
    border: 2px solid var(--border); flex-shrink: 0;
  }
  .au-avatar--fallback {
    display: flex; align-items: center; justify-content: center;
    background: var(--card); object-fit: initial;
    font-family: var(--fh); font-size: 24px; font-weight: 700; color: var(--text);
  }
  .au-bio {
    margin: 20px 0 0; max-width: 560px;
    font-family: var(--fb); font-size: 14px; line-height: 1.7; color: var(--muted);
  }
  .au-topics { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 18px; }
  .au-empty { color: var(--muted); padding: 32px 0; font-family: var(--fb); }

  @media (max-width: 600px) {
    .au-id-row { gap: 14px; }
    .au-avatar { width: 56px; height: 56px; }
  }
</style>
