---
// ============================================================
//  About (MARVEXA "Modern") — static brand story page. Faithful
//  reproduction of marvexa About.html: story hero, by-the-numbers,
//  philosophy values, craft/atelier, our-promise, team, FAQ, and
//  a closing CTA. Reveal + stat counters via a small vanilla script.
// ============================================================
import Layout from '~/layouts/Layout.astro';
import { resolveImage } from '~/lib/asset';
import '~/styles/about.css';
import Testimonials from '~/components/home/marvexa/Testimonials.astro';
import Newsletter from '~/components/home/marvexa/Newsletter.astro';

const philosophy = [
  {
    num: '01',
    title: 'Effortless Quality',
    desc: "We select only long-staple natural fibres, tested for 200+ washes. A great garment shouldn't need to announce itself — you simply feel it the moment you put it on.",
    path: '<path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" y1="8" x2="2" y2="22"/><line x1="17.5" y1="15" x2="9" y2="15"/>',
  },
  {
    num: '02',
    title: 'Considered Design',
    desc: 'No trend-chasing. Each piece is designed to work across seasons, occasions, and years. We ask: will this still feel right in five years? If yes — we make it.',
    path: '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
  },
  {
    num: '03',
    title: 'Comfort Without Compromise',
    desc: 'Good clothes should disappear on your body. Fit, drape, and movement are refined across an average of 14 prototypes on different body types. Never rushed.',
    path: '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>',
  },
  {
    num: '04',
    title: 'Responsible Practice',
    desc: 'Traceable supply chain, fair-wage partners, carbon-neutral shipping. We believe beautiful clothes and honest business are the same thing.',
    path: '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
  },
];

const craft = [
  { n: '01', t: 'Italian & Japanese Fabrics', d: 'Sourced directly from mills in Como, Biella, and Nishiwaki. No middlemen, no compromises.' },
  { n: '02', t: '14 Prototypes Per Style', d: 'Fit, drape, and movement are refined on different body types before a single unit is produced.' },
  { n: '03', t: '12-Point Quality Check', d: 'Seam strength, colourfastness, shrinkage — each piece is tested at every stage, not just the end.' },
  { n: '04', t: 'Lifetime Repair Promise', d: 'Send any MARVEXA piece back for repair, forever. The most sustainable garment is one that lasts.' },
];

const promise = [
  {
    title: '30-Day Free Returns',
    desc: 'Changed your mind? No problem. Return any item within 30 days, no questions asked. Free prepaid label included with every order.',
    badge: 'No Questions Asked',
    path: '<polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.99"/>',
  },
  {
    title: 'Lifetime Repair Promise',
    desc: 'We repair any MARVEXA piece for life, free of charge. A loose seam, worn button, or fraying hem — just send it back.',
    badge: 'Forever, Free',
    path: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  },
  {
    title: 'Carbon-Neutral Shipping',
    desc: 'Every order is shipped carbon-neutral. We offset 100% of emissions through verified reforestation projects in partnership with Ecologi.',
    badge: 'On Every Order',
    path: '<rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>',
  },
  {
    title: 'Secure, Flexible Payment',
    desc: 'Shop with confidence using any major card, Apple Pay, or PayPal. All transactions are SSL-encrypted. We never store card details.',
    badge: 'SSL Secured',
    path: '<rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>',
  },
];

const team = [
  { name: 'Sophie Laurent', role: 'Founder & Creative Director', bio: 'Parisian-trained with 15 years in luxury fashion. Founded MARVEXA with a vision for modern, refined dressing.', img: resolveImage('team-sophie.webp').src },
  { name: 'Emeka Osei', role: 'Head of Materials', bio: 'Former textile specialist at Loro Piana. Sources every fabric personally from mills in Italy and Japan.', img: resolveImage('team-emeka.webp').src },
  { name: 'Mia Thornton', role: 'Brand Director', bio: '10 years in fashion marketing across Paris and New York. Shapes every touchpoint of the MARVEXA story.', img: resolveImage('person-05.webp').src },
  { name: 'Jiro Nakamura', role: 'Lead Atelier', bio: 'Master tailor trained in Tokyo and Milan. Leads our atelier and oversees quality for every production run.', img: resolveImage('person-02.webp').src },
];

---

<Layout
  title="About MARVEXA"
  description="MARVEXA is a modern fashion house founded in Paris in 2019 — natural fibres, considered design, and craftsmanship built to last, with a lifetime repair promise on every piece."
>
  <main id="aboutModern" class="about-pg">
    {/* ── Story hero header ── */}
    <div class="cart-hd-block ab-reveal">
      <div class="cart-hd-inner">
        <div class="cart-hd-toprow">
          <nav class="cart-bc">
            <a href="/">Home</a>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            <span class="cart-bc-cur">About Us</span>
          </nav>
          <div class="cart-hd-perks">
            <span class="cart-hd-perk"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg> hello@marvexass26.com</span>
            <span class="cart-hd-perk-div"></span>
            <span class="cart-hd-perk"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.54 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l.81-.81a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg> +1 (212) 555-0140</span>
            <span class="cart-hd-perk-div"></span>
            <span class="cart-hd-perk cart-hd-perk--secure"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> Free Shipping Over $99</span>
          </div>
        </div>
        <div class="cart-hd-hero">
          <div class="cart-hd-hero-left">
            <div class="cart-hd-eyebrow">Our Story</div>
            <h1 class="cart-hd-title">About MARVEXA</h1>
            <p class="cart-hd-sub">Built on a belief that modern dressing should feel effortless, refined, and yours.</p>
          </div>
          <div class="cart-hd-stats">
            <div class="cart-hd-stat">
              <div class="cart-hd-stat-num">2019</div>
              <div class="cart-hd-stat-lbl">Founded</div>
            </div>
            <div class="cart-hd-stat-div"></div>
            <div class="cart-hd-stat">
              <div class="cart-hd-stat-num">3</div>
              <div class="cart-hd-stat-lbl">Stores</div>
            </div>
            <div class="cart-hd-stat-div"></div>
            <div class="cart-hd-stat">
              <div class="cart-hd-stat-num">80+</div>
              <div class="cart-hd-stat-lbl">Countries</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* ── Story ── */}
    <section class="ab-story">
      <div class="ab-story-grid">
        <div class="ab-story-img ab-reveal">
          <img src={resolveImage('about-story.webp').src} alt="MARVEXA brand story" loading="lazy" />
          <div class="ab-story-img-tag">Paris · 2019</div>
        </div>
        <div class="ab-story-txt ab-reveal" data-d="1">
          <div class="ab-story-num">01 — Our Beginning</div>
          <h2 class="ab-story-title">Dressed for the life<br />you actually live.</h2>
          <p class="ab-story-body">MARVEXA was born from a simple frustration — fashion that looked beautiful in editorials but felt wrong in real life. Too stiff. Too fast. Too forgettable.<br /><br />Sophie Laurent founded MARVEXA in Paris in 2019 with one conviction: modern people deserve clothes built the old way. Thoughtfully designed, carefully sourced, made to last — not for a season, but for years.</p>
          <div class="ab-story-milestones">
            <div class="ab-story-ms"><span class="ab-story-ms-y">2019</span><span class="ab-story-ms-t">Founded in Paris with a debut collection of 12 pieces</span></div>
            <div class="ab-story-ms"><span class="ab-story-ms-y">2021</span><span class="ab-story-ms-t">First flagship store — New York's West Village</span></div>
            <div class="ab-story-ms"><span class="ab-story-ms-y">2024</span><span class="ab-story-ms-t">London &amp; LA stores — 5,000+ customers in 80 countries</span></div>
          </div>
          <div class="ab-story-sig">
            <div class="ab-story-sig-av">SL</div>
            <div>
              <div class="ab-story-sig-name">Sophie Laurent</div>
              <div class="ab-story-sig-role">Founder &amp; Creative Director</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ── By the numbers ── */}
    <div class="ab-nums">
      <div class="ab-nums-inner ab-reveal">
        <div class="ab-nums-label">MARVEXA by the numbers</div>
        <div class="ab-nums-row">
          <div class="ab-num-cell">
            <div class="ab-num-bar"></div>
            <div class="ab-num-n" data-count="5" data-suffix="K+">0</div>
            <div class="ab-num-l">Customers</div>
            <div class="ab-num-s">Across 80 countries</div>
          </div>
          <div class="ab-num-cell">
            <div class="ab-num-bar"></div>
            <div class="ab-num-n" data-count="3" data-suffix="">0</div>
            <div class="ab-num-l">Flagship Stores</div>
            <div class="ab-num-s">NY · LA · London</div>
          </div>
          <div class="ab-num-cell">
            <div class="ab-num-bar"></div>
            <div class="ab-num-n" data-count="4.9" data-dec="1" data-suffix="">0</div>
            <div class="ab-num-l">Customer Rating</div>
            <div class="ab-num-s">3,200+ verified reviews</div>
          </div>
          <div class="ab-num-cell">
            <div class="ab-num-bar"></div>
            <div class="ab-num-n" data-count="100" data-suffix="%">0</div>
            <div class="ab-num-l">Natural Fibres</div>
            <div class="ab-num-s">No synthetic blends</div>
          </div>
          <div class="ab-num-cell">
            <div class="ab-num-bar"></div>
            <div class="ab-num-n">&#8734;</div>
            <div class="ab-num-l">Lifetime Repairs</div>
            <div class="ab-num-s">Every piece, always</div>
          </div>
        </div>
      </div>
    </div>

    {/* ── Philosophy ── */}
    <section class="ab-phil">
      <div class="ab-phil-c">
        <div class="ab-phil-head ab-reveal">
          <div class="ab-label">What We Stand For</div>
          <h2 class="ab-phil-head-title">A philosophy built<br />into every stitch.</h2>
          <p class="ab-phil-head-sub">Four values guide every decision — from how we source fabric to how we pack your order.</p>
        </div>
        <div class="ab-phil-grid">
          {
            philosophy.map((p, i) => (
              <div class="ab-phil-card ab-reveal" data-d={String(i % 2)}>
                <div class="ab-phil-icon-wrap">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={p.path} />
                </div>
                <div class="ab-phil-card-body">
                  <div class="ab-phil-card-num">{p.num}</div>
                  <h3 class="ab-phil-card-title">{p.title}</h3>
                  <p class="ab-phil-card-desc">{p.desc}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* ── Craft ── */}
    <section class="ab-craft">
      <div class="ab-craft-grid">
        <div class="ab-craft-txt ab-reveal">
          <div class="ab-label">How We Make It</div>
          <h2 class="ab-craft-title">Craftsmanship as a standard, not a selling point.</h2>
          <p class="ab-craft-body">Every MARVEXA piece passes through twelve quality checkpoints before leaving our atelier. We work exclusively with mills and manufacturers who have been in their craft for at least two generations.</p>
          <div class="ab-craft-list">
            {
              craft.map((c) => (
                <div class="ab-craft-item">
                  <div class="ab-craft-n">{c.n}</div>
                  <div>
                    <div class="ab-craft-t">{c.t}</div>
                    <div class="ab-craft-d">{c.d}</div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
        <div class="ab-craft-visual ab-reveal" data-d="1">
          <div class="ab-craft-img"><img src={resolveImage('about-craft.webp').src} alt="MARVEXA craftsmanship" loading="lazy" /></div>
          <div class="ab-craft-float">
            <div class="ab-craft-float-n">12×</div>
            <div class="ab-craft-float-l">Quality<br />Checkpoints</div>
          </div>
        </div>
      </div>
    </section>

    {/* ── Promise ── */}
    <section class="ab-promise">
      <div class="ab-promise-c">
        <div class="ab-promise-head ab-reveal">
          <div class="ab-promise-ey">Our Promise to You</div>
          <h2 class="ab-promise-title">Shop with complete<br />confidence.</h2>
          <p class="ab-promise-sub">Everything we do is designed to make your experience with MARVEXA as effortless as our clothes.</p>
        </div>
        <div class="ab-promise-grid">
          {
            promise.map((p, i) => (
              <div class="ab-promise-item ab-reveal" data-d={String(i % 4)}>
                <div class="ab-promise-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={p.path} />
                </div>
                <div class="ab-promise-item-title">{p.title}</div>
                <p class="ab-promise-item-desc">{p.desc}</p>
                <span class="ab-promise-badge">{p.badge}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* ── Team ── */}
    <section class="ab-team">
      <div class="ab-team-c">
        <div class="ab-team-head ab-reveal">
          <div class="ab-label">The People</div>
          <h2 class="ab-team-title">Meet the team.</h2>
        </div>
        <div class="ab-team-grid">
          {
            team.map((m, i) => (
              <div class="ab-team-card ab-reveal" data-d={String(i % 4)}>
                <div class="ab-team-photo"><img src={m.img} alt={m.name} loading="lazy" /></div>
                <div class="ab-team-info">
                  <div class="ab-team-role">{m.role}</div>
                  <div class="ab-team-name">{m.name}</div>
                  <div class="ab-team-bio">{m.bio}</div>
                  <div class="ab-team-links">
                    <a class="ab-team-lk" href="https://instagram.com" target="_blank" rel="noopener" aria-label={`${m.name} on Instagram`}><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a>
                    <a class="ab-team-lk" href="https://linkedin.com" target="_blank" rel="noopener" aria-label={`${m.name} on LinkedIn`}><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></a>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* ── Testimonials ── */}
    <Testimonials />
  </main>

  {/* ── Newsletter CTA (last — overlaps the footer; bg synced to Testimonials) ── */}
  <Newsletter surface="var(--bg)" padTop="0" />
</Layout>

<script>
  // Scroll-reveal + animated stat counters (matches marvexa About.html).
  const root = document.getElementById('aboutModern');
  if (root) {
    const reveals = root.querySelectorAll('.ab-reveal');
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (es) => es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }),
        { threshold: 0.12 },
      );
      reveals.forEach((el) => io.observe(el));
    } else {
      reveals.forEach((el) => el.classList.add('in'));
    }

    const animate = (el: Element) => {
      const target = parseFloat(el.getAttribute('data-count') || '0');
      const dec = parseInt(el.getAttribute('data-dec') || '0', 10);
      const suffix = el.getAttribute('data-suffix') || '';
      const dur = 1500;
      let start: number | null = null;
      const step = (ts: number) => {
        if (start === null) start = ts;
        const p = Math.min((ts - start) / dur, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        const val = (target * eased).toFixed(dec);
        el.textContent = (dec ? val : Math.round(Number(val)).toLocaleString('en-US')) + suffix;
        if (p < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    };
    const counters = root.querySelectorAll('.ab-num-n[data-count]');
    if ('IntersectionObserver' in window) {
      const cio = new IntersectionObserver(
        (es) => es.forEach((e) => { if (e.isIntersecting) { animate(e.target); cio.unobserve(e.target); } }),
        { threshold: 0.5 },
      );
      counters.forEach((el) => cio.observe(el));
    } else {
      counters.forEach(animate);
    }
  }
</script>
