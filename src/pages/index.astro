---
// ============================================================
//  Home (Maison) — server-rendered landing. Shopify data is fetched
//  here and passed to the dynamic sections; the rest are static
//  presentational sections. The Shopify data layer (getProducts) is
//  used as-is — never modified.
// ============================================================
import Layout from '~/layouts/Layout.astro';
import { getProducts } from '~/lib/shopify';
import { applyMarketCache } from '~/lib/market';
import type { ProductCard } from '~/lib/shopify/types';

import Hero from '~/components/home/maison/Hero.astro';
import Categories from '~/components/home/maison/Categories.astro';
import NewArrivals from '~/components/home/maison/NewArrivals.astro';
import Lookbook from '~/components/home/maison/Lookbook.astro';
import BestSellers from '~/components/home/maison/BestSellers.astro';
import StyleFeed from '~/components/home/maison/StyleFeed.astro';
import Campaign from '~/components/home/maison/Campaign.astro';
import Testimonials from '~/components/home/maison/Testimonials.astro';
import Journal from '~/components/home/maison/Journal.astro';
import Newsletter from '~/components/home/maison/Newsletter.astro';

let products: ProductCard[] = [];
let loadError = false;

const market = Astro.locals.market;
try {
  const page = await getProducts({ pageSize: 12, sortKey: 'BEST_SELLING' }, market);
  products = page.items;
} catch (err) {
  console.error('[home] Shopify load failed:', (err as Error).message);
  loadError = true;
}

// Edge-cache the home HTML (cart/wishlist are client-side). Market-aware:
// only the default market is shared-cached; other markets stay private so
// localized prices never leak across currencies.
if (!loadError) {
  applyMarketCache(Astro.response.headers, market);
}

const newArrivals = products.slice(0, 8);
const bestSellers = products.slice(0, 3);
---

<Layout>
  {
    loadError ? (
      <div class="wrap" style="padding: 160px 0 100px; text-align: center;">
        <h1 class="section-title">We hit a connection snag</h1>
        <p style="color: var(--muted); margin-top: 12px;">
          The catalogue couldn't load right now. Please try again shortly.
        </p>
      </div>
    ) : (
      <>
        <Hero />
        <Categories />
        <NewArrivals products={newArrivals} />
        <Lookbook />
        <BestSellers products={bestSellers} />
        <StyleFeed />
        <Campaign />
        <Testimonials />
        <Journal />
        <Newsletter />
      </>
    )
  }
</Layout>
