---
// ============================================================
//  Home (Marvexa) — server-rendered landing. Shopify data is fetched
//  here and passed to the dynamic sections; the rest are static
//  presentational sections. The Shopify data layer (getProducts) is
//  used as-is — never modified.
// ============================================================
import Layout from '~/layouts/Layout.astro';
import {
  getProducts,
  getAllCollections,
  getCollectionCount,
  getCollection as getShopifyCollection,
} from '~/lib/shopify';
import { applyMarketCache } from '~/lib/market';
import {
  BEST_SELLERS_COLLECTION_HANDLE,
  NEW_ARRIVALS_COLLECTION_HANDLE,
  LOOKBOOK_COLLECTION_HANDLES,
  LOOKBOOK_HOTSPOT_SLOTS,
} from '~/config/marvexa';
import type { ProductCard, Collection } from '~/lib/shopify/types';

import Hero from '~/components/home/marvexa/Hero.astro';
import Marquee from '~/components/home/marvexa/Marquee.astro';
import Categories from '~/components/home/marvexa/Categories.astro';
import NewArrivals from '~/components/home/marvexa/NewArrivals.astro';
import Lookbook from '~/components/home/marvexa/Lookbook.astro';
import BestSellers from '~/components/home/marvexa/BestSellers.astro';
import StyleFeed from '~/components/home/marvexa/StyleFeed.astro';
import Campaign from '~/components/home/marvexa/Campaign.astro';
import Testimonials from '~/components/home/marvexa/Testimonials.astro';
import Journal from '~/components/home/marvexa/Journal.astro';
import Newsletter from '~/components/home/marvexa/Newsletter.astro';

let products: ProductCard[] = [];
let newestProducts: ProductCard[] = [];
let catalogProducts: ProductCard[] = [];
let collections: Collection[] = [];
let loadError = false;

const market = Astro.locals.market;
try {
  // Fetch products + real collections together so the category grid reflects
  // the actual storefront (no hardcoded category cards / fake counts).
  // catalogProducts is the full catalogue (not just best-sellers/newest) —
  // Categories.astro tallies real per-category counts + top garment types
  // from it, matched by productType (same source of truth as the /products
  // sidebar filters), not from Shopify's own Collection membership, which
  // is curated by hand and can be a partial subset.
  const [page, newest, catalog, cols] = await Promise.all([
    getProducts({ pageSize: 12, sortKey: 'BEST_SELLING' }, market),
    getProducts({ pageSize: 12, sortKey: 'CREATED_AT', reverse: true }, market),
    getProducts({ pageSize: 250 }, market),
    getAllCollections(),
  ]);
  products = page.items;
  newestProducts = newest.items;
  catalogProducts = catalog.items;
  collections = cols;
} catch (err) {
  console.error('[home] Shopify load failed:', (err as Error).message);
  loadError = true;
}

// Edge-cache the home HTML (cart/wishlist are client-side). Market-aware:
// only the default market is shared-cached; other markets stay private so
// localized prices never leak across currencies.
if (!loadError) {
  applyMarketCache(Astro.response.headers, market);
}

// Best Sellers = the real `best-sellers` Shopify Collection (merchant-curated
// in Admin). Falls back to top BEST_SELLING catalogue products if the
// collection doesn't exist yet or is empty. New Arrivals = newest products,
// minus any that are also in the best-sellers row so nothing shows twice.
let bestSellers = products.slice(0, 3);
if (!loadError) {
  try {
    const bsCollection = await getShopifyCollection(
      { handle: BEST_SELLERS_COLLECTION_HANDLE, pageSize: 3, sortKey: 'BEST_SELLING' },
      market,
    );
    if (bsCollection?.products.items.length) {
      bestSellers = bsCollection.products.items;
    }
  } catch (err) {
    console.error('[home] Best Sellers collection load failed:', (err as Error).message);
  }
}
const bestSellerIds = new Set(bestSellers.map((p) => p.id));

// Aggregate review data for the Best-Sellers proof strip (real, not hardcoded).
const ratedProducts = products.filter((p) => p.rating != null);
const ratingAvg = ratedProducts.length
  ? ratedProducts.reduce((sum, p) => sum + (p.rating ?? 0), 0) / ratedProducts.length
  : null;
const reviewTotal = products.reduce((sum, p) => sum + (p.ratingCount ?? 0), 0) || null;

// ── Shop the Look — one real Shopify Collection per look (config: marvexa.ts).
// Products + their Admin sort order are live Shopify; hotspot pin positions
// are fixed presets (LOOKBOOK_HOTSPOT_SLOTS) applied by product order, since
// a collection has no per-product x/y field. A missing/empty collection is
// skipped, not shown broken.
interface ResolvedLookItem { top: string; left: string; cardLeft: boolean; product: ProductCard | null }
interface ResolvedLook { id: string; label: string; image: string; items: ResolvedLookItem[] }
let looks: ResolvedLook[] = [];
try {
  const fetched = await Promise.all(
    LOOKBOOK_COLLECTION_HANDLES.map((handle) =>
      getShopifyCollection({ handle, pageSize: LOOKBOOK_HOTSPOT_SLOTS.length }, market).catch(() => null),
    ),
  );
  looks = fetched
    .filter((c): c is NonNullable<typeof c> => !!c && c.products.items.length > 0)
    .map((c) => ({
      id: c.handle,
      label: c.title,
      image: c.image?.url ?? '',
      items: c.products.items.map((product, i) => ({ ...LOOKBOOK_HOTSPOT_SLOTS[i], product })),
    }));
} catch (err) {
  console.error('[home] Lookbook load failed:', (err as Error).message);
}

// New Arrivals = the real `new-arrivals` Shopify Collection (merchant-curated
// order in Admin — respects whatever sort the collection itself uses). Falls
// back to the newest-created catalogue products, minus anything already shown
// in Best Sellers, if the collection doesn't exist yet or is empty. Also
// drives the section footer's total count + "View All" link.
let newArrivals = newestProducts.filter((p) => !bestSellerIds.has(p.id)).slice(0, 8);
let naHref = '/products';
let naTotal: number | undefined;
let naTotalPlus = false;
if (!loadError) {
  try {
    const naCollection = await getShopifyCollection(
      { handle: NEW_ARRIVALS_COLLECTION_HANDLE, pageSize: 12 },
      market,
    );
    if (naCollection?.products.items.length) {
      newArrivals = naCollection.products.items.filter((p) => !bestSellerIds.has(p.id)).slice(0, 8);
      naHref = `/collections/${NEW_ARRIVALS_COLLECTION_HANDLE}`;
      const c = await getCollectionCount(NEW_ARRIVALS_COLLECTION_HANDLE);
      if (c) {
        naTotal = c.count;
        naTotalPlus = c.plus;
      }
    }
  } catch (err) {
    console.error('[home] New Arrivals collection load failed:', (err as Error).message);
  }
}
---

<Layout transparentHeader>
  {
    loadError ? (
      <div class="wrap" style="padding: 160px 0 100px; text-align: center;">
        <h1 class="section-title">We hit a connection snag</h1>
        <p style="color: var(--muted); margin-top: 12px;">
          The catalogue couldn't load right now. Please try again shortly.
        </p>
      </div>
    ) : (
      <>
        <Hero />
        <Marquee />
        <Categories collections={collections} products={catalogProducts} />
        <NewArrivals products={newArrivals} total={naTotal} totalPlus={naTotalPlus} viewAllHref={naHref} />
        <Lookbook looks={looks} />
        <BestSellers products={bestSellers} ratingAvg={ratingAvg} reviewTotal={reviewTotal} />
        <StyleFeed />
        <Campaign />
        <Testimonials />
        <Journal />
        <Newsletter />
      </>
    )
  }
</Layout>
