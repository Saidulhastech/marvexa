---
// ============================================================
//  Shop — the all-products listing. Maison's static "Shop" layout
//  (header block + filter sidebar + toolbar + grid + pagination)
//  ported onto real Shopify products. Cards carry data-* facets so
//  the sidebar filters, sort and view controls work entirely
//  client-side over the server-rendered grid.
// ============================================================
import Layout from '~/layouts/Layout.astro';
import { getProducts, PRODUCT_SORT_OPTIONS, resolveSort } from '~/lib/shopify';
import { applyMarketCache } from '~/lib/market';
import type { ProductCard as TProductCard } from '~/lib/shopify/types';
import ProductCard from '~/components/product/omnix/ProductCard.astro';

export const prerender = false;

const url = Astro.url;
const sortValue = url.searchParams.get('sort') ?? PRODUCT_SORT_OPTIONS[0].value;
const sort = resolveSort(PRODUCT_SORT_OPTIONS, sortValue);

let products: TProductCard[] = [];
let loadError = false;
try {
  const page = await getProducts(
    { pageSize: 48, sortKey: sort.sortKey, reverse: sort.reverse },
    Astro.locals.market,
  );
  products = page.items;
} catch (err) {
  console.error('[shop] load failed:', (err as Error).message);
  loadError = true;
}
if (!loadError) applyMarketCache(Astro.response.headers, Astro.locals.market);

const MATERIALS = ['linen', 'wool', 'cotton', 'silk', 'leather', 'cashmere'];
const OCCASIONS = ['everyday', 'work', 'weekend', 'evening', 'resort'];

function cardAttrs(p: TProductCard): Record<string, string> {
  const price = Math.round(Number(p.priceRange.minVariantPrice.amount) || 0);
  const compare = Number(p.compareAtPriceRange?.minVariantPrice?.amount) || 0;
  const tags = (p.tags ?? []).map((t) => t.toLowerCase());
  const sizeOpt = (p.options ?? []).find((o) => /size/i.test(o.name));
  const sizes = (sizeOpt?.optionValues ?? []).map((v) => v.name.toLowerCase());
  return {
    'data-cat': (p.productType ?? '').toLowerCase(),
    'data-price': String(price),
    'data-rating': String(p.rating ?? 0),
    'data-badge': p.isNew ? 'new' : compare > price ? 'sale' : 'none',
    'data-colors': (p.swatches ?? []).map((s) => s.name.toLowerCase()).join(','),
    'data-sizes': sizes.join(','),
    'data-mat': tags.filter((t) => MATERIALS.includes(t)).join(','),
    'data-occ': tags.filter((t) => OCCASIONS.includes(t)).join(','),
    'data-instock': p.availableForSale ? '1' : '0',
    'data-sale': compare > price ? '1' : '0',
  };
}

const total = products.length;
---

<Layout title="Shop" description="Browse the full Maison collection — refined wardrobe essentials.">
  <main class="shop-page">

    <div class="shop-hd-block">
      <div class="shop-hd-inner">

        <!-- Top row: Breadcrumb + perks -->
        <div class="shd-toprow">
          <nav class="shd-bc" aria-label="breadcrumb">
            <a href="/">Home</a>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
            <a href="/">Collections</a>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
            <span class="shd-bc-cur">All Products</span>
          </nav>
          <div class="shd-perks">
            <span class="shd-perk">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round">
                <path
                  d="M5 8h14M5 8a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-6a2 2 0 0 0-2-2M5 8V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v2"
                ></path>
              </svg>
              Free Shipping over $120
            </span>
            <span class="shd-perk-div"></span>
            <span class="shd-perk">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round">
                <path d="M9 14 4 9l5-5"></path>
                <path d="M4 9h10.5a5.5 5.5 0 0 1 0 11H11"></path>
              </svg>
              Free Returns
            </span>
            <span class="shd-perk-div"></span>
            <span class="shd-perk shd-perk--live">
              <span class="shd-live-dot"></span>
              SS26 — Live Now
            </span>
          </div>
        </div>

        <!-- Main hero row -->
        <div class="shd-hero">
          <div class="shd-hero-left">
            <div class="shd-eyebrow">SS26 Collection</div>
            <h1 class="shd-title">Shop Collection</h1>
            <p class="shd-sub">Refined wardrobe essentials, crafted for everyday confidence.</p>
          </div>
          <div class="shd-hero-stats">
            <div class="shd-stat">
              <div class="shd-stat-num" id="prod-count-hd">{total}</div>
              <div class="shd-stat-lbl">Products</div>
            </div>
            <div class="shd-stat-div"></div>
            <div class="shd-stat">
              <div class="shd-stat-num">5</div>
              <div class="shd-stat-lbl">Categories</div>
            </div>
            <div class="shd-stat-div"></div>
            <div class="shd-stat">
              <div class="shd-stat-num">7</div>
              <div class="shd-stat-lbl">New Arrivals</div>
            </div>
          </div>
        </div>

      </div>
    </div>


    <div class="shop-wrap">
      <!-- Active filter chips -->
      <div class="chips-bar" id="chips-bar"></div>

      <!-- Sidebar + Products grid -->
      <div class="shop-body">


        <aside class="sidebar">

          <!-- Header -->
          <div class="sb-hd">
            <h3>Filters</h3>
            <button class="sb-clear" data-action="reset-all">Clear All</button>
          </div>

          <!-- CATEGORY -->
          <div class="sb-group" id="grp-cat">
            <div class="sb-group-hd" data-toggle="grp-cat">
              <span class="sb-group-label">Category</span>
              <svg class="sb-toggle-icon open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round">
                <polyline points="18 15 12 9 6 15"></polyline>
              </svg>
            </div>
            <div class="sb-group-body sb-cats" id="grp-cat-body">
              <button class="sb-cat active" data-fcat="">All Products <span class="sb-cat-ct">{total}</span></button>
              <button class="sb-cat" data-fcat="women">Women <span class="sb-cat-ct">9</span></button>
              <button class="sb-cat" data-fcat="men">Men <span class="sb-cat-ct">7</span></button>
              <button class="sb-cat" data-fcat="bags">Bags <span class="sb-cat-ct">5</span></button>
              <button class="sb-cat" data-fcat="accessories">Accessories <span class="sb-cat-ct">4</span></button>
              <button class="sb-cat" data-fcat="new" data-special="new">New Arrivals <span class="sb-cat-ct">7</span
                ></button>
              <button class="sb-cat" data-fcat="sale" data-special="sale">On Sale <span class="sb-cat-ct">3</span
                ></button>
            </div>
          </div>

          <!-- COLOR -->
          <div class="sb-group" id="grp-color">
            <div class="sb-group-hd" data-toggle="grp-color">
              <span class="sb-group-label">Color</span>
              <svg class="sb-toggle-icon open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round">
                <polyline points="18 15 12 9 6 15"></polyline>
              </svg>
            </div>
            <div class="sb-group-body sb-colors" id="grp-color-body">
              <div class="sb-swatch-wrap" data-color="ivory">
                <div class="sb-swatch" style="background:#F5F0E8;border-color:#D8D5CE"></div>
              </div>
              <div class="sb-swatch-wrap" data-color="stone">
                <div class="sb-swatch" style="background:#D4C5A9"></div>
              </div>
              <div class="sb-swatch-wrap" data-color="camel">
                <div class="sb-swatch" style="background:#C8B8A2"></div>
              </div>
              <div class="sb-swatch-wrap" data-color="black">
                <div class="sb-swatch" style="background:#1D1D1B"></div>
              </div>
              <div class="sb-swatch-wrap" data-color="charcoal">
                <div class="sb-swatch" style="background:#3D3D3B"></div>
              </div>
              <div class="sb-swatch-wrap" data-color="slate">
                <div class="sb-swatch" style="background:#6B7FA3"></div>
              </div>
              <div class="sb-swatch-wrap" data-color="olive">
                <div class="sb-swatch" style="background:#7A8F3A"></div>
              </div>
              <div class="sb-swatch-wrap" data-color="rust">
                <div class="sb-swatch" style="background:#B4573F"></div>
              </div>
            </div>
          </div>

          <!-- SIZE -->
          <div class="sb-group" id="grp-size">
            <div class="sb-group-hd" data-toggle="grp-size">
              <span class="sb-group-label">Size</span>
              <svg class="sb-toggle-icon open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round">
                <polyline points="18 15 12 9 6 15"></polyline>
              </svg>
            </div>
            <div class="sb-group-body sb-sizes" id="grp-size-body">
              <button class="sb-size">XS</button>
              <button class="sb-size">S</button>
              <button class="sb-size">M</button>
              <button class="sb-size">L</button>
              <button class="sb-size">XL</button>
              <button class="sb-size">XXL</button>
              <button class="sb-size">28</button>
              <button class="sb-size">30</button>
              <button class="sb-size">32</button>
              <button class="sb-size">34</button>
            </div>
          </div>

          <!-- PRICE -->
          <div class="sb-group" id="grp-price">
            <div class="sb-group-hd" data-toggle="grp-price">
              <span class="sb-group-label">Price Range</span>
              <svg class="sb-toggle-icon open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round">
                <polyline points="18 15 12 9 6 15"></polyline>
              </svg>
            </div>
            <div class="sb-group-body sb-price" id="grp-price-body">
              <div class="sb-price-inputs">
                <div class="sb-price-input-wrap">
                  <span>$</span>
                  <input
                    type="number"
                    class="sb-price-input"
                    id="price-min-input"
                    min="60"
                    max="300"
                    value="60"
                    placeholder="60"
                    data-price-box="min"
                  />
                </div>
                <span class="sb-price-sep">—</span>
                <div class="sb-price-input-wrap">
                  <span>$</span>
                  <input
                    type="number"
                    class="sb-price-input"
                    id="price-max-input"
                    min="60"
                    max="300"
                    value="300"
                    placeholder="300"
                    data-price-box="max"
                  />
                </div>
              </div>
              <div class="sb-slider-track">
                <div class="sb-slider-fill" id="slider-fill"></div>
                <input
                  type="range"
                  class="sb-slider"
                  id="sb-slider-min-r"
                  min="60"
                  max="300"
                  value="60"
                  step="5"
                  data-price-slider
                />
                <input
                  type="range"
                  class="sb-slider"
                  id="sb-slider-max-r"
                  min="60"
                  max="300"
                  value="300"
                  step="5"
                  data-price-slider
                />
              </div>
            </div>
          </div>

          <!-- RATING -->
          <div class="sb-group" id="grp-rating">
            <div class="sb-group-hd" data-toggle="grp-rating">
              <span class="sb-group-label">Rating</span>
              <svg class="sb-toggle-icon open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round">
                <polyline points="18 15 12 9 6 15"></polyline>
              </svg>
            </div>
            <div class="sb-group-body sb-ratings" id="grp-rating-body">
              <div class="sb-rating" data-rating="4.5" data-rating-lbl="4.5+ Stars">
                <div class="sb-rating-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                <span class="sb-rating-lbl">4.5 &amp; above</span>
                <span class="sb-rating-check"></span>
              </div>
              <div class="sb-rating" data-rating="4.0" data-rating-lbl="4.0+ Stars">
                <div class="sb-rating-stars">&#9733;&#9733;&#9733;&#9733;&#9734;</div>
                <span class="sb-rating-lbl">4.0 &amp; above</span>
                <span class="sb-rating-check"></span>
              </div>
              <div class="sb-rating" data-rating="3.5" data-rating-lbl="3.5+ Stars">
                <div class="sb-rating-stars">&#9733;&#9733;&#9733;&#9734;&#9734;</div>
                <span class="sb-rating-lbl">3.5 &amp; above</span>
                <span class="sb-rating-check"></span>
              </div>
            </div>
          </div>

          <!-- MATERIAL -->
          <div class="sb-group" id="grp-mat">
            <div class="sb-group-hd" data-toggle="grp-mat">
              <span class="sb-group-label">Material</span>
              <svg class="sb-toggle-icon open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round">
                <polyline points="18 15 12 9 6 15"></polyline>
              </svg>
            </div>
            <div class="sb-group-body sb-mats" id="grp-mat-body">
              <button class="sb-pill" data-fmat="linen" data-pill-type="mat" data-pill-val="linen">Linen</button>
              <button class="sb-pill" data-fmat="wool" data-pill-type="mat" data-pill-val="wool">Wool</button>
              <button class="sb-pill" data-fmat="cotton" data-pill-type="mat" data-pill-val="cotton">Cotton</button>
              <button class="sb-pill" data-fmat="silk" data-pill-type="mat" data-pill-val="silk">Silk</button>
              <button class="sb-pill" data-fmat="leather" data-pill-type="mat" data-pill-val="leather">Leather</button>
              <button class="sb-pill" data-fmat="cashmere" data-pill-type="mat" data-pill-val="cashmere"
                >Cashmere</button
              >
            </div>
          </div>

          <!-- OCCASION -->
          <div class="sb-group" id="grp-occ">
            <div class="sb-group-hd" data-toggle="grp-occ">
              <span class="sb-group-label">Occasion</span>
              <svg class="sb-toggle-icon open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round">
                <polyline points="18 15 12 9 6 15"></polyline>
              </svg>
            </div>
            <div class="sb-group-body sb-occs" id="grp-occ-body">
              <button class="sb-pill" data-pill-type="occ" data-pill-val="everyday">Everyday</button>
              <button class="sb-pill" data-pill-type="occ" data-pill-val="work">Work</button>
              <button class="sb-pill" data-pill-type="occ" data-pill-val="weekend">Weekend</button>
              <button class="sb-pill" data-pill-type="occ" data-pill-val="evening">Evening</button>
              <button class="sb-pill" data-pill-type="occ" data-pill-val="resort">Resort</button>
            </div>
          </div>

          <!-- AVAILABILITY -->
          <div class="sb-group" id="grp-avl">
            <div class="sb-group-hd" data-toggle="grp-avl">
              <span class="sb-group-label">Availability</span>
              <svg class="sb-toggle-icon open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round">
                <polyline points="18 15 12 9 6 15"></polyline>
              </svg>
            </div>
            <div class="sb-group-body sb-avails" id="grp-avl-body">
              <button class="sb-pill" data-pill-type="avail" data-pill-val="sale">On Sale</button>
              <button class="sb-pill" data-pill-type="avail" data-pill-val="new">New Arrivals</button>
              <button class="sb-pill" data-pill-type="avail" data-pill-val="bestseller">Best Sellers</button>
            </div>
          </div>

        </aside>


        <!-- PRODUCT AREA -->
        <section class="prod-area">
          <!-- Count + Controls row -->
          <div class="prod-head">
            <div class="prod-count" id="prod-count">{total} products</div>
            <div class="shd-controls">
              <div class="shd-sort">
                <select id="sort-sel">
                  <option value="default">Sort: Featured</option>
                  <option value="price-asc">Price: Low to High</option>
                  <option value="price-desc">Price: High to Low</option>
                  <option value="rating">Top Rated</option>
                  <option value="newest">Newest First</option>
                  <option value="bestseller">Best Sellers</option>
                </select>
              </div>
              <div class="view-btns">
                <button class="view-btn active" id="vb3" data-view="3" aria-label="3-column grid">
                  <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
                    <rect x="1" y="1" width="3.5" height="4.5" rx="1" fill="currentColor"></rect>
                    <rect x="5.75" y="1" width="3.5" height="4.5" rx="1" fill="currentColor"></rect>
                    <rect x="10.5" y="1" width="3.5" height="4.5" rx="1" fill="currentColor"></rect>
                    <rect x="1" y="7" width="3.5" height="4.5" rx="1" fill="currentColor"></rect>
                    <rect x="5.75" y="7" width="3.5" height="4.5" rx="1" fill="currentColor"></rect>
                    <rect x="10.5" y="7" width="3.5" height="4.5" rx="1" fill="currentColor"></rect>
                  </svg>
                </button>
                <button class="view-btn" id="vb2" data-view="2" aria-label="2-column grid">
                  <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
                    <rect x="1" y="1" width="5.5" height="5.5" rx="1" fill="currentColor"></rect>
                    <rect x="8.5" y="1" width="5.5" height="5.5" rx="1" fill="currentColor"></rect>
                    <rect x="1" y="8.5" width="5.5" height="5.5" rx="1" fill="currentColor"></rect>
                    <rect x="8.5" y="8.5" width="5.5" height="5.5" rx="1" fill="currentColor"></rect>
                  </svg>
                </button>
              </div>
            </div>
          </div>

          {
            loadError ? (
              <div class="no-results">
                <h3>Unable to load products</h3>
                <p>Something went wrong fetching the collection. Please try again shortly.</p>
              </div>
            ) : total === 0 ? (
              <div class="no-results">
                <h3>No products yet</h3>
                <p>Check back soon — new pieces are on their way.</p>
              </div>
            ) : (
              <div class="pg" id="prod-grid">
                {products.map((p, i) => (
                  <ProductCard product={p} eager={i < 4} attrs={cardAttrs(p)} />
                ))}
              </div>
            )
          }

          <!-- Empty-state shown by the filter engine when nothing matches -->
          <div class="no-results" id="no-match" style="display:none">
            <h3>No matches</h3>
            <p>Try clearing a filter or two to see more pieces.</p>
          </div>

        </section>
      </div><!-- /shop-body -->
    </div><!-- /shop-wrap -->
  </main>
</Layout>

<style>
  .shop-page {
    background: var(--bg);
    min-height: 100vh;
    padding-top: 110px;
  }

  .shop-wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 44px;
  }

  /* ═══════════════════════════ SHOP HEADER BLOCK ═══════════════════════════ */
  .shop-hd-block {
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  /* subtle decorative accent line at top */
  .shop-hd-block::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
  }

  .shop-hd-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 44px;
  }

  /* ── Top row: breadcrumb + perks ── */
  .shd-toprow {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
  }

  .shd-bc {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--fb);
    font-size: 12px;
    color: var(--muted);
  }

  .shd-bc a {
    color: var(--muted);
    text-decoration: none;
    transition: color .18s;
  }

  .shd-bc a:hover {
    color: var(--text);
  }

  .shd-bc svg {
    opacity: .4;
    flex-shrink: 0;
  }

  .shd-bc-cur {
    color: var(--text);
    font-weight: 600;
    letter-spacing: .1px;
  }

  .shd-perks {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .shd-perk {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--fb);
    font-size: 11px;
    font-weight: 500;
    color: var(--muted);
    white-space: nowrap;
  }

  .shd-perk svg {
    color: var(--accent);
    flex-shrink: 0;
  }

  .shd-perk-div {
    width: 1px;
    height: 12px;
    background: var(--border);
  }

  .shd-perk--live {
    color: var(--accent);
    font-weight: 600;
  }

  .shd-live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {

    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }

    50% {
      opacity: .5;
      transform: scale(1.3);
    }
  }

  /* ── Main hero row ── */
  .shd-hero {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 32px;
    padding: 28px 0 32px;
  }

  .shd-hero-left {
    flex: 1;
  }

  .shd-eyebrow {
    font-family: var(--fb);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }

  .shd-title {
    font-family: var(--fh);
    font-size: 48px;
    font-weight: 700;
    line-height: .95;
    letter-spacing: -2px;
    color: var(--text);
    margin: 0 0 12px;
  }

  .shd-sub {
    font-family: var(--fb);
    font-size: 14px;
    font-weight: 400;
    color: var(--muted);
    margin: 0;
    line-height: 1.5;
    max-width: 400px;
  }

  .shd-hero-stats {
    display: flex;
    align-items: center;
    gap: 0;
    flex-shrink: 0;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .shd-stat {
