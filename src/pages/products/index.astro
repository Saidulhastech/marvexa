</style>

<script>
  // ============================================================
  //  Shop filter / sort / view controller — operates on the
  //  server-rendered ProductCard grid (.prod-card). All filtering,
  //  chip rendering, sorting and view-switching happen client-side
  //  over the cards' data-* facet attributes. Wishlist / quick-view /
  //  quick-add are handled by the global Overlays controller.
  // ============================================================
  type PillType = 'mat' | 'occ' | 'avail';

  interface FilterState {
    cat: string;
    catSpecial: string;
    colors: string[];
    sizes: string[];
    mats: string[];
    occs: string[];
    avails: string[];
    prMin: number;
    prMax: number;
    rating: number;
    ratingLbl: string;
  }

  const FLOOR = 60;
  const CEIL = 300;

  function freshState(): FilterState {
    return {
      cat: '',
      catSpecial: '',
      colors: [],
      sizes: [],
      mats: [],
      occs: [],
      avails: [],
      prMin: FLOOR,
      prMax: CEIL,
      rating: 0,
      ratingLbl: '',
    };
  }

  let F: FilterState = freshState();

  const grid = document.getElementById('prod-grid');
  const chipsBar = document.getElementById('chips-bar');
  const noMatch = document.getElementById('no-match');

  // Snapshot the server order so "default"/newest sorts can be restored.
  const originalOrder: HTMLElement[] = grid
    ? Array.from(grid.querySelectorAll<HTMLElement>('.prod-card'))
    : [];

  function cards(): HTMLElement[] {
    return grid ? Array.from(grid.querySelectorAll<HTMLElement>('.prod-card')) : [];
  }

  // ── Filter engine ─────────────────────────────────────────────────────────
  function matchCard(c: HTMLElement): boolean {
    const ds = c.dataset;
    // Category
    if (F.catSpecial === 'new') {
      if ((ds.badge || '') !== 'new') return false;
    } else if (F.catSpecial === 'sale') {
      if ((ds.sale || '0') !== '1' && (ds.badge || '') !== 'sale') return false;
    } else if (F.cat) {
      if ((ds.cat || '') !== F.cat) return false;
    }
    // Colors (OR within)
    if (F.colors.length) {
      const cc = (ds.colors || '').split(',').map((s) => s.trim()).filter(Boolean);
      if (!F.colors.some((col) => cc.indexOf(col) > -1)) return false;
    }
    // Sizes (OR within)
    if (F.sizes.length) {
      const cs = (ds.sizes || '').split(',').map((s) => s.trim().toLowerCase()).filter(Boolean);
      if (!F.sizes.some((sz) => cs.indexOf(sz) > -1)) return false;
    }
    // Price
    const p = parseFloat(ds.price || '0');
    if (p < F.prMin || p > F.prMax) return false;
    // Rating
    if (F.rating > 0 && parseFloat(ds.rating || '0') < F.rating) return false;
    // Material (card data-mat is a comma list; OR within)
    if (F.mats.length) {
      const cm = (ds.mat || '').split(',').map((s) => s.trim()).filter(Boolean);
      if (!F.mats.some((m) => cm.indexOf(m) > -1)) return false;
    }
    // Occasion
    if (F.occs.length) {
      const co = (ds.occ || '').split(',').map((s) => s.trim()).filter(Boolean);
      if (!F.occs.some((o) => co.indexOf(o) > -1)) return false;
    }
    // Availability
    if (F.avails.length) {
      const ok = F.avails.some((a) => {
        if (a === 'sale') return (ds.sale || '0') === '1';
        if (a === 'new') return (ds.badge || '') === 'new';
        // "bestseller" has no card data → treat as match-all (no-op).
        if (a === 'bestseller') return true;
        return false;
      });
      if (!ok) return false;
    }
    return true;
  }

  function updateCount(n: number): void {
    const el = document.getElementById('prod-count');
    if (el) el.textContent = n + ' product' + (n === 1 ? '' : 's');
    const elh = document.getElementById('prod-count-hd');
    if (elh) elh.textContent = String(n);
  }

  function doFilter(): void {
    let shown = 0;
    cards().forEach((c) => {
      if (matchCard(c)) {
        if (c.style.display === 'none') {
          c.style.display = '';
          c.style.animation = 'cardIn .28s ease forwards';
          window.setTimeout(() => { c.style.animation = ''; }, 300);
        }
        shown++;
      } else {
        c.style.display = 'none';
        c.style.animation = '';
      }
    });
    if (noMatch) noMatch.style.display = shown === 0 && originalOrder.length > 0 ? '' : 'none';
    updateCount(shown);
    renderChips();
  }

  // ── Category ────────────────────────────────────────────────────────────────
  function setCategory(btn: HTMLElement): void {
    document.querySelectorAll<HTMLElement>('.sb-cat').forEach((b) => b.classList.remove('active'));
    btn.classList.add('active');
    F.catSpecial = btn.dataset.special || '';
    F.cat = F.catSpecial ? '' : (btn.dataset.fcat || '');
    doFilter();
  }

  // ── Price ───────────────────────────────────────────────────────────────────
  function updateSliderFill(a: number, b: number): void {
    const fill = document.getElementById('slider-fill');
    if (!fill) return;
    const pct1 = ((a - FLOOR) / (CEIL - FLOOR)) * 100;
    const pct2 = ((b - FLOOR) / (CEIL - FLOOR)) * 100;
    fill.style.left = pct1 + '%';
    fill.style.width = (pct2 - pct1) + '%';
  }

  function onPriceSlider(): void {
    const mn = document.getElementById('sb-slider-min-r') as HTMLInputElement | null;
    const mx = document.getElementById('sb-slider-max-r') as HTMLInputElement | null;
    if (!mn || !mx) return;
    let a = parseFloat(mn.value);
    let b = parseFloat(mx.value);
    if (a > b) { const t = a; a = b; b = t; }
    F.prMin = a;
    F.prMax = b;
    const minBox = document.getElementById('price-min-input') as HTMLInputElement | null;
    const maxBox = document.getElementById('price-max-input') as HTMLInputElement | null;
    if (minBox) minBox.value = String(a);
    if (maxBox) maxBox.value = String(b);
    updateSliderFill(a, b);
    doFilter();
  }

  function onPriceBox(el: HTMLInputElement, which: 'min' | 'max'): void {
    const val = Math.min(CEIL, Math.max(FLOOR, parseFloat(el.value) || FLOOR));
    if (which === 'min') {
      F.prMin = val;
      const mn = document.getElementById('sb-slider-min-r') as HTMLInputElement | null;
      if (mn) mn.value = String(val);
    } else {
      F.prMax = val;
      const mx = document.getElementById('sb-slider-max-r') as HTMLInputElement | null;
      if (mx) mx.value = String(val);
    }
    updateSliderFill(F.prMin, F.prMax);
    doFilter();
  }

  function resetPriceUI(): void {
    const mn = document.getElementById('sb-slider-min-r') as HTMLInputElement | null;
    const mx = document.getElementById('sb-slider-max-r') as HTMLInputElement | null;
    if (mn) mn.value = String(FLOOR);
    if (mx) mx.value = String(CEIL);
    F.prMin = FLOOR;
    F.prMax = CEIL;
    const minBox = document.getElementById('price-min-input') as HTMLInputElement | null;
    const maxBox = document.getElementById('price-max-input') as HTMLInputElement | null;
    if (minBox) minBox.value = String(FLOOR);
    if (maxBox) maxBox.value = String(CEIL);
    updateSliderFill(FLOOR, CEIL);
  }

  // ── Rating ──────────────────────────────────────────────────────────────────
  function toggleRating(el: HTMLElement): void {
    const val = parseFloat(el.dataset.rating || '0');
    const lbl = el.dataset.ratingLbl || '';
    if (F.rating === val) {
      F.rating = 0;
      F.ratingLbl = '';
      el.classList.remove('active');
    } else {
      document.querySelectorAll<HTMLElement>('.sb-rating').forEach((r) => r.classList.remove('active'));
      el.classList.add('active');
      F.rating = val;
      F.ratingLbl = lbl;
    }
    doFilter();
  }

  // ── Pills (material / occasion / availability) ──────────────────────────────
  function togglePill(el: HTMLElement, type: PillType, val: string): void {
    el.classList.toggle('active');
    const arr: string[] = type === 'mat' ? F.mats : type === 'occ' ? F.occs : F.avails;
    const idx = arr.indexOf(val);
    if (idx > -1) arr.splice(idx, 1);
    else arr.push(val);
    doFilter();
  }

  const cap = (s: string): string => s.charAt(0).toUpperCase() + s.slice(1);

  // ── Chips ───────────────────────────────────────────────────────────────────
  function renderChips(): void {
    if (!chipsBar) return;
    chipsBar.innerHTML = '';
    let any = false;

    const addChip = (label: string, clearFn: () => void): void => {
      any = true;
      const c = document.createElement('span');
      c.className = 'chip';
      c.innerHTML = label + '<span class="chip-x">&times;</span>';
      const x = c.querySelector('.chip-x');
      if (x) x.addEventListener('click', clearFn);
      chipsBar.appendChild(c);
    };

    if (F.cat || F.catSpecial) {
      const lbl = F.catSpecial === 'new'
        ? 'New Arrivals'
        : F.catSpecial === 'sale'
          ? 'On Sale'
          : cap(F.cat);
      addChip(lbl, () => {
        F.cat = '';
        F.catSpecial = '';
        document.querySelectorAll<HTMLElement>('.sb-cat').forEach((b) => b.classList.remove('active'));
        const all = document.querySelector<HTMLElement>('.sb-cat[data-fcat=""]');
        if (all) all.classList.add('active');
        doFilter();
      });
    }
    F.colors.forEach((col) => {
      addChip(cap(col), () => {
        F.colors.splice(F.colors.indexOf(col), 1);
        document.querySelectorAll<HTMLElement>('.sb-swatch-wrap[data-color="' + col + '"]')
          .forEach((s) => s.classList.remove('active'));
        doFilter();
      });
    });
    F.sizes.forEach((sz) => {
      addChip(sz.toUpperCase(), () => {
        F.sizes.splice(F.sizes.indexOf(sz), 1);
        document.querySelectorAll<HTMLElement>('.sb-size').forEach((s) => {
          if ((s.textContent || '').trim().toLowerCase() === sz) s.classList.remove('active');
        });
        doFilter();
      });
    });
    if (F.prMin > FLOOR || F.prMax < CEIL) {
      addChip('$' + F.prMin + '–$' + F.prMax, () => { resetPriceUI(); doFilter(); });
    }
    if (F.rating > 0) {
      addChip(F.ratingLbl, () => {
        F.rating = 0;
        F.ratingLbl = '';
        document.querySelectorAll<HTMLElement>('.sb-rating').forEach((r) => r.classList.remove('active'));
        doFilter();
      });
    }
    F.mats.forEach((m) => {
      addChip(cap(m), () => {
        F.mats.splice(F.mats.indexOf(m), 1);
        document.querySelectorAll<HTMLElement>('.sb-pill[data-pill-type="mat"][data-pill-val="' + m + '"]')
          .forEach((p) => p.classList.remove('active'));
        doFilter();
      });
    });
    F.occs.forEach((o) => {
      addChip(cap(o), () => {
        F.occs.splice(F.occs.indexOf(o), 1);
        document.querySelectorAll<HTMLElement>('.sb-pill[data-pill-type="occ"][data-pill-val="' + o + '"]')
          .forEach((p) => p.classList.remove('active'));
        doFilter();
      });
    });
    F.avails.forEach((a) => {
      addChip(cap(a), () => {
        F.avails.splice(F.avails.indexOf(a), 1);
        document.querySelectorAll<HTMLElement>('.sb-pill[data-pill-type="avail"][data-pill-val="' + a + '"]')
          .forEach((p) => p.classList.remove('active'));
        doFilter();
      });
    });

    if (any) {
      const btn = document.createElement('button');
      btn.className = 'chips-reset';
      btn.textContent = 'Clear all';
      btn.addEventListener('click', resetAll);
      chipsBar.appendChild(btn);
    }
  }

  // ── Reset ───────────────────────────────────────────────────────────────────
  function resetAll(): void {
    F = freshState();
    document.querySelectorAll<HTMLElement>('.sb-cat').forEach((b) => b.classList.remove('active'));
    const allCat = document.querySelector<HTMLElement>('.sb-cat[data-fcat=""]');
    if (allCat) allCat.classList.add('active');
    document.querySelectorAll<HTMLElement>('.sb-swatch-wrap,.sb-size,.sb-rating,.sb-pill')
      .forEach((el) => el.classList.remove('active'));
    resetPriceUI();
    doFilter();
  }

  // ── Sort ────────────────────────────────────────────────────────────────────
  function doSort(): void {
    if (!grid) return;
    const sel = document.getElementById('sort-sel') as HTMLSelectElement | null;
    const val = sel ? sel.value : 'default';
    let ordered: HTMLElement[];
    if (val === 'price-asc') {
      ordered = cards().sort(
        (a, b) => parseFloat(a.dataset.price || '0') - parseFloat(b.dataset.price || '0'),
      );
    } else if (val === 'price-desc') {
      ordered = cards().sort(
        (a, b) => parseFloat(b.dataset.price || '0') - parseFloat(a.dataset.price || '0'),
      );
    } else if (val === 'rating') {
      ordered = cards().sort(
        (a, b) => parseFloat(b.dataset.rating || '0') - parseFloat(a.dataset.rating || '0'),
      );
    } else if (val === 'newest') {
      ordered = cards().sort(
        (a, b) =>
          (b.dataset.badge === 'new' ? 1 : 0) - (a.dataset.badge === 'new' ? 1 : 0),
      );
    } else {
      // default / bestseller → restore the server order.
      ordered = originalOrder.slice();
    }
    ordered.forEach((c) => grid.appendChild(c));
  }

  // ── View toggle ─────────────────────────────────────────────────────────────
  function setView(n: number): void {
    if (grid) grid.classList.toggle('cols-2', n === 2);
    const vb3 = document.getElementById('vb3');
    const vb2 = document.getElementById('vb2');
    if (vb3) vb3.classList.toggle('active', n === 3);
    if (vb2) vb2.classList.toggle('active', n === 2);
  }

  // ── Sidebar group collapse ──────────────────────────────────────────────────
  function toggleGroup(id: string): void {
    const body = document.getElementById(id + '-body');
    const icon = document.querySelector<HTMLElement>('#' + id + ' .sb-toggle-icon');
    if (!body) return;
    const isOpen = body.style.display !== 'none';
    body.style.display = isOpen ? 'none' : '';
    if (icon) icon.classList.toggle('open', !isOpen);
  }

  // ── Wiring (event delegation + listeners) ───────────────────────────────────
  // Group collapse
  document.querySelectorAll<HTMLElement>('.sb-group-hd[data-toggle]').forEach((hd) => {
    hd.addEventListener('click', () => toggleGroup(hd.dataset.toggle || ''));
  });

  // Clear-all buttons
  document.querySelectorAll<HTMLElement>('[data-action="reset-all"]').forEach((b) => {
    b.addEventListener('click', resetAll);
  });

  // Category
  document.querySelectorAll<HTMLElement>('.sb-cat').forEach((b) => {
    b.addEventListener('click', () => setCategory(b));
  });

  // Colors
  document.querySelectorAll<HTMLElement>('.sb-swatch-wrap').forEach((el) => {
    el.addEventListener('click', () => {
      el.classList.toggle('active');
      const c = el.dataset.color || '';
      const idx = F.colors.indexOf(c);
      if (idx > -1) F.colors.splice(idx, 1);
      else F.colors.push(c);
      doFilter();
    });
  });

  // Sizes
  document.querySelectorAll<HTMLElement>('.sb-size').forEach((el) => {
    el.addEventListener('click', () => {
      el.classList.toggle('active');
      const s = (el.textContent || '').trim().toLowerCase();
      const idx = F.sizes.indexOf(s);
      if (idx > -1) F.sizes.splice(idx, 1);
      else F.sizes.push(s);
      doFilter();
    });
  });

  // Price
  document.querySelectorAll<HTMLInputElement>('[data-price-slider]').forEach((el) => {
    el.addEventListener('input', onPriceSlider);
  });
  document.querySelectorAll<HTMLInputElement>('[data-price-box]').forEach((el) => {
    el.addEventListener('input', () => onPriceBox(el, el.dataset.priceBox === 'max' ? 'max' : 'min'));
  });

  // Rating
  document.querySelectorAll<HTMLElement>('.sb-rating').forEach((el) => {
    el.addEventListener('click', () => toggleRating(el));
  });

  // Pills (material / occasion / availability)
  document.querySelectorAll<HTMLElement>('.sb-pill[data-pill-type]').forEach((el) => {
    el.addEventListener('click', () =>
      togglePill(el, el.dataset.pillType as PillType, el.dataset.pillVal || ''),
    );
  });

  // Sort
  const sortSel = document.getElementById('sort-sel');
  if (sortSel) sortSel.addEventListener('change', doSort);

  // View
  document.querySelectorAll<HTMLElement>('.view-btn[data-view]').forEach((b) => {
    b.addEventListener('click', () => setView(parseInt(b.dataset.view || '3', 10)));
  });

  // Initial paint
  updateSliderFill(FLOOR, CEIL);
  renderChips();
</script>
