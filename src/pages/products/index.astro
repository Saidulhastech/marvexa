---
// ============================================================
//  Shop (OMNIX) — all-products PLP. Server-rendered grid wired to
//  real Shopify products with sort + cursor pagination. Filter
//  facets (category, brand, price, colour, rating, availability,
//  features) are DERIVED from the products on the current page and
//  applied client-side by a controller script. Search + grid/list
//  view toggle are functional. (Filtering scopes to the current
//  page because pagination is server-side, 12 products per page.)
// ============================================================
import Layout from '~/layouts/Layout.astro';
import { getProducts, PRODUCT_SORT_OPTIONS, resolveSort } from '~/lib/shopify';
import { applyMarketCache } from '~/lib/market';
import type { ProductCard as TProductCard } from '~/lib/shopify/types';
import ProductCard from '~/components/product/omnix/ProductCard.astro';
import '~/styles/shop.css';

const url = Astro.url;
const sortValue = url.searchParams.get('sort') ?? PRODUCT_SORT_OPTIONS[0].value;
const sort = resolveSort(PRODUCT_SORT_OPTIONS, sortValue);

let products: TProductCard[] = [];
let hasMore = false;
let loadError = false;

try {
  // Fetch a single large page so facet filtering works across the loaded set
  // client-side. Capped at 100 (not 250) to keep the Storefront query cost in
  // bounds now that each card carries its variants. `hasMore` flags when the
  // catalogue exceeds the loaded set so the counts don't claim to be the total.
  const page = await getProducts(
    {
      pageSize: 100,
      sortKey: sort.sortKey,
      reverse: sort.reverse,
    },
    Astro.locals.market,
  );
  products = page.items;
  hasMore = page.pageInfo?.hasNextPage ?? false;
} catch (err) {
  console.error('[products] load failed:', (err as Error).message);
  loadError = true;
}
const countLabel = `${products.length}${hasMore ? '+' : ''}`;

// Edge-cache the listing HTML (cart is client-side). Market-aware.
if (!loadError) {
  applyMarketCache(Astro.response.headers, Astro.locals.market);
}

// ---- Facets derived from the real products on this page ----
const slug = (s: string) =>
  s.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');

function countBy(values: string[]): [string, number][] {
  const m = new Map<string, number>();
  for (const v of values) {
    const k = v?.trim();
    if (k) m.set(k, (m.get(k) ?? 0) + 1);
  }
  return [...m.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
}

const categories = countBy(products.map((p) => p.productType ?? ''));
const brands = countBy(products.map((p) => p.vendor ?? ''));

const colorMap = new Map<string, string>();
for (const p of products)
  for (const s of p.swatches ?? []) if (s?.name && s?.color) colorMap.set(s.name.toLowerCase(), s.color);
const colors = [...colorMap.entries()]; // [name, cssColor]

const features = countBy(products.flatMap((p) => p.tags ?? [])).slice(0, 8);

const priceNums = products
  .map((p) => Number(p.priceRange.minVariantPrice.amount))
  .filter((n) => Number.isFinite(n));
const priceFloor = priceNums.length ? Math.floor(Math.min(...priceNums)) : 0;
const priceCeil = priceNums.length ? Math.max(10, Math.ceil(Math.max(...priceNums))) : 1000;

const hasAnyRating = products.some((p) => (p.rating ?? 0) > 0);

// Per-card data-* attributes the controller filters on.
function cardAttrs(p: TProductCard): Record<string, string> {
  const price = Number(p.priceRange.minVariantPrice.amount) || 0;
  const compare = Number(p.compareAtPriceRange?.minVariantPrice?.amount) || 0;
  return {
    'data-title': p.title.toLowerCase(),
    'data-price': String(Math.round(price)),
    'data-brand': p.vendor ?? '',
    'data-cat': p.productType ?? '',
    'data-colors': (p.swatches ?? []).map((s) => s.name.toLowerCase()).join(' '),
    'data-tags': (p.tags ?? []).map((t) => slug(t)).join(' '),
    'data-sale': compare > price ? '1' : '0',
    'data-instock': p.availableForSale ? '1' : '0',
    'data-rating': String(p.rating ?? 0),
  };
}

const chev = `<svg class="chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>`;
const check = `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
const star = `<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`;
---

<Layout title="Shop" description="Browse the full OMNIX catalogue — every product, hand-tested and spec-checked.">
  <main class="shop-main" id="shopModern">
    <div class="sm-wrap">
      <nav class="sm-crumb" aria-label="Breadcrumb">
        <a href="/">Home</a><span>/</span><span class="cur">Shop</span>
      </nav>

      <div class="sm-head">
        <div>
          <h1 class="sm-title">All Tech, Curated</h1>
          <p class="sm-sub">Every product hand-tested and spec-checked by our editors. Filter your way to the gear that actually fits.</p>
        </div>
        <div class="sm-head-stats">
          <div class="sm-stat"><b>{countLabel}</b><span>Products</span></div>
          <div class="sm-stat"><b>{categories.length || brands.length}</b><span>{categories.length ? 'Categories' : 'Brands'}</span></div>
          <div class="sm-stat"><b>${priceFloor}+</b><span>From</span></div>
        </div>
      </div>

      <div class="sm-layout" id="smLayout">
        <aside class="sm-filters" id="smFilters">
          <div class="sm-fhead">
            <span class="sm-ftitle">Filters <span class="sm-activecount" id="smActiveCount" style="display:none;">0</span></span>
            <button class="sm-clear" id="smClear" type="button">Clear all</button>
            <button class="sm-fclose" id="smFClose" type="button" aria-label="Close filters"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
          </div>

          <div class="sm-active" id="smActive"></div>

          <div class="sm-group">
            <div class="sm-gbody sm-gbody-pad">
              <div class="sm-search">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" id="smSearch" placeholder="Search products..." autocomplete="off">
              </div>
            </div>
          </div>

          {
            categories.length > 0 && (
              <div class="sm-group">
                <button class="sm-gtitle" type="button">Category <Fragment set:html={chev} /></button>
                <div class="sm-gbody">
                  {categories.map(([cat, n]) => (
                    <label class="sm-check">
                      <input type="checkbox" data-filter="cat" value={cat} />
                      <span class="sm-box"><Fragment set:html={check} /></span> {cat} <span class="cnt">{n}</span>
                    </label>
                  ))}
                </div>
              </div>
            )
          }

          <div class="sm-group">
            <button class="sm-gtitle" type="button">Price <Fragment set:html={chev} /></button>
            <div class="sm-gbody">
              <div class="sm-range">
                <div class="sm-range-track"><div class="sm-range-fill" id="smRangeFill"></div></div>
                <input type="range" id="smRangeMin" min={priceFloor} max={priceCeil} step="10" value={priceFloor} aria-label="Minimum price">
                <input type="range" id="smRangeMax" min={priceFloor} max={priceCeil} step="10" value={priceCeil} aria-label="Maximum price">
              </div>
              <div class="sm-price-inputs">
                <input type="number" id="smMin" placeholder="Min" min={priceFloor} max={priceCeil}>
                <span>&ndash;</span>
                <input type="number" id="smMax" placeholder="Max" min={priceFloor} max={priceCeil}>
              </div>
              <div class="sm-chips" id="smPriceChips">
                <button class="sm-chip" type="button" data-min="0" data-max="100">Under $100</button>
                <button class="sm-chip" type="button" data-min="100" data-max="300">$100&ndash;300</button>
                <button class="sm-chip" type="button" data-min="300" data-max="600">$300&ndash;600</button>
                <button class="sm-chip" type="button" data-min="600" data-max="">$600+</button>
              </div>
            </div>
          </div>

          {
            brands.length > 0 && (
              <div class="sm-group">
                <button class="sm-gtitle" type="button">Brand <Fragment set:html={chev} /></button>
                <div class="sm-gbody">
                  {brands.map(([brand, n]) => (
                    <label class="sm-check">
                      <input type="checkbox" data-filter="brand" value={brand} />
                      <span class="sm-box"><Fragment set:html={check} /></span> {brand} <span class="cnt">{n}</span>
                    </label>
                  ))}
                </div>
              </div>
            )
          }

          {
            hasAnyRating && (
              <div class="sm-group">
                <button class="sm-gtitle" type="button">Rating <Fragment set:html={chev} /></button>
                <div class="sm-gbody">
                  {[
                    { v: '4.5', label: '4.5 & up' },
                    { v: '4', label: '4.0 & up' },
                    { v: '3', label: '3.0 & up' },
                    { v: '0', label: 'Any rating' },
                  ].map((r, i) => (
                    <label class="sm-check is-radio">
                      <input type="radio" name="smRate" data-filter="rate" value={r.v} checked={i === 3} />
                      <span class="sm-box"><Fragment set:html={check} /></span>{' '}
                      <span class="sm-rate">{r.v !== '0' && <span class="stars"><Fragment set:html={star} /></span>} {r.label}</span>
                    </label>
                  ))}
                </div>
              </div>
            )
          }

          {
            colors.length > 0 && (
              <div class="sm-group">
                <button class="sm-gtitle" type="button">Color <Fragment set:html={chev} /></button>
                <div class="sm-gbody">
                  <div class="sm-swatches">
                    {colors.map(([name, css]) => (
                      <span
                        class="sm-sw"
                        data-color={name}
                        title={name}
                        style={`background:${css}`}
                        role="checkbox"
                        aria-checked="false"
                        aria-label={name}
                        tabindex="0"
                      />
                    ))}
                  </div>
                </div>
              </div>
            )
          }

          <div class="sm-group">
            <button class="sm-gtitle" type="button">Availability <Fragment set:html={chev} /></button>
            <div class="sm-gbody">
              <div class="sm-toggle">In stock only <span class="sm-switch" id="smInStock" role="switch" tabindex="0"></span></div>
              <div class="sm-toggle">Out of stock <span class="sm-switch" id="smOutStock" role="switch" tabindex="0"></span></div>
            </div>
          </div>

          <div class="sm-group">
            <button class="sm-gtitle" type="button">Offers <Fragment set:html={chev} /></button>
            <div class="sm-gbody">
              <div class="sm-toggle">On sale <span class="sm-switch" id="smOnSale" role="switch" tabindex="0"></span></div>
            </div>
          </div>

          {
            features.length > 0 && (
              <div class="sm-group">
                <button class="sm-gtitle" type="button">Features <Fragment set:html={chev} /></button>
                <div class="sm-gbody">
                  {features.map(([tag, n]) => (
                    <label class="sm-check">
                      <input type="checkbox" data-filter="feature" value={slug(tag)} />
                      <span class="sm-box"><Fragment set:html={check} /></span> {tag} <span class="cnt">{n}</span>
                    </label>
                  ))}
                </div>
              </div>
            )
          }

          <div class="sm-apply-row">
            <button class="sm-apply" id="smApply" type="button">Show results</button>
          </div>
        </aside>

        <div class="sm-results">
          <div class="sm-toolbar">
            <button class="sm-filterbtn" id="smFilterBtn" type="button"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="7" y1="12" x2="17" y2="12"/><line x1="10" y1="18" x2="14" y2="18"/></svg> Filters</button>
            <span class="sm-count" id="smCount">Showing <b>{products.length}</b> products</span>
            {hasMore && <span class="sm-count-note">Browsing the latest {products.length} — refine with filters or search for more.</span>}
            <div class="sm-tools">
              <div class="sm-view" role="group" aria-label="View mode">
                <button class="sm-viewbtn is-active" id="smGridBtn" type="button" aria-label="Grid view"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg></button>
                <button class="sm-viewbtn" id="smListBtn" type="button" aria-label="List view"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3.5" y1="6" x2="3.51" y2="6"/><line x1="3.5" y1="12" x2="3.51" y2="12"/><line x1="3.5" y1="18" x2="3.51" y2="18"/></svg></button>
              </div>
              <form class="sm-sortwrap" method="get" id="smSortForm">
                <label for="smSort">Sort by</label>
                <select class="sm-sort" id="smSort" name="sort">
                  {PRODUCT_SORT_OPTIONS.map((o) => (
                    <option value={o.value} selected={o.value === sort.value}>{o.label}</option>
                  ))}
                </select>
              </form>
            </div>
          </div>

          {
            loadError ? (
              <div class="sm-empty">
                <b>We hit a connection snag</b>
                The catalogue couldn't load right now. Please try again shortly.
              </div>
            ) : products.length === 0 ? (
              <div class="sm-empty">
                <b>No products found</b>
                Try a different sort or check back soon.
              </div>
            ) : (
              <>
                <div class="sm-grid" id="smGrid">
                  {products.map((p, i) => <ProductCard product={p} eager={i < 3} attrs={cardAttrs(p)} />)}
                </div>
                <div class="sm-empty" id="smNoMatch" style="display:none;">
                  <b>No matches</b>
                  No products on this page match your filters. Try clearing some.
                </div>
              </>
            )
          }

          {
            !loadError && products.length > 0 && (
              <div class="sm-more" id="smPagerWrap">
                <button class="sm-morebtn" id="smMore" type="button">Load more <span id="smMoreCount">+4</span></button>
                <p class="sm-moremeta" id="smMoreMeta">You've viewed {Math.min(8, products.length)} of {products.length} products</p>
              </div>
            )
          }
        </div>
      </div>

      <div class="sm-overlay" id="smOverlay"></div>
    </div>
  </main>
</Layout>

<style>
  .sm-pager { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; justify-content: center; }
  .sm-count-note { display: block; margin-top: 4px; font-size: 12.5px; color: var(--muted); }
</style>

<script>
  // ============================================================
  //  Shop filter controller — client-side filtering of the current
  //  page's product cards by data-* attributes, plus search,
  //  collapse, mobile drawer, and grid/list view.
  // ============================================================
  const $ = <T extends Element = HTMLElement>(s: string, r: ParentNode = document) =>
    r.querySelector<T>(s);
  const $$ = <T extends Element = HTMLElement>(s: string, r: ParentNode = document) =>
    Array.from(r.querySelectorAll<T>(s));

  const grid = $<HTMLElement>('#smGrid');
  const layout = $<HTMLElement>('#smLayout');
  if (grid && layout) {
    const cards = $$('.prod-card', grid);
    const noMatch = $<HTMLElement>('#smNoMatch');
    const countEl = $<HTMLElement>('#smCount b') ?? $<HTMLElement>('#smCount');
    const activeWrap = $<HTMLElement>('#smActive');
    const activeCount = $<HTMLElement>('#smActiveCount');
    const search = $<HTMLInputElement>('#smSearch');
    const minIn = $<HTMLInputElement>('#smMin');
    const maxIn = $<HTMLInputElement>('#smMax');
    const rMin = $<HTMLInputElement>('#smRangeMin');
    const rMax = $<HTMLInputElement>('#smRangeMax');
    const fill = $<HTMLElement>('#smRangeFill');
    const FLOOR = rMin ? Number(rMin.min) : 0;
    const CEIL = rMin ? Number(rMin.max) : 1000;

    type Active = { type: string; value: string; label: string };

    const titleCase = (s: string) =>
      s.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());

    function readState() {
      const checked = (filter: string) =>
        $$<HTMLInputElement>(`input[data-filter="${filter}"]:checked`).map((i) => i.value);
      const rate = $<HTMLInputElement>('input[data-filter="rate"]:checked');
      return {
        q: (search?.value ?? '').trim().toLowerCase(),
        cat: checked('cat').map((v) => v.toLowerCase()),
        brand: checked('brand').map((v) => v.toLowerCase()),
        feature: checked('feature'),
        colors: $$('.sm-sw.is-active').map((s) => (s as HTMLElement).dataset.color ?? ''),
        rate: rate ? Number(rate.value) : 0,
        inStock: $<HTMLElement>('#smInStock')?.classList.contains('is-on') ?? false,
        outStock: $<HTMLElement>('#smOutStock')?.classList.contains('is-on') ?? false,
        onSale: $<HTMLElement>('#smOnSale')?.classList.contains('is-on') ?? false,
        pMin: minIn?.value ? Number(minIn.value) : FLOOR,
        pMax: maxIn?.value ? Number(maxIn.value) : CEIL,
      };
    }

    const INITIAL = 8;
    const STEP = 4;
    let shown = INITIAL;
    const moreWrap = $<HTMLElement>('#smPagerWrap');
    const moreBtn = $<HTMLElement>('#smMore');
    const moreCount = $<HTMLElement>('#smMoreCount');
    const moreMeta = $<HTMLElement>('#smMoreMeta');

    function matchedCards() {
      const s = readState();
      const matched = cards.filter((card) => {
        const d = card.dataset;
        const price = Number(d.price ?? 0);
        const cardColors = (d.colors ?? '').split(/\s+/).filter(Boolean);
        const cardTags = (d.tags ?? '').split(/\s+/).filter(Boolean);
        return (
          (!s.q || (d.title ?? '').includes(s.q)) &&
          (!s.cat.length || s.cat.includes((d.cat ?? '').toLowerCase())) &&
          (!s.brand.length || s.brand.includes((d.brand ?? '').toLowerCase())) &&
          (!s.feature.length || s.feature.every((f) => cardTags.includes(f))) &&
          (!s.colors.length || s.colors.some((c) => cardColors.includes(c))) &&
          (!s.rate || Number(d.rating ?? 0) >= s.rate) &&
          (!s.inStock || d.instock === '1') &&
          (!s.outStock || d.instock === '0') &&
          (!s.onSale || d.sale === '1') &&
          price >= s.pMin &&
          price <= s.pMax
        );
      });
      return { matched, s };
    }

    // Render the current filter + reveal state (does NOT reset `shown`).
    function render() {
      const { matched, s } = matchedCards();
      const matchedSet = new Set(matched);
      const limit = Math.min(shown, matched.length);
      let revealed = 0;
      for (const card of cards) {
        const show = matchedSet.has(card) && revealed < limit;
        card.style.display = show ? '' : 'none';
        if (show) revealed++;
      }
      if (countEl) countEl.textContent = String(matched.length);
      if (noMatch) noMatch.style.display = matched.length === 0 ? '' : 'none';

      // Load-more controls
      const remaining = matched.length - limit;
      if (moreWrap) moreWrap.style.display = matched.length === 0 ? 'none' : '';
      if (moreBtn) moreBtn.style.display = remaining > 0 ? '' : 'none';
      if (moreCount) moreCount.textContent = '+' + Math.min(STEP, remaining);
      if (moreMeta)
        moreMeta.textContent =
          remaining > 0
            ? `You've viewed ${limit} of ${matched.length} products`
            : `Showing all ${matched.length} product${matched.length === 1 ? '' : 's'}`;
      renderActive(s);
    }

    // Apply a filter change — resets the reveal window to the first page.
    function apply() {
      shown = INITIAL;
      render();
    }

    function renderActive(s: ReturnType<typeof readState>) {
      const chips: Active[] = [];
      s.cat.forEach((v) => chips.push({ type: 'cat', value: v, label: titleCase(v) }));
      s.brand.forEach((v) => chips.push({ type: 'brand', value: v, label: titleCase(v) }));
      s.feature.forEach((v) => chips.push({ type: 'feature', value: v, label: titleCase(v) }));
      s.colors.forEach((v) => chips.push({ type: 'color', value: v, label: titleCase(v) }));
      if (s.rate) chips.push({ type: 'rate', value: String(s.rate), label: `${s.rate}★ & up` });
      if (s.inStock) chips.push({ type: 'instock', value: '1', label: 'In stock' });
      if (s.outStock) chips.push({ type: 'outstock', value: '1', label: 'Out of stock' });
      if (s.onSale) chips.push({ type: 'onsale', value: '1', label: 'On sale' });
      if (s.pMin > FLOOR || s.pMax < CEIL) chips.push({ type: 'price', value: '', label: `$${s.pMin}–$${s.pMax}` });
      if (s.q) chips.push({ type: 'q', value: '', label: `“${s.q}”` });

      if (activeWrap) {
        activeWrap.innerHTML = chips
          .map(
            (c) =>
              `<button class="sm-achip" data-clear="${c.type}" data-val="${c.value}">${c.label} ✕</button>`,
          )
          .join('');
        activeWrap.style.display = chips.length ? 'flex' : 'none';
      }
      if (activeCount) {
        activeCount.textContent = String(chips.length);
        activeCount.style.display = chips.length ? '' : 'none';
      }
    }

    // -- price slider <-> number inputs --
    function paintFill() {
      if (!fill || !rMin || !rMax) return;
      const lo = ((Number(rMin.value) - FLOOR) / (CEIL - FLOOR)) * 100;
      const hi = ((Number(rMax.value) - FLOOR) / (CEIL - FLOOR)) * 100;
      fill.style.left = lo + '%';
      fill.style.right = 100 - hi + '%';
    }
    function syncFromRange() {
      if (!rMin || !rMax) return;
      let lo = Number(rMin.value);
      let hi = Number(rMax.value);
      if (lo > hi) [lo, hi] = [hi, lo];
      if (minIn) minIn.value = String(lo);
      if (maxIn) maxIn.value = String(hi);
      paintFill();
      apply();
    }
    rMin?.addEventListener('input', syncFromRange);
    rMax?.addEventListener('input', syncFromRange);
    function syncFromNumber() {
      if (rMin && minIn?.value) rMin.value = String(Math.max(FLOOR, Number(minIn.value)));
      if (rMax && maxIn?.value) rMax.value = String(Math.min(CEIL, Number(maxIn.value)));
      paintFill();
      apply();
    }
    minIn?.addEventListener('change', syncFromNumber);
    maxIn?.addEventListener('change', syncFromNumber);

    // price quick-chips
    $$('#smPriceChips .sm-chip').forEach((chip) =>
      chip.addEventListener('click', () => {
        const lo = Number((chip as HTMLElement).dataset.min || FLOOR);
        const hi = (chip as HTMLElement).dataset.max ? Number((chip as HTMLElement).dataset.max) : CEIL;
        const active = chip.classList.contains('is-active');
        $$('#smPriceChips .sm-chip').forEach((c) => c.classList.remove('is-active'));
        if (active) {
          if (minIn) minIn.value = '';
          if (maxIn) maxIn.value = '';
          if (rMin) rMin.value = String(FLOOR);
          if (rMax) rMax.value = String(CEIL);
        } else {
          chip.classList.add('is-active');
          if (minIn) minIn.value = String(lo);
          if (maxIn) maxIn.value = String(hi);
          if (rMin) rMin.value = String(lo);
          if (rMax) rMax.value = String(Math.min(CEIL, hi));
        }
        paintFill();
        apply();
      }),
    );

    // checkboxes / radios
    $$<HTMLInputElement>('input[data-filter]').forEach((i) => i.addEventListener('change', apply));
    // search
    search?.addEventListener('input', apply);
    // colour swatches (mouse + keyboard; reflect state on aria-checked)
    const toggleSwatch = (sw: Element) => {
      const on = sw.classList.toggle('is-active');
      sw.setAttribute('aria-checked', on ? 'true' : 'false');
      apply();
    };
    $$('.sm-sw').forEach((sw) => {
      sw.addEventListener('click', () => toggleSwatch(sw));
      sw.addEventListener('keydown', (e) => {
        const k = (e as KeyboardEvent).key;
        if (k === 'Enter' || k === ' ') {
          e.preventDefault();
          toggleSwatch(sw);
        }
      });
    });
    // availability + offers toggles
    ['#smInStock', '#smOutStock', '#smOnSale'].forEach((sel) => {
      const el = $<HTMLElement>(sel);
      const toggle = () => {
        const turningOn = !el?.classList.contains('is-on');
        el?.classList.toggle('is-on');
        // "In stock only" and "Out of stock" are mutually exclusive.
        if (turningOn && sel === '#smInStock') $<HTMLElement>('#smOutStock')?.classList.remove('is-on');
        if (turningOn && sel === '#smOutStock') $<HTMLElement>('#smInStock')?.classList.remove('is-on');
        apply();
      };
      el?.addEventListener('click', toggle);
      el?.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
          e.preventDefault();
          toggle();
        }
      });
    });

    // active-chip removal
    activeWrap?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-clear]');
      if (!btn) return;
      clearOne(btn.dataset.clear ?? '', btn.dataset.val ?? '');
    });

    function clearOne(type: string, val: string) {
      const v = val.toLowerCase();
      if (['cat', 'brand', 'feature'].includes(type)) {
        $$<HTMLInputElement>(`input[data-filter="${type}"]`).forEach((i) => {
          if (i.value.toLowerCase() === v) i.checked = false;
        });
      } else if (type === 'color') {
        $$('.sm-sw').forEach((s) => {
          if ((s as HTMLElement).dataset.color === val) s.classList.remove('is-active');
        });
      } else if (type === 'rate') {
        const any = $<HTMLInputElement>('input[data-filter="rate"][value="0"]');
        if (any) any.checked = true;
      } else if (type === 'instock') {
        $<HTMLElement>('#smInStock')?.classList.remove('is-on');
      } else if (type === 'outstock') {
        $<HTMLElement>('#smOutStock')?.classList.remove('is-on');
      } else if (type === 'onsale') {
        $<HTMLElement>('#smOnSale')?.classList.remove('is-on');
      } else if (type === 'price') {
        resetPrice();
      } else if (type === 'q') {
        if (search) search.value = '';
      }
      apply();
    }

    function resetPrice() {
      if (minIn) minIn.value = '';
      if (maxIn) maxIn.value = '';
      if (rMin) rMin.value = String(FLOOR);
      if (rMax) rMax.value = String(CEIL);
      $$('#smPriceChips .sm-chip').forEach((c) => c.classList.remove('is-active'));
      paintFill();
    }

    // clear all
    $('#smClear')?.addEventListener('click', () => {
      $$<HTMLInputElement>('input[data-filter]').forEach((i) => {
        if (i.type === 'radio') i.checked = i.value === '0';
        else i.checked = false;
      });
      $$('.sm-sw').forEach((s) => s.classList.remove('is-active'));
      $<HTMLElement>('#smInStock')?.classList.remove('is-on');
      $<HTMLElement>('#smOutStock')?.classList.remove('is-on');
      $<HTMLElement>('#smOnSale')?.classList.remove('is-on');
      if (search) search.value = '';
      resetPrice();
      apply();
    });

    // group collapse
    $$('.sm-gtitle').forEach((t) =>
      t.addEventListener('click', () => t.closest('.sm-group')?.classList.toggle('is-collapsed')),
    );

    // load more (progressive reveal of the already-fetched catalogue)
    moreBtn?.addEventListener('click', () => {
      shown += STEP;
      render();
    });

    // grid / list view
    const gridBtn = $<HTMLElement>('#smGridBtn');
    const listBtn = $<HTMLElement>('#smListBtn');
    gridBtn?.addEventListener('click', () => {
      grid.classList.remove('is-list');
      gridBtn.classList.add('is-active');
      listBtn?.classList.remove('is-active');
    });
    listBtn?.addEventListener('click', () => {
      grid.classList.add('is-list');
      listBtn.classList.add('is-active');
      gridBtn?.classList.remove('is-active');
    });

    // mobile filter drawer (≤980px) / desktop hide filters
    const filters = $<HTMLElement>('#smFilters');
    const overlay = $<HTMLElement>('#smOverlay');
    const isMobile = () => window.matchMedia('(max-width: 980px)').matches;
    const openDrawer = () => {
      filters?.classList.add('is-open');
      overlay?.classList.add('is-open');
    };
    const closeDrawer = () => {
      filters?.classList.remove('is-open');
      overlay?.classList.remove('is-open');
    };
    $('#smFilterBtn')?.addEventListener('click', () => {
      if (isMobile()) openDrawer();
      else {
        const hidden = layout.classList.toggle('filters-hidden');
        $('#smFilterBtn')?.classList.toggle('is-off', hidden);
      }
    });
    $('#smFClose')?.addEventListener('click', closeDrawer);
    overlay?.addEventListener('click', closeDrawer);
    $('#smApply')?.addEventListener('click', closeDrawer);

    // -- URL query-param sync — filter state lives in the address bar so it is
    //    shareable, bookmarkable, and survives the sort reload (real-store
    //    behaviour). replaceState (not push) keeps history clean while the
    //    shopper tweaks facets; the lone `sort` param is preserved untouched. --
    const FILTER_PARAMS = ['cat', 'brand', 'feature', 'color', 'rate', 'instock', 'outstock', 'sale', 'min', 'max', 'q'];

    function writeUrl() {
      const s = readState();
      const url = new URL(window.location.href);
      const p = url.searchParams;
      FILTER_PARAMS.forEach((k) => p.delete(k));
      if (s.cat.length) p.set('cat', s.cat.join(','));
      if (s.brand.length) p.set('brand', s.brand.join(','));
      if (s.feature.length) p.set('feature', s.feature.join(','));
      if (s.colors.length) p.set('color', s.colors.join(','));
      if (s.rate) p.set('rate', String(s.rate));
      if (s.inStock) p.set('instock', '1');
      if (s.outStock) p.set('outstock', '1');
      if (s.onSale) p.set('sale', '1');
      if (s.pMin > FLOOR) p.set('min', String(s.pMin));
      if (s.pMax < CEIL) p.set('max', String(s.pMax));
      if (s.q) p.set('q', s.q);
      const qs = p.toString();
      window.history.replaceState(null, '', url.pathname + (qs ? '?' + qs : ''));
    }

    // Hydrate the filter UI from the URL on load (back/forward + shared links).
    function applyUrl() {
      const p = new URL(window.location.href).searchParams;
      const list = (k: string) => (p.get(k) ?? '').split(',').map((x) => x.trim()).filter(Boolean);
      const q = p.get('q');
      if (search && q) search.value = q;
      const setChecks = (filter: string, vals: string[]) =>
        $$<HTMLInputElement>(`input[data-filter="${filter}"]`).forEach((i) => {
          if (vals.includes(i.value.toLowerCase()) || vals.includes(i.value)) i.checked = true;
        });
      setChecks('cat', list('cat'));
      setChecks('brand', list('brand'));
      setChecks('feature', list('feature'));
      list('color').forEach((c) =>
        $$('.sm-sw').forEach((sw) => {
          if (((sw as HTMLElement).dataset.color ?? '').toLowerCase() === c) {
            sw.classList.add('is-active');
            sw.setAttribute('aria-checked', 'true');
          }
        }),
      );
      const rate = p.get('rate');
      if (rate) {
        const r = $<HTMLInputElement>(`input[data-filter="rate"][value="${rate}"]`);
        if (r) r.checked = true;
      }
      if (p.get('instock') === '1') $<HTMLElement>('#smInStock')?.classList.add('is-on');
      if (p.get('outstock') === '1') $<HTMLElement>('#smOutStock')?.classList.add('is-on');
      if (p.get('sale') === '1') $<HTMLElement>('#smOnSale')?.classList.add('is-on');
      const min = p.get('min');
      const max = p.get('max');
      if (min && minIn && rMin) { minIn.value = min; rMin.value = String(Math.max(FLOOR, Number(min))); }
      if (max && maxIn && rMax) { maxIn.value = max; rMax.value = String(Math.min(CEIL, Number(max))); }
    }

    // Mirror state into the URL on every change (render is the single funnel).
    const _render = render;
    render = function () {
      _render();
      writeUrl();
    };

    // Sort change → reload preserving the current filter params (a plain GET
    // submit would rebuild the query from the lone <select> and drop them).
    $<HTMLSelectElement>('#smSort')?.addEventListener('change', (e) => {
      const url = new URL(window.location.href);
      url.searchParams.set('sort', (e.target as HTMLSelectElement).value);
      window.location.assign(url.pathname + url.search);
    });

    // Back/forward between filter states → re-sync the UI without a full reload.
    window.addEventListener('popstate', () => {
      $$<HTMLInputElement>('input[data-filter]').forEach((i) => {
        if (i.type === 'radio') i.checked = i.value === '0';
        else i.checked = false;
      });
      $$('.sm-sw').forEach((s) => { s.classList.remove('is-active'); s.setAttribute('aria-checked', 'false'); });
      $<HTMLElement>('#smInStock')?.classList.remove('is-on');
      $<HTMLElement>('#smOutStock')?.classList.remove('is-on');
      $<HTMLElement>('#smOnSale')?.classList.remove('is-on');
      if (search) search.value = '';
      resetPrice();
      applyUrl();
      _render();
    });

    applyUrl();
    paintFill();
    apply();
  }
</script>
