---
// ============================================================
//  PDP (OMNIX "Modern") — product detail. Faithful reproduction of
//  the Modern Style HTML design, server-rendered from real Shopify
//  data and driven by a vanilla controller (gallery, variant→cart,
//  qty, tabs, sticky bar, aligns carousel). The cart uses the shared
//  nanostore (addItem/buyNow) so the header badge + drawer stay live.
// ============================================================
import Layout from '~/layouts/Layout.astro';
import ProductCard from '~/components/product/omnix/ProductCard.astro';
import { getProduct, getProductRecommendations } from '~/lib/shopify';
import { applyMarketCache } from '~/lib/market';
import { formatMoney, percentOff } from '~/lib/money';
import type { Image, Product, ProductCard as TProductCard } from '~/lib/shopify/types';
import '~/styles/product.css';

const { handle } = Astro.params;
const market = Astro.locals.market;

let product: Product | null = null;
let recommendations: TProductCard[] = [];
let loadFailed = false;

try {
  product = await getProduct(handle!, market);
} catch (err) {
  loadFailed = true;
  console.error('[product] load failed:', (err as Error).message);
}

if (product) {
  try {
    recommendations = await getProductRecommendations(product.id, 8, market);
  } catch (err) {
    console.error('[product] recommendations failed:', (err as Error).message);
  }
}

if (loadFailed) {
  Astro.response.status = 503;
} else if (!product) {
  Astro.response.status = 404;
} else {
  // Edge-cache the rendered product page (cart/account are client-side).
  // Market-aware: only the default market is shared-cached (see applyMarketCache).
  applyMarketCache(Astro.response.headers, market);
}

// Inline SVG placeholder so an imageless product still renders a real slide
// (empty gallery left the counter at "1 / 0" and broke prev/next navigation).
const PLACEHOLDER_IMAGE: Image = {
  url:
    'data:image/svg+xml,' +
    encodeURIComponent(
      '<svg xmlns="http://www.w3.org/2000/svg" width="800" height="800" viewBox="0 0 800 800"><rect width="800" height="800" fill="#f1f3f5"/><g fill="none" stroke="#ced4da" stroke-width="8"><rect x="250" y="280" width="300" height="220" rx="12"/><circle cx="330" cy="360" r="28"/><path d="M270 480l90-80 70 60 60-50 50 70"/></g></svg>',
    ),
  altText: 'Product image coming soon',
};
const images: Image[] =
  product && product.images.length
    ? product.images
    : product?.featuredImage
      ? [product.featuredImage]
      : [PLACEHOLDER_IMAGE];
const currency = product?.priceRange.minVariantPrice.currencyCode ?? 'USD';
const ogImage = product?.featuredImage?.url;

const money = (amt: number) => formatMoney({ amount: String(amt), currencyCode: currency });

// ---- Default variant + initial selection ----
const variants = product?.variants ?? [];
const defaultVariant = variants.find((v) => v.availableForSale) ?? variants[0] ?? null;
const selectedInit: Record<string, string> = {};
defaultVariant?.selectedOptions.forEach((o) => (selectedInit[o.name] = o.value));

const dPrice = defaultVariant ? Number(defaultVariant.price.amount) : Number(product?.priceRange.minVariantPrice.amount ?? 0);
const dCompare = defaultVariant?.compareAtPrice ? Number(defaultVariant.compareAtPrice.amount) : null;
const dOff = defaultVariant ? percentOff(defaultVariant.price, defaultVariant.compareAtPrice) : 0;
const dOnSale = dOff > 0 && dCompare != null;
const dSave = dOnSale && dCompare != null ? dCompare - dPrice : 0;
const dAvailable = defaultVariant?.availableForSale ?? false;

// Hide the variant pickers for a single default-title variant.
const singleVariant =
  !product ||
  product.options.length === 0 ||
  (product.options.length === 1 &&
    product.options[0].name === 'Title' &&
    product.options[0].optionValues.every((v) => v.name === 'Default Title'));

// "New" badge — match the card/grid rule (tagged `new` OR published < 30 days)
// so the badge is consistent between listing and detail.
const NEW_WINDOW_MS = 1000 * 60 * 60 * 24 * 30;
const isNew =
  (product?.tags ?? []).some((t) => t.toLowerCase() === 'new') ||
  (!!product?.createdAt && Date.now() - new Date(product.createdAt).getTime() < NEW_WINDOW_MS);

// Colour-option detection + swatch colour resolution (real Shopify swatch,
// else a named-colour fallback so the swatch still renders sensibly).
const NAMED_COLORS: Record<string, string> = {
  black: '#111418', white: '#ffffff', gray: '#808080', grey: '#808080',
  silver: '#d3d3d3', gold: '#c9a86a', 'rose gold': '#b76e79', blue: '#2563eb',
  navy: '#1e293b', red: '#dc2626', green: '#16a34a', pink: '#ec4899',
  purple: '#7c3aed', orange: '#ea580c', yellow: '#eab308', beige: '#e7d8c2',
  brown: '#8b5a2b', bronze: '#8c6239',
};
function isColorOption(opt: { name: string; optionValues: { swatch?: { color?: string | null } | null }[] }) {
  return /colou?r|finish|shade/i.test(opt.name) || opt.optionValues.some((v) => v.swatch?.color);
}
function swatchColor(ov: { name: string; swatch?: { color?: string | null } | null }) {
  return ov.swatch?.color || NAMED_COLORS[ov.name.toLowerCase()] || '#cbd5e1';
}

// ---- Data for the client controller ----
// Real local-pickup locations per variant (only the ones actually available).
const variantPickup = (v: (typeof variants)[number]) =>
  (v.storeAvailability ?? [])
    .filter((s) => s.available && s.locationName)
    .map((s) => ({
      name: s.city ? `${s.locationName} — ${s.city}` : s.locationName,
      time: s.pickUpTime ?? null,
    }));

const variantData = variants.map((v) => ({
  id: v.id,
  opts: Object.fromEntries(v.selectedOptions.map((o) => [o.name, o.value])),
  price: Number(v.price.amount),
  compareAt: v.compareAtPrice ? Number(v.compareAtPrice.amount) : null,
  available: v.availableForSale,
  qty: typeof v.quantityAvailable === 'number' ? v.quantityAvailable : null,
  img: v.image?.url ?? null,
  pickup: variantPickup(v),
}));

// SSR seed for the pickup block: first available pickup across variants. The
// controller refines this to the selected variant on load + every change.
const seedPickup = variantData.find((v) => v.pickup.length)?.pickup[0] ?? null;
const hasPickup = variantData.some((v) => v.pickup.length);
const alignsData = recommendations.map((p) => ({
  name: p.title,
  img: p.featuredImage?.url ?? '',
  price: Number(p.priceRange.minVariantPrice.amount),
  was: p.compareAtPriceRange?.minVariantPrice ? Number(p.compareAtPriceRange.minVariantPrice.amount) : null,
  href: `/products/${p.handle}`,
}));
const bootData = { currency, variants: variantData, aligns: alignsData, singleVariant };

const firstImg = images[0]?.url ?? '';

// ---- Real rating / stock / sku ----
const rating = product?.rating ?? null;
const ratingCount = product?.ratingCount ?? null;
const hasRating = rating != null && rating > 0;
const ratingRounded = hasRating ? Math.round(rating!) : 0;
const dSku = defaultVariant?.sku ?? null;
const dQty = defaultVariant?.quantityAvailable ?? null;
const dLowStock = typeof dQty === 'number' && dQty > 0 && dQty <= 10;
const dStockLabel = !dAvailable
  ? 'Currently out of stock'
  : dLowStock
    ? `Only ${dQty} left — order soon`
    : 'In stock — ships today';

// Highlights: real metafield → product tags fallback → none.
const highlights = (product?.highlights?.length ? product.highlights : (product?.tags ?? [])).slice(0, 4);

// Real spec rows from the custom.specifications metafield (if present).
const metaSpecs = product?.specs ?? [];
const metaSpecMid = Math.ceil(metaSpecs.length / 2);
const metaSpecGroups = metaSpecs.length
  ? [metaSpecs.slice(0, metaSpecMid), metaSpecs.slice(metaSpecMid)].filter((g) => g.length)
  : [];

// ---- Reviews — fully driven by real Shopify data ----
// Individual reviews come from a review metafield (review app); the store may
// expose only the aggregate rating, in which case there are no review cards.
const reviews = product?.reviews ?? [];
const hasReviews = reviews.length > 0;
const reviewCount = ratingCount ?? (hasReviews ? reviews.length : 0);
const showReviews = hasRating || hasReviews;
const ratingDisplay = hasRating
  ? rating!.toFixed(1)
  : hasReviews
    ? (reviews.reduce((s, r) => s + r.rating, 0) / reviews.length).toFixed(1)
    : '0.0';
const ratingStars = Math.round(Number(ratingDisplay));

// Star distribution → percentages [5★..1★]. Only when real reviews exist.
const dist = product?.ratingDistribution ?? null;
const distTotal = dist ? dist.reduce((a, b) => a + b, 0) : 0;
const distRows = dist
  ? dist.map((count, i) => ({ star: 5 - i, count, pct: distTotal ? Math.round((count / distTotal) * 100) : 0 }))
  : [];

// Avatar palette + initials for real review cards.
const AVATAR_COLORS = ['#2563EB', '#16A34A', '#F59E0B', '#EF4444', '#7C3AED', '#0891B2'];
const initialsOf = (name: string) =>
  name.split(/\s+/).map((w) => w[0]).join('').slice(0, 2).toUpperCase() || 'A';

// ---- Product JSON-LD (schema.org) for rich results ----
const variantPrices = variants.map((v) => Number(v.price.amount)).filter((n) => Number.isFinite(n));
const productJsonLd = product
  ? {
      '@context': 'https://schema.org',
      '@type': 'Product',
      name: product.title,
      description: product.description || undefined,
      image: images.map((i) => i.url),
      sku: dSku ?? undefined,
      ...(product.vendor ? { brand: { '@type': 'Brand', name: product.vendor } } : {}),
      offers:
        variants.length > 1
          ? {
              '@type': 'AggregateOffer',
              priceCurrency: currency,
              lowPrice: variantPrices.length ? Math.min(...variantPrices) : dPrice,
              highPrice: variantPrices.length ? Math.max(...variantPrices) : dPrice,
              offerCount: variants.length,
              availability: dAvailable ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
              url: Astro.url.href,
            }
          : {
              '@type': 'Offer',
              priceCurrency: currency,
              price: dPrice,
              availability: dAvailable ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
              url: Astro.url.href,
            },
      ...(hasRating
        ? {
            aggregateRating: {
              '@type': 'AggregateRating',
              ratingValue: rating,
              reviewCount: ratingCount ?? 0,
            },
          }
        : {}),
    }
  : undefined;

// ---- Breadcrumb JSON-LD (Home → Shop → Product) ----
const breadcrumbJsonLd = product
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site ?? Astro.url.origin).href },
        { '@type': 'ListItem', position: 2, name: 'Shop', item: new URL('/products', Astro.site ?? Astro.url.origin).href },
        { '@type': 'ListItem', position: 3, name: product.title, item: Astro.url.href },
      ],
    }
  : undefined;

const pdpJsonLd = [productJsonLd, breadcrumbJsonLd].filter(Boolean) as Record<string, unknown>[];
---

{
  product ? (
    <Layout
      title={product.seo?.title ?? product.title}
      description={product.seo?.description ?? product.description}
      image={ogImage}
      type="product"
      jsonLd={pdpJsonLd}
    >
      <div class="pm-main" id="prodModern">
        <script type="application/json" id="pmBoot" set:html={JSON.stringify(bootData)} />

        <div class="pm-wrap">
          {/* Breadcrumb */}
          <nav class="pm-crumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
            <a href="/products">Shop</a>
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
            <span class="cur">{product.title}</span>
          </nav>

          {/* TOP */}
          <div class="pm-top">
            {/* Gallery */}
            <div class="pm-gallery">
              <div class="pm-thumbs" id="pmThumbs">
                {images.map((img, i) => (
                  <button class:list={['pm-thumb', { 'is-active': i === 0 }]} data-idx={i}>
                    <img src={img.url} alt={img.altText ?? `${product.title} — ${i + 1}`} loading={i === 0 ? 'eager' : 'lazy'} />
                  </button>
                ))}
              </div>
              <div class="pm-stage" id="pmStage">
                <div class="pm-stage-badges">
                  {dOnSale && <span class="pm-sbadge sale">Save {money(dSave)}</span>}
                  {isNew && <span class="pm-sbadge new">New</span>}
                </div>
                <div class="pm-stage-tools">
                  <button class="pm-tool" id="pmZoom" aria-label="Toggle zoom" title="Zoom">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35M11 8v6M8 11h6"/></svg>
                  </button>
                  <button class="pm-tool" id="pmShare" aria-label="Share" title="Share">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.59 13.51l6.83 3.98M15.41 6.51l-6.82 3.98"/></svg>
                  </button>
                </div>
                <button class="pm-nav prev" id="pmPrev" aria-label="Previous image"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg></button>
                <button class="pm-nav next" id="pmNext" aria-label="Next image"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg></button>
                {images.map((img, i) => (
                  <div class:list={['pm-slide', { 'is-active': i === 0 }]} data-idx={i}><img src={img.url} alt={img.altText ?? product.title} /></div>
                ))}
                <div class="pm-counter"><span id="pmCurIdx">1</span> / {images.length}</div>
              </div>
            </div>

            {/* Info */}
            <div class="pm-info">
              <div class="pm-info-top">
                <span class="pm-brandrow">
                  {product.vendor && <span class="pm-brand">{product.vendor}</span>}
                  <span class="pm-brand-verified"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="9"/></svg>Verified brand</span>
                </span>
                <button
                  class="pm-wishbtn"
                  id="pmWish"
                  aria-label="Add to wishlist"
                  data-wish
                  data-handle={product.handle}
                  data-name={product.title}
                  data-price={money(dPrice)}
                  data-img={firstImg}
                  data-href={`/products/${product.handle}`}
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </button>
              </div>

              <h1 class="pm-title">{product.title}</h1>

              {hasRating ? (
                <div class="pm-ratingrow">
                  <span class="pm-stars" aria-label={`Rated ${rating} out of 5`}>
                    {Array.from({ length: 5 }).map((_, i) => (
                      <svg viewBox="0 0 24 24" fill="currentColor" style={i < ratingRounded ? '' : 'opacity:.25'}><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    ))}
                  </span>
                  <span class="pm-rating-txt"><b>{rating!.toFixed(1)}</b>{ratingCount ? <> &middot; <a href="#pmReviewsTab" data-gototab="reviews">{ratingCount} reviews</a></> : null}</span>
                  {dSku && <><span class="pm-stock-sep"></span><span class="pm-sold">SKU: {dSku}</span></>}
                </div>
              ) : dSku ? (
                <div class="pm-ratingrow">
                  <span class="pm-sold">SKU: {dSku}</span>
                </div>
              ) : null}

              <div class="pm-priceblock">
                <div class="pm-pricerow">
                  <span class="pm-price" id="pmPrice">{money(dPrice)}</span>
                  {dOnSale && dCompare != null && <span class="pm-price-was" id="pmWas">{money(dCompare)}</span>}
                  {dOnSale && <span class="pm-price-save" id="pmSave">Save {money(dSave)}</span>}
                </div>
                <p class="pm-price-note">or 4 interest-free payments of <b id="pmInstall">{money(dPrice / 4)}</b> with <a href="#">Klarna</a> &middot; <a href="#">Learn more</a></p>
              </div>

              <div class="pm-stock">
                <span class="pm-stock-badge" id="pmStockBadge"><span class="pm-stock-dot"></span>{dStockLabel}</span>
                <span class="pm-stock-sep"></span>
                <span class="pm-stock-meta"><svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7zM5.5 18.5a2.5 2.5 0 1 0 0-.01M18.5 18.5a2.5 2.5 0 1 0 0-.01"/></svg>Delivery &mdash; <b>2&ndash;5 business days</b></span>
              </div>

              {/* Store pickup — real Shopify Local Pickup (storeAvailability).
                  Hidden entirely when no location offers pickup for this product. */}
              {hasPickup && (
                <div class="pm-pickup" id="pmPickup">
                  <span class="pm-pickup-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l1-5h16l1 5M4 9v11a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1V9M3 9h18M9 21v-6h6v6"/></svg></span>
                  <div class="pm-pickup-txt">
                    <span class="pm-pickup-title"><b>Free pickup available</b> at <span class="pm-pickup-store" id="pmPickupStore">{seedPickup?.name}</span></span>
                    <span class="pm-pickup-sub"><span id="pmPickupTime">{seedPickup?.time ?? 'Ready soon'}</span><span id="pmPickupMore" style="display:none;"> &middot; <button type="button" class="pm-pickup-link" id="pmPickupCheck">Check other stores</button></span></span>
                  </div>
                  <span class="pm-pickup-badge">Pickup</span>
                </div>
              )}

              {highlights.length > 0 && (
                <ul class="pm-highlights">
                  {highlights.map((h) => (
                    <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>{h}</li>
                  ))}
                </ul>
              )}

              {/* Variant pickers (real Shopify options) — colour options render
                  as swatches, the rest as the bundle/option button group. */}
              {!singleVariant &&
                product.options.map((opt) =>
                  isColorOption(opt) ? (
                    <div class="pm-variant" data-option={opt.name}>
                      <div class="pm-variant-head">
                        <span class="pm-variant-label">{opt.name}</span>
                        <span class="pm-variant-cur">Selected: <b data-cur={opt.name}>{selectedInit[opt.name]}</b></span>
                      </div>
                      <div class="pm-swatches" data-opts={opt.name}>
                        {opt.optionValues.map((ov) => (
                          <button
                            class:list={['pm-swatch', { 'is-active': selectedInit[opt.name] === ov.name }]}
                            data-value={ov.name}
                            aria-label={ov.name}
                            title={ov.name}
                          >
                            <span style={`background:${swatchColor(ov)}`}></span>
                          </button>
                        ))}
                      </div>
                    </div>
                  ) : (
                    <div class="pm-variant" data-option={opt.name}>
                      <div class="pm-variant-head">
                        <span class="pm-variant-label">{opt.name}</span>
                        <span class="pm-variant-cur">Selected: <b data-cur={opt.name}>{selectedInit[opt.name]}</b></span>
                      </div>
                      <div class="pm-options" data-opts={opt.name}>
                        {opt.optionValues.map((ov) => (
                          <button class:list={['pm-option', { 'is-active': selectedInit[opt.name] === ov.name }]} data-value={ov.name}>
                            <span class="pm-option-name">{ov.name}</span>
                          </button>
                        ))}
                      </div>
                    </div>
                  ),
                )}

              {/* Buy */}
              <div class="pm-buy">
                <div class="pm-qty">
                  <button id="pmQtyDec" aria-label="Decrease quantity" disabled><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/></svg></button>
                  <input type="text" id="pmQty" value="1" inputmode="numeric" aria-label="Quantity">
                  <button id="pmQtyInc" aria-label="Increase quantity"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></button>
                </div>
                <button class="pm-addcart" id="pmAddCart" disabled={!dAvailable}>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                  <span id="pmAddLabel">Add to cart &mdash; <span id="pmAddTotal">{money(dPrice)}</span></span>
                </button>
              </div>
              <button class="pm-buynow" id="pmBuyNow" disabled={!dAvailable}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                Buy it now
              </button>

              <div class="pm-trust">
                <div class="pm-trust-item">
                  <span class="pm-trust-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7zM5.5 18.5a2.5 2.5 0 1 0 0-.01M18.5 18.5a2.5 2.5 0 1 0 0-.01"/></svg></span>
                  <span class="pm-trust-txt"><b>Fast shipping</b><span>Rates shown at checkout</span></span>
                </div>
                <div class="pm-trust-item">
                  <span class="pm-trust-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg></span>
                  <span class="pm-trust-txt"><b>2-year warranty</b><span>Plus optional protection</span></span>
                </div>
                <div class="pm-trust-item">
                  <span class="pm-trust-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg></span>
                  <span class="pm-trust-txt"><b>30-day returns</b><span>Free &amp; easy, no questions</span></span>
                </div>
                <div class="pm-trust-item">
                  <span class="pm-trust-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span>
                  <span class="pm-trust-txt"><b>Secure checkout</b><span>SSL encrypted payment</span></span>
                </div>
              </div>

              {/* Aligns well with (compact carousel) */}
              {alignsData.length > 0 && (
                <div class="pm-aligns">
                  <div class="pm-aligns-head">
                    <h3>Aligns well with</h3>
                    <div class="pm-aligns-nav">
                      <button class="pm-aligns-btn" id="pmAlignPrev" aria-label="Previous suggestion"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg></button>
                      <button class="pm-aligns-btn" id="pmAlignNext" aria-label="Next suggestion"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg></button>
                    </div>
                  </div>
                  <div class="pm-aligns-card" id="pmAlignCard"></div>
                </div>
              )}
            </div>
          </div>

          {/* DETAILS TABS */}
          <div class="pm-details" id="pmDetails">
            <div class="pm-tabs" role="tablist">
              <button class="pm-tab is-active" data-tab="overview" role="tab">Overview</button>
              <button class="pm-tab" data-tab="specs" role="tab">Specifications</button>
              <button class="pm-tab" data-tab="reviews" id="pmReviewsTab" role="tab">Reviews {reviewCount > 0 ? <span class="cnt">({reviewCount})</span> : null}</button>
              <button class="pm-tab" data-tab="shipping" role="tab">Shipping &amp; Returns</button>
            </div>

            {/* Overview */}
            <div class="pm-panel is-active" data-panel="overview">
              <div class="pm-ov">
                <div>
                  {product.descriptionHtml ? (
                    <div set:html={product.descriptionHtml} />
                  ) : (
                    <p class="pm-ov-lead">{product.description}</p>
                  )}
                </div>
                <div class="pm-feat-cards">
                  <div class="pm-feat-card">
                    <span class="pm-feat-card-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg></span>
                    <div><h4>Adaptive Hybrid ANC</h4><p>Six mics cancel up to 42dB and auto-tune to your surroundings.</p></div>
                  </div>
                  <div class="pm-feat-card">
                    <span class="pm-feat-card-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="6" width="18" height="12" rx="2"/><path d="M23 13v-2M19 10v4"/></svg></span>
                    <div><h4>60-Hour Battery</h4><p>A full week of listening; 5-min charge gives 5 hours.</p></div>
                  </div>
                  <div class="pm-feat-card">
                    <span class="pm-feat-card-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></span>
                    <div><h4>LDAC Hi-Res Audio</h4><p>Titanium drivers tuned for a wide, detailed soundstage.</p></div>
                  </div>
                </div>
              </div>
            </div>

            {/* Specs — real custom.specifications metafield when present, else the design's spec groups */}
            <div class="pm-panel" data-panel="specs">
              <div class="pm-specs">
                {metaSpecGroups.length > 0 ? (
                  metaSpecGroups.map((group, gi) => (
                    <div class="pm-spec-group">
                      <h4>{gi === 0 ? 'Specifications' : 'Details'}</h4>
                      <dl>
                        {group.map((row) => (
                          <div class="pm-spec-row"><dt>{row.label}</dt><dd>{row.value}</dd></div>
                        ))}
                      </dl>
                    </div>
                  ))
                ) : (
                  <>
                    <div class="pm-spec-group">
                      <h4>Audio</h4>
                      <dl>
                        <div class="pm-spec-row"><dt>Driver</dt><dd>40mm titanium-coated</dd></div>
                        <div class="pm-spec-row"><dt>Frequency response</dt><dd>4Hz &ndash; 40kHz</dd></div>
                        <div class="pm-spec-row"><dt>Impedance</dt><dd>32&Omega;</dd></div>
                        <div class="pm-spec-row"><dt>Codecs</dt><dd>LDAC, AAC, SBC</dd></div>
                      </dl>
                    </div>
                    <div class="pm-spec-group">
                      <h4>Noise Cancellation</h4>
                      <dl>
                        <div class="pm-spec-row"><dt>ANC depth</dt><dd>Up to 42dB</dd></div>
                        <div class="pm-spec-row"><dt>Microphones</dt><dd>6 (hybrid)</dd></div>
                        <div class="pm-spec-row"><dt>Modes</dt><dd>ANC / Transparency / Off</dd></div>
                        <div class="pm-spec-row"><dt>Wind reduction</dt><dd>Yes</dd></div>
                      </dl>
                    </div>
                    <div class="pm-spec-group">
                      <h4>Battery &amp; Charging</h4>
                      <dl>
                        <div class="pm-spec-row"><dt>Playback (ANC on)</dt><dd>60 hours</dd></div>
                        <div class="pm-spec-row"><dt>Fast charge</dt><dd>5 min = 5 hours</dd></div>
                        <div class="pm-spec-row"><dt>Charging</dt><dd>USB-C</dd></div>
                        <div class="pm-spec-row"><dt>Full charge</dt><dd>1.5 hours</dd></div>
                      </dl>
                    </div>
                    <div class="pm-spec-group">
                      <h4>Connectivity &amp; Build</h4>
                      <dl>
                        <div class="pm-spec-row"><dt>Bluetooth</dt><dd>5.3, multipoint</dd></div>
                        <div class="pm-spec-row"><dt>Range</dt><dd>Up to 10m</dd></div>
                        <div class="pm-spec-row"><dt>Weight</dt><dd>278g</dd></div>
                        <div class="pm-spec-row"><dt>In the box</dt><dd>Cable, 3.5mm, pouch</dd></div>
                      </dl>
                    </div>
                  </>
                )}
              </div>
            </div>

            {/* Reviews — entirely from real Shopify review metafields */}
            <div class="pm-panel" data-panel="reviews">
              {showReviews ? (
                <div class="pm-rev">
                  <div class="pm-rev-summary">
                    <div class="pm-rev-big">{ratingDisplay}</div>
                    <span class="pm-stars" aria-label={`${ratingDisplay} out of 5`}>
                      {Array.from({ length: 5 }).map((_, i) => (
                        <svg viewBox="0 0 24 24" fill="currentColor" style={i < ratingStars ? '' : 'opacity:.25'}><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                      ))}
                    </span>
                    <div class="pm-rev-count">{reviewCount > 0 ? `Based on ${reviewCount} review${reviewCount === 1 ? '' : 's'}` : 'Customer rating'}</div>
                    {distRows.length > 0 && (
                      <div class="pm-rev-bars">
                        {distRows.map((r) => (
                          <div class="pm-rev-bar"><span class="lbl">{r.star}&#9733;</span><span class="track"><span class="fill" style={`width:${r.pct}%`}></span></span><span class="pct">{r.pct}%</span></div>
                        ))}
                      </div>
                    )}
                    <button class="pm-rev-writebtn">Write a review</button>
                  </div>
                  <div class="pm-rev-list" id="pmRevList">
                    {hasReviews ? (
                      reviews.map((r, idx) => (
                        <div class="pm-rev-card">
                          <div class="pm-rev-card-top">
                            <span class="pm-rev-avatar" style={`background:${AVATAR_COLORS[idx % AVATAR_COLORS.length]};`}>{initialsOf(r.author)}</span>
                            <div class="pm-rev-who">
                              <div class="pm-rev-name">{r.author} <span class="pm-rev-verified"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>Verified buyer</span></div>
                              {r.date && <div class="pm-rev-date">{r.date}</div>}
                            </div>
                          </div>
                          <div class="pm-rev-card-stars"><span class="pm-stars" aria-label={`${r.rating} out of 5`}>
                            {Array.from({ length: 5 }).map((_, i) => (
                              <svg viewBox="0 0 24 24" fill="currentColor" style={i < Math.round(r.rating) ? '' : 'opacity:.25'}><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            ))}
                          </span></div>
                          {r.title && <h4 class="pm-rev-title">{r.title}</h4>}
                          {r.body && <p class="pm-rev-body">{r.body}</p>}
                        </div>
                      ))
                    ) : (
                      <div class="pm-rev-empty">
                        <p class="pm-ov-lead" style="margin:0 0 6px;">{reviewCount} verified {reviewCount === 1 ? 'rating' : 'ratings'} &middot; {ratingDisplay} average</p>
                        <p style="margin:0; color:var(--muted); font-family:var(--f-body); font-size:14px;">Written reviews appear here once a reviews app (e.g. Judge.me, Yotpo, Loox) is connected to this store.</p>
                      </div>
                    )}
                  </div>
                </div>
              ) : (
                <p class="pm-ov-lead">No reviews yet — be the first to review this product.</p>
              )}
            </div>

            {/* Shipping */}
            <div class="pm-panel" data-panel="shipping">
              <div class="pm-ship-grid">
                <div class="pm-ship-card">
                  <span class="pm-ship-card-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7zM5.5 18.5a2.5 2.5 0 1 0 0-.01M18.5 18.5a2.5 2.5 0 1 0 0-.01"/></svg></span>
                  <h4>Fast delivery</h4>
                  <p>Standard delivery in 5&ndash;7 business days, with express and overnight available at checkout. Shipping rates are calculated at checkout based on your address.</p>
                </div>
                <div class="pm-ship-card">
                  <span class="pm-ship-card-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg></span>
                  <h4>30-day easy returns</h4>
                  <p>Changed your mind? Return any unused item within 30 days for a full refund. We cover the return shipping &mdash; no questions asked.</p>
                </div>
                <div class="pm-ship-card">
                  <span class="pm-ship-card-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg></span>
                  <h4>2-year warranty</h4>
                  <p>Every order is covered by a 2-year manufacturer warranty. Add an Omnix Protection Plan for accidental damage and theft cover.</p>
                </div>
              </div>
            </div>
          </div>

          {/* Related */}
          {recommendations.length > 0 && (
            <section class="pm-related">
              <div class="pm-related-head">
                <h2>You may also like</h2>
                <p>More from {product.vendor ?? 'the store'} and the modern collection</p>
              </div>
              <div class="pm-related-grid" id="pmRelatedGrid">
                {recommendations.slice(0, 4).map((p) => <ProductCard product={p} />)}
              </div>
            </section>
          )}
        </div>

        {/* Sticky add bar */}
        <div class="pm-stickybar" id="pmStickyBar">
          <div class="pm-stickybar-inner">
            <div class="pm-sb-prod">
              <div class="pm-sb-thumb"><img src={firstImg} alt={product.title} loading="lazy" /></div>
              <div class="pm-sb-info">
                <div class="pm-sb-name">{product.title}</div>
                <div class="pm-sb-meta" id="pmSbMeta">{Object.values(selectedInit).join(' · ')}</div>
              </div>
            </div>
            <div class="pm-sb-price"><span id="pmSbPrice">{money(dPrice)}</span>{dOnSale && dCompare != null && <span class="was">{money(dCompare)}</span>}</div>
            <div class="pm-sb-actions">
              <div class="pm-qty">
                <button id="pmSbDec" aria-label="Decrease quantity" disabled><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/></svg></button>
                <input type="text" id="pmSbQty" value="1" inputmode="numeric" aria-label="Quantity">
                <button id="pmSbInc" aria-label="Increase quantity"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></button>
              </div>
              <button class="pm-addcart" id="pmSbAddCart" style="box-shadow:none;" disabled={!dAvailable}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                Add to cart
              </button>
            </div>
          </div>
        </div>
      </div>

      <script>
        import { addItem, buyNow, openCart } from '~/stores/cart';

        const root = document.getElementById('prodModern');
        const boot = document.getElementById('pmBoot');
        if (root && boot) {
          interface Pickup { name: string; time: string | null; }
          interface VData { id: string; opts: Record<string, string>; price: number; compareAt: number | null; available: boolean; qty: number | null; img: string | null; pickup: Pickup[]; }
          interface Align { name: string; img: string; price: number; was: number | null; href: string; }
          const data = JSON.parse(boot.textContent || '{}') as {
            currency: string; variants: VData[]; aligns: Align[]; singleVariant: boolean;
          };
          const $ = <T extends Element = HTMLElement>(s: string) => root.querySelector<T>(s);
          const $$ = <T extends Element = HTMLElement>(s: string) => Array.from(root.querySelectorAll<T>(s));

          const fmt0 = new Intl.NumberFormat('en-US', { style: 'currency', currency: data.currency, minimumFractionDigits: 0 });
          const fmt2 = new Intl.NumberFormat('en-US', { style: 'currency', currency: data.currency, minimumFractionDigits: 2 });
          const money = (n: number) => (Number.isInteger(n) ? fmt0 : fmt2).format(n);

          // ---- selection state ----
          const selected: Record<string, string> = {};
          const variants = data.variants;
          const base = variants.find((v) => v.available) ?? variants[0];
          if (base) Object.assign(selected, base.opts);
          let qty = 1;

          function currentVariant(): VData | undefined {
            if (data.singleVariant) return base;
            return variants.find((v) => Object.keys(selected).every((k) => v.opts[k] === selected[k]));
          }

          // ---- gallery ----
          const slides = $$('.pm-slide');
          const thumbs = $$('.pm-thumb');
          const stage = $('#pmStage');
          const total = slides.length;
          let cur = 0;
          function goTo(i: number) {
            if (!total) return;
            cur = (i + total) % total;
            slides.forEach((s) => s.classList.toggle('is-active', Number(s.dataset.idx) === cur));
            thumbs.forEach((t) => t.classList.toggle('is-active', Number(t.dataset.idx) === cur));
            const idxEl = $('#pmCurIdx'); if (idxEl) idxEl.textContent = String(cur + 1);
            stage?.classList.remove('is-zoom');
          }
          $('#pmThumbs')?.addEventListener('click', (e) => {
            const t = (e.target as HTMLElement).closest<HTMLElement>('.pm-thumb');
            if (t) goTo(Number(t.dataset.idx));
          });
          $('#pmPrev')?.addEventListener('click', () => goTo(cur - 1));
          $('#pmNext')?.addEventListener('click', () => goTo(cur + 1));
          $('#pmZoom')?.addEventListener('click', (e) => { e.stopPropagation(); stage?.classList.toggle('is-zoom'); });
          stage?.addEventListener('click', (e) => {
            if ((e.target as HTMLElement).closest('.pm-nav') || (e.target as HTMLElement).closest('.pm-tool')) return;
            stage.classList.toggle('is-zoom');
          });
          // ---- Share menu (Facebook / X / WhatsApp / Email / Copy link) ----
          const SHARE_ICONS: Record<string, string> = {
            facebook: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z"/></svg>',
            x: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.24 2.25h3.31l-7.23 8.26 8.5 11.24h-6.66l-5.21-6.82-5.97 6.82H1.68l7.73-8.84L1.25 2.25h6.83l4.71 6.23 5.45-6.23zm-1.16 17.52h1.83L7.08 4.13H5.12l11.96 15.64z"/></svg>',
            whatsapp: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M.06 24l1.69-6.16a11.87 11.87 0 0 1-1.59-5.95C.16 5.34 5.5 0 12.05 0a11.82 11.82 0 0 1 8.41 3.49 11.82 11.82 0 0 1 3.48 8.41c0 6.56-5.34 11.89-11.89 11.89a11.9 11.9 0 0 1-5.69-1.45L.06 24zm6.6-3.8c1.68.99 3.28 1.59 5.39 1.59 5.45 0 9.89-4.43 9.89-9.88a9.88 9.88 0 0 0-9.88-9.89c-5.45 0-9.89 4.43-9.89 9.88 0 2.22.65 3.88 1.51 5.26l-.99 3.65 3.97-1.04zm11.39-5.55c-.07-.12-.27-.2-.56-.34-.29-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.29-.77.96-.94 1.16-.17.2-.35.22-.64.07-.29-.15-1.25-.46-2.38-1.47-.88-.78-1.48-1.76-1.65-2.05-.17-.29-.02-.45.13-.6.13-.13.29-.34.44-.51.15-.17.2-.29.29-.49.1-.2.05-.37-.02-.51-.07-.15-.67-1.62-.92-2.21-.24-.58-.49-.5-.67-.51-.17-.01-.37-.01-.57-.01-.2 0-.52.07-.79.37-.27.29-1.04 1.01-1.04 2.48s1.06 2.88 1.21 3.08c.15.2 2.1 3.2 5.08 4.49.71.31 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.08 1.76-.72 2-1.41.25-.69.25-1.28.18-1.41z"/></svg>',
            email: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>',
            copy: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>',
          };
          // Share the canonical URL when present (the real public domain),
          // so links shared from a tunnel/preview host still point to prod.
          const shareUrl = () =>
            document.querySelector<HTMLLinkElement>('link[rel="canonical"]')?.href || location.href;
          let shareMenu: HTMLElement | null = null;
          function buildShareMenu(): HTMLElement | null {
            if (shareMenu || !stage) return shareMenu;
            const u = encodeURIComponent(shareUrl());
            const t = encodeURIComponent(document.title);
            const links: [string, string, string][] = [
              ['Facebook', 'facebook', `https://www.facebook.com/sharer/sharer.php?u=${u}`],
              ['X', 'x', `https://twitter.com/intent/tweet?url=${u}&text=${t}`],
              ['WhatsApp', 'whatsapp', `https://wa.me/?text=${t}%20${u}`],
              ['Email', 'email', `mailto:?subject=${t}&body=${u}`],
            ];
            shareMenu = document.createElement('div');
            shareMenu.className = 'pm-share-menu';
            shareMenu.setAttribute('role', 'menu');
            shareMenu.innerHTML =
              links
                .map(([label, icon, href]) =>
                  `<a class="pm-share-item" role="menuitem" href="${href}" target="_blank" rel="noopener noreferrer">${SHARE_ICONS[icon]}<span>${label}</span></a>`,
                )
                .join('') +
              `<button class="pm-share-item" type="button" role="menuitem" data-copy>${SHARE_ICONS.copy}<span>Copy link</span></button>`;
            // Keep clicks inside the menu from bubbling to the stage (which would zoom).
            shareMenu.addEventListener('click', (e) => e.stopPropagation());
            // Social links close the menu after opening their tab.
            shareMenu.querySelectorAll<HTMLElement>('a.pm-share-item').forEach((a) =>
              a.addEventListener('click', () => closeShareMenu()),
            );
            // Copy link → clipboard + inline "Copied!" confirmation (menu stays open).
            shareMenu.querySelector<HTMLElement>('[data-copy]')?.addEventListener('click', () => {
              navigator.clipboard?.writeText(shareUrl()).catch(() => {});
              const lbl = shareMenu!.querySelector<HTMLElement>('[data-copy] span');
              if (lbl) {
                lbl.textContent = 'Copied!';
                setTimeout(() => { lbl.textContent = 'Copy link'; }, 1300);
              }
            });
            stage.appendChild(shareMenu);
            return shareMenu;
          }
          const shareBtn = $('#pmShare');
          function closeShareMenu() {
            shareMenu?.classList.remove('is-show');
            shareBtn?.setAttribute('aria-expanded', 'false');
          }
          function toggleShareMenu() {
            const m = buildShareMenu();
            if (!m) return;
            if (m.classList.contains('is-show')) {
              closeShareMenu();
            } else {
              requestAnimationFrame(() => m.classList.add('is-show'));
              shareBtn?.setAttribute('aria-expanded', 'true');
            }
          }
          shareBtn?.setAttribute('aria-haspopup', 'true');
          shareBtn?.setAttribute('aria-expanded', 'false');
          shareBtn?.addEventListener('click', function (e: Event) {
            e.stopPropagation(); // never reach the stage zoom handler
            toggleShareMenu();
          });
          // Close on outside click or Esc.
          document.addEventListener('click', () => closeShareMenu());
          document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeShareMenu(); });
          document.addEventListener('keydown', (e) => {
            if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
            // Don't hijack arrows while typing in a field or while a modal/drawer
            // is open over the PDP.
            const ae = document.activeElement as HTMLElement | null;
            if (ae && /^(INPUT|TEXTAREA|SELECT)$/.test(ae.tagName)) return;
            if (document.querySelector('.qv-overlay.is-open, .cart-drawer.is-open, .search-overlay.is-open')) return;
            if (e.key === 'ArrowLeft') goTo(cur - 1);
            else goTo(cur + 1);
          });

          // ---- price / variant render ----
          // Grey out option values that can't combine with the current selection
          // (so an impossible combo like Red+XL can't be reached by clicking).
          function updateOptionStates() {
            if (data.singleVariant) return;
            $$('[data-opts]').forEach((group) => {
              const name = (group as HTMLElement).dataset.opts || '';
              group.querySelectorAll<HTMLElement>('.pm-option, .pm-swatch').forEach((btn) => {
                const trial = { ...selected, [name]: btn.dataset.value || '' };
                const ok = variants.some(
                  (v) => v.available && Object.keys(trial).every((k) => v.opts[k] === trial[k]),
                );
                btn.classList.toggle('is-unavailable', !ok);
              });
            });
          }

          function render() {
            const v = currentVariant();
            // Impossible combination → no variant. Show an explicit unavailable
            // state instead of silently falling back to a different variant's price.
            const invalidCombo = !v && !data.singleVariant;
            const price = v ? v.price : base?.price ?? 0;
            const compare = v ? v.compareAt : base?.compareAt ?? null;
            const onSale = !invalidCombo && compare != null && compare > price;
            const available = v?.available ?? false;

            const set = (sel: string, txt: string) => { const el = $(sel); if (el) el.textContent = txt; };
            set('#pmPrice', invalidCombo ? 'Unavailable' : money(price));
            set('#pmInstall', money(price / 4));
            set('#pmAddTotal', money(price * qty));
            set('#pmSbPrice', money(price));

            const was = $('#pmWas'); if (was) { was.textContent = compare != null ? money(compare) : ''; was.style.display = onSale ? '' : 'none'; }
            const save = $('#pmSave'); if (save) { save.textContent = onSale && compare != null ? `Save ${money(compare - price)}` : ''; save.style.display = onSale ? '' : 'none'; }
            const sbWas = $('.pm-sb-price .was'); if (sbWas) { sbWas.textContent = compare != null ? money(compare) : ''; sbWas.style.display = onSale ? '' : 'none'; }

            const meta = $('#pmSbMeta'); if (meta) meta.textContent = Object.values(selected).join(' · ');
            const stock = $('#pmStockBadge');
            if (stock) {
              const q = v?.qty ?? null;
              const label = !available
                ? 'Currently out of stock'
                : q != null && q > 0 && q <= 10
                  ? `Only ${q} left — order soon`
                  : 'In stock — ships today';
              stock.innerHTML = `<span class="pm-stock-dot"></span>${label}`;
            }

            const addLabel = $('#pmAddLabel');
            if (addLabel) addLabel.innerHTML = available ? `Add to cart &mdash; <span id="pmAddTotal">${money(price * qty)}</span>` : 'Sold out';
            [$('#pmAddCart'), $('#pmBuyNow'), $('#pmSbAddCart')].forEach((b) => {
              if (b) (b as HTMLButtonElement).disabled = !available;
            });

            // switch gallery to the variant image if it maps to a slide.
            // Compare without query params so a CDN transform/version diff
            // (?v=…, ?width=…) doesn't defeat the match.
            if (v?.img) {
              const bare = (u?: string | null) => (u ? u.split('?')[0] : '');
              const target = bare(v.img);
              const idx = slides.findIndex((s) => bare(s.querySelector('img')?.getAttribute('src')) === target);
              if (idx >= 0 && idx !== cur) goTo(idx);
            }

            updateOptionStates();
            renderPickup(v);
          }

          // option selection (button groups + colour swatches)
          $$('[data-opts]').forEach((group) => {
            const name = (group as HTMLElement).dataset.opts || '';
            group.addEventListener('click', (e) => {
              const btn = (e.target as HTMLElement).closest<HTMLElement>('.pm-option, .pm-swatch');
              if (!btn) return;
              selected[name] = btn.dataset.value || '';
              group.querySelectorAll('.pm-option, .pm-swatch').forEach((o) => o.classList.remove('is-active'));
              btn.classList.add('is-active');
              const cur = root!.querySelector(`[data-cur="${name}"]`);
              if (cur) cur.textContent = selected[name];
              render();
            });
          });

          // ---- qty (main + sticky synced) ----
          function setQty(v: number) {
            qty = Math.max(1, Math.min(99, Math.floor(v) || 1));
            ['#pmQty', '#pmSbQty'].forEach((s) => { const el = $<HTMLInputElement>(s); if (el) el.value = String(qty); });
            ['#pmQtyDec', '#pmSbDec'].forEach((s) => { const el = $<HTMLButtonElement>(s); if (el) el.disabled = qty <= 1; });
            render();
          }
          $('#pmQtyInc')?.addEventListener('click', () => setQty(qty + 1));
          $('#pmQtyDec')?.addEventListener('click', () => setQty(qty - 1));
          $('#pmSbInc')?.addEventListener('click', () => setQty(qty + 1));
          $('#pmSbDec')?.addEventListener('click', () => setQty(qty - 1));
          $<HTMLInputElement>('#pmQty')?.addEventListener('change', function () { setQty(Number(this.value)); });
          $<HTMLInputElement>('#pmSbQty')?.addEventListener('change', function () { setQty(Number(this.value)); });

          // ---- add to cart / buy now (shared nanostore cart) ----
          async function doAdd(btn: HTMLButtonElement | null) {
            const v = currentVariant();
            if (!v || !v.available) return;
            if (btn) { btn.disabled = true; btn.dataset.label = btn.dataset.label || btn.innerHTML; }
            await addItem(v.id, qty);
            openCart();
            if (btn) {
              btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Added';
              setTimeout(() => { btn.innerHTML = btn.dataset.label || 'Add to cart'; btn.disabled = false; render(); }, 1400);
            }
          }
          $<HTMLButtonElement>('#pmAddCart')?.addEventListener('click', function () { doAdd(this); });
          $<HTMLButtonElement>('#pmSbAddCart')?.addEventListener('click', function () { doAdd(this); });
          $<HTMLButtonElement>('#pmBuyNow')?.addEventListener('click', async () => {
            const v = currentVariant();
            if (v && v.available) await buyNow(v.id, qty);
          });

          // wishlist: handled globally by Overlays.astro via [data-wish] —
          // it toggles localStorage, the header badge, and the .is-active state.

          // ---- tabs ----
          function activateTab(name: string) {
            $$('.pm-tab').forEach((t) => t.classList.toggle('is-active', (t as HTMLElement).dataset.tab === name));
            $$('.pm-panel').forEach((p) => p.classList.toggle('is-active', (p as HTMLElement).dataset.panel === name));
          }
          $('.pm-tabs')?.addEventListener('click', (e) => {
            const t = (e.target as HTMLElement).closest<HTMLElement>('.pm-tab');
            if (t) activateTab(t.dataset.tab || 'overview');
          });
          $$('[data-gototab]').forEach((a) =>
            a.addEventListener('click', (e) => {
              e.preventDefault();
              activateTab((a as HTMLElement).dataset.gototab || 'overview');
              document.getElementById('pmDetails')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }),
          );

          // ---- aligns-well carousel (real recommendations) ----
          const aligns = data.aligns;
          const alignCard = $('#pmAlignCard');
          let alignIdx = 0;
          function renderAlign() {
            if (!alignCard || !aligns.length) return;
            const p = aligns[alignIdx];
            const was = p.was != null ? `<span class="was">${money(p.was)}</span>` : '';
            alignCard.innerHTML = `<span class="pm-aligns-thumb"><img src="${p.img}" alt="${p.name}"></span><span class="pm-aligns-meta"><span class="pm-aligns-name">${p.name}</span><span class="pm-aligns-price"><span class="now">${money(p.price)}</span>${was}</span></span><a href="${p.href}" class="pm-aligns-view">View</a>`;
          }
          function stepAlign(dir: number) {
            if (!alignCard || !aligns.length) return;
            alignCard.classList.add('is-fading');
            setTimeout(() => {
              alignIdx = (alignIdx + dir + aligns.length) % aligns.length;
              renderAlign();
              alignCard.classList.remove('is-fading');
            }, 180);
          }
          $('#pmAlignPrev')?.addEventListener('click', () => stepAlign(-1));
          $('#pmAlignNext')?.addEventListener('click', () => stepAlign(1));

          // ---- sticky bar visibility ----
          const bar = document.getElementById('pmStickyBar');
          const buyRow = $('.pm-buy');
          if ('IntersectionObserver' in window && buyRow && bar) {
            const io = new IntersectionObserver((entries) => {
              entries.forEach((en) => bar.classList.toggle('is-visible', !en.isIntersecting && en.boundingClientRect.top < 0));
            }, { threshold: 0 });
            io.observe(buyRow);
          }

          // ---- pickup: REAL Shopify Local Pickup per selected variant ----
          // Locations come from storeAvailability; "Check other stores" cycles
          // the real list. Block hides when the chosen variant has no pickup.
          const pickupBlock = $('#pmPickup');
          let pickupStores: Pickup[] = [];
          let pickupIdx = 0;
          function showPickupStore() {
            const s = pickupStores[pickupIdx];
            if (!s) return;
            const nameEl = $('#pmPickupStore'); if (nameEl) nameEl.textContent = s.name;
            const timeEl = $('#pmPickupTime'); if (timeEl) timeEl.textContent = s.time || 'Ready soon';
          }
          function renderPickup(v: VData | undefined) {
            if (!pickupBlock) return;
            pickupStores = (v?.available ? v.pickup : []) ?? [];
            pickupIdx = 0;
            if (!pickupStores.length) { pickupBlock.style.display = 'none'; return; }
            pickupBlock.style.display = '';
            showPickupStore();
            // Show "· Check other stores" only when there's more than one location.
            const more = $('#pmPickupMore');
            if (more) more.style.display = pickupStores.length > 1 ? '' : 'none';
          }
          $('#pmPickupCheck')?.addEventListener('click', () => {
            if (pickupStores.length < 2) return;
            pickupIdx = (pickupIdx + 1) % pickupStores.length;
            showPickupStore();
          });

          // init
          setQty(1);
          render();
          renderAlign();
        }
      </script>
    </Layout>
  ) : (
    <Layout title={loadFailed ? 'Something went wrong' : 'Product not found'} description="This product isn’t available." noindex>
      <div class="pm-main">
        <div class="pm-wrap" style="text-align:center; padding:120px 0;">
          <p class="pm-brand" style="color:var(--electric);">{loadFailed ? 'Error 503' : 'Error 404'}</p>
          <h1 class="pm-title" style="margin-top:12px;">
            {loadFailed ? 'Something went wrong' : 'Product not found'}
          </h1>
          <p style="margin-top:12px; color:var(--text-soft); font-family:var(--f-body);">
            {
              loadFailed
                ? "We couldn't load this product right now. Please try again shortly."
                : "We couldn't find that product."
            }
          </p>
          <a href="/products" class="pm-buynow" style="display:inline-flex; width:auto; margin-top:24px; text-decoration:none;">
            Shop all products
          </a>
        </div>
      </div>
    </Layout>
  )
}
