                </div>
              </div>

              {/* Materials & Care */}
              <div class="pm-acc-item">
                <div class="pm-acc-hd" data-acc>
                  <span class="pm-acc-title">Materials &amp; Care</span>
                  <svg class="pm-acc-icon" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="9" y1="3" x2="9" y2="15"/><line x1="3" y1="9" x2="15" y2="9"/></svg>
                </div>
                <div class="pm-acc-body">
                  <ul>
                    {materialsCare.map((m) => <li>{m}</li>)}
                  </ul>
                </div>
              </div>

              {/* Shipping & Returns */}
              <div class="pm-acc-item">
                <div class="pm-acc-hd" data-acc>
                  <span class="pm-acc-title">Shipping &amp; Returns</span>
                  <svg class="pm-acc-icon" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="9" y1="3" x2="9" y2="15"/><line x1="3" y1="9" x2="15" y2="9"/></svg>
                </div>
                <div class="pm-acc-body">
                  <ul>
                    {shippingReturns.map((s) => <li>{s}</li>)}
                  </ul>
                </div>
              </div>

              {/* Customer Reviews — real Shopify rating/distribution/reviews */}
              <div class:list={['pm-acc-item', { 'is-open': showReviews }]} id="pmReviewsAcc">
                <div class="pm-acc-hd" data-acc>
                  <span class="pm-acc-title">Customer Reviews{reviewCount > 0 ? ` (${reviewCount})` : ''}</span>
                  <svg class="pm-acc-icon" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="9" y1="3" x2="9" y2="15"/><line x1="3" y1="9" x2="15" y2="9"/></svg>
                </div>
                <div class="pm-acc-body">
                  {showReviews ? (
                    <>
                      <div class="pm-rsum">
                        <div class="pm-rbig">
                          <div class="pm-rscore">{ratingDisplay}</div>
                          <div class="pm-rstars-big" aria-label={`${ratingDisplay} out of 5`}>
                            {Array.from({ length: 5 }).map((_, i) => (
                              <svg viewBox="0 0 24 24" fill="currentColor" style={i < ratingStars ? '' : 'opacity:.3'}><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            ))}
                          </div>
                          <div class="pm-rct-big">{reviewCount > 0 ? `${reviewCount} review${reviewCount === 1 ? '' : 's'}` : 'Customer rating'}</div>
                        </div>
                        {distRows.length > 0 && (
                          <div class="pm-rbars">
                            {distRows.map((r) => (
                              <div class="pm-rbar"><span class="pm-rbar-lbl">{r.star}★</span><div class="pm-rbar-track"><div class="pm-rbar-fill" style={`width:${r.pct}%`}></div></div><span class="pm-rbar-pct">{r.pct}%</span></div>
                            ))}
                          </div>
                        )}
                      </div>
                      {hasReviews ? (
                        <div class="pm-rlist">
                          {reviews.map((r) => (
                            <div class="pm-rev2">
                              <div class="pm-rev2-stars" aria-label={`${r.rating} out of 5`}>
                                {Array.from({ length: 5 }).map((_, i) => (
                                  <svg viewBox="0 0 24 24" fill="currentColor" style={i < Math.round(r.rating) ? '' : 'opacity:.3'}><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                ))}
                              </div>
                              <div class="pm-rev2-hd">
                                <span class="pm-rev2-name">{r.author}</span>
                                {r.date && <span class="pm-rev2-date">{r.date}</span>}
                              </div>
                              {r.title && <h4 class="pm-rev2-title">{r.title}</h4>}
                              {r.body && <p class="pm-rev2-text">{r.body}</p>}
                              {r.verified && <div class="pm-rev2-verified"><svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>Verified Purchase</div>}
                            </div>
                          ))}
                        </div>
                      ) : (
                        <p class="pm-acc-note">{reviewCount} verified {reviewCount === 1 ? 'rating' : 'ratings'} &middot; {ratingDisplay} average. No written reviews for this product yet.</p>
                      )}
                    </>
                  ) : (
                    <p class="pm-acc-note">No reviews yet — be the first to review this product.</p>
                  )}

                  {/* Write a review — submits to Judge.me via /api/reviews (server-side, private token stays server-only) */}
                  <div class="pm-rf-block">
                    <button type="button" class="pm-rf-toggle" id="pmRfToggle">Write a review</button>
                    <form class="pm-rf" id="pmReviewForm" novalidate>
                      <div class="pm-rf-field">
                        <span class="pm-rf-label">Your rating</span>
                        <div class="pm-rf-stars" id="pmRfStars" role="radiogroup" aria-label="Rating">
                          {[1, 2, 3, 4, 5].map((n) => (
                            <button type="button" class="pm-rf-star" data-star={n} role="radio" aria-checked="false" aria-label={`${n} star${n === 1 ? '' : 's'}`}>
                              <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            </button>
                          ))}
                        </div>
                      </div>
                      <div class="pm-rf-row">
                        <div class="pm-rf-field">
                          <label class="pm-rf-label" for="pmRfName">Name</label>
                          <input class="pm-rf-input" id="pmRfName" name="name" type="text" required maxlength="120" autocomplete="name" />
                        </div>
                        <div class="pm-rf-field">
                          <label class="pm-rf-label" for="pmRfEmail">Email</label>
                          <input class="pm-rf-input" id="pmRfEmail" name="email" type="email" required autocomplete="email" />
                        </div>
                      </div>
                      <div class="pm-rf-field">
                        <label class="pm-rf-label" for="pmRfTitle">Title <span class="pm-rf-optional">(optional)</span></label>
                        <input class="pm-rf-input" id="pmRfTitle" name="title" type="text" maxlength="120" />
                      </div>
                      <div class="pm-rf-field">
                        <label class="pm-rf-label" for="pmRfBody">Review</label>
                        <textarea class="pm-rf-input pm-rf-textarea" id="pmRfBody" name="body" required maxlength="5000" rows="4"></textarea>
                      </div>
                      <p class="pm-rf-msg" id="pmRfMsg" role="status" aria-live="polite"></p>
                      <button type="submit" class="pm-rf-submit" id="pmRfSubmit">Submit review</button>
                    </form>
                  </div>
                </div>
              </div>
            </div>

            {/* Right: specs + returns sidebar */}
            <aside class="pm-dx-side">
              {sidebarSpecs.length > 0 && (
                <div class="pm-dcard">
                  <div class="pm-dcard-hd">Product Specs</div>
                  <div class="pm-dcard-body">
                    {sidebarSpecs.map((row) => (
                      <div class="pm-dspec"><span class="pm-dspec-key">{row.label}</span><span class="pm-dspec-val">{row.value}</span></div>
                    ))}
                  </div>
                </div>
              )}
              <div class="pm-dcard">
                <div class="pm-dcard-hd">Returns Policy</div>
                <div class="pm-dcard-body">
                  <div class="pm-dret-list">
                    {returnsPolicy.map((t) => (
                      <div class="pm-dret-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>{t}</div>
                    ))}
                  </div>
                </div>
              </div>
            </aside>
          </div>

          {/* Related */}
          {recommendations.length > 0 && (
            <section class="pm-related">
              <div class="pm-related-head">
                <h2>You may also like</h2>
                <p>More from {product.vendor ?? 'the store'} and the modern collection</p>
              </div>
              <div class="pm-related-grid" id="pmRelatedGrid">
                {recommendations.slice(0, 4).map((p) => <ProductCard product={p} />)}
              </div>
            </section>
          )}
        </div>

        {/* Sticky add bar */}
        <div class="pm-stickybar" id="pmStickyBar">
          <div class="pm-stickybar-inner">
            <div class="pm-sb-prod">
              <div class="pm-sb-thumb"><img src={firstImg} alt={product.title} loading="lazy" /></div>
              <div class="pm-sb-info">
                <div class="pm-sb-name">{product.title}</div>
                <div class="pm-sb-meta" id="pmSbMeta">{Object.values(selectedInit).join(' · ')}</div>
              </div>
            </div>
            <div class="pm-sb-price"><span id="pmSbPrice">{money(dPrice)}</span>{dOnSale && dCompare != null && <span class="was">{money(dCompare)}</span>}</div>
            <div class="pm-sb-actions">
              <div class="pm-qty">
                <button id="pmSbDec" aria-label="Decrease quantity" disabled><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/></svg></button>
                <input type="text" id="pmSbQty" value="1" inputmode="numeric" aria-label="Quantity">
                <button id="pmSbInc" aria-label="Increase quantity"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></button>
              </div>
              <button class="pm-addcart" id="pmSbAddCart" style="box-shadow:none;" disabled={!dAvailable}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                Add to cart
              </button>
            </div>
          </div>
        </div>
      </div>

      {/* Newsletter CTA (overlaps the footer) — bg synced to the section above */}
      <Newsletter surface="var(--bg)" />

      {/* Size Guide modal — only for products with a real size option */}
      {hasSizeOption && (
        <div class="pm-sg-overlay" id="pmSizeGuide">
          <div class="pm-sg-modal" role="dialog" aria-modal="true" aria-labelledby="pmSgTitle">
            <div class="pm-sg-hd">
              <h3 id="pmSgTitle">Size Guide</h3>
              <button class="pm-sg-close" id="pmSgClose" type="button" aria-label="Close size guide">✕</button>
            </div>
            <p class="pm-sg-note">
              {sizeChart?.note ?? 'All measurements in centimeters. For a relaxed fit, choose your usual size.'}
            </p>
            {sizeChart ? (
              <table class="pm-sg-table">
                <thead>
                  <tr>{sizeChart.columns.map((col) => <th>{col}</th>)}</tr>
                </thead>
                <tbody>
                  {sizeChart.rows.map((row) => (
                    <tr>{sizeChart!.columns.map((col) => <td>{row[col] ?? ''}</td>)}</tr>
                  ))}
                </tbody>
              </table>
            ) : (
              <table class="pm-sg-table">
                <thead>
                  <tr><th>Size</th><th>Bust</th><th>Waist</th><th>Hip</th><th>Shoulder</th></tr>
                </thead>
                <tbody>
                  <tr><td>XS</td><td>82–86</td><td>64–68</td><td>88–92</td><td>38</td></tr>
                  <tr><td>S</td><td>86–90</td><td>68–72</td><td>92–96</td><td>39.5</td></tr>
                  <tr><td>M</td><td>90–94</td><td>72–76</td><td>96–100</td><td>41</td></tr>
                  <tr><td>L</td><td>94–98</td><td>76–80</td><td>100–104</td><td>42.5</td></tr>
                  <tr><td>XL</td><td>98–104</td><td>80–86</td><td>104–110</td><td>44</td></tr>
                  <tr><td>XXL</td><td>104–110</td><td>86–92</td><td>110–116</td><td>46</td></tr>
                </tbody>
              </table>
            )}
          </div>
        </div>
      )}

      <script>
        import { addItem, buyNow, openCart } from '~/stores/cart';

        const root = document.getElementById('prodModern');
        const boot = document.getElementById('pmBoot');
        if (root && boot) {
          interface Pickup { name: string; time: string | null; }
          interface VData { id: string; opts: Record<string, string>; price: number; compareAt: number | null; available: boolean; qty: number | null; img: string | null; pickup: Pickup[]; }
          const data = JSON.parse(boot.textContent || '{}') as {
            currency: string; variants: VData[]; singleVariant: boolean; productId: string; deliveryEstimateDays: number;
          };
          const $ = <T extends Element = HTMLElement>(s: string) => root.querySelector<T>(s);
          const $$ = <T extends Element = HTMLElement>(s: string) => Array.from(root.querySelectorAll<T>(s));

          const fmt0 = new Intl.NumberFormat('en-US', { style: 'currency', currency: data.currency, minimumFractionDigits: 0 });
          const fmt2 = new Intl.NumberFormat('en-US', { style: 'currency', currency: data.currency, minimumFractionDigits: 2 });
          const money = (n: number) => (Number.isInteger(n) ? fmt0 : fmt2).format(n);

          // ---- selection state ----
          const selected: Record<string, string> = {};
          const variants = data.variants;
          const base = variants.find((v) => v.available) ?? variants[0];
          if (base) Object.assign(selected, base.opts);
          let qty = 1;

          function currentVariant(): VData | undefined {
            if (data.singleVariant) return base;
            return variants.find((v) => Object.keys(selected).every((k) => v.opts[k] === selected[k]));
          }

          // ---- gallery ----
          const slides = $$('.pm-slide');
          const thumbs = $$('.pm-thumb');
          const total = slides.length;
          let cur = 0;
          let zoomActive = false;
          function goTo(i: number) {
            if (!total) return;
            cur = (i + total) % total;
            slides.forEach((s) => s.classList.toggle('is-active', Number(s.dataset.idx) === cur));
            thumbs.forEach((t) => t.classList.toggle('is-active', Number(t.dataset.idx) === cur));
            const idxEl = $('#pmCurIdx'); if (idxEl) idxEl.textContent = String(cur + 1);
            // Reset any hover-zoom transform when the slide changes.
            zoomActive = false;
            slides.forEach((s) => {
              const im = s.querySelector<HTMLImageElement>('img');
              if (im) { im.style.transition = ''; im.style.transform = ''; im.style.transformOrigin = 'center center'; }
            });
          }
          $('#pmThumbs')?.addEventListener('click', (e) => {
            const t = (e.target as HTMLElement).closest<HTMLElement>('.pm-thumb');
            if (t) goTo(Number(t.dataset.idx));
          });
          $('#pmPrev')?.addEventListener('click', () => goTo(cur - 1));
          $('#pmNext')?.addEventListener('click', () => goTo(cur + 1));

          // ---- Cursor-follow hover zoom on the active slide (ported from HTML) ----
          const stageEl = $('#pmStage');
          const ZOOM = 2.2;
          const activeImg = () => stageEl?.querySelector<HTMLImageElement>('.pm-slide.is-active img') ?? null;
          function zoomOrigin(e: MouseEvent) {
            if (!stageEl) return;
            const r = stageEl.getBoundingClientRect();
            const x = (((e.clientX - r.left) / r.width) * 100).toFixed(2);
            const y = (((e.clientY - r.top) / r.height) * 100).toFixed(2);
            const img = activeImg();
            if (img) img.style.transformOrigin = `${x}% ${y}%`;
          }
          stageEl?.addEventListener('mouseenter', (e) => {
            const img = activeImg();
            if (!img) return;
            zoomActive = true;
            zoomOrigin(e as MouseEvent);
            img.style.transition = 'transform .35s cubic-bezier(.25,.46,.45,.94)';
            img.style.transform = `scale(${ZOOM})`;
            // After the zoom-in settles, drop the transition so origin tracks the cursor with no lag.
            setTimeout(() => { if (zoomActive) img.style.transition = 'none'; }, 360);
          });
          stageEl?.addEventListener('mousemove', (e) => {
            if (!zoomActive) return;
            zoomOrigin(e as MouseEvent);
            const img = activeImg();
            if (img) img.style.transform = `scale(${ZOOM})`;
          });
          stageEl?.addEventListener('mouseleave', () => {
            zoomActive = false;
            const img = activeImg();
            if (!img) return;
            img.style.transition = 'transform .3s cubic-bezier(.25,.46,.45,.94)';
            img.style.transform = 'scale(1)';
            img.style.transformOrigin = 'center center';
          });
          document.addEventListener('keydown', (e) => {
            if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
            // Don't hijack arrows while typing in a field or while a modal/drawer
            // is open over the PDP.
            const ae = document.activeElement as HTMLElement | null;
            if (ae && /^(INPUT|TEXTAREA|SELECT)$/.test(ae.tagName)) return;
            if (document.querySelector('.qv-overlay.is-open, .cart-drawer.is-open, .search-overlay.is-open')) return;
            if (e.key === 'ArrowLeft') goTo(cur - 1);
            else goTo(cur + 1);
          });

          // ---- price / variant render ----
          // Grey out option values that can't combine with the current selection
          // (so an impossible combo like Red+XL can't be reached by clicking).
          function updateOptionStates() {
            if (data.singleVariant) return;
            $$('[data-opts]').forEach((group) => {
              const name = (group as HTMLElement).dataset.opts || '';
              group.querySelectorAll<HTMLElement>('.pm-option, .pm-swatch').forEach((btn) => {
                const trial = { ...selected, [name]: btn.dataset.value || '' };
                const ok = variants.some(
                  (v) => v.available && Object.keys(trial).every((k) => v.opts[k] === trial[k]),
                );
                btn.classList.toggle('is-unavailable', !ok);
              });
            });
          }

          function render() {
            const v = currentVariant();
            // Impossible combination → no variant. Show an explicit unavailable
            // state instead of silently falling back to a different variant's price.
            const invalidCombo = !v && !data.singleVariant;
            const price = v ? v.price : base?.price ?? 0;
            const compare = v ? v.compareAt : base?.compareAt ?? null;
            const onSale = !invalidCombo && compare != null && compare > price;
            const available = v?.available ?? false;

            const set = (sel: string, txt: string) => { const el = $(sel); if (el) el.textContent = txt; };
            set('#pmPrice', invalidCombo ? 'Unavailable' : money(price));
            set('#pmSbPrice', money(price));

            const was = $('#pmWas'); if (was) { was.textContent = compare != null ? money(compare) : ''; was.style.display = onSale ? '' : 'none'; }
            const save = $('#pmSave'); if (save) { const pct = onSale && compare ? Math.round(((compare - price) / compare) * 100) : 0; save.textContent = pct > 0 ? `Save ${pct}%` : ''; save.style.display = onSale ? '' : 'none'; }
            const sbWas = $('.pm-sb-price .was'); if (sbWas) { sbWas.textContent = compare != null ? money(compare) : ''; sbWas.style.display = onSale ? '' : 'none'; }

            const meta = $('#pmSbMeta'); if (meta) meta.textContent = Object.values(selected).join(' · ');
            const stock = $('#pmStockBadge');
            if (stock) {
              const q = v?.qty ?? null;
              const label = !available
                ? 'Currently out of stock'
                : q != null && q > 0 && q <= 10
                  ? `Only ${q} left — order soon`
                  : 'In stock — ships today';
              stock.innerHTML = `<span class="pm-stock-dot"></span>${label}`;
            }

            const addLabel = $('#pmAddLabel');
            if (addLabel) addLabel.textContent = available ? 'Add to Bag' : 'Sold out';
            [$('#pmAddCart'), $('#pmBuyNow'), $('#pmSbAddCart')].forEach((b) => {
              if (b) (b as HTMLButtonElement).disabled = !available;
            });

            // switch gallery to the variant image if it maps to a slide.
            // Compare without query params so a CDN transform/version diff
            // (?v=…, ?width=…) doesn't defeat the match.
            if (v?.img) {
              const bare = (u?: string | null) => (u ? u.split('?')[0] : '');
              const target = bare(v.img);
              const idx = slides.findIndex((s) => bare(s.querySelector('img')?.getAttribute('src')) === target);
              if (idx >= 0 && idx !== cur) goTo(idx);
            }

            updateOptionStates();
            renderPickup(v);
          }

          // option selection (button groups + colour swatches)
          $$('[data-opts]').forEach((group) => {
            const name = (group as HTMLElement).dataset.opts || '';
            group.addEventListener('click', (e) => {
              const btn = (e.target as HTMLElement).closest<HTMLElement>('.pm-option, .pm-swatch');
              if (!btn) return;
              selected[name] = btn.dataset.value || '';
              group.querySelectorAll('.pm-option, .pm-swatch').forEach((o) => o.classList.remove('is-active'));
              btn.classList.add('is-active');
              const cur = root!.querySelector(`[data-cur="${name}"]`);
              if (cur) cur.textContent = selected[name];
              render();
            });
          });

          // ---- qty (main + sticky synced) ----
          function setQty(v: number) {
            qty = Math.max(1, Math.min(99, Math.floor(v) || 1));
            ['#pmQty', '#pmSbQty'].forEach((s) => { const el = $<HTMLInputElement>(s); if (el) el.value = String(qty); });
            ['#pmQtyDec', '#pmSbDec'].forEach((s) => { const el = $<HTMLButtonElement>(s); if (el) el.disabled = qty <= 1; });
            render();
          }
          $('#pmQtyInc')?.addEventListener('click', () => setQty(qty + 1));
          $('#pmQtyDec')?.addEventListener('click', () => setQty(qty - 1));
          $('#pmSbInc')?.addEventListener('click', () => setQty(qty + 1));
          $('#pmSbDec')?.addEventListener('click', () => setQty(qty - 1));
          $<HTMLInputElement>('#pmQty')?.addEventListener('change', function () { setQty(Number(this.value)); });
          $<HTMLInputElement>('#pmSbQty')?.addEventListener('change', function () { setQty(Number(this.value)); });

          // ---- add to cart / buy now (shared nanostore cart) ----
          async function doAdd(btn: HTMLButtonElement | null) {
            const v = currentVariant();
            if (!v || !v.available) return;
            if (btn) { btn.disabled = true; btn.dataset.label = btn.dataset.label || btn.innerHTML; }
            // addItem swallows its own errors and returns { cart }; treat a null
            // cart as failure so we never show "Added" or leave the button stuck.
            const res = await addItem(v.id, qty);
            if (!res.cart) {
              if (btn) { btn.innerHTML = btn.dataset.label || 'Add to cart'; btn.disabled = false; }
              return;
            }
            openCart();
            if (btn) {
              btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Added';
              setTimeout(() => { btn.innerHTML = btn.dataset.label || 'Add to cart'; btn.disabled = false; render(); }, 1400);
            }
          }
          $<HTMLButtonElement>('#pmAddCart')?.addEventListener('click', function () { doAdd(this); });
          $<HTMLButtonElement>('#pmSbAddCart')?.addEventListener('click', function () { doAdd(this); });
          $<HTMLButtonElement>('#pmBuyNow')?.addEventListener('click', async () => {
            const v = currentVariant();
            if (v && v.available) await buyNow(v.id, qty);
          });

          // wishlist: handled globally by Overlays.astro via [data-wish] —
          // it toggles localStorage, the header badge, and the .is-active state.

          // ---- details accordions ----
          $$('.pm-acc-hd').forEach((hd) =>
            hd.addEventListener('click', () => hd.closest('.pm-acc-item')?.classList.toggle('is-open')),
          );
          // "N reviews" link in the rating row → open + scroll to the reviews accordion.
          $$('[data-gototab]').forEach((a) =>
            a.addEventListener('click', (e) => {
              e.preventDefault();
              const acc = document.getElementById('pmReviewsAcc');
              acc?.classList.add('is-open');
              acc?.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }),
          );

          // ---- sticky bar visibility ----
          const bar = document.getElementById('pmStickyBar');
          const buyRow = $('.pm-buyrow');
          if ('IntersectionObserver' in window && buyRow && bar) {
            const io = new IntersectionObserver((entries) => {
              entries.forEach((en) => bar.classList.toggle('is-visible', !en.isIntersecting && en.boundingClientRect.top < 0));
            }, { threshold: 0 });
            io.observe(buyRow);
          }

          // ---- pickup: REAL Shopify Local Pickup per selected variant ----
          // Locations come from storeAvailability; "Check other stores" cycles
          // the real list. Block hides when the chosen variant has no pickup.
          const pickupBlock = $('#pmPickup');
          let pickupStores: Pickup[] = [];
          let pickupIdx = 0;
          function showPickupStore() {
            const s = pickupStores[pickupIdx];
            if (!s) return;
            const nameEl = $('#pmPickupStore'); if (nameEl) nameEl.textContent = s.name;
            const timeEl = $('#pmPickupTime'); if (timeEl) timeEl.textContent = s.time || 'Ready soon';
          }
          function renderPickup(v: VData | undefined) {
            if (!pickupBlock) return;
            pickupStores = (v?.available ? v.pickup : []) ?? [];
            pickupIdx = 0;
            if (!pickupStores.length) { pickupBlock.style.display = 'none'; return; }
            pickupBlock.style.display = '';
            showPickupStore();
            // Show "· Check other stores" only when there's more than one location.
            const more = $('#pmPickupMore');
            if (more) more.style.display = pickupStores.length > 1 ? '' : 'none';
          }
          $('#pmPickupCheck')?.addEventListener('click', () => {
            if (pickupStores.length < 2) return;
            pickupIdx = (pickupIdx + 1) % pickupStores.length;
            showPickupStore();
          });

          // ---- Size Guide modal ----
          // The overlay/modal render OUTSIDE #prodModern, so query the document
          // (root-scoped `$` would return null and the button would do nothing).
          const sgOverlay = document.getElementById('pmSizeGuide');
          const openSizeGuide = () => sgOverlay?.classList.add('is-open');
          const closeSizeGuide = () => sgOverlay?.classList.remove('is-open');
          $('#pmSizeGuideBtn')?.addEventListener('click', openSizeGuide);
          document.getElementById('pmSgClose')?.addEventListener('click', closeSizeGuide);
          sgOverlay?.addEventListener('click', (e) => { if (e.target === sgOverlay) closeSizeGuide(); });
          document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeSizeGuide(); });

          // ---- Delivery estimate (real date, computed fresh client-side) ----
          const ddEl = $('#pmDeliveryDate');
          if (ddEl) {
            const d = new Date(Date.now() + data.deliveryEstimateDays * 86400000);
            ddEl.textContent = d.toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' });
          }

          // ---- Share: copy link ----
          $('#pmShareCopy')?.addEventListener('click', () => {
            const url = document.querySelector<HTMLLinkElement>('link[rel="canonical"]')?.href || location.href;
            navigator.clipboard?.writeText(url).catch(() => {});
            const btn = $('#pmShareCopy');
            btn?.classList.add('is-copied');
            setTimeout(() => btn?.classList.remove('is-copied'), 1300);
          });

          // ---- Write a review — posts to /api/reviews (server proxies to Judge.me) ----
          const rfBlock = $('#pmReviewForm')?.closest<HTMLElement>('.pm-rf-block');
          const rfToggle = $<HTMLButtonElement>('#pmRfToggle');
          const rfForm = $<HTMLFormElement>('#pmReviewForm');
          const rfStars = $$('#pmRfStars .pm-rf-star');
          const rfMsg = $('#pmRfMsg');
          const rfSubmit = $<HTMLButtonElement>('#pmRfSubmit');
          let rfRating = 0;

          rfToggle?.addEventListener('click', () => rfBlock?.classList.toggle('is-open'));

          function setRfRating(n: number) {
            rfRating = n;
            rfStars.forEach((s) => {
              const on = Number(s.dataset.star) <= n;
              s.classList.toggle('is-active', on);
              s.setAttribute('aria-checked', String(Number(s.dataset.star) === n));
            });
          }
          rfStars.forEach((s) => s.addEventListener('click', () => setRfRating(Number(s.dataset.star))));

          rfForm?.addEventListener('submit', async (e) => {
            e.preventDefault();
            if (!rfMsg) return;
            rfMsg.textContent = '';
            rfMsg.classList.remove('is-error', 'is-ok');

            const name = $<HTMLInputElement>('#pmRfName')?.value.trim() ?? '';
            const email = $<HTMLInputElement>('#pmRfEmail')?.value.trim() ?? '';
            const title = $<HTMLInputElement>('#pmRfTitle')?.value.trim() ?? '';
            const body = $<HTMLTextAreaElement>('#pmRfBody')?.value.trim() ?? '';

            if (!rfRating) { rfMsg.textContent = 'Please select a rating.'; rfMsg.classList.add('is-error'); return; }
            if (!name || !email || !body) { rfMsg.textContent = 'Name, email and review are required.'; rfMsg.classList.add('is-error'); return; }

            if (rfSubmit) rfSubmit.disabled = true;
            try {
              const res = await fetch('/api/reviews', {
                method: 'POST',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({ productId: data.productId, rating: rfRating, name, email, title, body }),
              });
              const json = await res.json().catch(() => ({ ok: false, error: 'Could not submit your review.' }));
              if (!res.ok || !json.ok) throw new Error(json.error || 'Could not submit your review.');

              rfMsg.textContent = 'Thanks! Your review has been submitted and will appear once approved.';
              rfMsg.classList.add('is-ok');
              rfForm.reset();
              setRfRating(0);
              setTimeout(() => rfBlock?.classList.remove('is-open'), 2200);
            } catch (err) {
              rfMsg.textContent = err instanceof Error ? err.message : 'Could not submit your review.';
              rfMsg.classList.add('is-error');
            } finally {
              if (rfSubmit) rfSubmit.disabled = false;
            }
          });

          // init
          setQty(1);
          render();
        }
      </script>
    </Layout>
  ) : (
    <Layout title={loadFailed ? 'Something went wrong' : 'Product not found'} description="This product isn’t available." noindex>
      <div class="pm-main">
        <div class="pm-wrap" style="text-align:center; padding:120px 0;">
          <p class="pm-brand">{loadFailed ? 'Error 503' : 'Error 404'}</p>
          <h1 class="pm-title" style="margin-top:12px;">
            {loadFailed ? 'Something went wrong' : 'Product not found'}
          </h1>
          <p style="margin-top:12px; color:var(--muted); font-family:var(--fb);">
            {
              loadFailed
                ? "We couldn't load this product right now. Please try again shortly."
                : "We couldn't find that product."
            }
          </p>
          <a href="/products" class="pm-buynow" style="display:inline-flex; width:auto; margin-top:24px; text-decoration:none;">
            Shop all products
          </a>
        </div>
      </div>
    </Layout>
  )
}
