---
// ============================================================
//  Layout — Marvexa html shell. Loads the design system (plain CSS),
//  Plus Jakarta Sans + Inter fonts, SEO <head>, and the vanilla chrome
//  (announcement, header, footer, cart drawer, mobile nav).
// ============================================================
import '~/styles/marvexa.css';
import '~/styles/drawers.css';
import { BRAND } from '~/config/marvexa';
import SEO from '~/components/seo/SEO.astro';
import Announcement from '~/components/layout/marvexa/Announcement.astro';
import Header from '~/components/layout/marvexa/Header.astro';
import Footer from '~/components/layout/marvexa/Footer.astro';
import CartDrawer from '~/components/layout/marvexa/CartDrawer.astro';
import Overlays from '~/components/layout/marvexa/Overlays.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noFooter?: boolean;
  /** Transparent-over-hero header. Set true ONLY on pages with a dark
      full-bleed hero behind the header (e.g. the homepage). Defaults to a
      solid header so inner pages don't show white text on a light bg. */
  transparentHeader?: boolean;
}

const { title, description, image, type, noindex, jsonLd, noFooter = false, transparentHeader = false } = Astro.props;

// Site-wide JSON-LD: Organization + WebSite (merged with any page blocks).
// Only include `sameAs` profiles that point at a real account (a path beyond
// the bare domain). Placeholder homepages like "https://instagram.com" would
// emit invalid/misleading structured data, so they're dropped.
const sameAs = [BRAND.social.instagram, BRAND.social.twitter, BRAND.social.youtube].filter((href) => {
  try {
    return new URL(href).pathname.replace(/\/+$/, '') !== '';
  } catch {
    return false;
  }
});
const baseJsonLd: Record<string, unknown>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: BRAND.legalName,
    url: Astro.site?.href ?? Astro.url.origin,
    ...(sameAs.length > 0 ? { sameAs } : {}),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: BRAND.name,
    url: Astro.site?.href ?? Astro.url.origin,
  },
];
const pageJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const allJsonLd = [...baseJsonLd, ...pageJsonLd];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    {/* Warm the Shopify image CDN early so product images aren't gated on a
        cold connection (helps LCP on product grids/PDP). */}
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin />

    {/* Fonts — Plus Jakarta Sans (headings) · Inter (body), matching the Marvexa template */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap"
    />

    <SEO {title} {description} {image} {type} {noindex} jsonLd={allJsonLd} />
  </head>

  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    <Announcement />
    <Header solid={!transparentHeader} />

    <main id="main">
      <slot />
    </main>

    {!noFooter && <Footer />}

    {/* Global cart drawer (nanostore-driven) + secondary overlays */}
    <CartDrawer />
    <Overlays />

    {/* Reveal-on-scroll: adds .on to any .rv element as it enters view. */}
    <script>
      const els = document.querySelectorAll('.rv');
      if (!('IntersectionObserver' in window) || matchMedia('(prefers-reduced-motion: reduce)').matches) {
        els.forEach((el) => el.classList.add('on'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('on');
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.05 },
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
