---
// ============================================================
//  PostCard — OMNIX `.blog-card` for a blog post, linking to the
//  post detail page (/blog/<id>). Reused by the journal index,
//  author pages, and "related posts". Mirrors the home BlogTeasers.
// ============================================================
import { Image } from 'astro:assets';
import { getEntry, type CollectionEntry } from 'astro:content';
import { resolveImage } from '~/lib/asset';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { title, image, excerpt, tags, date, readingTime } = post.data;
const href = `/blog/${post.id}`;
const author = post.data.author ? await getEntry('authors', post.data.author) : undefined;
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' });
---

<article class="blog-card">
  <a href={href} class="blog-media">
    <Image src={resolveImage(image)} alt={title} width={560} height={360} />
  </a>
  <div class="blog-body">
    <div class="blog-date">
      <span class="blog-date-txt">
        {fmt(date)}
        {readingTime && <>&nbsp;·&nbsp; {readingTime}</>}
      </span>
      {author && (
        <a class="blog-author" href={`/blog/author/${post.data.author}`}>{author.data.name}</a>
      )}
    </div>
    <h4><a href={href}>{title}</a></h4>
    <p>{excerpt}</p>
    {tags.length > 0 && (
      <div class="blog-tags">
        {tags.map((t) => <span class="blog-tag">{t}</span>)}
      </div>
    )}
  </div>
</article>

<style is:global>
  .blog-card h4 a { color: inherit; }
  /* Date row: date on the left, author right-aligned. */
  .blog-card .blog-date {
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
  }
  .blog-card .blog-date-txt { white-space: nowrap; }
  .blog-card .blog-author {
    font-weight: 600; color: var(--text); white-space: nowrap;
    overflow: hidden; text-overflow: ellipsis;
  }
  .blog-card .blog-author:hover { color: var(--electric); }
</style>
