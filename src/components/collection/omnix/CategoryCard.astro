---
// ============================================================
//  CategoryCard (OMNIX `.cat-card`) — one Shopify collection as a
//  lifestyle category tile. Reused by the category grid.
// ============================================================
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Icon from '~/components/ui/omnix/Icon.astro';

interface Props {
  title: string;
  href: string;
  /** Remote Shopify URL or local ImageMetadata (fallback art). */
  image?: string | ImageMetadata | null;
  count?: number | null;
  /** Append "+" when the real count exceeds the fetched cap. */
  countPlus?: boolean;
  eager?: boolean;
}
const { title, href, image, count, countPlus = false, eager = false } = Astro.props;
const isRemote = typeof image === 'string';
---

<a href={href} class="cat-card">
  <div class="cat-img">
    {
      image &&
        (isRemote ? (
          <Image src={image as string} alt={title} width={480} height={360} loading={eager ? 'eager' : 'lazy'} />
        ) : (
          <Image src={image as ImageMetadata} alt={title} width={480} height={360} loading={eager ? 'eager' : 'lazy'} />
        ))
    }
  </div>
  <div class="cat-body">
    <div class="cat-label">
      <div>
        <h6>{title}</h6>
        {count != null && <span>{count}{countPlus ? '+' : ''} products</span>}
      </div>
    </div>
    <div class="cat-shop"><Icon name="arrow-right" size={13} stroke={2.5} /></div>
  </div>
</a>
