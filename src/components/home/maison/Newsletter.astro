---
---

<section class="newsletter" aria-labelledby="nl-h">
  <div class="wrap">
    <div class="nl-card rv">

      <!-- Left: copy -->
      <div class="nl-card__left">
        <div class="nl-card__eyebrow">Newsletter</div>
        <h2 class="nl-card__heading" id="nl-h">The Season's Best,<br>Delivered Weekly.</h2>
        <p class="nl-card__sub">Early access to new arrivals, exclusive styling edits, and member-only offers — every
          week.</p>
      </div>

      <!-- Right: form -->
      <div class="nl-card__right">
        <form class="nl-form" novalidate>
          <div class="nl-field">
            <input type="email" class="nl-input" placeholder="Your email address" required autocomplete="email"
              aria-label="Email address" />
          </div>
          <button type="submit" class="nl-btn">
            Subscribe Now
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </button>
          <p class="nl-fine">No spam. Unsubscribe anytime. &nbsp;<a href="#">Privacy Policy</a>.</p>
        </form>
      </div>

    </div>
  </div>
</section>

<style>
  .newsletter {
    background: var(--bg2);
    padding: 140px 0 0;
  }

  .nl-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 64px 80px;
    box-shadow: 0 20px 64px rgba(0, 0, 0, 0.07), 0 4px 16px rgba(0, 0, 0, 0.04);
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 80px;
    align-items: center;
    position: relative;
    z-index: 10;
    margin-bottom: -120px;
  }

  .nl-card__left {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .nl-card__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--fb);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
  }

  .nl-card__eyebrow::before {
    content: '';
    display: block;
    width: 18px;
    height: 1px;
    background: var(--accent);
  }

  .nl-card__heading {
    font-family: var(--fh);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -2px;
    color: var(--text);
    margin: 0 0 16px;
  }

  .nl-card__sub {
    font-family: var(--fb);
    font-size: 15px;
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
    max-width: 380px;
  }

  /* Right: form */
  .nl-card__right {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .nl-field {
    margin-bottom: 10px;
  }

  .nl-input {
    width: 100%;
    padding: 15px 18px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 4px;
    font-family: var(--fb);
    font-size: 14px;
    color: var(--text);
    outline: none;
    transition: border-color 0.22s, background 0.22s;
    box-sizing: border-box;
  }

  .nl-input::placeholder {
    color: #aaa;
  }

  .nl-input:focus {
    border-color: var(--accent);
    background: #fff;
  }

  .nl-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    background: var(--text);
    color: #fff;
    font-family: var(--fb);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    padding: 15px 24px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    margin-bottom: 14px;
    transition: background 0.2s, transform 0.15s;
  }

  .nl-btn:hover {
    background: var(--accent);
  }

  .nl-btn:active {
    transform: scale(0.98);
  }

  .nl-fine {
    font-family: var(--fb);
    font-size: 11px;
    color: #aaa;
    line-height: 1.5;
    text-align: center;
  }

  .nl-fine a {
    color: var(--muted);
    text-decoration: underline;
  }

  @media (max-width: 900px) {
    .nl-card {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 48px 40px 52px;
      margin-bottom: -100px;
    }

    .nl-card__sub {
      max-width: 100%;
    }
  }

  @media (max-width: 600px) {
    .newsletter {
      padding: 72px 0 0;
    }

    .nl-card {
      border-radius: 14px;
      padding: 40px 28px 44px;
      margin-bottom: -80px;
    }
  }

  @media (max-width: 980px) {
    .newsletter__inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 40px;
    }
  }

  @media (max-width: 768px) {
    .newsletter__inner {
      gap: 32px;
    }
  }
</style>

<script>
  (() => {
    const form = document.querySelector<HTMLFormElement>('.nl-form');
    if (!form) return;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const btn = form.querySelector<HTMLButtonElement>('button[type=submit]');
      const inp = form.querySelector<HTMLInputElement>('input');
      if (!btn || !inp) return;

      btn.textContent = "✓ You're subscribed!";
      btn.style.background = '#617230';
      inp.value = '';
      inp.placeholder = 'Thanks for joining!';

      setTimeout(() => {
        btn.textContent = 'Subscribe';
        btn.style.background = '';
        inp.placeholder = 'Your email address';
      }, 5000);
    });
  })();
</script>
