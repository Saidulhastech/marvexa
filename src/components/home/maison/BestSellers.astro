---
import { formatMoney } from '~/lib/money';
import type { ProductCard as TProductCard } from '~/lib/shopify/types';

interface Props {
  products: TProductCard[];
}

const { products } = Astro.props;
const top = products.slice(0, 3);

// Static design values from the template (Shopify has no ratings).
const RATINGS = ['4.9', '4.8', '4.9'];
const SOLD = ['1,847 sold', '1,240 sold', '2,153 sold'];
---

<section class="bestsellers" aria-labelledby="bs-h">
  <div class="wrap">

    <!-- Header -->
    <div class="bs-head rv">
      <div class="bs-head__left">
        <div class="bs-head__eyebrow">Most Loved</div>
        <h2 class="bs-head__title" id="bs-h">Best Sellers</h2>
      </div>
      <div class="bs-head__right">
        <a href="/products" class="btn btn-outline">View All <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg></a>
      </div>
    </div>

    <!-- 3-card grid -->
    <div class="bs-grid">
      {top.map((p, i) => (
        <div class={`pc rv${i > 0 ? ' d1' : ''}`}>
          <div class="pc__wrap">
            <a href={`/products/${p.handle}`}>
              <img
                src={p.featuredImage?.url}
                alt={p.featuredImage?.altText ?? p.title} class="pc__img" loading="lazy" />
            </a>
            <span class="bs-rank">{`#0${i + 1}`}</span>

            <button class="pc__wish" aria-label="Add to wishlist" onclick="toggleWish(this)"><svg width="14" height="14"
                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path
                  d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
              </svg></button>
            <div class="pc__icons">
              <button class="pc__icon-btn" data-tip="Compare" aria-label="Compare"><svg width="14" height="14"
                  viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                  <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                  <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
                </svg></button>
              <button class="pc__icon-btn" data-tip="Quick View" aria-label="Quick View"><svg width="14" height="14"
                  viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                  <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" />
                  <circle cx="12" cy="12" r="3" />
                </svg></button>
            </div>
            <button class="pc__add">Add to Cart</button>
          </div>
          <div class="pc__info">
            <div class="bs-rating">
              <div class="bs-stars"><svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
                  <path
                    d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg><svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
                  <path
                    d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg><svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
                  <path
                    d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg><svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
                  <path
                    d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg><svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
                  <path
                    d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg></div>
              <span class="bs-rating-num">{RATINGS[i]}</span>
              <span class="bs-sold">· {SOLD[i]}</span>
            </div>
            <a href={`/products/${p.handle}`} class="pc__name">{p.title}</a>
            <div class="pc__foot">
              <span class="pc__price">{formatMoney(p.priceRange.minVariantPrice)}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Trust proof cards -->
    <div class="bs-proof rv">
      <div class="bs-proof__item">
        <svg class="bs-proof__icon" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
        </svg>
        <span class="bs-proof__stat">4.8 / 5</span>
        <span class="bs-proof__label">Average rating across 12,000+ verified reviews</span>
      </div>
      <div class="bs-proof__item">
        <svg class="bs-proof__icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="1.7" stroke-linecap="round">
          <path d="M1 3h15v13H1z" />
          <path d="M16 8h4l3 3v5h-7V8z" />
          <circle cx="5.5" cy="18.5" r="2.5" />
          <circle cx="18.5" cy="18.5" r="2.5" />
        </svg>
        <span class="bs-proof__stat">Free Shipping</span>
        <span class="bs-proof__label">On all orders over $150. Delivered in 2–4 days</span>
      </div>
      <div class="bs-proof__item">
        <svg class="bs-proof__icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="1.7" stroke-linecap="round">
          <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
          <path d="M3 3v5h5" />
        </svg>
        <span class="bs-proof__stat">30-Day Returns</span>
        <span class="bs-proof__label">No questions asked. Free returns on every order</span>
      </div>
      <div class="bs-proof__item">
        <svg class="bs-proof__icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="1.7" stroke-linecap="round">
          <rect x="3" y="11" width="18" height="11" rx="2" />
          <path d="M7 11V7a5 5 0 0 1 10 0v4" />
        </svg>
        <span class="bs-proof__stat">Secure Checkout</span>
        <span class="bs-proof__label">SSL encrypted. Your data is always protected</span>
      </div>
    </div>

  </div>
</section>

<style>
  .bestsellers {
    padding: 120px 0 110px;
    background: var(--bg);
  }

  /* ── Header ── */
  .bs-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 52px;
  }

  .bs-head__left {
    flex: 1;
    min-width: 0;
  }

  .bs-head__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--fb);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
  }

  .bs-head__eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .bs-head__title {
    font-family: var(--fh);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -2px;
    line-height: 1;
    margin: 0;
  }

  .bs-head__right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 16px;
    flex-shrink: 0;
    padding-bottom: 4px;
  }

  .bs-head__sub {
    font-family: var(--fb);
    font-size: 14px;
    line-height: 1.65;
    color: var(--muted);
    max-width: 250px;
    text-align: right;
  }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--fb);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 13px 28px;
    transition: background var(--ease), color var(--ease), border-color var(--ease), transform .12s ease;
    cursor: pointer;
  }

  .btn:active {
    transform: scale(.97)
  }

  .btn-outline {
    background: transparent;
    color: var(--text);
    border: 1.5px solid var(--text)
  }

  .btn-outline:hover {
    background: var(--text);
    color: var(--white)
  }

  /* ── 3-column even grid ── */
  .bs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* Rank badge */
  .bs-rank {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 4;
    font-family: var(--fh);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: .3px;
    color: var(--text);
    background: rgba(255, 255, 255, .92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, .45);
    border-radius: 3px;
    padding: 3px 9px;
    line-height: 1.5;
  }

  /* Push product badges below rank badge so they don't overlap */
  .bestsellers .pc__badges {
    top: 46px;
  }

  /* Rating row */
  .bs-rating {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 6px;
  }

  .bs-stars {
    display: flex;
    align-items: center;
    gap: 1.5px;
    color: #C8A75E;
  }

  .bs-rating-num {
    font-family: var(--fb);
    font-size: 11px;
    font-weight: 700;
    color: var(--text);
  }

  .bs-sold {
    font-family: var(--fb);
    font-size: 11px;
    color: var(--muted);
  }

  /* ── Trust / Proof strip ── */
  .bs-proof {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    margin-top: 52px;
  }

  .bs-proof__item {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 24px 22px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 4px;
    transition: border-color .2s ease, box-shadow .2s ease;
  }

  .bs-proof__item:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 20px rgba(0, 0, 0, .06);
  }

  .bs-proof__icon {
    color: var(--accent);
    flex-shrink: 0;
  }

  .bs-proof__stat {
    font-family: var(--fh);
    font-size: 22px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -.5px;
    line-height: 1;
  }

  .bs-proof__label {
    font-family: var(--fb);
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
    letter-spacing: .1px;
  }

  /* ════════════════════════════════
     PRODUCT CARD — shared structure
  ════════════════════════════════ */
  .pc {
    position: relative;
  }

  .pc__wrap {
    position: relative;
    overflow: hidden;
    background: var(--card);
    border-radius: 3px;
  }

  .pc__img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: top;
    display: block;
    transition: transform .65s cubic-bezier(.25, .46, .45, .94);
  }

  .pc:hover .pc__img {
    transform: scale(1.06);
  }

  /* ── Badges — glass on solid ───── */
  .pc__badges {
    position: absolute;
    top: 12px;
    left: 12px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    z-index: 3;
  }

  .badge {
    display: inline-block;
    padding: 4px 10px;
    font-family: var(--fb);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.1px;
    text-transform: uppercase;
    border-radius: 3px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .badge-s {
    background: rgba(180, 87, 63, .86);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, .2);
  }

  /* ── Wishlist — glass circle, always visible ── */
  .pc__wish {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 4;
    width: 34px;
    height: 34px;
    background: rgba(255, 255, 255, .88);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, .55);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background .2s ease, transform .2s ease;
    box-shadow: 0 2px 10px rgba(0, 0, 0, .1);
  }

  .pc__wish:hover {
    background: #fff;
    transform: scale(1.08);
  }

  .pc__wish svg {
    transition: fill .22s ease, stroke .22s ease;
  }

  .pc__wish.active svg {
    fill: var(--rust);
    stroke: var(--rust);
  }

  /* ── Icon actions — Compare + Quick View ── */
  .pc__icons {
    position: absolute;
    top: 54px;
    right: 12px;
    z-index: 4;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .pc__icon-btn {
    width: 34px;
    height: 34px;
    background: rgba(255, 255, 255, .88);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, .55);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transform: translateX(10px);
    transition: opacity .25s ease, transform .28s cubic-bezier(.25, .46, .45, .94), background .18s ease;
    box-shadow: 0 2px 10px rgba(0, 0, 0, .1);
    position: relative;
  }

  .pc__icon-btn:nth-child(1) {
    transition-delay: 0s;
  }

  .pc__icon-btn:nth-child(2) {
    transition-delay: .07s;
  }

  .pc:hover .pc__icon-btn {
    opacity: 1;
    transform: translateX(0);
  }

  .pc__icon-btn:hover {
    background: #fff;
    transform: translateX(0) scale(1.09) !important;
  }

  .pc__icon-btn::after {
    content: attr(data-tip);
    position: absolute;
    right: calc(100% + 8px);
    top: 50%;
    transform: translateY(-50%);
    background: var(--dark);
    color: #fff;
    font-family: var(--fb);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: .4px;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 4px 8px;
    border-radius: 3px;
    opacity: 0;
    pointer-events: none;
    transition: opacity .15s ease;
  }

  .pc__icon-btn:hover::after {
    opacity: 1;
  }

  /* ── Quick Add — slides up from bottom ── */
  .pc__add {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 14px 12px;
    background: var(--dark);
    color: var(--white);
    font-family: var(--fb);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    opacity: 0;
    transform: translateY(100%);
    transition: opacity .26s ease, transform .3s cubic-bezier(.25, .46, .45, .94), background .2s ease;
    z-index: 3;
    text-align: center;
  }

  .pc:hover .pc__add {
    opacity: 1;
    transform: translateY(0);
  }

  .pc__add:hover {
    background: var(--accent);
  }

  /* ════════════════════════════════
     PRODUCT CARD — INFO AREA
  ════════════════════════════════ */
  .pc__info {
    padding: 14px 0 4px;
  }

  /* Product name — full line */
  .pc__name {
    font-family: var(--fh);
    font-size: 15px;
    font-weight: 600;
    line-height: 1.25;
    color: var(--text);
    letter-spacing: -.3px;
    margin: 0 0 10px;
    display: block;
    text-decoration: none;
  }

  /* Price + Swatches — one row */
  .pc__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .pc__price {
    font-family: var(--fb);
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
    letter-spacing: -.1px;
  }

  .pc__price s {
    color: var(--muted);
    font-weight: 400;
    font-size: 11px;
    margin-right: 3px;
  }

  .pc__price--sale {
    color: var(--rust);
  }

  @media (max-width: 1100px) {
    .bs-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .bs-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .bs-grid > .pc:nth-child(1),
    .bs-grid > .pc:nth-child(2),
    .bs-grid > .pc:nth-child(3) {
      grid-column: span 1;
    }

    .bs-head__sub {
      text-align: left;
      max-width: 100%;
    }

    .bs-proof {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
