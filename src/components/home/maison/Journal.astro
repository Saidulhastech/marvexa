---
---

<section class="blog" aria-labelledby="blog-h">
  <div class="wrap">
    <div class="bs-head rv">
      <div class="bs-head__left">
        <div class="bs-head__eyebrow">The MAISON Journal</div>
        <h2 class="bs-head__title" id="blog-h">Style &amp; Stories</h2>
      </div>
      <div class="bs-head__right">
        <a href="/blog" class="btn btn-outline">
          All Articles
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>
    </div>
    <div class="blog-grid">
      <article class="blog-card">
        <div class="blog-card__img-wrap">
          <img
            src="https://images.unsplash.com/photo-1559697242-cacab5d5b62c?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
            alt="Wardrobe guide" class="blog-card__img" loading="lazy" />
          <div class="blog-card__img-overlay"></div>
          <span class="blog-card__tag">Style Guide</span>
        </div>
        <div class="blog-card__body">
          <div class="blog-card__meta">
            <span class="blog-card__date">May 8, 2026</span>
            <span class="blog-card__meta-dot"></span>
            <span class="blog-card__read-time">6 min read</span>
          </div>
          <h3 class="blog-card__title">How to Build a Wardrobe That Works All Year Round</h3>
          <p class="blog-card__exc">The 12 essential pieces that form the foundation of a truly versatile wardrobe —
            plus tips on mixing and layering effortlessly.</p>
          <div class="blog-card__footer">
            <div class="blog-card__author">
              <div class="blog-card__av">E</div>
              <span class="blog-card__author-name">Emma Laurent</span>
            </div>
            <a href="/blog" class="blog-card__link">Read
              <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round">
                <path d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </article>
      <article class="blog-card">
        <div class="blog-card__img-wrap">
          <img
            src="https://images.unsplash.com/photo-1559127452-cb4ef7888fa1?q=80&w=2069&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
            alt="Premium knitwear care" class="blog-card__img" loading="lazy" />
          <div class="blog-card__img-overlay"></div>
          <span class="blog-card__tag">Care Guide</span>
        </div>
        <div class="blog-card__body">
          <div class="blog-card__meta">
            <span class="blog-card__date">April 22, 2026</span>
            <span class="blog-card__meta-dot"></span>
            <span class="blog-card__read-time">4 min read</span>
          </div>
          <h3 class="blog-card__title">The Proper Way to Care for Premium Knitwear</h3>
          <p class="blog-card__exc">Your wool and cashmere pieces deserve the best care. Keep them looking exceptional
            for years with our expert guide.</p>
          <div class="blog-card__footer">
            <div class="blog-card__author">
              <div class="blog-card__av">T</div>
              <span class="blog-card__author-name">Tom Sinclair</span>
            </div>
            <a href="/blog" class="blog-card__link">Read
              <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round">
                <path d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </article>
      <article class="blog-card">
        <div class="blog-card__img-wrap">
          <img
            src="https://images.unsplash.com/photo-1562592282-9dd0ca7d71ac?q=80&w=2101&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
            alt="SS 2026 collection story" class="blog-card__img" loading="lazy" />
          <div class="blog-card__img-overlay"></div>
          <span class="blog-card__tag">Brand Story</span>
        </div>
        <div class="blog-card__body">
          <div class="blog-card__meta">
            <span class="blog-card__date">April 10, 2026</span>
            <span class="blog-card__meta-dot"></span>
            <span class="blog-card__read-time">5 min read</span>
          </div>
          <h3 class="blog-card__title">Behind the Collection: The Inspiration for SS 2026</h3>
          <p class="blog-card__exc">A conversation with our creative team about the ideas and materials that shaped
            this season's defining looks.</p>
          <div class="blog-card__footer">
            <div class="blog-card__author">
              <div class="blog-card__av">A</div>
              <span class="blog-card__author-name">Arya Nakamura</span>
            </div>
            <a href="/blog" class="blog-card__link">Read
              <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round">
                <path d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .wrap {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--fb);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 13px 28px;
    transition: background var(--ease), color var(--ease), border-color var(--ease), transform .12s ease;
    cursor: pointer;
  }

  .btn:active {
    transform: scale(.97)
  }

  .btn-outline {
    background: transparent;
    color: var(--text);
    border: 1.5px solid var(--text)
  }

  .btn-outline:hover {
    background: var(--text);
    color: var(--white)
  }

  .rv {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity .6s ease, transform .6s ease
  }

  .rv.on {
    opacity: 1;
    transform: translateY(0)
  }

  .bs-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 52px;
  }

  .bs-head__left {
    flex: 1;
    min-width: 0;
  }

  .bs-head__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--fb);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
  }

  .bs-head__eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .bs-head__title {
    font-family: var(--fh);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -2px;
    line-height: 1;
    margin: 0;
  }

  .bs-head__right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 16px;
    flex-shrink: 0;
    padding-bottom: 4px;
  }

  .blog {
    padding-top: 120px;
    background: var(--bg2);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .blog-card {
    cursor: pointer;
    border-radius: 14px;
    overflow: hidden;
    background: var(--white);
    border-top: 2px solid transparent;
    box-shadow: 0 0 0 1px var(--border);
    display: flex;
    flex-direction: column;
    transition: box-shadow .3s ease, transform .3s ease, border-top-color .3s ease;
  }

  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 28px rgba(0, 0, 0, .08), 0 0 0 1px var(--border);
    border-top-color: var(--accent);
  }

  .blog-card__img-wrap {
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
  }

  .blog-card__img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
    transition: transform .5s cubic-bezier(.25, .46, .45, .94);
  }

  .blog-card:hover .blog-card__img {
    transform: scale(1.06);
  }

  .blog-card__img-overlay {
    position: absolute;
    inset: 0;
    background: rgba(17, 17, 17, 0);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .3s ease;
  }

  .blog-card:hover .blog-card__img-overlay {
    background: rgba(17, 17, 17, .18);
  }

  .blog-card__body {
    padding: 20px 22px 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0;
  }

  .blog-card__tag {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--accent);
    color: var(--white);
    padding: 4px 11px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    border-radius: 100px;
  }

  .blog-card__meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
    margin-top: 0;
  }

  .blog-card__date {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .5px;
    text-transform: uppercase;
    color: var(--muted);
  }

  .blog-card__meta-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--border);
    flex-shrink: 0;
  }

  .blog-card__read-time {
    font-size: 10px;
    color: var(--muted);
  }

  .blog-card__title {
    font-family: var(--fh);
    font-size: 17px;
    font-weight: 700;
    line-height: 1.32;
    letter-spacing: -.3px;
    margin-bottom: 10px;
    color: var(--text);
    transition: color var(--ease);
  }

  .blog-card:hover .blog-card__title {
    color: var(--accent);
  }

  .blog-card__exc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.62;
    margin-bottom: 20px;
    flex: 1;
  }

  .blog-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 14px;
    border-top: 1px solid var(--border);
  }

  .blog-card__author {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .blog-card__av {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--bg2);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 700;
    color: var(--muted);
    flex-shrink: 0;
  }

  .blog-card__author-name {
    font-size: 11px;
    font-weight: 600;
    color: var(--text);
  }

  .blog-card__link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .8px;
    text-transform: uppercase;
    color: var(--muted);
    transition: color var(--ease);
  }

  .blog-card:hover .blog-card__link {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .bs-head {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }

    .bs-head__right {
      align-items: flex-start;
    }
  }

  @media (max-width: 1100px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
