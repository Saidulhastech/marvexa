<section class="stl" id="lb" aria-labelledby="stl-h">
  <div class="stl__inner">

    <!-- ═══ LEFT: Image Panel ═══ -->
    <div class="stl__img-panel">

      <!-- Look label badge -->
      <div class="stl__look-label">
        <span class="stl__look-dot"></span>
        <span class="stl__look-label-text" id="stl-look-text">Look 01 — SS 2026</span>
      </div>

      <!-- Look 01 Image -->
      <div class="stl__img-slot active" data-look="1">
        <img
          src="https://images.unsplash.com/photo-1672753755304-140359dc739a?q=80&w=1964&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
          alt="Look 01 — SS 2026" class="stl__img" loading="lazy" />
        <!-- Pin 1: Shirt -->
        <div class="stl__pin" style="top:30%;left:38%;" aria-label="Oversized Linen Shirt" role="button" tabindex="0">
          <div class="stl__pin-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2.5" stroke-linecap="round">
              <path d="M12 5v14M5 12h14" />
            </svg></div>
          <div class="stl__pin-popup pop-right">
            <img src="https://images.unsplash.com/photo-1591047139829-d91aecb6caea?w=300&auto=format&fit=crop&q=70"
              class="stl__popup-img" alt="Oversized Linen Shirt" />
            <div class="stl__popup-body">
              <div class="stl__popup-cat">Women · Tops</div>
              <div class="stl__popup-name">Oversized Linen Shirt</div>
              <div class="stl__popup-row">
                <span class="stl__popup-price">$165</span>
                <button class="stl__popup-add" onclick="addToCart('Oversized Linen Shirt',165)">+ Bag</button>
              </div>
            </div>
          </div>
        </div>
        <!-- Pin 2: Trousers -->
        <div class="stl__pin" style="top:62%;left:32%;" aria-label="Relaxed Tailored Trousers" role="button"
          tabindex="0">
          <div class="stl__pin-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2.5" stroke-linecap="round">
              <path d="M12 5v14M5 12h14" />
