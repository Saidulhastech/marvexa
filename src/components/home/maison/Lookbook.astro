            </div>
          </div>
        </div>
        <!-- Pin 3: Bag -->
        <div class="stl__pin" style="top:72%;right:20%;" aria-label="Leather Crossbody Bag" role="button"
          tabindex="0">
          <div class="stl__pin-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor"
