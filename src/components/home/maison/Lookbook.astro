            <img src="https://images.unsplash.com/photo-1509631179647-0177331693ae?w=300&auto=format&fit=crop&q=70"
              class="stl__popup-img" alt="Relaxed Tailored Trousers" />
            <div class="stl__popup-body">
              <div class="stl__popup-cat">Women · Bottoms</div>
              <div class="stl__popup-name">Relaxed Tailored Trousers</div>
              <div class="stl__popup-row">
                <span class="stl__popup-price">$185</span>
                <button class="stl__popup-add" onclick="addToCart('Relaxed Tailored Trousers',185)">+ Bag</button>
