<script>
  // ── Shop the Look — look switcher & add all ──
  type Look = { label: string; total: string; items: [string, number][] };

  const stlLooks: Record<number, Look> = {
    1: { label: 'Look 01 — SS 2026', total: '$570', items: [['Oversized Linen Shirt', 165], ['Relaxed Tailored Trousers', 185], ['Leather Crossbody Bag', 220]] },
    2: { label: 'Look 02 — AW 2026', total: '$495', items: [['Merino Wool Crewneck', 165], ['Tailored Chino Trousers', 155], ['Premium Sunglasses', 175]] },
    3: { label: 'Look 03 — Resort 2026', total: '$615', items: [['Silk Slip Dress', 235], ['Cashmere Ribbed Scarf', 95], ['Leather Crossbody Bag', 285]] }
  };

  function addToCart(name: string, price: number) {
    const fn = (window as any).addToCart;
    if (typeof fn === 'function') fn(name, price);
  }

  function switchLook(num: number) {
    // Images
    document.querySelectorAll('.stl__img-slot').forEach(s => s.classList.remove('active'));
    const slot = document.querySelector('.stl__img-slot[data-look="' + num + '"]');
    if (slot) slot.classList.add('active');
    // Switcher btns
    document.querySelectorAll<HTMLElement>('.stl__sw-btn').forEach(b => {
      b.classList.toggle('active', b.dataset.look == String(num));
      b.setAttribute('aria-selected', b.dataset.look == String(num) ? 'true' : 'false');
    });
    // Items
    document.querySelectorAll('.stl__items').forEach(el => el.classList.add('hidden'));
    const items = document.getElementById('stl-items-' + num);
    if (items) items.classList.remove('hidden');
    // Badge label
    const lbl = document.getElementById('stl-look-text');
    if (lbl && stlLooks[num]) lbl.textContent = stlLooks[num].label;
    // Total
    const tot = document.getElementById('stl-total');
    if (tot && stlLooks[num]) tot.textContent = stlLooks[num].total;
  }

  function stlAdd(btn: HTMLElement, name: string, price: number) {
    addToCart(name, price);
    const svgCheck = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M20 6 9 17l-5-5"/></svg>';
    const svgBag = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>';
    btn.innerHTML = svgCheck;
    btn.classList.add('added');
    setTimeout(() => { btn.innerHTML = svgBag; btn.classList.remove('added'); }, 2200);
  }

  function stlAddAll() {
    const activeLook = parseInt(document.querySelector<HTMLElement>('.stl__sw-btn.active')?.dataset.look || '1');
    const look = stlLooks[activeLook];
    if (!look) return;
    look.items.forEach(([name, price]) => addToCart(name, price));
    const btn = document.querySelector<HTMLElement>('.stl__add-all');
    if (!btn) return;
    const origText = btn.textContent;
    btn.textContent = '✓ All Items Added';
    btn.style.background = '#4a7a1e';
    setTimeout(() => { btn.textContent = origText; btn.style.background = ''; }, 2500);
  }

  // Expose for inline onclick handlers in the markup above.
  (window as any).switchLook = switchLook;
  (window as any).stlAdd = stlAdd;
  (window as any).stlAddAll = stlAddAll;
</script>
