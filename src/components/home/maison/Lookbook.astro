    </div><!-- /stl__img-panel -->

    <!-- ═══ RIGHT: Content Panel ═══ -->
    <div class="stl__panel rv d1">

      <!-- Header -->
      <div class="stl__eyebrow">Shop the Look</div>
      <h2 class="stl__title" id="stl-h">Curated for the<br>Modern Wardrobe</h2>
      <p class="stl__desc">Three pieces, one complete look. Every item ships free over $150.</p>

      <!-- Look switcher thumbnails -->
      <div class="stl__switcher" role="tablist" aria-label="Select a look">
        <button class="stl__sw-btn active" data-look="1" onclick="switchLook(1)" role="tab" aria-selected="true"
          aria-label="Look 01">
          <img
            src="https://images.unsplash.com/photo-1672753755304-140359dc739a?q=80&w=1964&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
            class="stl__sw-img" alt="Look 01" />
          <span class="stl__sw-label">Look 01</span>
        </button>
        <button class="stl__sw-btn" data-look="2" onclick="switchLook(2)" role="tab" aria-selected="false"
          aria-label="Look 02">
