---
// ============================================================
//  BlogTeasers — OMNIX "From the journal" grid. Content from the
//  `blog` mdx collection. Each card links to its post.
// ============================================================
import { getCollection } from 'astro:content';
import SectionHeading from '~/components/ui/omnix/SectionHeading.astro';
import PostCard from '~/components/blog/PostCard.astro';

const posts = (await getCollection('blog')).sort((a, b) => a.data.order - b.data.order);
---

{
  posts.length > 0 && (
    <section class="sec">
      <div class="container">
        <SectionHeading
          eyebrow="From the Omnix journal"
          title="Buy smarter. Read deeper."
          body="Long-form buying guides and gear stories, written by people who use the things they review."
          link={{ label: 'Visit the journal', href: '/blog' }}
        />

        <div class="blog-grid">
          {posts.map((p) => <PostCard post={p} />)}
        </div>
      </div>
    </section>
  )
}
