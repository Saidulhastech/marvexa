---
// ============================================================
//  Newsletter — OMNIX inline signup band. UI only (no backend).
//  Content-driven.
// ============================================================
import { getEntry } from 'astro:content';
import Icon from '~/components/ui/omnix/Icon.astro';

const n = (await getEntry('newsletter', 'main'))!.data;
---

<section class="news">
  <div class="container">
    <div class="news-inner">
      {n.eyebrow && <div class="sec-eyebrow" style="color: var(--accent-dk); justify-content: center; display: inline-flex;">{n.eyebrow}</div>}
      <h2 class="h2" set:html={n.title} />
      {n.body && <p>{n.body}</p>}
      <form class="news-form" id="newsForm" novalidate aria-label="Newsletter signup">
        <input type="email" aria-label="Email address" placeholder={n.placeholder} required autocomplete="email" />
        <button type="submit" class="btn btn-primary">{n.cta}</button>
      </form>
      {
        n.perks.length > 0 && (
          <div class="news-perks">
            {n.perks.map((p) => (
              <span><Icon name="check" size={14} stroke={2.4} /> {p}</span>
            ))}
          </div>
        )
      }
    </div>
  </div>
</section>

<script>
  // UI-only: confirm in place (no backend wired yet).
  document.getElementById('newsForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = (e.currentTarget as HTMLFormElement).querySelector('button');
    if (btn) btn.textContent = 'Subscribed ✓';
  });
</script>
