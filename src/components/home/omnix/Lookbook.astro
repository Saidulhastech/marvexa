---
// ============================================================
//  Lookbook — OMNIX "Shop the look": one hero image with product
//  hotspots. Hero image + dot coordinates are editorial (content
//  collection); the PRODUCT at each hotspot is pulled LIVE from
//  Shopify — pinned by `handle`, or filled from best-sellers.
//  Rating is shown only if a source ever provides it (Shopify has
//  no native review field) — otherwise blank.
// ============================================================
import { Image } from 'astro:assets';
import { getEntry } from 'astro:content';
import { resolveImage } from '~/lib/asset';
import { getProduct, getProducts } from '~/lib/shopify';
import { formatMoney, percentOff, hasPriceRange } from '~/lib/money';

const lb = (await getEntry('lookbook', 'main'))!.data;
const hero = resolveImage(lb.image);
const market = Astro.locals.market;

// Best-seller pool fills any hotspot without an explicit handle.
const pool = (await getProducts({ pageSize: lb.hotspots.length, sortKey: 'BEST_SELLING' }, market)).items;
let poolIdx = 0;

const hotspots = (
  await Promise.all(
    lb.hotspots.map(async (h) => {
      const p = h.handle ? await getProduct(h.handle, market) : pool[poolIdx++];
      if (!p) return null;
      const price = p.priceRange.minVariantPrice;
      const compareAt = p.compareAtPriceRange?.minVariantPrice ?? null;
      const off = percentOff(price, compareAt);
      return {
        top: h.top,
        left: h.left,
        cardLeft: h.cardLeft,
        brand: p.vendor ?? '',
        name: p.title,
        price: (hasPriceRange(p.priceRange) ? 'From ' : '') + formatMoney(price),
        was: compareAt && off > 0 ? formatMoney(compareAt) : '',
        img: p.featuredImage ?? null,
        href: `/products/${p.handle}`,
        rating: '', // no Shopify review source — blank unless one is wired
      };
    }),
  )
).filter((h): h is NonNullable<typeof h> => h !== null);
---

<section class="lookbook-sec">
  <div class="container">
    <div class="lookbook-wrap">
      <Image class="lookbook-img" src={hero} alt="Shop the look" width={1440} height={720} />
      <div class="lk-img-veil"></div>

      <div class="lk-hotspots">
        {
          hotspots.map((h) => (
            <div class="lk-hotspot" style={`top:${h.top}; left:${h.left};`}>
              <div class="lk-dot">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8">
                  <line x1="12" y1="5" x2="12" y2="19" />
                  <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
              </div>
              <div class:list={['lk-product-card', { 'lk-card-left': h.cardLeft }]}>
                <div class="lk-pc-img">
                  {h.img && (
                    <Image src={h.img.url} alt={h.img.altText ?? h.name} width={120} height={120} />
                  )}
                </div>
                <div class="lk-pc-body">
                  {h.brand && <div class="lk-pc-brand">{h.brand}</div>}
                  <div class="lk-pc-name">{h.name}</div>
                  {h.rating && (
                    <div class="lk-pc-rating">
                      <span class="lk-stars">★★★★★</span>
                      <span class="lk-rcount">{h.rating}</span>
                    </div>
                  )}
                  <div class="lk-pc-price-row">
                    <span class="lk-pc-price">{h.price}</span>
                    {h.was && <span class="lk-pc-was">{h.was}</span>}
                  </div>
                  <a class="lk-pc-add" href={h.href}>Shop now</a>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  // Touch has no hover — make the +dot tap-to-toggle its product card.
  // Click a dot: open its card (and close any other). Click outside: close.
  const root = document.querySelector('.lookbook-sec .lk-hotspots');
  if (root) {
    const hotspots = Array.from(root.querySelectorAll<HTMLElement>('.lk-hotspot'));
    const isMobile = () => window.matchMedia('(max-width: 768px)').matches;

    const clearPos = (card: HTMLElement) => {
      // Wipe inline overrides → desktop CSS (absolute beside dot) takes over.
      card.style.position = '';
      card.style.left = '';
      card.style.right = '';
      card.style.top = '';
    };

    // Mobile: `.lk-hotspot` has a transform, so `position:fixed` would anchor
    // to it, not the viewport — use `absolute` and convert the desired
    // viewport spot into the hotspot's local coords (translation-only, so
    // viewport offsets == local offsets). Clamp 8px inside every screen edge.
    const placeCard = (spot: HTMLElement) => {
      const card = spot.querySelector<HTMLElement>('.lk-product-card');
      const dot = spot.querySelector<HTMLElement>('.lk-dot');
      if (!card || !dot) return;
      if (!isMobile()) {
        clearPos(card);
        return;
      }
      const M = 8;
      const s = spot.getBoundingClientRect();
      const d = dot.getBoundingClientRect();
      const cw = card.offsetWidth;
      const ch = card.offsetHeight;
      // Desired viewport position: centered on the dot, clamped to the screen.
      let vLeft = d.left + d.width / 2 - cw / 2;
      vLeft = Math.max(M, Math.min(vLeft, window.innerWidth - cw - M));
      let vTop = d.bottom + 10; // below the dot…
      if (vTop + ch > window.innerHeight - M) vTop = d.top - ch - 10; // …flip above
      vTop = Math.max(M, vTop);
      // Local coords relative to the hotspot's box.
      card.style.position = 'absolute';
      card.style.right = 'auto';
      card.style.left = `${vLeft - s.left}px`;
      card.style.top = `${vTop - s.top}px`;
    };

    // Close = just drop `.is-open` → card fades out IN PLACE (no clearPos, which
    // would snap it back to the CSS default mid-fade and cause a jump). Inline
    // coords stay until the next open recomputes them, or desktop clears them.
    const closeAll = (except?: HTMLElement) =>
      hotspots.forEach((h) => h !== except && h.classList.remove('is-open'));

    const clearAll = () =>
      hotspots.forEach((h) => {
        const c = h.querySelector<HTMLElement>('.lk-product-card');
        if (c) clearPos(c);
      });

    hotspots.forEach((spot) => {
      const dot = spot.querySelector('.lk-dot');
      dot?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const open = spot.classList.contains('is-open');
        closeAll(spot);
        if (!open) {
          // Position while still invisible (opacity 0), then reveal → no flash.
          placeCard(spot);
          spot.classList.add('is-open');
        } else {
          spot.classList.remove('is-open');
        }
      });
    });

    // Tap elsewhere or resize closes the open card. On resize into desktop,
    // also wipe inline coords so the desktop CSS layout takes back over.
    document.addEventListener('click', () => closeAll());
    window.addEventListener('resize', () => {
      closeAll();
      if (!isMobile()) clearAll();
    });
  }
</script>
