---
// ============================================================
//  CuratedSetups — OMNIX "Bundle & Save". Fixed-price bundles, pure
//  Shopify standard (no app): each bundle is an ordinary Shopify
//  *product* (its own SKU, priced as the bundle) tagged `bundle`, with
//  its contents listed in the `custom.bundle_items` metafield. "Add
//  bundle" drops the ONE bundle variant into the cart like any product.
//  Included items + Save are read live from the referenced products.
// ============================================================
import { Image } from 'astro:assets';
import { getBundleProducts } from '~/lib/shopify';
import type { BundleProduct } from '~/lib/shopify/types';
import { formatMoney } from '~/lib/money';
import SectionHeading from '~/components/ui/omnix/SectionHeading.astro';
import Icon from '~/components/ui/omnix/Icon.astro';

// Feature-icon colour palette, cycled per component row.
const PALETTE = [
  { bg: '#EEF4FF', fg: '#2563eb' },
  { bg: '#F3EEFF', fg: '#7c3aed' },
  { bg: '#ECFDF5', fg: '#059669' },
  { bg: '#FFF7ED', fg: '#ea580c' },
  { bg: '#FFF1F2', fg: '#e11d48' },
];

// Product-type glyphs, cycled per row (we don't know each component's real
// category, so vary the icon by position — matches the Modern Style design).
const BUNDLE_ICONS = ['headphone', 'monitor', 'volume', 'clock', 'music', 'smartphone', 'camera', 'mic'] as const;

function toCard(b: BundleProduct, card = 0) {
  const items = b.components.slice(0, 4);
  const now = Number(b.price?.amount ?? 0);
  const was = Number(b.compareAtPrice?.amount ?? 0);
  const hasDiscount = was > now;

  return {
    handle: b.handle,
    title: b.title,
    tag: `${b.components.length}-piece bundle`,
    // Link to the configurator — shopper picks each component's variant there.
    href: `/bundles/${b.handle}`,
    thumbs: items.slice(0, 3),
    features: items.map((c, i) => ({
      name: c.title,
      spec: c.vendor ?? '',
      icon: BUNDLE_ICONS[(card * 3 + i) % BUNDLE_ICONS.length],
      image: c.image,
      ...PALETTE[i % PALETTE.length],
    })),
    priceNow: formatMoney(b.price),
    priceWas: hasDiscount ? formatMoney(b.compareAtPrice!) : undefined,
    save: hasDiscount ? formatMoney({ amount: String(was - now), currencyCode: b.price.currencyCode }) : undefined,
  };
}

let cards: ReturnType<typeof toCard>[] = [];
try {
  const bundles = await getBundleProducts(undefined, undefined, Astro.locals.market);
  cards = bundles.map((b, i) => toCard(b, i)).filter((c) => c.features.length > 0);
} catch (err) {
  // Never let a bundles fetch break the home page — just hide the section.
  console.error('[bundles] load failed:', (err as Error).message);
}
---

{
  cards.length > 0 && (
    <section class="sec sec-frost">
      <div class="container">
        <SectionHeading
          eyebrow="Bundle & Save"
          title="Curated setups that just work, together."
          body="We test every bundle as a complete system — the same engineers who built the products picked the combos."
          link={{ label: 'All bundles', href: '/collections' }}
        />

        <div class="bundle-grid">
          {cards.map((b) => (
            <article class="bundle">
              <div class="bundle-head">
                {b.tag && <span class="bundle-tag">{b.tag}</span>}
                {b.save && <span class="bundle-save">Save {b.save}</span>}
              </div>
              <div class="bundle-items">
                {b.thumbs.map((t, i) => (
                  <>
                    {i > 0 && <span class="bundle-plus">+</span>}
                    <div class="bundle-item">
                      {t.image ? (
                        <Image
                          src={t.image.url}
                          alt={t.image.altText ?? t.title}
                          width={120}
                          height={120}
                          widths={[120, 240]}
                          sizes="120px"
                        />
                      ) : (
                        <div class="bundle-item-empty" />
                      )}
                    </div>
                  </>
                ))}
              </div>
              <h4>{b.title}</h4>
              <ul class="bundle-feat-ul">
                {b.features.map((f) => (
                  <li>
                    <span class="bundle-feat-icon" style={`background:${f.bg};color:${f.fg};`}>
                      <Icon name={f.icon} size={16} stroke={2} />
                    </span>
                    <div class="bundle-feat-info">
                      <span class="bundle-feat-name">{f.name}</span>
                      {f.spec && <span class="bundle-feat-spec">{f.spec}</span>}
                    </div>
                    <span class="bundle-feat-badge">Included</span>
                  </li>
                ))}
              </ul>
              <div class="bundle-foot">
                <div class="bundle-price">
                  <span class="now">{b.priceNow}</span>
                  {b.priceWas && <span class="was">{b.priceWas}</span>}
                </div>
                <a class="btn btn-dark btn-sm" href={b.href}>Customize bundle</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}
