---
// ============================================================
//  PromoBanner — OMNIX `.promo-grid` (two image promo cards).
//  Content-driven; reused if more promos are added.
// ============================================================
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { resolveImage } from '~/lib/asset';
import Icon from '~/components/ui/omnix/Icon.astro';

const order = ['trade-in', 'gaming'];
const promos = (await getCollection('promo')).sort(
  (a, b) => order.indexOf(a.id) - order.indexOf(b.id),
);
---

{
  promos.length > 0 && (
    <section class="sec sec-compact" style="margin-top:0; padding-top:0; position:relative; z-index:2;">
      <div class="container">
        <div class="promo-grid">
          {promos.map((p) => (
            <div class="promo">
              <Image class="bg" src={resolveImage(p.data.image)} alt={p.data.tag ?? 'Promotion'} width={760} height={420} />
              {p.data.tag && <span class="tag">{p.data.tag}</span>}
              <h3 set:html={p.data.title} />
              {p.data.body && <p>{p.data.body}</p>}
              {p.data.cta && (
                <a class="btn btn-light promo-cta" href={p.data.cta.href}>
                  {p.data.cta.label}
                  <Icon name="arrow-right" size={16} stroke={2.4} class="arr" />
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
