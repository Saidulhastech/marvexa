---
// ============================================================
//  BrandStrip — OMNIX scrolling partner brands. Two identical
//  tracks for a seamless loop. Content-driven.
// ============================================================
import { getCollection } from 'astro:content';

const brands = (await getCollection('brands')).sort((a, b) => a.id.localeCompare(b.id));
---

<section class="brand-strip">
  <div class="container">
    <div class="lead">Trusted brands we partner with</div>
  </div>
  <div class="brand-scroll-outer">
    <div class="brand-scroll-inner">
      {
        [0, 1].map(() => (
          <div class="brand-scroll-track">
            {brands.map((b, i) => (
              <>
                {i > 0 && <div class="brand-scroll-sep" />}
                <div class="brand" set:html={b.data.name} />
              </>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</section>
