---
// ============================================================
//  Spotlight — OMNIX dark product feature band with carousel.
//  First slide renders server-side; all slides are pre-optimized
//  and embedded so the prev/next arrows can swap fields client-side
//  (mirrors the original's field-swap carousel). Content-driven.
// ============================================================
import { getImage } from 'astro:assets';
import { getCollection } from 'astro:content';
import { resolveImage } from '~/lib/asset';
import Icon from '~/components/ui/omnix/Icon.astro';

const slides = (await getCollection('spotlight')).sort((a, b) => a.data.order - b.data.order);

// Pre-optimize each slide image and build a JSON payload for the script.
const payload = await Promise.all(
  slides.map(async (s) => {
    const opt = await getImage({ src: resolveImage(s.data.image), width: 720, height: 720, format: 'webp' });
    return { ...s.data, imageSrc: opt.src };
  }),
);
const first = payload[0];
const hasCarousel = payload.length > 1;
---

{
  first && (
    <section class="sec" style="padding-top: 120px; padding-bottom: 80px;">
      <div class="container">
        <div class="spot" id="spotCarousel">
          <div class="spot-media">
            <div class="spot-badge" id="spotBadge">{first.badge}</div>
            <img id="spotImg" src={first.imageSrc} alt={first.badge ?? 'Product spotlight'} width="720" height="720" />
            {hasCarousel && (
              <>
                <button class="spot-arrow spot-arrow-prev" id="spotPrev" aria-label="Previous"><Icon name="chevron-left" size={18} stroke={2.4} /></button>
                <button class="spot-arrow spot-arrow-next" id="spotNext" aria-label="Next"><Icon name="chevron-right" size={18} stroke={2.4} /></button>
              </>
            )}
          </div>
          <div class="spot-body">
            {first.eyebrow && <div class="spot-eyebrow" id="spotEyebrow">{first.eyebrow}</div>}
            <h2 class="h2" id="spotTitle" set:html={first.title} />
            <p id="spotDesc">{first.body}</p>
            <ul class="spot-features" id="spotFeatures">
              {first.features.map((f) => (
                <li><Icon name="check" size={18} stroke={2.4} />{f}</li>
              ))}
            </ul>
            <div class="spot-foot">
              <div class="spot-price">
                <span class="now" id="spotNow">{first.priceNow}</span>
                <span class="was" id="spotWas">{first.priceWas}</span>
              </div>
              {first.primary && (
                <a class="btn btn-light" id="spotCta" href={first.primary.href}>
                  {first.primary.label}
                  <Icon name="arrow-right" size={16} stroke={2.4} class="arr" />
                </a>
              )}
              {first.secondary && <a class="btn btn-ghost" href={first.secondary.href} style="color:#fff;">{first.secondary.label}</a>}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}

{hasCarousel && <script type="application/json" id="spotData" set:html={JSON.stringify(payload)} />}

<script>
  // Spotlight carousel — swap fields from the embedded slide data.
  type Slide = {
    badge?: string; eyebrow?: string; title?: string; body?: string;
    imageSrc: string; features?: string[]; priceNow?: string; priceWas?: string;
    primary?: { href: string };
  };
  const dataEl = document.getElementById('spotData');
  const prev = document.getElementById('spotPrev');
  const next = document.getElementById('spotNext');
  if (dataEl && prev && next) {
    const data: Slide[] = JSON.parse(dataEl.textContent || '[]');
    const $ = (id: string) => document.getElementById(id);
    const CHECK =
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
    let i = 0;
    const render = () => {
      const s = data[i];
      const img = $('spotImg') as HTMLImageElement | null;
      if (img) { img.src = s.imageSrc; img.alt = s.badge || ''; }
      const set = (id: string, v?: string) => { const el = $(id); if (el) el.textContent = v || ''; };
      set('spotBadge', s.badge);
      set('spotEyebrow', s.eyebrow);
      const title = $('spotTitle'); if (title) title.innerHTML = s.title || '';
      set('spotDesc', s.body);
      const feat = $('spotFeatures');
      if (feat) feat.innerHTML = (s.features || []).map((f) => `<li>${CHECK}${f}</li>`).join('');
      set('spotNow', s.priceNow);
      set('spotWas', s.priceWas);
      if (s.primary) $('spotCta')?.setAttribute('href', s.primary.href);
    };
    const go = (d: number) => { i = (i + d + data.length) % data.length; render(); };
    prev.addEventListener('click', () => go(-1));
    next.addEventListener('click', () => go(1));
  }
</script>
