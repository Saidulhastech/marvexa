---
// ============================================================
//  Testimonials — OMNIX 3-column scrolling marquee of reviews.
//  Content from the `testimonials` md collection; each column's
//  cards are duplicated for a seamless CSS loop.
// ============================================================
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const all = (await getCollection('testimonials')).sort((a, b) => a.data.order - b.data.order);

// Distribute into 3 columns, round-robin.
const cols: (typeof all)[] = [[], [], []];
all.forEach((t, i) => cols[i % 3].push(t));
---

<section class="test-sec">
  <div class="container">
    <div class="test-head">
      <div class="test-eye"><span class="test-eye-dot"></span> Customer stories</div>
      <h2 class="h2">Loved by the people who use it.</h2>
      <p class="test-head-sub">
        Real reviews from verified buyers in 47 countries — no cherry-picking, no paid placements, just honest feedback
        from people who paid full price for their gear.
      </p>
      <div class="test-head-trust">
        <span class="stars">★★★★★</span>
        <span><b>4.9</b> from <b>28,400+</b> verified reviews</span>
      </div>
    </div>

    <div class="test-marquee">
      {
        cols.map((col, ci) => (
          <div class:list={['test-col', { 'is-reverse': ci === 1, [`test-col-${ci + 1}`]: true }]}>
            {[...col, ...col].map((t) => (
              <div class="test-card">
                <div class="test-card-row">
                  <div class="test-stars">{'★'.repeat(t.data.rating)}</div>
                  {t.data.verified && (
                    <div class="test-verified">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                      Verified
                    </div>
                  )}
                </div>
                <p class="test-qtext">{t.data.quote}</p>
                <div class="test-card-foot">
                  {t.data.avatar && (
                    <div class="test-avatar">
                      <Image src={t.data.avatar} alt={t.data.author} width={48} height={48} inferSize={false} />
                    </div>
                  )}
                  <div>
                    <div class="test-author">{t.data.author}</div>
                    {t.data.role && <div class="test-meta">{t.data.role}</div>}
                  </div>
                </div>
              </div>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</section>
