---
// ============================================================
//  Marquee — OMNIX infinite scroll strip. Two identical tracks
//  (second aria-hidden) for a seamless CSS loop. Content-driven.
// ============================================================
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { resolveImage } from '~/lib/asset';

const items = (await getCollection('marquee')).sort((a, b) => a.id.localeCompare(b.id));
---

<section class="marquee-sec">
  <div class="marquee-inner">
    {
      [false, true].map((hidden) => (
        <div class="marquee-track" aria-hidden={hidden ? 'true' : undefined}>
          {items.map((it) => (
            <>
              <span class:list={['marquee-item', { 'is-accent': it.data.accent }]}>
                <Image class="marquee-prod-img" src={resolveImage(it.data.image)} alt={it.data.label} width={48} height={48} />
                {it.data.label}
              </span>
              <span class="marquee-dot" />
            </>
          ))}
        </div>
      ))
    }
  </div>
</section>
