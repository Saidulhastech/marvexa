---
---

<section class="testimonials" aria-labelledby="tm-h">
  <div class="wrap">

    <div class="tm-head rv">
      <div class="tm-head__eyebrow">Verified Reviews</div>
      <h2 class="tm-head__title" id="tm-h">What Our Community Says</h2>
    </div>

    <div class="tm-body rv d1">
      <span class="tm-qmark" aria-hidden="true">"</span>

      <div class="tm-inner">

        <!-- Text panel -->
        <div class="tm-text" id="tmText">
          <!-- populated by JS -->
        </div>

        <!-- Portrait panel -->
        <div class="tm-portrait-wrap">
          <img class="tm-portrait-img" id="tmPortrait" src="" alt="" loading="lazy" />
        </div>

      </div>

      <!-- Navigation bar -->
      <div class="tm-nav">
        <span class="tm-nav__counter" id="tmCounter"><span>01</span> / 05</span>
        <div class="tm-thumbs" id="tmThumbs"></div>
        <div class="tm-nav__arrows">
          <button class="tm-arr" id="tmPrev" aria-label="Previous review">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6" />
            </svg>
          </button>
          <button class="tm-arr" id="tmNext" aria-label="Next review">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6" />
            </svg>
          </button>
        </div>
      </div>

    </div><!-- /tm-body -->

  </div>
</section>

<style>
  .testimonials {
    padding: 108px 0 116px;
    background: var(--bg);
  }

  /* ── Head ── */
  .tm-head {
    text-align: center;
    margin-bottom: 60px;
  }

  .tm-head__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--fb);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .tm-head__eyebrow::before,
  .tm-head__eyebrow::after {
    content: '';
    display: block;
    width: 18px;
    height: 1px;
    background: var(--accent);
  }

  .tm-head__title {
    font-family: var(--fh);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -2px;
    line-height: 1;
    margin: 0;
  }

  /* ── Body card ── */
  .tm-body {
    position: relative;
    background: var(--dark);
    border-radius: 20px;
    padding: 72px 72px 64px;
    overflow: hidden;
  }

  /* giant ghost quotation mark */
  .tm-qmark {
    position: absolute;
    top: -24px;
    left: 56px;
    font-family: var(--fh);
    font-size: 280px;
    font-weight: 800;
    color: #fff;
    opacity: 0.04;
    line-height: 1;
    user-select: none;
    pointer-events: none;
  }

  /* subtle accent gradient blob top-right */
  .tm-body::before {
    content: '';
    position: absolute;
    top: -80px;
    right: -80px;
    width: 340px;
    height: 340px;
    background: radial-gradient(circle, rgba(122, 143, 58, 0.18) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ── Inner 2-col grid ── */
  .tm-inner {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 72px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  /* ── Text panel ── */
  .tm-text {
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .tm-text.tm-text--exit {
    opacity: 0;
    transform: translateY(14px);
  }

  .tm-product {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 100px;
    padding: 5px 14px 5px 10px;
    font-family: var(--fb);
    font-size: 11px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.75);
    letter-spacing: 0.2px;
    margin-bottom: 28px;
    width: fit-content;
  }

  .tm-product svg {
    color: var(--accent);
    flex-shrink: 0;
  }

  .tm-stars {
    display: flex;
    gap: 3px;
    margin-bottom: 20px;
  }

  .tm-quote {
    font-family: var(--fh);
    font-size: clamp(22px, 2.4vw, 32px);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.92);
    line-height: 1.45;
    letter-spacing: -0.6px;
    margin: 0 0 36px;
  }

  .tm-author {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .tm-author__name {
    font-family: var(--fb);
    font-size: 14px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.88);
  }

  .tm-author__meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .tm-author__loc {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: var(--fb);
    font-size: 12px;
    color: rgba(255, 255, 255, 0.42);
  }

  .tm-author__verified {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--fb);
    font-size: 11px;
    font-weight: 600;
    color: var(--accent);
  }

  /* ── Portrait panel ── */
  .tm-portrait-wrap {
    position: relative;
    width: 360px;
    height: 440px;
    border-radius: 14px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .tm-portrait-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.4s ease;
  }

  .tm-portrait-img.tm-img--exit {
    opacity: 0;
  }

  /* subtle inner border on portrait */
  .tm-portrait-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    pointer-events: none;
  }

  /* ── Navigation bar ── */
  .tm-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 48px;
    padding: 0 4px;
  }

  .tm-nav__counter {
    font-family: var(--fh);
    font-size: 13px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 1px;
    min-width: 56px;
  }

  .tm-nav__counter span {
    color: rgba(255, 255, 255, 0.7);
  }

  .tm-thumbs {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .tm-thumb {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.25s, transform 0.25s, opacity 0.25s;
    opacity: 0.4;
    flex-shrink: 0;
  }

  .tm-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .tm-thumb.tm-thumb--active {
    border-color: var(--accent);
    opacity: 1;
    transform: scale(1.15);
  }

  .tm-thumb:hover:not(.tm-thumb--active) {
    opacity: 0.7;
    transform: scale(1.06);
  }

  .tm-nav__arrows {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .tm-arr {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.07);
    color: rgba(255, 255, 255, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.22s, border-color 0.22s, color 0.22s, transform 0.22s;
  }

  .tm-arr:hover {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.3);
    color: #fff;
    transform: scale(1.08);
  }

  .tm-arr:active {
    transform: scale(0.95);
  }
</style>

<script>
  // ─── TESTIMONIAL CAROUSEL ────────────────────────────────────────────────
  (function () {
    var reviews = [
      {
        portrait: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=600&q=88',
        thumb: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=120&q=80',
        name: 'Sophie M.',
        loc: 'London, UK',
        product: 'Linen Blazer',
        date: 'March 2025',
        quote: 'The linen blazer has become my absolute go-to piece. Effortlessly polished, incredibly comfortable — I reach for it every single week without thinking twice.'
      },
      {
        portrait: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&q=88',
        thumb: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=120&q=80',
        name: 'James R.',
        loc: 'New York, US',
        product: 'Wool Blend Coat',
        date: 'January 2025',
        quote: 'Finally a brand that truly gets quality. The wool coat is exceptional — warm, structured, and honestly gets better with every single wear. Worth every penny.'
      },
      {
        portrait: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=600&q=88',
        thumb: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=120&q=80',
        name: 'Amara K.',
        loc: 'Paris, France',
        product: 'Silk Slip Dress',
        date: 'February 2025',
        quote: "I've never received so many compliments on my wardrobe. Everything fits like it was made for me. I genuinely will not shop anywhere else from now on."
      },
      {
        portrait: 'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=600&q=88',
        thumb: 'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=120&q=80',
        name: 'David K.',
        loc: 'Toronto, Canada',
        product: 'Cashmere Turtleneck',
        date: 'December 2024',
        quote: 'The cashmere sweater is genuinely the softest thing I own. The quality is remarkable — it still looks brand new after a full year of regular wear.'
      },
      {
        portrait: 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=600&q=88',
        thumb: 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=120&q=80',
        name: 'Emma L.',
        loc: 'Stockholm, Sweden',
        product: 'Cotton Poplin Shirt',
        date: 'April 2025',
        quote: 'Perfect sizing, lightning-fast delivery, and quality that genuinely exceeded expectations. The shirt is immaculate — crisp, structured, effortlessly elegant.'
      }
    ];

    var activeIdx = 0;
    var animating = false;
    var total = reviews.length;
    var touchStartX = null;
    var autoTimer = null;

    function starsSVG() {
      var s = '<svg width="13" height="13" viewBox="0 0 24 24" fill="#C8A75E" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>';
      return s + s + s + s + s;
    }

    function buildText(r) {
      return (
        '<div class="tm-product">' +
        '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>' +
        r.product +
        '</div>' +
        '<div class="tm-stars">' + starsSVG() + '</div>' +
        '<blockquote class="tm-quote">"' + r.quote + '"</blockquote>' +
        '<div class="tm-author">' +
        '<div class="tm-author__name">' + r.name + '</div>' +
        '<div class="tm-author__meta">' +
        '<span class="tm-author__loc">' +
        '<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>' +
        r.loc +
        '</span>' +
        '<span class="tm-author__verified">' +
        '<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>' +
        'Verified · ' + r.date +
        '</span>' +
        '</div>' +
        '</div>'
      );
    }

    function updateCounter() {
      var el = document.getElementById('tmCounter');
      if (!el) return;
      var n = String(activeIdx + 1);
      if (n.length < 2) n = '0' + n;
      var tot = String(total);
      if (tot.length < 2) tot = '0' + tot;
      el.innerHTML = '<span>' + n + '</span> / ' + tot;
    }

    function updateThumbs() {
      document.querySelectorAll('#tmThumbs .tm-thumb').forEach(function (t, i) {
        t.classList.toggle('tm-thumb--active', i === activeIdx);
      });
    }

    function transitionTo(idx) {
      if (animating || idx === activeIdx) return;
      animating = true;

      var textEl = document.getElementById('tmText');
      var portraitEl = document.getElementById('tmPortrait');
      if (!textEl || !portraitEl) return;

      /* fade out */
      textEl.classList.add('tm-text--exit');
      portraitEl.classList.add('tm-img--exit');

      setTimeout(function () {
        activeIdx = idx;
        var r = reviews[activeIdx];

        /* swap content */
        textEl.innerHTML = buildText(r);
        portraitEl.src = r.portrait;
        portraitEl.alt = r.name;

        updateCounter();
        updateThumbs();

        /* fade in */
        textEl.classList.remove('tm-text--exit');
        portraitEl.classList.remove('tm-img--exit');

        setTimeout(function () { animating = false; }, 380);
      }, 280);
    }

    function navigate(dir) {
      transitionTo(dir === 'next'
        ? (activeIdx + 1) % total
        : (activeIdx - 1 + total) % total
      );
    }

    function startAuto() {
      clearInterval(autoTimer);
      autoTimer = setInterval(function () {
        if (!document.hidden) navigate('next');
      }, 5800);
    }

    function init() {
      var textEl = document.getElementById('tmText');
      var portraitEl = document.getElementById('tmPortrait');
      var thumbsEl = document.getElementById('tmThumbs');
      if (!textEl || !portraitEl || !thumbsEl) return;

      /* initial render */
      var r0 = reviews[0];
      textEl.innerHTML = buildText(r0);
      portraitEl.src = r0.portrait;
      portraitEl.alt = r0.name;
      updateCounter();

      /* thumbnails */
      reviews.forEach(function (r, i) {
        var div = document.createElement('div');
        div.className = 'tm-thumb' + (i === 0 ? ' tm-thumb--active' : '');
        div.setAttribute('role', 'button');
        div.setAttribute('tabindex', '0');
        div.setAttribute('aria-label', 'Review by ' + r.name);
        div.innerHTML = '<img src="' + r.thumb + '" alt="' + r.name + '" loading="lazy" />';
        div.addEventListener('click', function () { clearInterval(autoTimer); transitionTo(i); startAuto(); });
        div.addEventListener('keydown', function (e) { if (e.key === 'Enter' || e.key === ' ') { clearInterval(autoTimer); transitionTo(i); startAuto(); } });
        thumbsEl.appendChild(div);
      });

      /* arrows */
      var prevBtn = document.getElementById('tmPrev');
      var nextBtn = document.getElementById('tmNext');
      if (prevBtn) prevBtn.addEventListener('click', function () { clearInterval(autoTimer); navigate('prev'); startAuto(); });
      if (nextBtn) nextBtn.addEventListener('click', function () { clearInterval(autoTimer); navigate('next'); startAuto(); });

      /* touch swipe */
      var body = document.querySelector('.tm-body');
      if (body) {
        body.addEventListener('touchstart', function (e) { touchStartX = e.touches[0].clientX; }, { passive: true });
        body.addEventListener('touchend', function (e) {
          if (touchStartX === null) return;
          var dx = e.changedTouches[0].clientX - touchStartX;
          if (Math.abs(dx) > 50) { clearInterval(autoTimer); navigate(dx < 0 ? 'next' : 'prev'); startAuto(); }
          touchStartX = null;
        }, { passive: true });
        body.addEventListener('mouseenter', function () { clearInterval(autoTimer); });
        body.addEventListener('mouseleave', startAuto);
      }

      /* keyboard */
      document.addEventListener('keydown', function (e) {
        var active = document.activeElement;
        var inSection = document.querySelector('.testimonials');
        if (!inSection || !inSection.contains(active)) return;
        if (e.key === 'ArrowLeft') { clearInterval(autoTimer); navigate('prev'); startAuto(); }
        if (e.key === 'ArrowRight') { clearInterval(autoTimer); navigate('next'); startAuto(); }
      });

      startAuto();
    }

    document.addEventListener('DOMContentLoaded', init);
  }());
</script>
