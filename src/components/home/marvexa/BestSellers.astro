---
import { getCollection } from 'astro:content';
import ProductCard from '~/components/product/marvexa/ProductCard.astro';
import Icon from '~/components/ui/marvexa/Icon.astro';
import type { ProductCard as TProductCard } from '~/lib/shopify/types';

interface Props {
  products: TProductCard[];
  /** Real average rating across the catalogue (drives the proof strip). */
  ratingAvg?: number | null;
  /** Real total review count across the catalogue. */
  reviewTotal?: number | null;
}

const { products, ratingAvg = null, reviewTotal = null } = Astro.props;
const top = products.slice(0, 3);

// Proof strip from the `proof` content collection (stable display order by id).
const ORDER = ['rating', 'shipping', 'returns', 'secure'];
const proofItems = (await getCollection('proof')).sort(
  (a, b) => ORDER.indexOf(a.id) - ORDER.indexOf(b.id),
);

// Replace the `rating` item's copy with the real aggregate when available.
const proof = proofItems.map((item) => {
  if (item.id !== 'rating' || ratingAvg == null) return item.data;
  return {
    ...item.data,
    stat: `${ratingAvg.toFixed(1)} / 5`,
    label: reviewTotal
      ? `Average rating across ${reviewTotal.toLocaleString()}+ verified reviews`
      : item.data.label,
  };
});
---

<section class="bestsellers" aria-labelledby="bs-h">
  <div class="wrap">

    <!-- Header -->
    <div class="bs-head rv">
      <div class="bs-head__left">
        <div class="bs-head__eyebrow">Most Loved</div>
        <h2 class="bs-head__title" id="bs-h">Best Sellers</h2>
      </div>
      <div class="bs-head__right">
        <a href="/products" class="btn btn-outline">View All <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg></a>
      </div>
    </div>

    <!-- 3-card grid — shared ProductCard (real add-to-cart / wishlist / ratings) -->
    <div class="bs-grid">
      {top.map((p, i) => (
        <div class={`bs-card rv${i > 0 ? ' d1' : ''}`}>
          <span class="bs-rank">{`#0${i + 1}`}</span>
          <ProductCard product={p} eager={i < 3} />
        </div>
      ))}
    </div>

    <!-- Trust proof cards — driven by the `proof` collection + real rating -->
    <div class="bs-proof rv">
      {proof.map((item) => (
        <div class="bs-proof__item">
          <span class="bs-proof__icon"><Icon name={item.icon} size={22} /></span>
          <span class="bs-proof__stat">{item.stat}</span>
          <span class="bs-proof__label">{item.label}</span>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .bestsellers {
    padding: 120px 0 110px;
    background: var(--bg);
  }

  /* ── Header ── */
  .bs-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 52px;
  }

  .bs-head__left {
    flex: 1;
    min-width: 0;
  }

  .bs-head__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--fb);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
  }

  .bs-head__eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .bs-head__title {
    font-family: var(--fh);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -2px;
    line-height: 1;
    margin: 0;
  }

  .bs-head__right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 16px;
    flex-shrink: 0;
    padding-bottom: 4px;
  }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--fb);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 13px 28px;
    transition: background var(--ease), color var(--ease), border-color var(--ease), transform .12s ease;
    cursor: pointer;
  }

  .btn:active {
    transform: scale(.97)
  }

  .btn-outline {
    background: transparent;
    color: var(--text);
    border: 1.5px solid var(--text)
  }

  .btn-outline:hover {
    background: var(--text);
    color: var(--white)
  }

  /* ── 3-column even grid ── */
  .bs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* Card wrapper carries the rank badge over the shared ProductCard. */
  .bs-card {
    position: relative;
  }

  /* Rank badge */
  .bs-rank {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 5;
    font-family: var(--fh);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: .3px;
    color: var(--text);
    background: rgba(255, 255, 255, .92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, .45);
    border-radius: 3px;
    padding: 3px 9px;
    line-height: 1.5;
  }

  /* Nudge ProductCard's own badges down so they never sit under the rank. */
  .bs-card :global(.prod-badges) {
    top: 46px;
  }

  /* ── Trust / Proof strip ── */
  .bs-proof {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    margin-top: 52px;
  }

  .bs-proof__item {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 24px 22px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 4px;
    transition: border-color .2s ease, box-shadow .2s ease;
  }

  .bs-proof__item:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 20px rgba(0, 0, 0, .06);
  }

  .bs-proof__icon {
    display: inline-flex;
    color: var(--accent);
    flex-shrink: 0;
  }

  .bs-proof__stat {
    font-family: var(--fh);
    font-size: 22px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -.5px;
    line-height: 1;
  }

  .bs-proof__label {
    font-family: var(--fb);
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
    letter-spacing: .1px;
  }

  @media (max-width: 1100px) {
    .bs-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .bs-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .bs-proof {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
