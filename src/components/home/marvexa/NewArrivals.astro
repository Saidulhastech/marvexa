---
import ProductCard from '~/components/product/omnix/ProductCard.astro';
import type { ProductCard as TProductCard } from '~/lib/shopify/types';

interface Props {
  products: TProductCard[];
}

const { products } = Astro.props;
---

<section class="new-arrivals" aria-labelledby="na-h">
  <div class="wrap">

    <!-- Section header — left title · right filters -->
    <div class="na-header rv">
      <div class="na-header__left">
        <div class="na-header__eyebrow">New Arrivals</div>
        <h2 class="na-header__title" id="na-h">Fresh This Week</h2>
      </div>
      <div class="na-filters" role="tablist" aria-label="Filter by category">
        <button class="na-tab on" role="tab" aria-selected="true" data-cat="all">All</button>
        <button class="na-tab" role="tab" aria-selected="false" data-cat="women">Women</button>
        <button class="na-tab" role="tab" aria-selected="false" data-cat="men">Men</button>
        <button class="na-tab" role="tab" aria-selected="false" data-cat="accessories">Accessories</button>
      </div>
    </div>

    <!-- Products grid -->
    <div class="products-grid rv d1" id="na-grid">
      {products.map((p, i) => (
        <ProductCard product={p} eager={i < 4} attrs={{ 'data-cat': (p.productType ?? '').toLowerCase() }} />
      ))}
    </div>

  </div>
</section>

<script>
  function initNewArrivalsFilter() {
    const grid = document.getElementById('na-grid');
    if (!grid) return;

    const tabs = document.querySelectorAll<HTMLButtonElement>('.na-filters .na-tab');
    const cards = grid.querySelectorAll<HTMLElement>('.prod-card');

    function applyFilter(cat: string) {
      cards.forEach((card) => {
        const cardCat = (card.getAttribute('data-cat') ?? '').toLowerCase();
        const show = cat === 'all' || cardCat.includes(cat);
        card.style.display = show ? '' : 'none';
      });
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const cat = (tab.getAttribute('data-cat') ?? 'all').toLowerCase();
        tabs.forEach((t) => {
          t.classList.remove('on');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('on');
        tab.setAttribute('aria-selected', 'true');
        applyFilter(cat);
      });
    });
  }

  initNewArrivalsFilter();
</script>

<style>
  /* ══════════════════════════════════════════════════
   ⑥ NEW ARRIVALS
══════════════════════════════════════════════════ */
  .new-arrivals {
    padding: 0px 120px 120px 120px;
    background: var(--bg);
  }

  /* Section header — left title, right filters */
  .na-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 40px;
  }

  .na-header__left {
    flex: 1;
    min-width: 0;
  }

  .na-header__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--fb);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
  }

  .na-header__eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .na-header__title {
    font-family: var(--fh);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -2px;
    line-height: 1;
    margin: 0;
  }

  /* Filter tabs — pill style, right-aligned */
  .na-filters {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    background: var(--bg2);
    border: 1px solid var(--border);
    padding: 4px;
    border-radius: 40px;
    flex-shrink: 0;
    margin-bottom: 4px;
  }

  .na-tab {
    font-family: var(--fb);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .3px;
    color: var(--muted);
    padding: 7px 18px;
    cursor: pointer;
    transition: all .2s ease;
    background: none;
    border: none;
    border-radius: 30px;
    line-height: 1;
    white-space: nowrap;
  }

  .na-tab.on,
  .na-tab:hover {
    background: var(--white);
    color: var(--text);
    box-shadow: 0 1px 4px rgba(0, 0, 0, .08);
  }

  /* Products grid */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  @media (max-width: 1100px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
  }
</style>
