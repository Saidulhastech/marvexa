---
// ============================================================
//  Shop the Look (Marvexa) — curated outfit looks, LIVE Shopify data.
//  Each look's hotspots resolve to real products (pinned by handle or
//  filled from best-sellers in src/pages/index.astro). Name / price /
//  image and the inline size + colour variant pickers all come from
//  Shopify. "Add Complete Look" adds every selected variant in one go.
//  Editorial bits (look photo, label, pin coordinates) live in
//  src/content/lookbook.yaml.
// ============================================================
import { Image } from 'astro:assets';
import { formatMoney } from '~/lib/money';
import { tryResolveImage } from '~/lib/asset';
import { colorHex } from '~/lib/shopify/transforms';
import type { ProductCard, Product } from '~/lib/shopify/types';

interface LookItemIn { top: string; left: string; cardLeft: boolean; product: ProductCard | Product | null }
interface LookIn { id: string; label: string; image: string; items: LookItemIn[] }
const { looks = [] } = Astro.props as { looks: LookIn[] };

const COLOR_RE = /colou?r|finish|shade/i;
const isUrl = (s: string) => /^https?:\/\//.test(s);

// Build a render view-model for one hotspot product, mirroring ProductCard's
// variant logic: every real option becomes an inline picker; a single in-stock
// variant resolves the add target directly.
function buildItem(raw: LookItemIn) {
  const p = raw.product;
  if (!p) return null;
  const variants = p.variants ?? [];
  const realOptions = (p.options ?? []).filter(
    (o) => !(o.name === 'Title' && o.optionValues.every((v) => v.name === 'Default Title')),
  );
  const colorOpt = realOptions.find((o) => COLOR_RE.test(o.name) || o.optionValues.some((v) => v.swatch?.color));
  const def = variants.find((v) => v.availableForSale) ?? variants[0] ?? null;
  const min = p.priceRange?.minVariantPrice;
  const currency = min?.currencyCode ?? def?.price.currencyCode ?? 'USD';

  // An option value is sellable when at least one available variant carries it.
  const valueAvailable = (optName: string, val: string) =>
    variants.some((v) => v.availableForSale && v.selectedOptions.some((o) => o.name === optName && o.value === val));

  const options = realOptions.map((o) => ({
    name: o.name,
    isColor: o === colorOpt,
    values: o.optionValues.map((ov) => ({
      name: ov.name,
      // Real Shopify swatch hex when set, else map the colour name → hex.
      color: o === colorOpt ? colorHex(ov.name, ov.swatch?.color) : null,
      available: valueAvailable(o.name, ov.name),
    })),
  }));
  // Compact variant table the client uses to resolve a selection → variant id,
  // price and image (so picking a colour swaps the thumbnail).
  const variantTable = variants.map((v) => ({
    id: v.id,
    opts: Object.fromEntries(v.selectedOptions.map((o) => [o.name, o.value])),
    price: Number(v.price.amount),
    img: v.image?.url ?? null,
    available: v.availableForSale,
  }));
  const defaultOpts = def ? Object.fromEntries(def.selectedOptions.map((o) => [o.name, o.value])) : {};
  const price = def ? Number(def.price.amount) : Number(min?.amount ?? 0);
  const cat =
    (p as ProductCard).collections?.[0]?.title ?? p.productType ?? p.vendor ?? '';

  return {
    handle: p.handle,
    title: p.title,
    href: `/products/${p.handle}`,
    img: p.featuredImage?.url ?? '',
    cat,
    currency,
    soldOut: !p.availableForSale,
    defaultVariantId: def?.id ?? null,
    defaultOpts,
    price,
    priceLabel: formatMoney(def?.price ?? min ?? null),
    hasOptions: options.length > 0,
    options,
    variantTable,
    top: raw.top,
    left: raw.left,
    cardLeft: raw.cardLeft,
  };
}

const looksVm = looks
  .map((l) => {
    const items = l.items.map(buildItem).filter((x): x is NonNullable<typeof x> => x !== null);
    const currency = items[0]?.currency ?? 'USD';
    const total = items.reduce((s, it) => s + it.price, 0);
    return {
      id: l.id,
      label: l.label,
      currency,
      items,
      totalLabel: formatMoney({ amount: String(total), currencyCode: currency }),
      imgAsset: isUrl(l.image) ? null : tryResolveImage(l.image),
      imgUrl: isUrl(l.image) ? l.image : null,
    };
  })
  .filter((l) => l.items.length > 0);

const hasLooks = looksVm.length > 0;

// Inline bag SVG (reused on every add button).
const bagSvg =
  '<path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>';
---

{hasLooks && (
  <section class="stl" id="lb" aria-labelledby="stl-h" data-stl>
    <div class="stl__inner">

      {/* ═══ LEFT: Image panel — one slot per look ═══ */}
      <div class="stl__img-panel">
        {looksVm.map((look, li) => (
          <div class:list={['stl__img-slot', { active: li === 0 }]} data-look-slot={look.id}>
            <div class="stl__look-label">
              <span class="stl__look-dot" />
              <span class="stl__look-label-text">{look.label}</span>
            </div>
            {look.imgAsset ? (
              <Image src={look.imgAsset} alt={look.label} class="stl__img" loading="lazy" width={1200} height={1500} />
            ) : (
              <img src={look.imgUrl} alt={look.label} class="stl__img" loading="lazy" />
            )}

            {look.items.map((it, idx) => (
              <div class="stl__pin" style={`top:${it.top};left:${it.left};`} aria-label={it.title} role="button" tabindex="0">
                <div class="stl__pin-dot">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                    <path d="M12 5v14M5 12h14" />
                  </svg>
                </div>
                <div class:list={['stl__pin-popup', it.cardLeft ? 'pop-left' : 'pop-right']}>
                  {it.img && <img src={it.img} class="stl__popup-img" alt={it.title} />}
                  <div class="stl__popup-body">
                    {it.cat && <div class="stl__popup-cat">{it.cat}</div>}
                    <div class="stl__popup-name">{it.title}</div>
                    <div class="stl__popup-row">
                      <span class="stl__popup-price">{it.priceLabel}</span>
                      {it.soldOut ? (
                        <a class="stl__popup-add" href={it.href}>View</a>
                      ) : (
                        <button class="stl__popup-add" data-stl-add data-look={look.id} data-idx={idx}>+ Bag</button>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        ))}
      </div>

      {/* ═══ RIGHT: Content panel ═══ */}
      <div class="stl__panel rv d1">
        <div class="stl__eyebrow">Shop the Look</div>
        <h2 class="stl__title" id="stl-h">Curated for the<br />Modern Wardrobe</h2>
        <p class="stl__desc">Pick your size, build the full outfit, add it in one tap.</p>

        {/* Look switcher thumbnails */}
        {looksVm.length > 1 && (
          <div class="stl__switcher" role="tablist" aria-label="Select a look">
            {looksVm.map((look, li) => (
              <button
                class:list={['stl__sw-btn', { active: li === 0 }]}
                data-look-switch={look.id}
                role="tab"
                aria-selected={li === 0 ? 'true' : 'false'}
                aria-label={`Look 0${li + 1}`}
              >
                {look.imgAsset ? (
                  <Image src={look.imgAsset} alt={`Look 0${li + 1}`} class="stl__sw-img" width={200} height={250} />
                ) : (
                  <img src={look.imgUrl} class="stl__sw-img" alt={`Look 0${li + 1}`} />
                )}
                <span class="stl__sw-label">Look 0{li + 1}</span>
              </button>
            ))}
          </div>
        )}

        {/* Per-look item lists */}
        {looksVm.map((look, li) => (
          <div class:list={['stl__look-block', { hidden: li !== 0 }]} data-look-block={look.id}>
            <div class="stl__items">
              {look.items.map((it, idx) => (
                <div
                  class="stl__item"
                  data-stl-item
                  data-look={look.id}
                  data-idx={idx}
                  data-variant-id={it.soldOut ? '' : it.defaultVariantId ?? ''}
                  data-price={it.price}
                  data-currency={it.currency}
                  data-img={it.img}
                  data-variants={JSON.stringify(it.variantTable)}
                  data-default={JSON.stringify(it.defaultOpts)}
                >
                  <span class="stl__item-num">0{idx + 1}</span>
                  {it.img ? (
                    <img src={it.img} alt={it.title} class="stl__item-img" loading="lazy" />
                  ) : (
                    // Always occupy the image's grid column even with no photo —
                    // omitting the element entirely shifts every following cell
                    // back one column (CSS Grid auto-placement), squeezing the
                    // info/size-picker column down to the image column's width.
                    <div class="stl__item-img stl__item-img--empty" role="img" aria-label={it.title}>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2" />
                        <circle cx="8.5" cy="8.5" r="1.5" />
                        <path d="m21 15-5-5L5 21" />
                      </svg>
                    </div>
                  )}
                  <div class="stl__item-info">
                    {it.cat && <div class="stl__item-cat">{it.cat}</div>}
                    <a class="stl__item-name" href={it.href}>{it.title}</a>
                    <div class="stl__item-bottom">
                      <span class="stl__item-price" data-row-price>{it.priceLabel}</span>
                    </div>

                    {/* Inline variant pickers — size as pills, colour as swatches */}
                    {it.options.map((opt) => (
                      <div class="stl__opt" data-opt data-opt-name={opt.name}>
                        {!opt.isColor && <span class="stl__opt-label">{opt.name}</span>}
                        <div class={opt.isColor ? 'stl__item-sws' : 'stl__sizes'}>
                          {opt.values.map((v) =>
                            opt.isColor ? (
                              <button
                                type="button"
                                class:list={['look-sw', { 'is-sel': it.defaultOpts[opt.name] === v.name, 'is-off': !v.available }]}
                                style={`background:${v.color ?? '#ccc'}`}
                                title={v.available ? v.name : `${v.name} — sold out`}
                                aria-label={v.name}
                                aria-pressed={it.defaultOpts[opt.name] === v.name}
                                data-val
                                data-opt-name={opt.name}
                                data-val-name={v.name}
                                disabled={!v.available}
                              />
                            ) : (
                              <button
                                type="button"
                                class:list={['stl__size', { active: it.defaultOpts[opt.name] === v.name, 'is-off': !v.available }]}
                                aria-pressed={it.defaultOpts[opt.name] === v.name}
                                data-val
                                data-opt-name={opt.name}
                                data-val-name={v.name}
                                disabled={!v.available}
                              >
                                {v.name}
                              </button>
                            ),
                          )}
                        </div>
                      </div>
                    ))}
                  </div>

                  {it.soldOut ? (
                    <a class="stl__item-add" href={it.href} aria-label="View product">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" set:html={bagSvg} />
                    </a>
                  ) : (
                    <button class="stl__item-add" data-stl-add data-look={look.id} data-idx={idx} aria-label="Add to bag">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" set:html={bagSvg} />
                    </button>
                  )}
                </div>
              ))}
            </div>

            {/* Total + add-all */}
            <div class="stl__total">
              <div class="stl__total-meta">
                <span class="stl__total-label">Complete Look · {look.items.length} items</span>
                <span class="stl__total-ship">✓ Free shipping included</span>
              </div>
              <div class="stl__total-right">
                <span class="stl__total-price" data-stl-total data-look={look.id} data-currency={look.currency}>{look.totalLabel}</span>
              </div>
            </div>
            <div class="stl__actions">
              <button class="stl__add-all" data-stl-addall data-look={look.id}>Add Complete Look to Cart</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .stl {
    background: var(--dark);
    overflow: hidden;
  }

  .stl__inner {
    display: grid;
    grid-template-columns: 58% 42%;
    min-height: 700px;
    align-items: stretch;
  }

  /* ── Left: Image panel ── */
  .stl__img-panel {
    position: relative;
    overflow: hidden;
    min-height: 700px;
    align-self: stretch;
  }

  .stl__img-slot {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity .55s cubic-bezier(.4, 0, .2, 1);
    pointer-events: none;
  }

  .stl__img-slot.active {
    opacity: 1;
    pointer-events: auto;
  }

  .stl__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: brightness(.82);
    transition: transform .7s cubic-bezier(.25, .46, .45, .94);
  }

  .stl__img-slot.active .stl__img {
    transform: scale(1);
  }

  .stl__img-slot:not(.active) .stl__img {
    transform: scale(1.04);
  }

  /* Look badge — top left */
  .stl__look-label {
    position: absolute;
    top: 24px;
    left: 24px;
    z-index: 6;
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, .1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, .15);
    border-radius: 30px;
    padding: 6px 16px 6px 8px;
    pointer-events: none;
  }

  .stl__look-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  .stl__look-label-text {
    font-family: var(--fb);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, .9);
  }

  /* ── Hotspot pins ── */
  .stl__pin {
    position: absolute;
    z-index: 5;
    cursor: pointer;
    padding: 0;
    -webkit-tap-highlight-color: transparent;
  }

  .stl__pin-dot {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(255, 255, 255, .95);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 0 0 rgba(255, 255, 255, .4);
    animation: stl-pulse 2.8s ease infinite;
    transition: transform .2s ease, background .2s ease;
    position: relative;
    z-index: 2;
  }

  .stl__pin:hover .stl__pin-dot,
  .stl__pin:focus-visible .stl__pin-dot {
    transform: scale(1.15);
    background: #fff;
  }

  .stl__pin:focus {
    outline: none;
  }

  .stl__pin:focus-visible {
    outline: 2px solid rgba(255, 255, 255, .5);
    outline-offset: 3px;
    border-radius: 50%;
  }

  .stl__pin-dot svg {
    flex-shrink: 0;
  }

  @keyframes stl-pulse {

    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(255, 255, 255, .35), 0 2px 12px rgba(0, 0, 0, .2);
    }

    50% {
      box-shadow: 0 0 0 10px rgba(255, 255, 255, 0), 0 2px 12px rgba(0, 0, 0, .2);
    }
  }

  /* Pin popup card */
  .stl__pin-popup {
    position: absolute;
    bottom: 42px;
    left: 50%;
    transform: translateX(-50%) translateY(6px);
    width: 190px;
    background: #fff;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, .22);
    opacity: 0;
    pointer-events: none;
    transition: opacity .22s ease, transform .22s cubic-bezier(.25, .46, .45, .94);
    z-index: 10;
  }

  .stl__pin-popup.pop-right {
    left: 38px;
    bottom: auto;
    top: 50%;
    transform: translateX(0) translateY(-50%) translateY(4px);
  }

  .stl__pin-popup.pop-left {
    left: auto;
    right: 38px;
    bottom: auto;
    top: 50%;
    transform: translateX(0) translateY(-50%) translateY(4px);
  }

  .stl__pin:hover .stl__pin-popup {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .stl__pin:hover .stl__pin-popup.pop-right {
    transform: translateX(0) translateY(-50%);
  }

  .stl__pin:hover .stl__pin-popup.pop-left {
    transform: translateX(0) translateY(-50%);
  }

  .stl__popup-img {
    width: 100%;
    height: 100px;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  .stl__popup-body {
    padding: 10px 12px 12px;
  }

  .stl__popup-cat {
    font-family: var(--fb);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 3px;
  }

  .stl__popup-name {
    font-family: var(--fb);
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
    margin-bottom: 6px;
  }

  .stl__popup-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .stl__popup-price {
    font-family: var(--fb);
    font-size: 13px;
    font-weight: 700;
    color: var(--text);
  }

  .stl__popup-add {
    font-family: var(--fb);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #fff;
    background: var(--dark);
    border: none;
    cursor: pointer;
    padding: 5px 11px;
    border-radius: 2px;
    text-decoration: none;
    transition: background .18s ease;
  }

  .stl__popup-add:hover {
    background: var(--accent);
  }

  /* ── Right: Content panel ── */
  .stl__panel {
    padding: 52px 48px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0;
    background: var(--dark);
  }

  .stl__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--fb);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
  }

  .stl__eyebrow::before {
    content: '';
    display: block;
    width: 22px;
    height: 1px;
    background: var(--accent);
  }

  .stl__title {
    font-family: var(--fh);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -1.5px;
    color: #fff;
    margin: 0 0 8px;
  }

  .stl__desc {
    font-family: var(--fb);
    font-size: 14px;
    line-height: 1.65;
    color: rgba(255, 255, 255, .45);
    margin: 0 0 28px;
  }

  /* Look switcher thumbnails */
  .stl__switcher {
    display: flex;
    gap: 8px;
    margin-bottom: 28px;
  }

  .stl__sw-btn {
    position: relative;
    flex: 1;
    height: 72px;
    border: 2px solid transparent;
    border-radius: 4px;
    overflow: hidden;
    cursor: pointer;
    padding: 0;
    background: none;
    transition: border-color .22s ease;
  }

  .stl__sw-btn.active {
    border-color: var(--accent);
  }

  .stl__sw-btn:not(.active):hover {
    border-color: rgba(255, 255, 255, .25);
  }

  .stl__sw-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
    filter: brightness(.7);
    transition: filter .22s ease;
  }

  .stl__sw-btn.active .stl__sw-img,
  .stl__sw-btn:hover .stl__sw-img {
    filter: brightness(.85);
  }

  .stl__sw-label {
    position: absolute;
    bottom: 5px;
    left: 0;
    right: 0;
    text-align: center;
    font-family: var(--fb);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, .9);
  }

  /* Look blocks */
  .stl__look-block.hidden {
    display: none;
  }

  /* Product items */
  .stl__items {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 24px;
  }

  .stl__item {
    display: grid;
    grid-template-columns: 18px 52px 1fr auto;
    align-items: start;
    gap: 12px;
    padding: 12px 14px;
    background: rgba(255, 255, 255, .04);
    border: 1px solid rgba(255, 255, 255, .07);
    border-radius: 6px;
    transition: background .2s ease, border-color .2s ease;
  }

  .stl__item:hover {
    background: rgba(255, 255, 255, .07);
    border-color: rgba(255, 255, 255, .12);
  }

  /* Highlighted when the shopper tries to add without picking a size. */
  .stl__item--need {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent) inset;
  }

  .stl__item-num {
    font-family: var(--fb);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .5px;
    color: rgba(255, 255, 255, .25);
    line-height: 1;
    padding-top: 4px;
  }

  .stl__item-img {
    width: 52px;
    height: 60px;
    object-fit: cover;
    object-position: top;
    border-radius: 3px;
    display: block;
    flex-shrink: 0;
  }

  .stl__item-img--empty {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, .05);
    border: 1px solid rgba(255, 255, 255, .08);
    color: rgba(255, 255, 255, .3);
  }

  .stl__item-info {
    flex: 1;
    min-width: 0;
  }

  .stl__item-cat {
    font-family: var(--fb);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: .8px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, .3);
    margin-bottom: 3px;
  }

  .stl__item-name {
    display: block;
    font-family: var(--fb);
    font-size: 13px;
    font-weight: 600;
    color: #fff;
    line-height: 1.3;
    margin-bottom: 6px;
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .stl__item-name:hover {
    color: var(--accent);
  }

  .stl__item-bottom {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .stl__item-price {
    font-family: var(--fb);
    font-size: 13px;
    font-weight: 700;
    color: rgba(255, 255, 255, .9);
  }

  /* Inline option pickers */
  .stl__opt {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 6px;
  }

  .stl__opt-label {
    font-family: var(--fb);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .6px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, .3);
    flex-shrink: 0;
  }

  .stl__sizes {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .stl__size {
    min-width: 26px;
    padding: 4px 7px;
    font-family: var(--fb);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .4px;
    color: rgba(255, 255, 255, .75);
    background: rgba(255, 255, 255, .05);
    border: 1px solid rgba(255, 255, 255, .15);
    border-radius: 3px;
    cursor: pointer;
    transition: all .16s ease;
  }

  .stl__size:hover {
    border-color: rgba(255, 255, 255, .4);
    color: #fff;
  }

  .stl__size.active {
    background: #fff;
    border-color: #fff;
    color: var(--dark);
  }

  .stl__size.is-off {
    opacity: .35;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  .stl__item-sws {
    display: flex;
    gap: 4px;
  }

  .look-sw {
    width: 14px;
    height: 14px;
    padding: 0;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, .18);
    display: block;
    flex-shrink: 0;
    cursor: pointer;
    transition: transform .15s ease, box-shadow .15s ease;
  }

  .look-sw:hover {
    transform: scale(1.12);
  }

  .look-sw.is-sel {
    box-shadow: 0 0 0 2px var(--dark), 0 0 0 3px #fff;
  }

  .look-sw.is-off {
    opacity: .35;
    cursor: not-allowed;
  }

  .stl__item-add {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, .15);
    background: rgba(255, 255, 255, .05);
    color: rgba(255, 255, 255, .7);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .18s ease, border-color .18s ease, color .18s ease;
    flex-shrink: 0;
  }

  .stl__item-add:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .stl__item-add.added {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  /* Total bar */
  .stl__total {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0;
    border-top: 1px solid rgba(255, 255, 255, .08);
    border-bottom: 1px solid rgba(255, 255, 255, .08);
    margin-bottom: 20px;
  }

  .stl__total-meta {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .stl__total-label {
    font-family: var(--fb);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, .4);
  }

  .stl__total-ship {
    font-family: var(--fb);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: .2px;
  }

  .stl__total-right {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .stl__total-price {
    font-family: var(--fh);
    font-size: 24px;
    font-weight: 700;
    color: #fff;
    letter-spacing: -.5px;
  }

  /* Actions */
  .stl__actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .stl__add-all {
    flex: 1;
    padding: 14px 20px;
    background: var(--accent);
    color: #fff;
    font-family: var(--fb);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    border-radius: 3px;
    transition: background .2s ease, transform .15s ease;
  }

  .stl__add-all:hover {
    background: #8fa342;
    transform: translateY(-1px);
  }

  .stl__add-all:active {
    transform: translateY(0);
  }

  /* ── Responsive: stack the two panels below the desktop split ── */
  @media (max-width: 980px) {
    .stl__inner {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .stl__img-panel {
      min-height: 0;
      aspect-ratio: 4 / 5;
    }

    .stl__img-slot {
      position: relative;
      opacity: 1;
      height: 100%;
    }

    .stl__img-slot:not(.active) {
      display: none;
    }

    .stl__panel {
      padding: 40px var(--gutter, 24px);
    }
  }

  @media (max-width: 600px) {
    .stl__panel {
      padding: 32px 20px;
    }

    .stl__item-name {
      white-space: normal;
    }

    .stl__title {
      font-size: clamp(28px, 8vw, 40px);
    }
  }
</style>

<script>
  // ── Shop the Look — inline variant selection + complete-look add ──
  import { addItem, openCart } from '../../../stores/cart';

  type Variant = { id: string; opts: Record<string, string>; price: number; img: string | null; available: boolean };

  function money(n: number, cur: string): string {
    try {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: cur,
        minimumFractionDigits: n % 1 === 0 ? 0 : 2,
      }).format(n);
    } catch {
      return `${cur} ${n.toFixed(2)}`;
    }
  }

  function initLookbook() {
    const root = document.querySelector<HTMLElement>('[data-stl]');
    if (!root) return;

    const findRow = (look: string, idx: string) =>
      root.querySelector<HTMLElement>(`[data-stl-item][data-look="${look}"][data-idx="${idx}"]`);

    // Swap the row thumbnail (and its matching pin popup image) to `url`.
    function swapImg(row: HTMLElement, url?: string | null) {
      if (!url) return;
      const thumb = row.querySelector<HTMLImageElement>('.stl__item-img');
      if (thumb) thumb.src = url;
      const pinAdd = root!.querySelector<HTMLElement>(
        `.stl__pin [data-stl-add][data-look="${row.dataset.look}"][data-idx="${row.dataset.idx}"]`,
      );
      const popImg = pinAdd?.closest('.stl__pin')?.querySelector<HTMLImageElement>('.stl__popup-img');
      if (popImg) popImg.src = url;
    }

    // Resolve a row's current option selection → variant id + price + image.
    function resolveRow(row: HTMLElement) {
      const variants: Variant[] = JSON.parse(row.dataset.variants || '[]');
      const sel: Record<string, string> = JSON.parse(row.dataset.selected || row.dataset.default || '{}');
      const keys = Object.keys(sel);
      // No options → keep the server-rendered default variant id.
      if (keys.length && variants.length) {
        const match = variants.find((v) => keys.every((k) => v.opts[k] === sel[k]));
        row.dataset.variantId = match && match.available ? match.id : '';
        if (match) {
          row.dataset.price = String(match.price);
          const pr = row.querySelector<HTMLElement>('[data-row-price]');
          if (pr) pr.textContent = money(match.price, row.dataset.currency || 'USD');
          // Variant image when set, else fall back to the product's featured image.
          swapImg(row, match.img || row.dataset.img);
        }
      }
      row.classList.remove('stl__item--need');
      updateTotal(row.dataset.look || '');
    }

    function updateTotal(look: string) {
      const rows = root!.querySelectorAll<HTMLElement>(`[data-stl-item][data-look="${look}"]`);
      let sum = 0;
      rows.forEach((r) => (sum += Number(r.dataset.price || 0)));
      const el = root!.querySelector<HTMLElement>(`[data-stl-total][data-look="${look}"]`);
      if (el) el.textContent = money(sum, el.dataset.currency || 'USD');
    }

    function selectVal(row: HTMLElement, name: string, val: string) {
      const grp = row.querySelector(`[data-opt][data-opt-name="${name}"]`);
      grp?.querySelectorAll<HTMLElement>('[data-val]').forEach((b) => {
        const on = b.dataset.valName === val;
        b.setAttribute('aria-pressed', String(on));
        if (b.classList.contains('look-sw')) b.classList.toggle('is-sel', on);
        else b.classList.toggle('active', on);
      });
      const sel: Record<string, string> = JSON.parse(row.dataset.selected || row.dataset.default || '{}');
      sel[name] = val;
      row.dataset.selected = JSON.stringify(sel);
      resolveRow(row);
    }

    function flagNeed(row: HTMLElement) {
      row.classList.add('stl__item--need');
      setTimeout(() => row.classList.remove('stl__item--need'), 2400);
    }

    function feedbackAdd(row: HTMLElement) {
      const btn = row.querySelector<HTMLElement>('[data-stl-add]');
      if (!btn) return;
      btn.classList.add('added');
      setTimeout(() => btn.classList.remove('added'), 1800);
    }

    function switchLook(id: string) {
      root!.querySelectorAll<HTMLElement>('[data-look-slot]').forEach((s) =>
        s.classList.toggle('active', s.dataset.lookSlot === id),
      );
      root!.querySelectorAll<HTMLElement>('[data-look-block]').forEach((b) =>
        b.classList.toggle('hidden', b.dataset.lookBlock !== id),
      );
      root!.querySelectorAll<HTMLElement>('[data-look-switch]').forEach((b) => {
        const on = b.dataset.lookSwitch === id;
        b.classList.toggle('active', on);
        b.setAttribute('aria-selected', String(on));
      });
    }

    async function addAll(look: string, btn: HTMLElement) {
      const rows = [...root!.querySelectorAll<HTMLElement>(`[data-stl-item][data-look="${look}"]`)];
      // Sold-out items render a "View" link (no add button) and never resolve a
      // variant — skip them, don't treat them as an un-picked size.
      const active = rows.filter((r) => r.querySelector('button[data-stl-add]'));
      const needSize = active.filter((r) => !r.dataset.variantId);
      if (needSize.length) {
        needSize.forEach(flagNeed);
        const t = btn.textContent;
        btn.textContent = 'Select all sizes';
        setTimeout(() => (btn.textContent = t), 2200);
        return;
      }
      const ids = active.map((r) => r.dataset.variantId!).filter(Boolean);
      if (!ids.length) {
        const t = btn.textContent;
        btn.textContent = 'Nothing available';
        setTimeout(() => (btn.textContent = t), 2200);
        return;
      }
      btn.setAttribute('disabled', '');
      // Open the drawer up front (it shows a loading spinner while busy) so the
      // shopper gets instant feedback instead of waiting for every line to POST.
      // Then add sequentially — the store's seq guard would otherwise drop
      // earlier concurrent replies. Suppress addItem's own auto-open.
      openCart();
      for (const id of ids) await addItem(id, 1, { open: false });
      const t = btn.textContent;
      btn.textContent = '✓ Added to Cart';
      btn.style.background = '#4a7a1e';
      setTimeout(() => {
        btn.textContent = t;
        btn.style.background = '';
        btn.removeAttribute('disabled');
      }, 2500);
    }

    // Delegated clicks
    root.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      const val = target.closest<HTMLElement>('[data-val]');
      if (val && !(val as HTMLButtonElement).disabled) {
        const row = val.closest<HTMLElement>('[data-stl-item]');
        if (row) selectVal(row, val.dataset.optName!, val.dataset.valName!);
        return;
      }

      const add = target.closest<HTMLElement>('[data-stl-add]');
      if (add) {
        const row = findRow(add.dataset.look!, add.dataset.idx!);
        if (!row) return;
        if (!row.dataset.variantId) {
          flagNeed(row);
          return;
        }
        addItem(row.dataset.variantId, 1).then(() => openCart());
        feedbackAdd(row);
        return;
      }

      const all = target.closest<HTMLElement>('[data-stl-addall]');
      if (all) {
        addAll(all.dataset.look!, all);
        return;
      }

      const sw = target.closest<HTMLElement>('[data-look-switch]');
      if (sw) switchLook(sw.dataset.lookSwitch!);
    });

    // Keyboard: pins are focusable; Enter/Space adds the first hotspot item.
    root.querySelectorAll<HTMLElement>('.stl__pin').forEach((pin) => {
      pin.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          pin.querySelector<HTMLElement>('[data-stl-add]')?.click();
        }
      });
    });

    // Seed each row's resolved variant + per-look totals.
    root.querySelectorAll<HTMLElement>('[data-stl-item]').forEach((row) => {
      row.dataset.selected = row.dataset.default || '{}';
      resolveRow(row);
    });
  }

  initLookbook();
</script>
