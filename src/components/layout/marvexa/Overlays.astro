---
// ============================================================
//  Overlays (MARVEXA) — search overlay, account drawer, wishlist
//  drawer, newsletter popup, back-to-top + the global UI controller
//  that opens/closes them via [data-open]/[data-close] triggers and
//  ⌘K / Esc. Cart opening is delegated to the nanostore.
//  Account → links to real /account routes. Wishlist → localStorage
//  (no Shopify wishlist). Newsletter → UI only.
// ============================================================
import Icon from '~/components/ui/marvexa/Icon.astro';
import { BRAND } from '~/config/marvexa';
import { resolveImage } from '~/lib/asset';
import { getProducts, type ProductCard } from '~/lib/shopify';
import { formatMoney } from '~/lib/money';
import { Image } from 'astro:assets';

// Trending pills + "Popular right now" cards from real catalog data — the
// categories/brands and top best-sellers. Falls back to a static list if
// Shopify is unreachable.
let trending: string[] = [];
let popular: ProductCard[] = [];
try {
  const { items } = await getProducts({ pageSize: 16, sortKey: 'BEST_SELLING' }, Astro.locals.market);
  popular = items.slice(0, 4);
  const seen = new Set<string>();
  for (const p of items) {
    for (const term of [p.productType, p.vendor]) {
      const t = (term ?? '').trim();
      // Skip blanks, the shop-handle vendor (e.g. "elexy-demo"), and dups.
      if (!t || t.includes('-') || seen.has(t.toLowerCase())) continue;
      seen.add(t.toLowerCase());
      trending.push(t);
    }
  }
  trending = trending.slice(0, 8);
} catch {
  /* fall back below */
}
if (trending.length === 0) {
  trending = [
    'Linen Blazer', 'Wide Leg Trousers', 'Knitwear', 'Dresses',
    'Leather Bags', 'Silk Shirts', 'New Arrivals', 'Sale',
  ];
}
const popupImg = resolveImage('look-01.webp');
---

{/* SEARCH OVERLAY */}
<div class="search-overlay" id="searchOverlay">
  <div class="search-box">
    <form class="search-input-row" id="searchForm">
      <span class="search-ic"><Icon name="search" size={20} /></span>
      <input type="search" id="searchInput" name="q" aria-label="Search styles, collections, products" placeholder="Search styles, collections, products…" autocomplete="off" />
      <span class="search-spinner" id="searchSpinner" aria-hidden="true"></span>
      <button type="button" class="search-close-btn" data-close="search" aria-label="Close search"><Icon name="x" size={18} stroke={2.2} /></button>
    </form>
    <div class="search-hints" id="searchHints">
      <div class="search-hint-label">Trending Searches</div>
      <div class="search-hint-pills">
        {trending.map((t) => <button class="search-hint-pill" type="button" data-q={t}>{t}</button>)}
      </div>
      {popular.length > 0 && (
        <div class="search-pop">
          <div class="search-hint-label">Popular Right Now</div>
          <div class="search-pop-grid">
            {popular.map((p) => (
              <a class="search-pop-card" href={`/products/${p.handle}`}>
                <span class="search-pop-media">
                  {p.featuredImage?.url && (
                    <img src={`${p.featuredImage.url}${p.featuredImage.url.includes('?') ? '&' : '?'}width=360`} alt={p.featuredImage.altText ?? p.title} loading="lazy" />
                  )}
                </span>
                <span class="search-pop-name">{p.title}</span>
                <span class="search-pop-price">{formatMoney(p.priceRange.minVariantPrice)}</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
    {/* Live results (real Shopify predictive search) injected here as you type. */}
    <div class="search-results" id="searchResults" hidden></div>
  </div>
</div>

{/* ACCOUNT DRAWER */}
<div class="acct-overlay" data-close="account"></div>
<aside class="acct-drawer" id="acctDrawer" role="dialog" aria-modal="true" aria-label="Account">
  <div class="acct-head">
    <h5>My Account</h5>
    <button class="acct-x" data-close="account" aria-label="Close account"><Icon name="x" size={16} stroke={2.4} /></button>
  </div>
  <div class="acct-hero">
    <div class="acct-avatar-wrap"><Icon name="user" size={28} stroke={1.8} /></div>
    <div class="acct-hero-text">
      <span>Welcome to {BRAND.name}</span>
      <strong>Sign in for the best experience</strong>
    </div>
    <div class="acct-cta-row">
      <a href="/account/login" class="acct-btn-primary">Sign In</a>
      <a href="/account/login" class="acct-btn-ghost">Register</a>
    </div>
  </div>
  <div class="acct-body">
    <div class="acct-section-label">Quick Links</div>
    <a href="/account" class="acct-link"><Icon name="user" size={16} /> Your account</a>
    <a href="/products" class="acct-link"><Icon name="cart" size={16} /> Continue shopping</a>
    <a href="/contact" class="acct-link"><Icon name="mail" size={16} /> Contact Us</a>
  </div>
</aside>

{/* WISHLIST DRAWER (localStorage only) */}
<div class="wish-overlay" data-close="wishlist"></div>
<aside class="wish-drawer" id="wishDrawer" role="dialog" aria-modal="true" aria-label="Wishlist">
  <div class="wish-drawer__head">
    <div class="wish-drawer__head-left">
      <span class="wish-drawer__title">Wishlist</span>
      <span class="wish-drawer__sub" id="wishCount">0 saved items</span>
    </div>
    <button class="wish-x" data-close="wishlist" aria-label="Close wishlist"><Icon name="x" size={16} stroke={2.4} /></button>
  </div>
  <div class="wish-drawer__body">
    <div class="wish-empty" id="wishEmpty">
      <Icon name="heart" size={48} stroke={1.5} />
      <p>Your wishlist is empty. Save items you love and find them here.</p>
    </div>
    <div id="wishList"></div>
  </div>
  <div class="wish-foot" id="wishFoot" style="display:none">
    <button class="btn btn-primary btn-block" id="wishMoveAll" type="button">
      Move All to Bag <Icon name="arrow-right" size={14} stroke={2.4} />
    </button>
  </div>
</aside>

{/* NEWSLETTER POPUP (UI only) */}
<div class="popup-backdrop" id="popupBackdrop" role="dialog" aria-modal="true" aria-labelledby="popupTitle">
  <div class="popup">
    <div class="popup-visual"><Image src={popupImg} alt="Newsletter" width={420} height={520} /></div>
    <div class="popup-body">
      <button class="popup-close" data-close="popup" aria-label="Close popup"><Icon name="x" size={16} stroke={2.4} /></button>
      <div id="popupFormView">
        <div class="popup-eyebrow">Limited offer</div>
        <h4 id="popupTitle">Get 10% off your<br />first {BRAND.name} order.</h4>
        <p>Drop your email below. We'll send your discount code instantly — no strings attached.</p>
        <form class="popup-form" id="popupForm" novalidate>
          <div class="popup-input-wrap">
            <Icon name="mail" size={16} />
            <input class="popup-input" type="email" name="email" aria-label="Email address" placeholder="your@email.com" required autocomplete="email" />
          </div>
          <button type="submit" class="popup-submit">Claim my 10% off <Icon name="arrow-right" size={16} stroke={2.4} /></button>
        </form>
        <p class="popup-skip">No thanks, <a href="#" data-close="popup">I'll pay full price</a>.</p>
      </div>
      <div class="popup-success" id="popupSuccess">
        <div class="success-ic"><Icon name="check" size={30} stroke={2.4} /></div>
        <h5>You're in! Welcome to {BRAND.name}.</h5>
        <p>Your discount code is ready. Use it at checkout today.</p>
        <div class="popup-discount"><span class="code">WELCOME10</span><button class="copy-btn" id="copyCodeBtn">Copy</button></div>
      </div>
    </div>
  </div>
</div>

{/* QUICK VIEW MODAL — populated from the card's data-* attributes */}
<div class="qv-overlay" id="qvOverlay" role="dialog" aria-modal="true" aria-labelledby="qvName">
  <div class="qv-modal">
    <button class="qv-close" data-close="qview" aria-label="Close quick view"><Icon name="x" size={16} stroke={2.4} /></button>
    <div class="qv-media"><img id="qvImg" src="" alt="" /></div>
    <div class="qv-body">
      <div class="qv-brand" id="qvBrand"></div>
      <div class="qv-name" id="qvName"></div>
      <div class="qv-rating" id="qvRating" style="display:none"></div>
      <div class="qv-price-row">
        <span class="now" id="qvPrice"></span>
        <span class="was" id="qvWas" style="display:none"></span>
        <span class="save" id="qvSave" style="display:none"></span>
      </div>
      <div class="qv-divider"></div>
      <p class="qv-desc" id="qvDesc"></p>
      <ul class="qv-specs" id="qvSpecs"></ul>
      <div class="qv-variants" id="qvVariants"></div>
      <div class="qv-divider"></div>
      <div class="qv-buy">
        <div class="qv-qty">
          <button type="button" id="qvQtyDec" aria-label="Decrease quantity">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/></svg>
          </button>
          <input type="text" id="qvQty" value="1" inputmode="numeric" aria-label="Quantity" />
          <button type="button" id="qvQtyInc" aria-label="Increase quantity">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
          </button>
        </div>
        <button class="btn btn-primary" id="qvAdd"><Icon name="cart" size={16} stroke={2.4} /> Add to Cart</button>
        <button class="btn btn-secondary qv-wishbtn" id="qvWish" aria-label="Add to wishlist"><Icon name="heart" size={16} /></button>
      </div>
      <a class="qv-details" id="qvDetails" href="#">View full details
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>
</div>

{/* BACK TO TOP */}
<button class="to-top" id="toTop" aria-label="Back to top"><Icon name="arrow-up" size={18} stroke={2.4} /></button>

<style>
  /* ════════════════════════════════════════════════════════════════
     OVERLAYS (Marvexa skin) — search, account, wishlist, popup,
     quick-view, back-to-top, toast. Markup/IDs/classes are produced
     by the controller script below; only visuals live here.
  ════════════════════════════════════════════════════════════════ */

  /* ── Shared spin keyframe ─────────────────────────────────────── */
  @keyframes marvexa-spin { to { transform: rotate(360deg); } }

  /* ── Search overlay (full-screen blur) ───────────────────────── */
  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 1200;
    background: rgba(250, 250, 247, .98);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    display: flex;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity .25s ease;
  }

  .search-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .search-box {
    width: 100%;
    max-width: 760px;
    padding: 56px var(--gutter) 32px;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  }

  .search-input-row {
    display: flex;
    align-items: center;
    gap: 14px;
    border-bottom: 2px solid var(--text);
    padding-bottom: 16px;
  }

  .search-ic {
    color: var(--muted);
    display: flex;
    flex-shrink: 0;
  }

  #searchInput {
    flex: 1;
    font-family: var(--fh);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 600;
    letter-spacing: -.5px;
    color: var(--text);
    background: none;
    border: none;
  }

  #searchInput::placeholder {
    color: var(--border);
  }

  .search-spinner {
    width: 18px;
    height: 18px;
    border: 2px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    flex-shrink: 0;
    display: none;
  }

  .search-spinner.is-on {
    display: block;
    animation: marvexa-spin .6s linear infinite;
  }

  .search-close-btn {
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--card);
    border-radius: 50%;
    color: var(--text);
    transition: background .2s ease, color .2s ease;
    flex-shrink: 0;
  }

  .search-close-btn kbd {
    font-family: var(--fb);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .5px;
  }

  .search-close-btn:hover {
    background: var(--text);
    color: #fff;
  }

  .search-hints {
    padding-top: 32px;
  }

  .search-hint-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 12px;
  }

  .search-hint-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .search-hint-pill {
    padding: 8px 14px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 50px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
    transition: all .18s ease;
  }

  .search-hint-pill:hover {
    background: var(--text);
    color: #fff;
    border-color: var(--text);
  }

  /* Popular right now (default product grid) */
  .search-pop {
    margin-top: 32px;
  }

  .search-pop-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  .search-pop-card {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .search-pop-media {
    display: block;
    aspect-ratio: 1 / 1;
    border-radius: 10px;
    overflow: hidden;
    background: var(--card);
    margin-bottom: 10px;
  }

  .search-pop-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform .4s ease;
  }

  .search-pop-card:hover .search-pop-media img {
    transform: scale(1.04);
  }

  .search-pop-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
    margin-bottom: 3px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .search-pop-card:hover .search-pop-name {
    color: var(--accent);
  }

  .search-pop-price {
    font-size: 12px;
    color: var(--muted);
  }

  /* Live results container (template element → scoped is fine).
     The .sr-* CHILDREN are injected via innerHTML at runtime, so Astro's
     scope attribute never reaches them — their styles live in the global
     sheet (src/styles/drawers.css, .search-results .sr-…). */
  .search-results {
    padding-top: 28px;
  }

  /* ── Side drawers (account, wishlist) ────────────────────────── */
  .acct-overlay,
  .wish-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, .44);
    z-index: 1098;
    opacity: 0;
    pointer-events: none;
    transition: opacity .3s ease;
  }

  .acct-overlay.is-open,
  .wish-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .acct-drawer,
  .wish-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 400px;
    max-width: 100vw;
    background: var(--white);
    z-index: 1099;
    transform: translateX(100%);
    transition: transform .35s cubic-bezier(.25, .46, .45, .94);
    display: flex;
    flex-direction: column;
  }

  .acct-drawer.is-open,
  .wish-drawer.is-open {
    transform: translateX(0);
  }

  .acct-head,
  .wish-head {
    padding: 18px 22px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
  }

  .acct-head h5,
  .wish-head h5 {
    font-family: var(--fh);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -.3px;
    display: flex;
    align-items: center;
    gap: 9px;
  }

  .wish-drawer__head {
    padding: 20px 22px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
  }

  .wish-drawer__head-left {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .wish-drawer__title {
    font-family: var(--fh);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -.3px;
  }

  .wish-drawer__sub {
    font-size: 11px;
    color: var(--muted);
  }

  .acct-x,
  .wish-x {
    width: 34px;
    height: 34px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text);
    transition: all .2s ease;
  }

  .acct-x:hover,
  .wish-x:hover {
    background: var(--card);
    color: var(--text);
  }

  /* Account hero + links */
  .acct-hero {
    padding: 28px 22px;
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 14px;
  }

  .acct-avatar-wrap {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--card);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text);
  }

  .acct-hero-text {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .acct-hero-text span {
    font-size: 11px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 700;
  }

  .acct-hero-text strong {
    font-family: var(--fh);
    font-size: 17px;
    font-weight: 700;
  }

  .acct-cta-row {
    display: flex;
    gap: 8px;
    width: 100%;
  }

  .acct-btn-primary,
  .acct-btn-ghost {
    flex: 1;
    text-align: center;
    padding: 12px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .8px;
    text-transform: uppercase;
    border-radius: 8px;
    transition: all .2s ease;
  }

  .acct-btn-primary {
    background: var(--text);
    color: #fff;
    border: 1.5px solid var(--text);
  }

  .acct-btn-primary:hover {
    background: var(--accent);
    border-color: var(--accent);
  }

  .acct-btn-ghost {
    background: transparent;
    color: var(--text);
    border: 1.5px solid var(--border);
  }

  .acct-btn-ghost:hover {
    border-color: var(--text);
  }

  .acct-body {
    padding: 18px 22px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .acct-section-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
  }

  .acct-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 10px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    transition: background .15s ease, color .15s ease;
  }

  .acct-link:hover {
    background: var(--bg2);
    color: var(--accent);
  }

  /* Wishlist body */
  .wish-drawer__body {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 16px 22px;
  }

  .wish-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 50vh;
    gap: 14px;
    text-align: center;
    padding: 40px 24px;
    color: var(--border);
  }

  .wish-empty p {
    font-size: 14px;
    color: var(--muted);
    max-width: 240px;
  }

  .wish-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .wish-item {
    position: relative;
  }

  .wish-item__img-wrap {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    background: var(--card);
    margin-bottom: 8px;
  }

  .wish-item__img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: top;
    display: block;
    transition: transform .4s ease;
  }

  .wish-item:hover .wish-item__img {
    transform: scale(1.04);
  }

  .wish-item__del {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 28px;
    height: 28px;
    background: var(--white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    box-shadow: 0 2px 8px rgba(0, 0, 0, .1);
    transition: background .2s ease, color .2s ease;
  }

  .wish-item__del:hover {
    background: var(--rust);
    color: #fff;
  }

  .wish-item__name {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .wish-item__price {
    font-size: 11px;
    color: var(--muted);
    margin-bottom: 6px;
  }

  .wish-item__atc {
    display: block;
    width: 100%;
    padding: 7px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .8px;
    text-transform: uppercase;
    color: var(--text);
    transition: background .2s ease, color .2s ease, border-color .2s ease;
  }

  .wish-item__atc:hover {
    background: var(--text);
    color: #fff;
    border-color: var(--text);
  }

  .wish-foot {
    padding: 16px 22px;
    border-top: 1px solid var(--border);
    flex-shrink: 0;
  }

  /* ── Newsletter popup ────────────────────────────────────────── */
  .popup-backdrop {
    position: fixed;
    inset: 0;
    z-index: 1300;
    background: rgba(0, 0, 0, .55);
    display: flex;
