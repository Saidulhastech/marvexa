  /* Toast styles moved to global src/styles/drawers.css — the toast node is
     created at runtime (document.createElement) so Astro's scoped styles
     can't reach it. */

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 720px) {
