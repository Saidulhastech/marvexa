---
// ============================================================
//  Market selector (OMNIX) — replaces the old static "EN / USD".
//  Lists the shop's REAL Shopify markets (countries + currencies)
//  from the Storefront `localization` query and lets the shopper
//  switch. Choosing a market POSTs to /api/market, which persists
//  the choice + re-pins the cart, then reloads so SSR re-renders
//  every price in the new currency (via @inContext). Degrades to a
//  plain label when the store has a single market or the API fails.
// ============================================================
import Icon from '~/components/ui/omnix/Icon.astro';
import { getLocalizationOnce } from '~/lib/shopify';

const market = Astro.locals.market;
// Request-scoped: one Storefront call even with multiple selectors on the page.
const loc = await getLocalizationOnce(Astro.locals);
const countries = loc?.availableCountries ?? [];

// Currency of the active market — for the trigger label ("EN / USD").
const current =
  countries.find((c) => c.isoCode === market.country) ?? loc?.country ?? null;
const currencyCode = current?.currency?.isoCode ?? '';
const label = `${market.language} / ${currencyCode || market.country}`;

// Best language for a country: keep the shopper's current language if that
// country offers it, else the country's first available language.
function langFor(c: (typeof countries)[number]): string {
  const langs = c.availableLanguages ?? [];
  const keep = langs.find((l) => l.isoCode === market.language);
  return (keep ?? langs[0])?.isoCode ?? market.language;
}

// Redirect back to the current page so prices re-render in place.
const redirectTo = Astro.url.pathname + Astro.url.search;
const multi = countries.length > 1;
---

{
  multi ? (
    <form class="mkt" method="POST" action="/api/market">
      <input type="hidden" name="redirect" value={redirectTo} />
      <span class="mkt-face" aria-hidden="true">
        <Icon name="globe" size={13} />
        <span class="mkt-cur">{label}</span>
        <Icon name="chevron-down" size={12} />
      </span>
      <select
        name="market"
        class="mkt-select"
        aria-label="Country and currency"
        data-market-select
      >
        {countries.map((c) => (
          <option value={`${c.isoCode}|${langFor(c)}`} selected={c.isoCode === market.country}>
            {c.name} ({c.currency.isoCode})
          </option>
        ))}
      </select>
      <noscript>
        <button type="submit" class="mkt-go">Go</button>
      </noscript>
    </form>
  ) : (
    <span class="mkt mkt-static">
      <Icon name="globe" size={13} />
      <span class="mkt-cur">{label}</span>
    </span>
  )
}

<style>
  .mkt {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .mkt-face {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    line-height: 1;
    pointer-events: none; /* the transparent <select> on top handles clicks */
  }
  .mkt-static {
    gap: 5px;
  }
  .mkt-cur {
    font-variant-numeric: tabular-nums;
  }
  /* The native select sits invisibly over the face so the styled label shows
     while the browser renders its own accessible dropdown on interaction. */
  .mkt-select {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    border: 0;
    padding: 0;
    opacity: 0;
    cursor: pointer;
    font: inherit;
    -webkit-appearance: none;
    appearance: none;
  }
  .mkt-go {
    margin-left: 6px;
    cursor: pointer;
  }
</style>

<script>
  // Auto-submit the moment the shopper picks a market (no extra "Go" click).
  document.querySelectorAll<HTMLSelectElement>('[data-market-select]').forEach((sel) => {
    sel.addEventListener('change', () => sel.form?.submit());
  });
</script>
