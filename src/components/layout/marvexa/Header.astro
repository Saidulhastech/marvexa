---
// ============================================================
//  Header (Marvexa) — fixed transparent-over-hero bar that turns
//  solid on scroll. Logo, primary nav with Women/Men mega menus,
//  and the action cluster (search / account / wishlist / cart /
//  burger). Action triggers carry data-open="…"; the controller in
//  Overlays.astro opens the matching overlay. Cart badge (#cartBadge)
//  is driven by the nanostore (CartDrawer); wishlist (#wishBadge) by
//  Overlays. Mobile menu (#mobMenu) toggles .is-open via the same
//  controller. Header scroll state + announce-collapse are local JS.
// ============================================================
import { BRAND } from '~/config/marvexa';
import { resolveImage } from '~/lib/asset';
import { getAllCollections, getProducts } from '~/lib/shopify';
import type { Collection, ProductCard } from '~/lib/shopify/types';

// Primary nav follows the Marvexa design: New Arrivals, Women + Men mega menus,
// then Bags / Accessories / Sale. Top-level category links resolve to a real
// Shopify collection when the store has one (matched by handle or title) and
// fall back to the slug. Mega sub-links route to catalogue search so they
// always land on a real results page even before those collections exist.
let collections: Collection[] = [];
try {
  collections = await getAllCollections();
} catch (err) {
  console.error('[header] collections load failed:', (err as Error).message);
}

// Real sale stats — scan the catalogue for genuine markdowns (compareAtPrice >
// price) and take the deepest discount. Drives the mega "X% Off" badges: they
// stay hidden while nothing is on sale and surface the true max % the moment a
// merchant sets a compare-at price. No hardcoded percentages.
let saleStats = { hasSale: false, maxPct: 0 };
try {
  const page = await getProducts({ pageSize: 250 }, Astro.locals.market);
  let max = 0;
  for (const p of page.items as ProductCard[]) {
    const price = Number(p.priceRange.minVariantPrice.amount) || 0;
    const compare = Number(p.compareAtPriceRange?.minVariantPrice?.amount) || 0;
    if (compare > price && price > 0) max = Math.max(max, Math.round((1 - price / compare) * 100));
  }
  saleStats = { hasSale: max > 0, maxPct: max };
} catch (err) {
  console.error('[header] sale stats failed:', (err as Error).message);
}
const saleBadge = saleStats.hasSale ? `${saleStats.maxPct}% Off` : undefined;
const saleTag = saleStats.hasSale ? 'Sale' : undefined;
const SALE_HREF = '/products?sale=1';

const slugify = (s: string) =>
  s.toLowerCase().replace(/&/g, ' and ').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');

// Resolve a category label to a real collection handle, else its slug.
const handleFor = (label: string) => {
  const key = label.toLowerCase();
  const m = collections.find(
    (c) => (c.handle ?? '').toLowerCase() === key || (c.title ?? '').trim().toLowerCase() === key,
  );
  return m?.handle ?? slugify(label);
};

// Mega sub-link fallback target: search the catalogue by the label (always resolves).
const searchFor = (label: string) => `/products?q=${encodeURIComponent(label)}`;

type MegaLink = { label: string; href?: string; badge?: string; rust?: boolean };
interface Mega {
  label: string;
  href: string;
  columns: { title: string; links: MegaLink[] }[];
  image: string;
  imageLabel: string;
}

const MEGAS: Mega[] = [
  {
    label: 'Women',
    href: `/collections/${handleFor('Women')}`,
    columns: [
      {
        title: 'Clothing',
        links: [
          { label: 'Dresses', badge: 'New' },
          { label: 'Blazers & Jackets' },
          { label: 'Tops & Shirts' },
          { label: 'Trousers & Shorts' },
          { label: 'Knitwear' },
          { label: 'Skirts', badge: saleTag, rust: true },
        ],
      },
      {
        title: 'Shop By',
        links: [
          { label: 'New Arrivals', href: '/products?sort=newest' },
          { label: 'Best Sellers', href: '/products?sort=best-selling' },
          { label: 'Organic Linen Edit' },
          { label: 'Under $150' },
          { label: 'Sale Items', href: SALE_HREF, badge: saleBadge, rust: true },
        ],
      },
    ],
    image: resolveImage('feed-03.webp').src,
    imageLabel: 'SS26 Drop',
  },
  {
    label: 'Men',
    href: `/collections/${handleFor('Men')}`,
    columns: [
      {
        title: 'Clothing',
        links: [
          { label: 'Shirts', badge: 'New' },
          { label: 'Blazers & Jackets' },
          { label: 'Trousers' },
          { label: 'Shorts' },
          { label: 'Knitwear' },
          { label: 'T-Shirts', badge: saleTag, rust: true },
        ],
      },
      {
        title: 'Shop By',
        links: [
          { label: 'New Arrivals', href: '/products?sort=newest' },
          { label: 'Best Sellers', href: '/products?sort=best-selling' },
          { label: 'Linen Collection' },
          { label: 'Under $120' },
          { label: 'Sale Items', href: SALE_HREF, badge: saleBadge, rust: true },
        ],
      },
    ],
    image: resolveImage('nav-promo-02.webp').src,
    imageLabel: "Men's Edit",
  },
];

// Plain top-level links after the megas. "Sale" points at the real on-sale view.
const flatLinks = ['Bags', 'Accessories', 'Sale'].map((label) => {
  const sale = label.toLowerCase() === 'sale';
  return { label, href: sale ? SALE_HREF : `/collections/${handleFor(label)}`, sale };
});

// Mobile menu mirrors the same top-level set (no mega panels on mobile).
const mobLinks = [
  ...MEGAS.map((m) => ({ label: m.label, href: m.href, sale: false })),
  ...flatLinks,
];

const initial = (BRAND.name?.[0] ?? 'M').toUpperCase();

interface Props {
  /** Solid (light bg, dark text) from the top — for pages without a dark hero.
      When false the header is transparent over the hero until scrolled. */
  solid?: boolean;
}
const { solid = false } = Astro.props;
---

<header class:list={['header', { scrolled: solid }]} id="siteHeader" data-solid={solid ? '1' : undefined}>
  <div class="header__inner">
    <a href="/" class="header__logo" aria-label={`${BRAND.name} Home`}>
      <div class="header__logo-m">{initial}</div>
      {BRAND.name}
    </a>

    <nav class="header__nav" role="navigation" aria-label="Main">
      <a href="/products?sort=newest" class="nav-link new-a">New Arrivals</a>

      {MEGAS.map((m) => (
        <div class="nav-link has-mega" tabindex="0" role="button" aria-haspopup="true" aria-expanded="false">
          {m.label}
          <svg class="nav-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
            <polyline points="6 9 12 15 18 9" />
          </svg>
          <div class="mega" role="menu">
            {m.columns.map((col) => (
              <div>
                <div class="mega__col-title">{col.title}</div>
                <div class="mega__links">
                  {col.links.map((l) => (
                    <a href={l.href ?? searchFor(l.label)} class="mega__link">
                      {l.label}
                      {l.badge && <span class:list={['mega__link-badge', { rust: l.rust }]}>{l.badge}</span>}
                    </a>
                  ))}
                </div>
              </div>
            ))}
            <div>
              <a href={m.href} class="mega__img-card">
                <img src={m.image} alt={`${m.label}'s campaign`} />
                <span class="mega__img-label">{m.imageLabel}</span>
              </a>
            </div>
          </div>
        </div>
      ))}

      {flatLinks.map((l) => (
        <a href={l.href} class:list={['nav-link', { sale: l.sale }]}>{l.label}</a>
      ))}
    </nav>

    <div class="header__actions">
      <button class="hbtn" data-open="search" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.35-4.35" /></svg>
      </button>
      <button class="hbtn" data-open="account" aria-label="My Account">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
      </button>

      <div class="hbtn-divider"></div>

      <button class="hbtn" data-open="wishlist" aria-label="Wishlist">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" /></svg>
        <span class="h-badge" id="wishBadge" style="display:none">0</span>
      </button>

      <a href="/compare" class="hbtn" aria-label="Compare">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3L4 7l4 4" /><line x1="4" y1="7" x2="20" y2="7" /><path d="M16 21l4-4-4-4" /><line x1="20" y1="17" x2="4" y2="17" /></svg>
        <span class="h-badge" id="compareBadge" style="display:none">0</span>
      </a>

      <button class="hbtn" data-open="cart" aria-label="Shopping bag">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" /><line x1="3" y1="6" x2="21" y2="6" /><path d="M16 10a4 4 0 0 1-8 0" /></svg>
        <span class="h-badge" id="cartBadge" style="display:none">0</span>
      </button>

      <button class="hbtn hbtn--menu" data-open="mobile" aria-label="Open navigation menu">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="15" y2="18" /></svg>
      </button>
    </div>
  </div>
</header>

{/* Mobile slide-in menu — opened by data-open="mobile" via the Overlays controller. */}
<div class="mob-overlay" data-close="mobile" aria-hidden="true"></div>
<div class="mob-menu" id="mobMenu" role="dialog" aria-modal="true" aria-label="Mobile navigation">
  <div class="mob-menu__head">
    <div class="mob-logo">
      <div class="mob-logo-m">{initial}</div>
      {BRAND.name}
    </div>
    <button class="mob-close" data-close="mobile" aria-label="Close menu">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
    </button>
  </div>
  <nav class="mob-menu__nav">
    <a href="/products?sort=newest" class="mob-nav-link new-a">New Arrivals<span class="mob-nav-badge">New</span></a>
    {mobLinks.map((l) => (
      <a href={l.href} class:list={['mob-nav-link', { sale: l.sale }]}>{l.label}</a>
    ))}
    <a href="/products" class="mob-nav-link">All Products</a>
  </nav>
  <div class="mob-menu__info">
    <div class="mob-info-item">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="1" y="3" width="15" height="13" rx="2" /><path d="M16 8h4l3 5v3h-7V8z" /><circle cx="5.5" cy="18.5" r="2.5" /><circle cx="18.5" cy="18.5" r="2.5" /></svg>
      Free shipping on orders $99+
    </div>
    <div class="mob-info-item">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><polyline points="23 4 23 10 17 10" /><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" /></svg>
      Easy 30-day returns
    </div>
    <div class="mob-info-item">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
      Secure checkout
    </div>
  </div>
  <div class="mob-menu__bottom">
    <a href="/account" class="mob-bottom-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
      My Account
    </a>
    <a href="/wishlist" class="mob-bottom-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" /></svg>
      Wishlist
    </a>
    <a href="/pages/faq" class="mob-bottom-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="10" /><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
      Help & FAQ
    </a>
    <a href="/account" class="mob-bottom-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" /></svg>
      Track My Order
    </a>
  </div>
</div>

<style>
  .header {
    position: fixed;
    top: 38px;
    left: 0;
    right: 0;
    z-index: 1000;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: top .35s cubic-bezier(.25, .46, .45, .94), background .3s ease, border-color .3s ease, box-shadow .3s ease;
  }

  .header.ann-hidden {
    top: 0;
  }

  /* mobile announcement bar wraps to 2 lines (56px) — keep header below it */
  @media (max-width: 768px) {
    .header {
      top: 56px;
    }
  }

  .header.scrolled {
    background: rgba(250, 250, 247, .97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-color: var(--border);
    box-shadow: 0 1px 0 rgba(0, 0, 0, .04);
  }

  .header__inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 var(--gutter);
    height: 68px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
  }

  .header__logo {
    font-family: var(--fh);
    font-size: 17px;
    font-weight: 800;
    letter-spacing: -.3px;
    text-transform: uppercase;
    color: var(--white);
    transition: color .3s ease;
    display: inline-flex;
    align-items: center;
    gap: 9px;
  }

  .header.scrolled .header__logo {
    color: var(--text);
  }

  .header__logo-m {
    width: 30px;
    height: 30px;
    border: 1.5px solid var(--accent);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    color: var(--accent);
    font-weight: 900;
    flex-shrink: 0;
    transition: background .2s ease, color .2s ease;
  }

  .header__logo:hover .header__logo-m {
    background: var(--accent);
    color: #fff;
  }

  .header__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2px;
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 13px;
    font-weight: 600;
    color: rgba(255, 255, 255, .88);
    padding: 7px 11px;
    border-radius: 7px;
    cursor: pointer;
    transition: color .22s ease, background .22s ease;
    letter-spacing: .1px;
    white-space: nowrap;
  }

  .header.scrolled .nav-link {
    color: var(--text);
  }

  .nav-link:hover {
    background: rgba(255, 255, 255, .1);
  }

  .header.scrolled .nav-link:hover {
    background: rgba(17, 17, 17, .05);
  }

  .nav-link.new-a {
    color: var(--accent) !important;
  }

  .header.scrolled .nav-link.new-a {
    color: #5B6B28 !important;
  }

  .nav-link.sale {
    color: var(--rust) !important;
  }

  .nav-link.has-mega .nav-chevron {
    transition: transform .22s ease;
  }

  .nav-link.has-mega:hover .nav-chevron {
    transform: rotate(180deg);
  }

  .mega {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 24px;
    min-width: 520px;
    box-shadow: 0 24px 64px rgba(0, 0, 0, .13), 0 4px 16px rgba(0, 0, 0, .06);
    display: grid;
    grid-template-columns: 1fr 1fr 120px;
    gap: 20px;
    opacity: 0;
    pointer-events: none;
    transition: opacity .22s ease, transform .22s ease;
    z-index: 200;
  }

  /* Invisible bridge across the 10px gap between the trigger and the menu, so
     moving the cursor down to the mega doesn't drop :hover and close it. */
  .mega::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: -14px;
    height: 14px;
  }

  .nav-link.has-mega:hover .mega,
  .nav-link.has-mega:focus-within .mega {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .mega__col-title {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }

  .mega__links {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .mega__link {
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    padding: 7px 9px;
    border-radius: 7px;
    transition: background .15s ease, color .15s ease;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .mega__link:hover {
    background: var(--bg2);
    color: var(--accent);
  }

  .mega__link-badge {
    font-size: 8px;
    font-weight: 700;
    letter-spacing: .8px;
    text-transform: uppercase;
    background: var(--accent);
    color: #fff;
    padding: 2px 5px;
    border-radius: 3px;
  }

  .mega__link-badge.rust {
    background: var(--rust);
  }

  .mega__img-card {
    border-radius: 10px;
    overflow: hidden;
    position: relative;
    aspect-ratio: 2/3;
    display: block;
  }

  .mega__img-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform .4s ease;
  }

  .mega__img-card:hover img {
    transform: scale(1.06);
  }

  .mega__img-label {
    position: absolute;
    bottom: 9px;
    left: 9px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #fff;
    background: rgba(17, 17, 17, .58);
    backdrop-filter: blur(6px);
    padding: 4px 8px;
    border-radius: 4px;
  }

  .header__actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 2px;
  }

  .hbtn {
    position: relative;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border-radius: 8px;
    color: rgba(255, 255, 255, .88);
    transition: color .22s ease, background .22s ease;
    flex-shrink: 0;
  }

  .header.scrolled .hbtn {
    color: var(--text);
  }

  .hbtn:hover {
    background: rgba(255, 255, 255, .1);
  }

  .header.scrolled .hbtn:hover {
    background: rgba(17, 17, 17, .06);
    color: var(--accent);
  }

  .h-badge {
    position: absolute;
    top: 7px;
    right: 6px;
    min-width: 15px;
    height: 15px;
    border-radius: 8px;
    background: var(--accent);
    color: #fff;
    font-size: 8px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
    line-height: 1;
    pointer-events: none;
    transition: transform .2s ease;
  }

  .hbtn:hover .h-badge {
    transform: scale(1.12);
  }

  .hbtn--menu {
    display: none;
  }

  .hbtn-divider {
    width: 1px;
    height: 20px;
    background: rgba(255, 255, 255, .15);
    margin: 0 4px;
    flex-shrink: 0;
    transition: background .3s ease;
  }

  .header.scrolled .hbtn-divider {
    background: var(--border);
  }

  /* ── Mobile menu ─────────────────────────────────────── */
  .mob-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, .5);
    z-index: 1198;
    opacity: 0;
    pointer-events: none;
    transition: opacity .3s ease;
  }

  .mob-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .mob-menu {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 320px;
    max-width: 100vw;
    background: var(--dark);
    z-index: 1199;
    transform: translateX(-100%);
    transition: transform .35s cubic-bezier(.25, .46, .45, .94);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  }

  .mob-menu.is-open {
    transform: translateX(0);
  }

  .mob-menu__head {
    padding: 22px 22px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(255, 255, 255, .07);
    flex-shrink: 0;
  }

  .mob-logo {
    font-family: var(--fh);
    font-size: 17px;
    font-weight: 800;
    color: var(--white);
    display: flex;
    align-items: center;
    gap: 8px;
  }

