---
// ============================================================
//  Footer (Marvexa) — brand + social + link columns + payment chips.
//  Content from the `footer` collection; social from BRAND.
// ============================================================
import { getEntry } from 'astro:content';
import { BRAND } from '~/config/marvexa';

const entry = await getEntry('footer', 'main');
const f = entry!.data;

const legalLinks = [
  { label: 'Privacy', href: '/pages/privacy-policy' },
  { label: 'Terms', href: '/pages/terms-and-conditions' },
  { label: 'Cookies', href: '/pages/cookies' },
];
---

<footer class="footer" role="contentinfo">
  <div class="wrap">
    <div class="footer__top">
      <div>
        <a href="/" class="footer__logo">{BRAND.name}</a>
        {f.blurb && <p class="footer__desc">{f.blurb}</p>}
        <div class="footer__socials">
          <a href={BRAND.social.instagram} class="footer__soc" aria-label="Instagram">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5" /><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" /><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" /></svg>
          </a>
          <a href={BRAND.social.pinterest ?? '#'} class="footer__soc" aria-label="Pinterest">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83l1.23-5.19s-.31-.63-.31-1.57c0-1.47.85-2.57 1.91-2.57.9 0 1.34.68 1.34 1.49 0 .91-.58 2.27-.88 3.53-.25 1.05.52 1.91 1.56 1.91 1.87 0 3.12-2.4 3.12-5.24 0-2.16-1.46-3.68-3.56-3.68-2.42 0-3.85 1.82-3.85 3.69 0 .73.28 1.51.63 1.94l-.23.95-.29.11C7.9 13.26 7 11.41 7 9.83 7 7.15 9.07 4.7 12.38 4.7c2.66 0 4.72 1.89 4.72 4.43 0 2.64-1.66 4.76-3.97 4.76-.78 0-1.51-.4-1.76-.88l-.47 1.79c-.17.66-.63 1.49-.94 2 .71.22 1.46.34 2.24.34 5.52 0 10-4.48 10-10S17.52 2 12 2z" /></svg>
          </a>
          <a href={BRAND.social.tiktok ?? '#'} class="footer__soc" aria-label="TikTok">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5" /></svg>
          </a>
          <a href={BRAND.social.youtube} class="footer__soc" aria-label="YouTube">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.57A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z" /><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" /></svg>
          </a>
        </div>
      </div>

      {
        f.columns.map((col) => (
          <div>
            <div class="footer__col-h">{col.title}</div>
            <ul class="footer__links">
              {col.links.map((l) => (
                <li>
                  <a href={l.href} set:html={l.label} />
                </li>
              ))}
            </ul>
            {col.note && <p class="footer__hours">{col.note}</p>}
          </div>
        ))
      }
    </div>

    <div class="footer__bot">
      <span class="footer__copy">{f.legal}</span>
      <div class="footer__pay">
        {f.payments.map((p) => <span class="pay-chip">{p}</span>)}
      </div>
      <div class="footer__legal">
        {legalLinks.map((l) => <a href={l.href}>{l.label}</a>)}
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--dark);
    padding-top: 120px;
  }

  .footer__top {
    padding: 64px 0 52px;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 40px;
  }

  .footer__logo {
    font-family: var(--fh);
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -.3px;
    text-transform: uppercase;
    color: var(--white);
    display: block;
    margin-bottom: 12px;
  }

  .footer__desc {
    font-size: 13px;
    line-height: 1.62;
    color: rgba(255, 255, 255, .4);
    max-width: 220px;
    margin-bottom: 20px;
  }

  .footer__socials {
    display: flex;
    gap: 8px;
  }

  .footer__soc {
    width: 32px;
    height: 32px;
    border: 1px solid rgba(255, 255, 255, .12);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, .5);
    transition: border-color var(--ease), color var(--ease);
  }

  .footer__soc:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .footer__col-h {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, .3);
    margin-bottom: 18px;
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: 11px;
  }

  .footer__links a {
    font-size: 13px;
    color: rgba(255, 255, 255, .55);
    transition: color var(--ease);
  }

  .footer__links a:hover {
    color: var(--white);
  }

  .footer__hours {
    font-size: 12px;
    color: rgba(255, 255, 255, .28);
    margin-top: 14px;
    line-height: 1.6;
  }

  .footer__bot {
    padding: 20px 0;
    border-top: 1px solid rgba(255, 255, 255, .07);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer__copy {
    font-size: 12px;
    color: rgba(255, 255, 255, .28);
  }

  .footer__pay {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .pay-chip {
    padding: 3px 8px;
    background: rgba(255, 255, 255, .06);
    border: 1px solid rgba(255, 255, 255, .09);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .6px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, .35);
  }

  .footer__legal {
    display: flex;
    gap: 20px;
  }

  .footer__legal a {
    font-size: 12px;
    color: rgba(255, 255, 255, .28);
    transition: color var(--ease);
  }

  .footer__legal a:hover {
    color: rgba(255, 255, 255, .6);
  }

  @media (max-width: 1100px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }
  }

  @media (max-width: 768px) {
    .footer__bot {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
