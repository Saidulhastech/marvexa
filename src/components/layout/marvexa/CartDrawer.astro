---
// ============================================================
//  Cart drawer (MARVEXA skin, real Shopify cart). Markup matches the
//  template; the script binds it to the framework-agnostic nanostore
//  (stores/cart.ts) — render lines, totals, badges, and checkout.
//  "You may also like" is real Shopify best-sellers; each + Add uses
//  the product's first variant. Coupon is design-only (no discount
//  wiring yet).
// ============================================================
import Icon from '~/components/ui/marvexa/Icon.astro';
import { BRAND } from '~/config/marvexa';

// Free-shipping meter threshold (display only — see BRAND.freeShippingThreshold).
// 0/null hides the bar entirely.
const FREE_SHIP = BRAND.freeShippingThreshold ?? 0;
---

<div class="cart-overlay" data-close="cart"></div>
<aside class="cart-drawer" id="cartDrawer" role="dialog" aria-modal="true" aria-label="Shopping cart" data-free-ship={FREE_SHIP}>
  <div class="cart-header">
    <div class="cart-head-left">
      <span class="cart-title">Shopping Bag</span>
      <span class="cart-subcount" id="cartChip"></span>
    </div>
    <button class="cart-x" data-close="cart" aria-label="Close cart">
      <Icon name="x" size={16} stroke={2.4} />
    </button>
  </div>

  {/* Free-shipping progress meter — dynamic from the live cart subtotal. */}
  {FREE_SHIP > 0 && (
    <div class="cart-ship-bar" id="cartShipBar" style="display:none;">
      <div class="cart-ship-bar__msg" id="shipMsg"></div>
      <div class="cart-ship-bar__track"><div class="cart-ship-bar__fill" id="shipFill" style="width:0%"></div></div>
    </div>
  )}

  <div class="cart-error" id="cartError" role="alert" style="display:none;"></div>

  <div class="cart-body" id="cartBody">
    <div class="cart-empty" id="cartEmpty">
      <div class="empty-ic"><Icon name="cart" size={32} stroke={1.5} /></div>
      <h6>Your cart is empty</h6>
      <p>Add something from the store — deals, new arrivals, or staff picks.</p>
      <a class="btn btn-primary btn-sm" href="/products">Start shopping</a>
    </div>
    {/* Shown while the first line is being added (drawer opened optimistically). */}
    <div class="cart-loading" id="cartLoading" style="display:none" aria-live="polite" aria-busy="true">
      <span class="cart-spinner" aria-hidden="true"></span>
      <p>Adding to your bag…</p>
    </div>
    {/* Cart lines injected by the script below. */}
    <div id="cartLines"></div>
  </div>

  <div id="cartSummaryWrap" style="display:none;">
    <div class="cart-coupon">
      <form id="couponForm">
        <input type="text" id="couponInput" aria-label="Coupon code" placeholder="Promo or gift code…" autocomplete="off" />
        <button type="submit" class="cc-apply" id="couponApply">Apply</button>
      </form>
      <div class="cart-coupon-codes" id="couponCodes"></div>
      <div class="cart-coupon-msg" id="couponMsg"></div>
    </div>

    <div class="cart-summary">
      <div class="cs-row"><span>Subtotal</span><span id="csSubtotal">$0</span></div>
      <div class="cs-row"><span>Shipping</span><span id="csShipping">Calculated at checkout</span></div>
      <div class="cs-row" id="csDiscountRow" style="display:none;">
        <span id="csDiscountLabel">Discount</span><span id="csDiscount" style="color:#5D8A3C"></span>
      </div>
      <div class="cs-row total"><span>Estimated Total</span><span id="csTotal">$0</span></div>
    </div>
    <div class="cart-trust">
      <span><Icon name="check" size={13} stroke={2.4} /> Secure checkout</span>
      <span><Icon name="check" size={13} stroke={2.4} /> Free 30-day returns</span>
      <span><Icon name="check" size={13} stroke={2.4} /> Fast delivery</span>
    </div>
    <div class="cart-pay" aria-hidden="true">
      <span class="pay-icon">VISA</span>
      <span class="pay-icon">MC</span>
      <span class="pay-icon">AMEX</span>
      <span class="pay-icon">PayPal</span>
      <span class="pay-icon">GPay</span>
    </div>
    <div class="cart-ctas">
      <button class="btn btn-primary btn-block btn-lg cart-checkout-btn" id="cartCheckout">
        Checkout · <span id="csBtnTotal">$0</span>
        <Icon name="arrow-right" size={12} stroke={2.2} />
      </button>
      <button class="cart-continue" data-close="cart">Continue Shopping</button>
    </div>
  </div>
</aside>

<style>
  /* ── Overlay + drawer shell (Marvexa skin) ───────────────────────── */
  .cart-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, .44);
    z-index: 1098;
    opacity: 0;
    pointer-events: none;
    transition: opacity .3s ease;
  }

  .cart-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 440px;
    max-width: 100vw;
    background: var(--white);
    z-index: 1099;
    transform: translateX(100%);
    transition: transform .35s cubic-bezier(.25, .46, .45, .94);
    display: flex;
    flex-direction: column;
  }

  .cart-drawer.is-open {
    transform: translateX(0);
  }

  /* ── Header ──────────────────────────────────────────────────────── */
  .cart-header {
    padding: 18px 22px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
    gap: 8px;
  }

  .cart-head-left {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cart-title {
    font-family: var(--fh);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -.3px;
  }

  .cart-subcount {
    font-size: 11px;
    color: var(--muted);
  }

  .cart-x {
    width: 34px;
    height: 34px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text);
    transition: all .2s ease;
  }

  .cart-x:hover {
    background: var(--card);
    color: var(--text);
  }

  /* ── Free-shipping progress meter ────────────────────────────────── */
  .cart-ship-bar {
    padding: 12px 22px;
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }

  .cart-ship-bar__msg {
    font-size: 11px;
    color: var(--text);
    margin-bottom: 8px;
    font-weight: 500;
  }

  .cart-ship-bar__msg strong {
    color: var(--accent);
  }

  .cart-ship-bar__track {
    height: 4px;
    background: var(--card);
    border-radius: 4px;
    overflow: hidden;
  }

  .cart-ship-bar__fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), #9aaf50);
    border-radius: 4px;
    transition: width .7s cubic-bezier(.25, .46, .45, .94);
  }

  /* ── Payment icons ───────────────────────────────────────────────── */
  .cart-pay {
    padding: 0 22px 14px;
    display: flex;
    gap: 5px;
    align-items: center;
    flex-wrap: wrap;
  }

  .pay-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 5px;
    min-width: 36px;
    height: 22px;
    padding: 0 6px;
    font-size: 8px;
    font-weight: 800;
    color: #888;
    letter-spacing: .3px;
    white-space: nowrap;
    font-family: var(--fb);
  }

  /* ── Error / status ──────────────────────────────────────────────── */
  .cart-error {
    margin: 12px 22px 0;
    padding: 10px 12px;
    background: color-mix(in srgb, var(--rust) 8%, #fff);
    color: var(--rust);
    border: 1px solid color-mix(in srgb, var(--rust) 28%, #fff);
    border-radius: 8px;
    font-size: 13px;
    line-height: 1.4;
  }

  /* ── Body + empty state ──────────────────────────────────────────── */
  .cart-body {
    flex: 1;
    overflow-y: auto;
    padding: 8px 0;
  }

  .cart-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    gap: 14px;
    text-align: center;
    padding: 40px 24px;
  }

  .cart-empty .empty-ic {
    color: var(--border);
  }

  .cart-empty h6 {
    font-family: var(--fh);
    font-size: 16px;
    font-weight: 700;
  }

  .cart-empty p {
    font-size: 14px;
    color: var(--muted);
    max-width: 240px;
  }

  /* ── Loading state (first add, optimistic open) ──────────────────── */
  .cart-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    gap: 16px;
    text-align: center;
    padding: 40px 24px;
  }

  .cart-loading p {
    font-size: 14px;
    color: var(--muted);
  }

  .cart-spinner {
    width: 30px;
    height: 30px;
    border: 2.5px solid var(--border);
    border-top-color: var(--text);
    border-radius: 50%;
    animation: cart-spin .7s linear infinite;
  }

  @keyframes cart-spin {
    to { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .cart-spinner { animation-duration: 1.6s; }
  }

  /* ── Cart line (markup generated in the script) ──────────────────── */
  .cart-item {
    display: flex;
    gap: 12px;
    padding: 12px 22px;
    border-bottom: 1px solid rgba(216, 213, 206, .45);
    transition: background .15s ease, opacity .15s ease;
  }

  .cart-item:hover {
    background: rgba(240, 238, 233, .3);
  }

  .cart-item.is-busy {
    opacity: 0.5;
    pointer-events: none;
  }

  .cart-item.is-soldout .ci-name {
    color: var(--muted);
  }

  .ci-img {
    width: 76px;
    height: 96px;
    border-radius: 8px;
    overflow: hidden;
    background: var(--card);
    flex-shrink: 0;
  }

  .ci-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .ci-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-width: 0;
  }

  .ci-name {
    font-size: 13px;
    font-weight: 600;
    line-height: 1.35;
    color: var(--text);
    margin-bottom: 2px;
  }

  .ci-meta {
    font-size: 11px;
    color: var(--muted);
  }

  .ci-soldout {
    font-size: 11px;
    font-weight: 600;
    color: var(--rust);
    margin: 2px 0;
  }

  .ci-price {
    font-size: 13px;
    font-weight: 700;
    color: var(--text);
  }

  .ci-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 8px;
    gap: 8px;
  }

  .ci-qty {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ci-qty button {
    width: 26px;
    height: 26px;
    border: 1px solid var(--border);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    background: none;
    color: var(--text);
    transition: background .15s ease, border-color .15s ease;
  }

  .ci-qty button:hover:not(:disabled) {
    background: var(--bg2);
    border-color: var(--muted);
  }

  .ci-qty button:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .ci-qty span {
    font-size: 12px;
    font-weight: 700;
    min-width: 18px;
    text-align: center;
  }

  .ci-btns {
    display: flex;
    align-items: center;
    margin-top: 5px;
  }

  .ci-remove,
  .ci-save {
    font-size: 10px;
    color: var(--muted);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: var(--fb);
    transition: color .15s ease;
  }

  .ci-remove:hover {
    color: var(--rust);
  }

  .ci-save {
    border-left: 1px solid var(--border);
    padding-left: 8px;
    margin-left: 8px;
  }

  .ci-save:hover {
    color: var(--accent);
  }

  /* ── Coupon ──────────────────────────────────────────────────────── */
  .cart-coupon {
    padding: 12px 22px;
    border-top: 1px solid var(--border);
    flex-shrink: 0;
  }

  #couponForm {
    display: flex;
    gap: 8px;
  }

  #couponInput {
    flex: 1;
    padding: 9px 12px;
    font-size: 12px;
    border: 1px solid var(--border);
    border-radius: 7px;
    background: var(--bg2);
    color: var(--text);
    transition: border-color .2s ease;
  }

  #couponInput:focus {
    border-color: var(--accent);
  }

  .cc-apply {
    padding: 9px 14px;
    background: var(--text);
    color: #fff;
    border-radius: 7px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .8px;
    text-transform: uppercase;
    white-space: nowrap;
    transition: background .2s ease;
  }

  .cc-apply:hover:not(:disabled) {
    background: var(--accent);
  }

  .cart-coupon-codes {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 10px;
  }

  .coupon-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 600;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 4px 10px;
  }

  .coupon-chip button {
    color: var(--muted);
    font-size: 13px;
    line-height: 1;
  }

  .coupon-chip button:hover {
    color: var(--rust);
  }

  .cart-coupon-msg {
    font-size: 11px;
    margin-top: 8px;
  }

  .cart-coupon-msg.is-ok {
    color: var(--accent);
  }

  .cart-coupon-msg.is-err {
    color: var(--rust);
  }

  .cart-coupon-msg.is-info {
    color: var(--muted);
  }

  /* ── Summary + CTAs + trust ──────────────────────────────────────── */
  .cart-summary {
    padding: 16px 22px 4px;
    border-top: 1px solid var(--border);
  }

  .cs-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 4px 0;
    font-size: 12px;
    color: var(--muted);
  }

  .cs-row.total {
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    border-top: 1px solid var(--border);
    margin-top: 6px;
    padding-top: 10px;
  }

  .cs-row.total span:last-child {
    font-family: var(--fh);
  }

  .cart-ctas {
    padding: 8px 22px 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cart-checkout-btn {
    border-radius: 10px;
  }

  .cart-continue {
    display: block;
    width: 100%;
    text-align: center;
    font-size: 11px;
    color: var(--muted);
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--fb);
    padding: 6px;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color .2s ease;
  }

  .cart-continue:hover {
    color: var(--text);
  }

  .cart-trust {
    padding: 0 22px 18px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .cart-trust span {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 10px;
    font-weight: 600;
    color: var(--muted);
  }

  .cart-trust span svg {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .cart-drawer {
      width: 100vw;
    }
  }
</style>

<script>
  import {
    $cart,
    $cartOpen,
    $cartError,
    $cartBusy,
    $busyLines,
    initCart,
    updateItem,
    removeItem,
    applyDiscount,
    checkout,
  } from '../../../stores/cart';
  import { formatMoney } from '../../../lib/money';
  import type { Cart } from '../../../lib/shopify/types';

  // Single money formatter shared with the rest of the app (MARVEXA "$289" style,
  // locale + currency safe) so the drawer and quick-view never disagree.
  const money = (m?: { amount: string; currencyCode: string } | null) => (m ? formatMoney(m) : '$0');

  // Escape merchant-controlled strings before they go into innerHTML.
  const esc = (s: unknown) =>
    String(s ?? '').replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] as string,
    );

  const drawer = document.getElementById('cartDrawer');
  const FREE_SHIP = Number(drawer?.dataset.freeShip ?? 0);
  const linesEl = document.getElementById('cartLines');
  const emptyEl = document.getElementById('cartEmpty');
  const loadingEl = document.getElementById('cartLoading');
  const summaryWrap = document.getElementById('cartSummaryWrap');
  const chip = document.getElementById('cartChip');
  const headerBadge = document.getElementById('cartBadge');
  const errorEl = document.getElementById('cartError');

  function renderLines(cart: Cart | null) {
    if (!linesEl) return;
    const lines = cart?.lines ?? [];
    linesEl.innerHTML = lines
      .map((l) => {
        const m = l.merchandise;
        const img = m.image?.url ?? m.product.featuredImage?.url ?? '';
        const opts = m.selectedOptions
          .filter((o) => o.value && o.value !== 'Default Title')
          .map((o) => o.value)
          .join(' · ');
        // Stock-aware: cap inc at the variant's available qty (when tracked) and
        // the global 99; flag a line that is no longer purchasable.
        const qa = typeof m.quantityAvailable === 'number' ? m.quantityAvailable : null;
        const max = Math.min(99, qa ?? 99);
        const atMax = l.quantity >= max;
        const soldOut = m.availableForSale === false;
        return `
        <div class="cart-item${soldOut ? ' is-soldout' : ''}" data-line="${esc(l.id)}">
          <div class="ci-img"><img src="${esc(img)}" alt="${esc(m.product.title)}" loading="lazy"></div>
          <div class="ci-info">
            <div>
              <a class="ci-name" href="/products/${esc(m.product.handle)}">${esc(m.product.title)}</a>
              ${opts ? `<div class="ci-meta">${esc(opts)}</div>` : ''}
              ${soldOut ? '<div class="ci-soldout">No longer available</div>' : ''}
            </div>
            <div class="ci-row">
              <span class="ci-price">${money(l.cost.totalAmount)}</span>
              <div class="ci-qty">
                <button data-act="dec" aria-label="Decrease">−</button>
                <span>${l.quantity}</span>
                <button data-act="inc" aria-label="Increase"${soldOut || atMax ? ' disabled' : ''}>+</button>
              </div>
            </div>
            <div class="ci-btns">
              <button class="ci-remove" data-act="remove">Remove</button>
              <button class="ci-save" data-act="save">Save for later</button>
            </div>
          </div>
        </div>`;
      })
      .join('');
    applyBusyLines($busyLines.get());
  }

  // Empty vs loading: while a mutation is in-flight and the cart has no lines
  // yet (drawer opened optimistically on the first add), show a spinner instead
  // of the "cart is empty" message — otherwise it flashes empty then fills.
  function updateEmptyState(hasItems: boolean) {
    const busy = $cartBusy.get();
    if (emptyEl) emptyEl.style.display = !hasItems && !busy ? '' : 'none';
    if (loadingEl) loadingEl.style.display = !hasItems && busy ? '' : 'none';
  }

  function render(cart: Cart | null) {
    const count = cart?.totalQuantity ?? 0;
    const hasItems = count > 0;

    updateEmptyState(hasItems);
    if (summaryWrap) summaryWrap.style.display = hasItems ? '' : 'none';
    if (chip) chip.textContent = count > 0 ? `${count} item${count > 1 ? 's' : ''}` : '';
    if (headerBadge) {
      headerBadge.textContent = String(count);
      headerBadge.style.display = hasItems ? '' : 'none';
    }

    renderLines(cart);

    const sub = money(cart?.cost.subtotalAmount);
    const tot = money(cart?.cost.totalAmount);
    const set = (id: string, v: string) => {
      const el = document.getElementById(id);
      if (el) el.textContent = v;
    };
    set('csSubtotal', sub);
    set('csTotal', tot);
    set('csBtnTotal', tot);

    renderShipBar(cart, hasItems);
    renderDiscount(cart);
  }

  // Free-shipping meter — remaining amount + progress, from the live subtotal.
  function renderShipBar(cart: Cart | null, hasItems: boolean) {
    if (FREE_SHIP <= 0) return;
    const bar = document.getElementById('cartShipBar');
    if (bar) bar.style.display = hasItems ? '' : 'none';
    if (!hasItems) return;
    const cur = cart?.cost.subtotalAmount.currencyCode ?? 'USD';
    const subAmt = Number(cart?.cost.subtotalAmount.amount ?? 0);
    const remaining = Math.max(0, FREE_SHIP - subAmt);
    const pct = Math.min(100, Math.round((subAmt / FREE_SHIP) * 100));
    const msg = document.getElementById('shipMsg');
    const fill = document.getElementById('shipFill');
    if (msg) {
      msg.innerHTML = remaining > 0
        ? `Add <strong>${money({ amount: String(remaining), currencyCode: cur })}</strong> more for <strong>free shipping</strong>`
        : `<strong>You’ve unlocked free shipping!</strong>`;
    }
    if (fill) fill.style.width = pct + '%';
  }

  // Discount summary row + applied-code chips, driven by Shopify's cart.
  function renderDiscount(cart: Cart | null) {
    const allocs = cart?.discountAllocations ?? [];
    const discountTotal = allocs.reduce((s, a) => s + Number(a.discountedAmount.amount), 0);
    const currency = cart?.cost.subtotalAmount.currencyCode ?? 'USD';

    const row = document.getElementById('csDiscountRow');
    const amountEl = document.getElementById('csDiscount');
    if (row && amountEl) {
      if (discountTotal > 0) {
        amountEl.textContent = '−' + money({ amount: String(discountTotal), currencyCode: currency });
        row.style.display = '';
      } else {
        row.style.display = 'none';
      }
    }

    // Only codes Shopify accepted (applicable) are shown as removable chips.
    const codes = (cart?.discountCodes ?? []).filter((c) => c.applicable);
    const codesEl = document.getElementById('couponCodes');
    if (codesEl) {
      codesEl.innerHTML = codes
        .map(
          (c) => `
          <span class="coupon-chip" data-code="${esc(c.code)}">
            ${esc(c.code)}
            <button type="button" data-remove-code="${esc(c.code)}" aria-label="Remove ${esc(c.code)}">×</button>
          </span>`,
        )
        .join('');
    }
  }

  // Per-line busy spinners (disable that row's controls while a mutation runs).
  function applyBusyLines(busy: Record<string, boolean>) {
    document.querySelectorAll<HTMLElement>('.cart-item[data-line]').forEach((row) => {
      const on = !!busy[row.dataset.line || ''];
      row.classList.toggle('is-busy', on);
      row.querySelectorAll<HTMLButtonElement>('button[data-act]').forEach((b) => (b.disabled = on));
    });
  }
  $busyLines.subscribe(applyBusyLines);

  // Surface cart errors AND Shopify stock warnings (out-of-stock / qty clamped)
  // inside the drawer — without this, a failed add opens to a silent empty cart.
  $cartError.subscribe((msg) => {
    if (!errorEl) return;
    errorEl.textContent = msg ?? '';
    errorEl.style.display = msg ? '' : 'none';
  });

  // Global busy → disable checkout while a mutation is mid-flight, and swap the
  // empty message for the loading spinner when the cart is still empty.
  $cartBusy.subscribe((busy) => {
    const co = document.getElementById('cartCheckout') as HTMLButtonElement | null;
    if (co) co.disabled = busy;
    updateEmptyState(($cart.get()?.totalQuantity ?? 0) > 0);
  });

  // ---- Focus trap + restore (cart opens via the store, not setOpen) --------
  const FOCUSABLE = 'a[href],button:not([disabled]),input:not([disabled]),[tabindex]:not([tabindex="-1"])';
  let lastFocused: HTMLElement | null = null;
  function trapTab(e: KeyboardEvent) {
    if (e.key !== 'Tab' || !drawer) return;
    const items = Array.from(drawer.querySelectorAll<HTMLElement>(FOCUSABLE)).filter(
      (el) => el.offsetParent !== null,
    );
    if (!items.length) return;
    const first = items[0];
    const last = items[items.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  }

  // Open/close — toggle the MARVEXA is-open class from store state + trap focus.
  $cartOpen.subscribe((open) => {
    drawer?.classList.toggle('is-open', open);
    document.querySelector('.cart-overlay')?.classList.toggle('is-open', open);
    document.body.classList.toggle('no-scroll', open);
    if (open && drawer) {
      lastFocused = document.activeElement as HTMLElement;
      document.addEventListener('keydown', trapTab);
      window.requestAnimationFrame(() =>
        drawer.querySelector<HTMLElement>(FOCUSABLE)?.focus(),
      );
    } else {
      document.removeEventListener('keydown', trapTab);
      lastFocused?.focus();
      lastFocused = null;
    }
  });
  $cart.subscribe(render);

  // Line controls (event delegation).
  linesEl?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button[data-act]');
    if (!btn) return;
    const row = btn.closest<HTMLElement>('[data-line]');
    const lineId = row?.dataset.line;
    if (!lineId) return;
    const cart = $cart.get();
    const line = cart?.lines.find((l) => l.id === lineId);
    const qty = line?.quantity ?? 1;
    const act = (btn as HTMLElement).dataset.act;
    if (act === 'inc') updateItem(lineId, qty + 1);
    else if (act === 'dec') updateItem(lineId, qty - 1);
    else if (act === 'remove') removeItem(lineId);
    else if (act === 'save') saveForLater(lineId);
  });

  // "Save for later" — move a Shopify cart line into the localStorage wishlist,
  // then remove it from the cart. Mirrors the HTML template's behaviour.
  const WISH_KEY = 'marvexa_wishlist';
  function saveForLater(lineId: string) {
    const cart = $cart.get();
    const line = cart?.lines.find((l) => l.id === lineId);
    if (!line) return;
    const m = line.merchandise;
    const handle = m.product.handle;
    try {
      const items = JSON.parse(localStorage.getItem(WISH_KEY) || '[]') as Array<{ handle: string }>;
      if (!items.some((i) => i.handle === handle)) {
        items.push({
          handle,
          name: m.product.title,
          price: money(m.price),
          img: m.image?.url ?? m.product.featuredImage?.url ?? '',
          href: `/products/${handle}`,
          variantId: m.id,
        } as never);
        localStorage.setItem(WISH_KEY, JSON.stringify(items));
        // Tell the wishlist drawer (Overlays) to re-render badge + list.
        window.dispatchEvent(new CustomEvent('wishlist:changed'));
      }
    } catch {
      /* localStorage unavailable — still remove the line */
    }
    removeItem(lineId);
  }

  document.getElementById('cartCheckout')?.addEventListener('click', () => checkout());

  // Coupon — real Shopify discount codes via cartDiscountCodesUpdate.
  const couponInput = document.getElementById('couponInput') as HTMLInputElement | null;
  const couponApply = document.getElementById('couponApply') as HTMLButtonElement | null;
  const couponMsg = document.getElementById('couponMsg');

  function setCouponMsg(text: string, ok: boolean | null) {
    if (!couponMsg) return;
    couponMsg.textContent = text;
    couponMsg.classList.toggle('is-ok', ok === true);
    couponMsg.classList.toggle('is-err', ok === false);
    couponMsg.classList.toggle('is-info', ok === null && text !== '');
  }

  /** Send the full set of codes Shopify should hold (it replaces, not merges). */
  async function submitCodes(codes: string[], context: { adding?: string } = {}) {
    if (couponApply) couponApply.disabled = true;
    setCouponMsg('Checking…', null);
    try {
      const data = await applyDiscount(codes);
      // Null cart = the cart expired server-side, not a bad code. Say so instead
      // of mislabelling a valid code as invalid.
      if (!data.cart && !data.error && !data.userErrors?.length) {
        setCouponMsg('Your cart expired — add items again.', false);
        return;
      }
      const applied = (data.cart?.discountCodes ?? []).filter((c) => c.applicable);
      const adding = context.adding?.toLowerCase();
      if (data.error || data.userErrors?.length) {
        setCouponMsg(data.userErrors?.[0]?.message ?? 'Could not apply the code.', false);
      } else if (adding && !applied.some((c) => c.code.toLowerCase() === adding)) {
        // Shopify dropped the code we just tried → it's invalid/not applicable.
        setCouponMsg(`“${context.adding}” isn’t a valid code.`, false);
      } else if (adding) {
        setCouponMsg('Discount applied.', true);
        if (couponInput) couponInput.value = '';
      } else {
        setCouponMsg('', null); // a removal — no message needed
      }
    } finally {
      if (couponApply) couponApply.disabled = false;
    }
  }

  document.getElementById('couponForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const code = couponInput?.value.trim() ?? '';
    if (!code) {
      setCouponMsg('Enter a code.', false);
      return;
    }
    const existing = ($cart.get()?.discountCodes ?? [])
      .filter((c) => c.applicable)
      .map((c) => c.code);
    // Merge with codes already on the cart (mutation replaces the whole set),
    // dedupe case-insensitively so re-applying the same code is a no-op.
    const seen = new Set(existing.map((c) => c.toLowerCase()));
    const next = seen.has(code.toLowerCase()) ? existing : [...existing, code];
    submitCodes(next, { adding: code });
  });

  // Remove an applied code (chip × button).
  document.getElementById('couponCodes')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-remove-code]');
    if (!btn) return;
    const remove = btn.dataset.removeCode?.toLowerCase();
    const next = ($cart.get()?.discountCodes ?? [])
      .filter((c) => c.applicable && c.code.toLowerCase() !== remove)
      .map((c) => c.code);
    submitCodes(next);
  });

  initCart();
</script>
