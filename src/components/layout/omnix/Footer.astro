---
// ============================================================
//  Footer (OMNIX) — columns + brand + social + payment chips.
//  Content from the `footer` collection.
// ============================================================
import { getEntry } from 'astro:content';
import { BRAND } from '~/config/omnix';

const entry = await getEntry('footer', 'main');
const f = entry!.data;
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="foot-brand">
        <a href="/" class="logo">
          <span class="logo-mark">O</span>
          {BRAND.name}<span class="logo-dot">.</span>
        </a>
        {f.blurb && <p>{f.blurb}</p>}
        <div class="foot-social">
          <a href={BRAND.social.instagram} aria-label="Instagram">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href={BRAND.social.youtube} aria-label="YouTube">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg>
          </a>
          <a href={BRAND.social.twitter} aria-label="X">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href={BRAND.social.tiktok ?? '#'} aria-label="TikTok">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V9.31a8.16 8.16 0 0 0 4.77 1.53V7.39a4.85 4.85 0 0 1-1.84-.7z"/></svg>
          </a>
        </div>
      </div>

      {
        f.columns.map((col, idx) => (
          <div class="foot-col">
            <h6>{col.title}</h6>
            <ul>
              {col.links.map((l) => (
                <li>
                  <a href={l.href} set:html={l.label} />
                </li>
              ))}
            </ul>
            {idx === f.columns.length - 1 && f.app.length > 0 && (
              <div class="foot-app">
                {f.app.map((a) => (
                  <a href={a.href}>
                    {a.icon === 'apple' ? (
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
                    ) : (
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M3 20.5v-17c0-.59.34-1.11.84-1.35L13.69 12 3.84 21.85c-.5-.25-.84-.76-.84-1.35zM16.81 15.12L6.05 21.34l8.49-8.49zm3.35-4.31c.34.27.59.69.59 1.19s-.25.92-.59 1.19L18.5 14.39 15.61 12l2.65-2.61zM6.05 2.66l10.76 6.22-2.27 2.27z"/></svg>
                    )}
                    <span><small>{a.sub}</small><b>{a.label}</b></span>
                  </a>
                ))}
              </div>
            )}
          </div>
        ))
      }
    </div>

    <div class="footer-bottom">
      <span>{f.legal}</span>
      <div class="pay-row">
        {f.payments.map((p) => <span class="pay-chip">{p}</span>)}
      </div>
    </div>
  </div>
</footer>
