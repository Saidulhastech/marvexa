---
// ============================================================
//  Footer (Maison) — brand + social + link columns + payment chips.
//  Content from the `footer` collection; social from BRAND.
// ============================================================
import { getEntry } from 'astro:content';
import { BRAND } from '~/config/omnix';

const entry = await getEntry('footer', 'main');
const f = entry!.data;

const legalLinks = [
  { label: 'Privacy', href: '/pages/privacy-policy' },
  { label: 'Terms', href: '/pages/terms-and-conditions' },
  { label: 'Cookies', href: '/pages/cookies' },
];
---

<footer class="footer" role="contentinfo">
  <div class="wrap">
    <div class="footer__top">
      <div>
        <a href="/" class="footer__logo">{BRAND.name}</a>
        {f.blurb && <p class="footer__desc">{f.blurb}</p>}
        <div class="footer__socials">
          <a href={BRAND.social.instagram} class="footer__soc" aria-label="Instagram">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5" /><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" /><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" /></svg>
          </a>
          <a href={BRAND.social.youtube} class="footer__soc" aria-label="YouTube">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.57A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z" /><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" /></svg>
          </a>
          <a href={BRAND.social.twitter} class="footer__soc" aria-label="X">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" /></svg>
          </a>
          <a href={BRAND.social.tiktok ?? '#'} class="footer__soc" aria-label="TikTok">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V9.31a8.16 8.16 0 0 0 4.77 1.53V7.39a4.85 4.85 0 0 1-1.84-.7z" /></svg>
          </a>
        </div>
      </div>

      {
        f.columns.map((col) => (
          <div>
            <div class="footer__col-h">{col.title}</div>
            <ul class="footer__links">
              {col.links.map((l) => (
                <li>
                  <a href={l.href} set:html={l.label} />
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="footer__bot">
      <span class="footer__copy">{f.legal}</span>
      <div class="footer__pay">
        {f.payments.map((p) => <span class="pay-chip">{p}</span>)}
      </div>
      <div class="footer__legal">
        {legalLinks.map((l) => <a href={l.href}>{l.label}</a>)}
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--dark);
    padding-top: 120px;
  }

  .footer__top {
    padding: 64px 0 52px;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 40px;
  }

  .footer__logo {
    font-family: var(--fh);
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -.3px;
    color: var(--white);
    display: block;
    margin-bottom: 12px;
  }

  .footer__desc {
    font-size: 13px;
    line-height: 1.62;
    color: rgba(255, 255, 255, .4);
    max-width: 220px;
    margin-bottom: 20px;
  }

  .footer__socials {
    display: flex;
    gap: 8px;
  }

  .footer__soc {
    width: 32px;
    height: 32px;
    border: 1px solid rgba(255, 255, 255, .12);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, .5);
    transition: border-color var(--ease), color var(--ease);
  }

  .footer__soc:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .footer__col-h {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, .3);
    margin-bottom: 18px;
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: 11px;
  }

  .footer__links a {
    font-size: 13px;
    color: rgba(255, 255, 255, .55);
    transition: color var(--ease);
  }

  .footer__links a:hover {
    color: var(--white);
  }

  .footer__bot {
    padding: 20px 0;
    border-top: 1px solid rgba(255, 255, 255, .07);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer__copy {
    font-size: 12px;
    color: rgba(255, 255, 255, .28);
  }

  .footer__pay {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .pay-chip {
    padding: 3px 8px;
    background: rgba(255, 255, 255, .06);
    border: 1px solid rgba(255, 255, 255, .09);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .6px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, .35);
  }

  .footer__legal {
    display: flex;
    gap: 20px;
  }

  .footer__legal a {
    font-size: 12px;
    color: rgba(255, 255, 255, .28);
    transition: color var(--ease);
  }

  .footer__legal a:hover {
    color: rgba(255, 255, 255, .6);
  }

  @media (max-width: 1100px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }
  }

  @media (max-width: 768px) {
    .footer__bot {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
