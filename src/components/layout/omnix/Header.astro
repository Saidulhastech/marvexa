---
// ============================================================
//  Header (Maison) — fixed transparent-over-hero bar that turns
//  solid on scroll. Logo, primary nav with Women/Men mega menus,
//  and the action cluster (search / account / wishlist / cart /
//  burger). Action triggers carry data-open="…"; the controller in
//  Overlays.astro opens the matching overlay. Cart badge (#cartBadge)
//  is driven by the nanostore (CartDrawer); wishlist (#wishBadge) by
//  Overlays. Mobile menu (#mobMenu) toggles .is-open via the same
//  controller. Header scroll state + announce-collapse are local JS.
// ============================================================
import { BRAND } from '~/config/omnix';

// Primary nav (mega columns). Hrefs map to storefront routes.
const womenMega = {
  clothing: [
    { label: 'Dresses', href: '/collections/dresses', badge: 'New' },
    { label: 'Blazers & Jackets', href: '/collections/blazers' },
    { label: 'Tops & Shirts', href: '/collections/tops' },
    { label: 'Trousers & Shorts', href: '/collections/trousers' },
    { label: 'Knitwear', href: '/collections/knitwear' },
    { label: 'Skirts', href: '/collections/skirts', badge: 'Sale', rust: true },
  ],
  shopBy: [
    { label: 'New Arrivals', href: '/products?sort=newest' },
    { label: 'Best Sellers', href: '/products' },
    { label: 'Organic Linen Edit', href: '/collections/linen' },
    { label: 'Under $150', href: '/collections/under-150' },
    { label: 'Sale Items', href: '/collections/sale', badge: '50% Off', rust: true },
  ],
  img: { src: 'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=200&auto=format&fit=crop&q=80', label: 'SS26 Drop', href: '/collections/women' },
};
const menMega = {
  clothing: [
    { label: 'Shirts', href: '/collections/shirts', badge: 'New' },
    { label: 'Blazers & Jackets', href: '/collections/blazers' },
    { label: 'Trousers', href: '/collections/trousers' },
    { label: 'Shorts', href: '/collections/shorts' },
    { label: 'Knitwear', href: '/collections/knitwear' },
    { label: 'T-Shirts', href: '/collections/tshirts', badge: 'Sale', rust: true },
  ],
  shopBy: [
    { label: 'New Arrivals', href: '/products?sort=newest' },
    { label: 'Best Sellers', href: '/products' },
    { label: 'Linen Collection', href: '/collections/linen' },
    { label: 'Under $120', href: '/collections/under-120' },
    { label: 'Sale Items', href: '/collections/sale', badge: '40% Off', rust: true },
  ],
  img: { src: 'https://images.unsplash.com/photo-1602810318383-e386cc2a3ccf?w=200&auto=format&fit=crop&q=80', label: "Men's Edit", href: '/collections/men' },
};
const megas = [
  { name: 'Women', data: womenMega },
  { name: 'Men', data: menMega },
];

const initial = (BRAND.name?.[0] ?? 'M').toUpperCase();
---

<header class="header" id="siteHeader">
  <div class="header__inner">
    <a href="/" class="header__logo" aria-label={`${BRAND.name} Home`}>
      <div class="header__logo-m">{initial}</div>
      {BRAND.name}
    </a>

    <nav class="header__nav" role="navigation" aria-label="Main">
      <a href="/products?sort=newest" class="nav-link new-a">New Arrivals</a>

      {
        megas.map((m) => (
          <div class="nav-link has-mega" tabindex="0" role="button" aria-haspopup="true" aria-expanded="false">
            {m.name}
            <svg class="nav-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
              <polyline points="6 9 12 15 18 9" />
            </svg>
            <div class="mega" role="menu">
              <div>
                <div class="mega__col-title">Clothing</div>
                <div class="mega__links">
                  {m.data.clothing.map((l) => (
                    <a href={l.href} class="mega__link">
                      {l.label}
                      {l.badge && <span class:list={['mega__link-badge', { rust: l.rust }]}>{l.badge}</span>}
                    </a>
                  ))}
                </div>
              </div>
              <div>
                <div class="mega__col-title">Shop By</div>
                <div class="mega__links">
                  {m.data.shopBy.map((l) => (
                    <a href={l.href} class="mega__link">
                      {l.label}
                      {l.badge && <span class:list={['mega__link-badge', { rust: l.rust }]}>{l.badge}</span>}
                    </a>
                  ))}
                </div>
              </div>
              <div>
                <a href={m.data.img.href} class="mega__img-card">
                  <img src={m.data.img.src} alt={`${m.name} campaign`} />
                  <span class="mega__img-label">{m.data.img.label}</span>
                </a>
              </div>
            </div>
          </div>
        ))
      }

      <a href="/collections/bags" class="nav-link">Bags</a>
      <a href="/collections/accessories" class="nav-link">Accessories</a>
      <a href="/collections/sale" class="nav-link sale">Sale</a>
    </nav>

    <div class="header__actions">
      <button class="hbtn" data-open="search" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.35-4.35" /></svg>
      </button>
      <button class="hbtn" data-open="account" aria-label="My Account">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
      </button>

      <div class="hbtn-divider"></div>

      <button class="hbtn" data-open="wishlist" aria-label="Wishlist">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" /></svg>
        <span class="h-badge" id="wishBadge" style="display:none">0</span>
      </button>

      <button class="hbtn" data-open="cart" aria-label="Shopping bag">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" /><line x1="3" y1="6" x2="21" y2="6" /><path d="M16 10a4 4 0 0 1-8 0" /></svg>
        <span class="h-badge" id="cartBadge" style="display:none">0</span>
      </button>

      <button class="hbtn hbtn--menu" data-open="mobile" aria-label="Open navigation menu">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="15" y2="18" /></svg>
      </button>
    </div>
  </div>
</header>

{/* Mobile slide-in menu — opened by data-open="mobile" via the Overlays controller. */}
<div class="mob-overlay" data-close="mobile" aria-hidden="true"></div>
<div class="mob-menu" id="mobMenu" role="dialog" aria-modal="true" aria-label="Mobile navigation">
  <div class="mob-menu__head">
    <div class="mob-logo">
      <div class="mob-logo-m">{initial}</div>
      {BRAND.name}
    </div>
    <button class="mob-close" data-close="mobile" aria-label="Close menu">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
    </button>
  </div>
  <nav class="mob-menu__nav">
    <a href="/products?sort=newest" class="mob-nav-link new-a">New Arrivals<span class="mob-nav-badge">SS26</span></a>
    <a href="/collections/women" class="mob-nav-link">Women</a>
    <a href="/collections/men" class="mob-nav-link">Men</a>
    <a href="/collections/bags" class="mob-nav-link">Bags</a>
    <a href="/collections/accessories" class="mob-nav-link">Accessories</a>
    <a href="/collections/sale" class="mob-nav-link sale">Sale<span class="mob-nav-badge rust">Up to 50%</span></a>
  </nav>
  <div class="mob-menu__info">
    <div class="mob-info-item">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="1" y="3" width="15" height="13" rx="2" /><path d="M16 8h4l3 5v3h-7V8z" /><circle cx="5.5" cy="18.5" r="2.5" /><circle cx="18.5" cy="18.5" r="2.5" /></svg>
      Free shipping on orders $150+
    </div>
    <div class="mob-info-item">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><polyline points="23 4 23 10 17 10" /><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" /></svg>
      Easy 30-day returns
    </div>
    <div class="mob-info-item">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
      Secure checkout
    </div>
  </div>
  <div class="mob-menu__bottom">
    <a href="/account" class="mob-bottom-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
      My Account
    </a>
    <a href="/wishlist" class="mob-bottom-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" /></svg>
      Wishlist
    </a>
    <a href="/pages/faq" class="mob-bottom-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="10" /><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
      Help & FAQ
    </a>
    <a href="/account" class="mob-bottom-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" /></svg>
      Track My Order
    </a>
  </div>
</div>

<style>
  .header {
    position: fixed;
    top: 38px;
    left: 0;
    right: 0;
    z-index: 1000;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: top .35s cubic-bezier(.25, .46, .45, .94), background .3s ease, border-color .3s ease, box-shadow .3s ease;
  }

  .header.ann-hidden {
    top: 0;
  }

  .header.scrolled {
    background: rgba(250, 250, 247, .97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-color: var(--border);
    box-shadow: 0 1px 0 rgba(0, 0, 0, .04);
  }

  .header__inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 var(--gutter);
    height: 68px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
  }

  .header__logo {
    font-family: var(--fh);
    font-size: 17px;
    font-weight: 800;
    letter-spacing: -.3px;
    color: var(--white);
    transition: color .3s ease;
    display: inline-flex;
    align-items: center;
    gap: 9px;
  }

  .header.scrolled .header__logo {
    color: var(--text);
  }

  .header__logo-m {
    width: 30px;
    height: 30px;
    border: 1.5px solid var(--accent);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    color: var(--accent);
    font-weight: 900;
    flex-shrink: 0;
    transition: background .2s ease, color .2s ease;
  }

  .header__logo:hover .header__logo-m {
    background: var(--accent);
    color: #fff;
  }

  .header__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2px;
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 13px;
    font-weight: 600;
    color: rgba(255, 255, 255, .88);
    padding: 7px 11px;
    border-radius: 7px;
    cursor: pointer;
    transition: color .22s ease, background .22s ease;
    letter-spacing: .1px;
    white-space: nowrap;
  }

  .header.scrolled .nav-link {
    color: var(--text);
  }

  .nav-link:hover {
    background: rgba(255, 255, 255, .1);
  }

  .header.scrolled .nav-link:hover {
    background: rgba(17, 17, 17, .05);
  }

  .nav-link.new-a {
    color: var(--accent) !important;
  }

  .header.scrolled .nav-link.new-a {
    color: #5B6B28 !important;
  }

  .nav-link.sale {
    color: var(--rust) !important;
  }

  .nav-link.has-mega .nav-chevron {
    transition: transform .22s ease;
  }

  .nav-link.has-mega:hover .nav-chevron {
    transform: rotate(180deg);
  }

  .mega {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 24px;
    min-width: 520px;
    box-shadow: 0 24px 64px rgba(0, 0, 0, .13), 0 4px 16px rgba(0, 0, 0, .06);
    display: grid;
    grid-template-columns: 1fr 1fr 120px;
    gap: 20px;
    opacity: 0;
    pointer-events: none;
    transition: opacity .22s ease, transform .22s ease;
    z-index: 200;
  }

  .nav-link.has-mega:hover .mega,
  .nav-link.has-mega:focus-within .mega {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .mega__col-title {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }

  .mega__links {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .mega__link {
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    padding: 7px 9px;
    border-radius: 7px;
    transition: background .15s ease, color .15s ease;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .mega__link:hover {
    background: var(--bg2);
    color: var(--accent);
  }

  .mega__link-badge {
    font-size: 8px;
    font-weight: 700;
    letter-spacing: .8px;
    text-transform: uppercase;
    background: var(--accent);
    color: #fff;
    padding: 2px 5px;
    border-radius: 3px;
  }

  .mega__link-badge.rust {
    background: var(--rust);
  }

  .mega__img-card {
    border-radius: 10px;
    overflow: hidden;
    position: relative;
    aspect-ratio: 2/3;
    display: block;
  }

  .mega__img-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform .4s ease;
  }

  .mega__img-card:hover img {
    transform: scale(1.06);
  }

  .mega__img-label {
    position: absolute;
    bottom: 9px;
    left: 9px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #fff;
    background: rgba(17, 17, 17, .58);
    backdrop-filter: blur(6px);
    padding: 4px 8px;
    border-radius: 4px;
  }

  .header__actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 2px;
  }

  .hbtn {
    position: relative;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border-radius: 8px;
    color: rgba(255, 255, 255, .88);
    transition: color .22s ease, background .22s ease;
    flex-shrink: 0;
  }

  .header.scrolled .hbtn {
    color: var(--text);
  }

  .hbtn:hover {
    background: rgba(255, 255, 255, .1);
  }

  .header.scrolled .hbtn:hover {
    background: rgba(17, 17, 17, .06);
    color: var(--accent);
  }

  .h-badge {
    position: absolute;
    top: 7px;
    right: 6px;
    min-width: 15px;
    height: 15px;
    border-radius: 8px;
    background: var(--accent);
    color: #fff;
    font-size: 8px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
    line-height: 1;
    pointer-events: none;
    transition: transform .2s ease;
  }

  .hbtn:hover .h-badge {
    transform: scale(1.12);
  }

  .hbtn--menu {
    display: none;
  }

  .hbtn-divider {
    width: 1px;
    height: 20px;
    background: rgba(255, 255, 255, .15);
    margin: 0 4px;
    flex-shrink: 0;
    transition: background .3s ease;
  }

  .header.scrolled .hbtn-divider {
    background: var(--border);
  }

  /* ── Mobile menu ─────────────────────────────────────── */
  .mob-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, .5);
    z-index: 1198;
    opacity: 0;
    pointer-events: none;
    transition: opacity .3s ease;
  }

  .mob-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .mob-menu {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 320px;
    max-width: 100vw;
    background: var(--dark);
    z-index: 1199;
    transform: translateX(-100%);
    transition: transform .35s cubic-bezier(.25, .46, .45, .94);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  }

  .mob-menu.is-open {
    transform: translateX(0);
  }

  .mob-menu__head {
    padding: 22px 22px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(255, 255, 255, .07);
    flex-shrink: 0;
  }

  .mob-logo {
    font-family: var(--fh);
    font-size: 17px;
    font-weight: 800;
    color: var(--white);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .mob-logo-m {
    width: 28px;
    height: 28px;
    border: 1.5px solid var(--accent);
    border-radius: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: var(--accent);
    font-weight: 900;
  }

  .mob-close {
    width: 34px;
    height: 34px;
    background: rgba(255, 255, 255, .07);
    border: 1px solid rgba(255, 255, 255, .1);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, .55);
    transition: all .2s ease;
  }

  .mob-close:hover {
    background: rgba(255, 255, 255, .13);
    color: var(--white);
  }

  .mob-menu__nav {
    padding: 8px 0;
    flex: 1;
  }

  .mob-nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 22px;
    font-size: 15px;
    font-weight: 600;
    color: rgba(255, 255, 255, .78);
    border-bottom: 1px solid rgba(255, 255, 255, .05);
    transition: color .2s ease, background .2s ease;
  }

  .mob-nav-link:hover {
    color: var(--white);
    background: rgba(255, 255, 255, .04);
  }

  .mob-nav-link.new-a {
    color: var(--accent);
  }

  .mob-nav-link.sale {
    color: var(--rust);
  }

  .mob-nav-badge {
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    background: var(--accent);
    color: #fff;
    padding: 2px 6px;
    border-radius: 3px;
  }

  .mob-nav-badge.rust {
    background: var(--rust);
  }

  .mob-menu__info {
    padding: 16px 22px;
    border-top: 1px solid rgba(255, 255, 255, .07);
  }

  .mob-info-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 0;
    font-size: 12px;
    font-weight: 500;
    color: rgba(255, 255, 255, .42);
    border-bottom: 1px solid rgba(255, 255, 255, .04);
  }

  .mob-info-item svg {
    flex-shrink: 0;
  }

  .mob-menu__bottom {
    padding: 16px 22px 28px;
    border-top: 1px solid rgba(255, 255, 255, .07);
    flex-shrink: 0;
  }

  .mob-bottom-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 0;
    font-size: 13px;
    font-weight: 500;
    color: rgba(255, 255, 255, .45);
    border-bottom: 1px solid rgba(255, 255, 255, .04);
    transition: color .2s ease;
  }

  .mob-bottom-link:hover {
    color: rgba(255, 255, 255, .88);
  }

  .mob-bottom-link svg {
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .header__inner {
      height: 64px;
    }

    .header__nav {
      display: none;
    }

    .hbtn--menu {
      display: flex;
    }

    .hbtn-divider {
      display: none;
    }
  }
</style>

<script>
  // Solid header on scroll (transparent over the hero by default).
  const header = document.getElementById('siteHeader');
  if (header) {
    const onScroll = () => header.classList.toggle('scrolled', window.scrollY > 20);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
