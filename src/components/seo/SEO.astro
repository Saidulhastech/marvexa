---
// ============================================================
//  SEO — reusable <head> meta block. Renders title, description,
//  canonical, Open Graph, Twitter cards, and optional JSON-LD.
//  Used by Layout.astro; pass page-specific props per route.
// ============================================================
import { BRAND } from '~/config/marvexa';

interface Props {
  title?: string;
  description?: string;
  /** Absolute or site-relative OG image URL. */
  image?: string;
  /** og:type — "website" for pages, "product" for PDPs, etc. */
  type?: string;
  /** Discourage indexing for utility pages. */
  noindex?: boolean;
  /** One or more JSON-LD objects injected as <script type="application/ld+json">. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = BRAND.description,
  image,
  type = 'website',
  noindex = false,
  jsonLd,
} = Astro.props;

const pageTitle = title ? `${title} · ${BRAND.name}` : `${BRAND.name} — ${BRAND.tagline}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;
// Default social card → branded OG image; pages can override via `image` prop.
const ogImage = new URL(image ?? '/og-image.png', Astro.site ?? Astro.url.origin).href;
const blocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

{/* Open Graph */}
<meta property="og:type" content={type} />
<meta property="og:site_name" content={BRAND.name} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
{ogImage && <meta property="og:image" content={ogImage} />}

{/* Twitter */}
<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

{
  blocks.map((block) => (
    <script type="application/ld+json" set:html={JSON.stringify(block)} />
  ))
}
