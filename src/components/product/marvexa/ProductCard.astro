---
// ============================================================
//  ProductCard (MARVEXA skin, Shopify data). Reused by every product
//  grid (best-sellers, recommendations). Quick Add adds the first
//  variant (Option B) or links to the PDP; Quick View opens the
//  shared modal. Wishlist + Compare are localStorage. "New" badge
//  and colour swatches come from real Shopify data when available.
// ============================================================
import { Image } from 'astro:assets';
import type { ProductCard as TProductCard } from '~/lib/shopify/types';
import { formatMoney, percentOff, hasPriceRange } from '~/lib/money';
import Icon from '~/components/ui/marvexa/Icon.astro';

interface Props {
  product: TProductCard;
  /** Eager-load for above-the-fold grids (better LCP). */
  eager?: boolean;
  /** Space-separated tab keys this card belongs to (for grid filtering). */
  tabs?: string;
  /** Extra data-* attributes spread onto the card (shop facet filtering). */
  attrs?: Record<string, string>;
}
const { product, eager = false, tabs, attrs = {} } = Astro.props;

const href = `/products/${product.handle}`;
const price = product.priceRange.minVariantPrice;
const compareAt = product.compareAtPriceRange?.minVariantPrice ?? null;
const off = percentOff(price, compareAt);
// "From" when variants span more than one price (matches Shopify Dawn default).
const fromPrefix = hasPriceRange(product.priceRange) ? 'From ' : '';
const img = product.featuredImage;
const soldOut = !product.availableForSale;
const canQuickAdd = !soldOut && !!product.firstVariantId && product.firstVariantAvailable !== false;

// ---- Variant-aware quick add ----------------------------------------------
// Real options excluding the implicit single "Title / Default Title" option.
const variants = product.variants ?? [];
const realOptions = (product.options ?? []).filter(
  (o) => !(o.name === 'Title' && o.optionValues.every((v) => v.name === 'Default Title')),
);
// A product needs the picker only when more than one option must be chosen
// (e.g. Colour + Size). A colour-only product is fully resolved by the swatch.
const needsPicker = canQuickAdd && variants.length > 1 && realOptions.length >= 2;

// Colour option detection mirrors the PDP (real swatch value or a colour-ish name).
const colorOpt = realOptions.find(
  (o) => /colou?r|finish|shade/i.test(o.name) || o.optionValues.some((v) => v.swatch?.color),
);
const colorName = colorOpt?.name ?? null;

// Card swatches enriched with the variant image + (single-option only) its id,
// so a click can swap the card image and retarget Quick Add.
const swatches = (product.swatches ?? []).map((s) => {
  const variant = colorName
    ? variants.find((v) => v.selectedOptions.some((o) => o.name === colorName && o.value === s.name))
    : undefined;
  // Sold out when no available variant carries this colour (Dawn-style strike).
  const available = colorName
    ? variants.some(
        (v) =>
          v.availableForSale &&
          v.selectedOptions.some((o) => o.name === colorName && o.value === s.name),
      )
    : true;
  return {
    name: s.name,
    color: s.color,
    img: variant?.image?.url ?? null,
    available,
    // Only safe to add directly when colour is the *only* option and in stock.
    variantId: realOptions.length === 1 && available ? variant?.id ?? null : null,
  };
});

// Compact variant + option payloads for the Quick View picker (multi-option).
const pickerData = needsPicker
  ? JSON.stringify(
      variants.map((v) => ({
        id: v.id,
        opts: Object.fromEntries(v.selectedOptions.map((o) => [o.name, o.value])),
        price: Number(v.price.amount),
        compareAt: v.compareAtPrice ? Number(v.compareAtPrice.amount) : null,
        img: v.image?.url ?? null,
        available: v.availableForSale,
      })),
    )
  : '';
const optionData = needsPicker
  ? JSON.stringify(
      realOptions.map((o) => ({
        name: o.name,
        isColor: o === colorOpt,
        values: o.optionValues.map((ov) => ({ name: ov.name, color: ov.swatch?.color ?? null })),
      })),
    )
  : '';
const currency = price.currencyCode;

// Real review data (metafields) — rating row only renders when present.
const rating = product.rating ?? null;
const ratingCount = product.ratingCount ?? null;
const starsFull = rating != null ? Math.round(rating) : 0;
// Eyebrow: prefer product type (e.g. "Men"), fall back to vendor.
const eyebrow = product.productType?.trim() || product.vendor?.trim() || '';
---

<article class="prod-card" data-tabs={tabs} {...attrs}>
  <div class="prod-media">
    <a href={href} aria-label={product.title}>
      {
        img ? (
          <Image
            src={img.url}
            alt={img.altText ?? product.title}
            width={600}
            height={600}
            widths={[300, 600]}
            sizes="(max-width: 640px) 50vw, 300px"
            loading={eager ? 'eager' : 'lazy'}
          />
        ) : (
          <div class="prod-media-empty" role="img" aria-label={product.title}>
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2" />
              <circle cx="8.5" cy="8.5" r="1.5" />
              <path d="m21 15-5-5L5 21" />
            </svg>
            <span>Marvexa</span>
          </div>
        )
      }
    </a>
    <div class="prod-badges">
      {soldOut && <span class="badge badge-hot">Sold out</span>}
      {!soldOut && product.isNew && <span class="badge badge-new">New</span>}
      {!soldOut && off > 0 && <span class="badge badge-sale">-{off}%</span>}
    </div>
    <div class="prod-icons">
      <button
        class="prod-icon-btn prod-wish"
        aria-label="Add to wishlist"
        data-wish
        data-handle={product.handle}
        data-name={product.title}
        data-price={formatMoney(price)}
        data-img={img?.url ?? ''}
        data-href={href}
        data-variant-id={canQuickAdd ? product.firstVariantId : ''}
        data-needs-picker={needsPicker ? '1' : ''}
        data-variants={pickerData}
        data-options={optionData}
        data-currency={currency}
      >
        <Icon name="heart" size={15} />
      </button>
      <button class="prod-icon-btn prod-compare" aria-label="Add to compare" data-compare data-handle={product.handle}>
        <Icon name="compare" size={14} />
      </button>
      <button
        class="prod-icon-btn prod-qview"
        aria-label="Quick view"
        data-qview
        data-handle={product.handle}
        data-name={product.title}
        data-price={formatMoney(price)}
        data-was={compareAt && off > 0 ? formatMoney(compareAt) : ''}
        data-save={off > 0 ? `Save ${off}%` : ''}
        data-desc={product.description ?? ''}
        data-img={img?.url ?? ''}
        data-brand={product.vendor ?? ''}
        data-href={href}
        data-currency={currency}
        data-variant-id={canQuickAdd ? product.firstVariantId : ''}
        data-variants={pickerData}
        data-options={optionData}
      >
        <Icon name="eye" size={14} />
      </button>
    </div>
    <div class="prod-actions">
      {
        canQuickAdd ? (
          needsPicker ? (
            <button
              class="prod-quick"
              data-add
              data-pick
              data-handle={product.handle}
              data-name={product.title}
              data-img={img?.url ?? ''}
              data-brand={product.vendor ?? ''}
              data-href={href}
              data-currency={currency}
              data-variants={pickerData}
              data-options={optionData}
            >
              Select Options
            </button>
          ) : (
            <button class="prod-quick" data-add data-variant-id={product.firstVariantId}>
              Add to Bag
            </button>
          )
        ) : (
          <a class="prod-quick" href={href}>
            {soldOut ? 'View Product' : 'Add to Bag'}
          </a>
        )
      }
    </div>
  </div>
  <div class="prod-body">
    <div class="prod-meta">
      {eyebrow && <span class="prod-brand">{eyebrow}</span>}
    </div>
    <h3 class="prod-title"><a href={href}>{product.title}</a></h3>
    <div class="prod-foot">
      <div class="prod-price">
        <span class="now">{fromPrefix}{formatMoney(price)}</span>
        {compareAt && off > 0 && <span class="was">{formatMoney(compareAt)}</span>}
      </div>
      {
        swatches.length > 0 && (
          <div class="prod-swatches">
            {swatches.slice(0, 4).map((s) => (
              <button
                type="button"
                class:list={['swatch', { 'is-unavailable': !s.available }]}
                style={`background:${s.color}`}
                title={s.available ? s.name : `${s.name} — sold out`}
                aria-label={s.available ? s.name : `${s.name}, sold out`}
                aria-disabled={!s.available}
                data-swatch
                data-name={s.name}
                data-img={s.img ?? ''}
                data-variant-id={s.variantId ?? ''}
              />
            ))}
            {swatches.length > 4 && <span class="swatch-more">+{swatches.length - 4}</span>}
          </div>
        )
      }
    </div>
    {
      rating != null && (
        <div class="prod-rating">
          <span class="prod-stars" aria-label={`Rated ${rating} out of 5`}>
            {Array.from({ length: 5 }).map((_, i) => (
              <span class:list={['star-ic', { 'is-on': i < starsFull }]}>
                <Icon name="star" size={12} />
              </span>
            ))}
          </span>
          {ratingCount != null && <span class="prod-rcount">({ratingCount})</span>}
        </div>
      )
    }
  </div>
</article>

<style>
  /* ProductCard — Marvexa skin. Markup + data-* wiring unchanged; only
     visuals. Hover reveals the compare icon and the slide-up action bar. */
  .prod-card {
    position: relative;
  }

  .prod-media {
    position: relative;
    overflow: hidden;
    background: var(--card);
    border-radius: 3px;
  }

  .prod-media > a {
    display: block;
  }

  .prod-media img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: top;
    transition: transform .65s cubic-bezier(.25, .46, .45, .94);
  }

  .prod-card:hover .prod-media img {
    transform: scale(1.06);
  }

  .prod-media-empty {
    width: 100%;
    aspect-ratio: 3/4;
    background: var(--card);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: color-mix(in srgb, var(--ink, #111) 28%, transparent);
  }

  .prod-media-empty span {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* Badges — top-left glass chips */
  .prod-badges {
    position: absolute;
    top: 12px;
    left: 12px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    z-index: 3;
  }

  .badge {
    display: inline-block;
    padding: 4px 10px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.1px;
    text-transform: uppercase;
    border-radius: 3px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .badge-new {
    background: var(--accent);
    color: #fff;
  }

  .badge-sale {
    background: rgba(180, 87, 63, .86);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, .2);
  }

  .badge-hot {
    background: rgba(17, 17, 17, .78);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, .14);
  }

  /* Icon stack — top-right round buttons (wishlist / compare / quick view) */
  .prod-icons {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 4;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .prod-icon-btn {
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, .92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, .6);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text);
    box-shadow: 0 2px 10px rgba(0, 0, 0, .1);
    transition: opacity .25s ease, transform .28s cubic-bezier(.25, .46, .45, .94), background .18s ease, color .18s ease;
  }

  .prod-icon-btn:hover {
    background: #fff;
    color: var(--accent);
  }

  /* Wishlist sits always-visible; compare + quick view reveal on hover. */
  .prod-compare,
  .prod-qview {
    opacity: 0;
    transform: translateX(10px);
  }

  .prod-card:hover .prod-compare,
  .prod-card:hover .prod-qview {
    opacity: 1;
    transform: translateX(0);
  }

  .prod-wish.is-active {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  .prod-wish.is-active svg {
    fill: #fff;
  }

  .prod-compare.is-active {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  /* Add-to-bag bar — full-width olive, slides up from the bottom on hover */
  .prod-actions {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    opacity: 0;
    transform: translateY(100%);
    transition: opacity .24s ease, transform .3s cubic-bezier(.25, .46, .45, .94);
    z-index: 3;
  }

  .prod-card:hover .prod-actions {
    opacity: 1;
    transform: translateY(0);
  }

  .prod-quick {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 15px 8px;
    background: var(--dark);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    transition: background .18s ease;
  }

  .prod-quick:hover {
    background: var(--accent);
  }

  /* Info */
  .prod-body {
    padding: 14px 0 4px;
  }

  .prod-meta {
    margin-bottom: 6px;
    min-height: 12px;
  }

  .prod-brand {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--muted);
    opacity: .8;
  }

  .prod-title {
    font-family: var(--fh);
    font-size: 15px;
    font-weight: 600;
    line-height: 1.25;
    color: var(--text);
    letter-spacing: -.3px;
    margin: 0 0 10px;
  }

  .prod-title a:hover {
    color: var(--accent);
  }

  .prod-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .prod-price {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -.1px;
    white-space: nowrap;
  }

  .prod-price .was {
    color: var(--muted);
    font-weight: 400;
    font-size: 11px;
    text-decoration: line-through;
    margin-left: 4px;
  }

  /* Swatches */
  .prod-swatches {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .swatch {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 1.5px solid rgba(0, 0, 0, .1);
    position: relative;
    transition: transform .15s ease;
  }

  .swatch:hover {
    transform: scale(1.22);
  }

  .swatch.is-active::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 1.5px solid var(--text);
  }

  .swatch.is-unavailable {
    opacity: .4;
  }

  .swatch.is-unavailable::before {
    content: '';
    position: absolute;
    inset: 0;
    margin: auto;
    width: 140%;
    height: 1.5px;
    background: var(--muted);
    transform: rotate(-45deg);
    transform-origin: center;
  }

  .swatch-more {
    font-size: 10px;
    font-weight: 600;
    color: var(--muted);
  }

  /* Rating row */
  .prod-rating {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 8px;
  }

  .prod-stars {
    display: inline-flex;
    align-items: center;
    gap: 1px;
  }

  .star-ic {
    display: inline-flex;
    color: var(--border);
  }

  .star-ic svg {
    width: 12px;
    height: 12px;
  }

  .star-ic.is-on {
    color: var(--accent);
  }

  .star-ic.is-on svg {
    fill: var(--accent);
  }

  .prod-rcount {
    font-size: 11px;
    font-weight: 500;
    color: var(--muted);
  }
</style>
