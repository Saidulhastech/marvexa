---
// ============================================================
//  DealCard (OMNIX `.deal-card`) — distinct from ProductCard:
//  discount bubble + deal actions. Shopify data; links to PDP
//  (Option A). Demo stock bar omitted (no inventory data here).
// ============================================================
import { Image } from 'astro:assets';
import type { ProductCard as TProductCard } from '~/lib/shopify/types';
import { formatMoney, percentOff, hasPriceRange } from '~/lib/money';
import Icon from '~/components/ui/omnix/Icon.astro';

interface Props {
  product: TProductCard;
  eager?: boolean;
}
const { product, eager = false } = Astro.props;

const href = `/products/${product.handle}`;
const price = product.priceRange.minVariantPrice;
const compareAt = product.compareAtPriceRange?.minVariantPrice ?? null;
const off = percentOff(price, compareAt);
// "From" when variants span more than one price (matches Shopify Dawn default).
const fromPrefix = hasPriceRange(product.priceRange) ? 'From ' : '';
const img = product.featuredImage;
const soldOut = !product.availableForSale;
const canQuickAdd = !soldOut && !!product.firstVariantId && product.firstVariantAvailable !== false;

// Rating — only when the store actually has a `reviews.rating` metafield.
const rating = typeof product.rating === 'number' ? product.rating : null;
const ratingCount = product.ratingCount ?? null;

// Stock bar — needs real inventory. The full "Sold X / Y" bar needs a
// `custom.stock_goal` too; with only inventory we show "Only N left".
const left = typeof product.totalInventory === 'number' && product.totalInventory >= 0
  ? product.totalInventory
  : null;
const goal = product.stockGoal && product.stockGoal > 0 ? product.stockGoal : null;
// Bar only renders when the goal is a real batch total (>= units left), so the
// invariant `sold + left = goal` always holds — no contradictory "Sold 0 / 10
// · Only 272 left". When goal < left the goal is mis-set; we drop to "Only N left".
const showBar = left !== null && goal !== null && goal! >= left!;
const sold = showBar ? goal! - left! : 0;
const soldPct = showBar ? Math.round((sold / goal!) * 100) : 0;
const showLeft = left !== null && left > 0;
---

<article class="deal-card">
  <div class="deal-media">
    <a href={href} aria-label={product.title}>
      {
        img && (
          <Image
            src={img.url}
            alt={img.altText ?? product.title}
            width={600}
            height={600}
            widths={[300, 600]}
            sizes="(max-width: 640px) 50vw, 300px"
            loading={eager ? 'eager' : 'lazy'}
          />
        )
      }
    </a>
    {off > 0 && <div class="deal-off-bubble">-{off}%</div>}
    <div class="deal-icon-row">
      <button
        class="deal-icon-btn"
        aria-label="Add to wishlist"
        data-wish
        data-handle={product.handle}
        data-name={product.title}
        data-price={formatMoney(price)}
        data-img={img?.url ?? ''}
        data-href={href}
      >
        <Icon name="heart" size={15} />
      </button>
      <button class="deal-icon-btn" aria-label="Add to compare" data-compare data-handle={product.handle}>
        <Icon name="compare" size={14} />
      </button>
    </div>
  </div>
  <div class="deal-card-body">
    <div class="prod-meta deal-meta-row">
      {product.vendor && <span class="prod-brand">{product.vendor}</span>}
      {
        rating !== null && (
          <span class="deal-rating" title={ratingCount ? `${ratingCount} reviews` : undefined}>
            <Icon name="star" size={13} />
            <span class="deal-rating-val">{rating.toFixed(1)}</span>
          </span>
        )
      }
    </div>
    <h3 class="prod-title"><a href={href}>{product.title}</a></h3>
    <div class="prod-foot" style="margin-top: 4px;">
      <div class="prod-price">
        <span class="now">{fromPrefix}{formatMoney(price)}</span>
        {compareAt && off > 0 && <span class="was">{formatMoney(compareAt)}</span>}
      </div>
    </div>
    {
      (showBar || showLeft) && (
        <div class="deal-stock">
          {showBar && (
            <div class="stock-bar">
              <span class="stock-bar-fill" style={`width:${soldPct}%`} />
            </div>
          )}
          <div class="stock-meta">
            {showBar ? <span>Sold {sold} / {goal}</span> : <span />}
            {showLeft && <b>Only {left} left</b>}
          </div>
        </div>
      )
    }
    <div class="deal-actions">
      {
        canQuickAdd ? (
          <button class="deal-quick" data-add data-variant-id={product.firstVariantId}>
            <Icon name="plus" size={13} stroke={2.4} /> Quick Add
          </button>
        ) : (
          <a class="deal-quick" href={href}>
            <Icon name="plus" size={13} stroke={2.4} /> {soldOut ? 'View' : 'Quick Add'}
          </a>
        )
      }
      <button
        class="deal-qview"
        aria-label="Quick view"
        data-qview
        data-handle={product.handle}
        data-name={product.title}
        data-price={formatMoney(price)}
        data-was={compareAt && off > 0 ? formatMoney(compareAt) : ''}
        data-save={off > 0 ? `Save ${off}%` : ''}
        data-desc={product.description ?? ''}
        data-img={img?.url ?? ''}
        data-brand={product.vendor ?? ''}
        data-href={href}
        data-variant-id={canQuickAdd ? product.firstVariantId : ''}
      >
        <Icon name="eye" size={14} />
      </button>
    </div>
  </div>
</article>
