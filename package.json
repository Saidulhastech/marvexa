{
  "name": "marvexa",
  "description": "Marvexa — modern fashion headless Shopify storefront",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "astro",
    "astro-theme",
    "shopify",
    "headless",
    "ecommerce",
    "storefront",
    "ssr"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:cloudflare": "astro build",
    "build:node": "astro build",
    "build:vercel": "astro build",
    "build:netlify": "astro build",
    "start:node": "node ./dist/server/entry.mjs",
    "preview": "astro build && wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "astro": "astro",
    "release:patch": "npm version patch -m \"chore: release %s\" && git push && git push --tags",
    "release:minor": "npm version minor -m \"chore: release %s\" && git push && git push --tags",
    "release:major": "npm version major -m \"chore: release %s\" && git push && git push --tags"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.2",
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/netlify": "^8.1.0",
    "@astrojs/node": "^11.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^11.0.1",
    "astro": "^7.0.7",
    "nanostores": "^1.4.0",
    "wrangler": "^4.110.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "^6.0.3"
  }
}
